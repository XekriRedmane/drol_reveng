                                ;  loop to map ENTITY_FLOOR_COL/XOFF_IDX to a
                                ;  screen-X residue in JOY_V_DOWN.)

; --- Rescue-child sprite tables (per step phase x direction) ---
; Width = $03, height = $1A or $1C; indexed by PROJ_FRAME_IDX[$0358,Y].
; The four pairs sit/$75E9/$75F0 (low) and $76DB/...$76F0 (high).
RESCUE_SPR_NEG_END_LO  = $75DB  ; -dir end-of-step body (h=$1A)
RESCUE_SPR_NEG_END_HI  = $76DB
