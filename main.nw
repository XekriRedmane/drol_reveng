<<enemy a draw>>=

        ORG $1423
ENEMY_A_DRAW:
        SUBROUTINE
        ; Per-frame draw + player-collision for the enemy-A slot.
        ; Completes the entity-draw triplet (with ENEMY_B_DRAW and
        ; ENEMY_C_DRAW).  Unlike B/C, enemy-A is rendered as a
        ; two-sprite composite (body + feet) with a four-frame
        ; walking animation driven by ZP_FRAME_COUNTER bits 1-2;
        ; drift state simply collapses the animation to a fixed
        ; stance (there is no drift puff).  Player-hit awards +$0300
        ; BCD and decrements ZP_GAME_OVER, matching enemy-B.
        ;
        ; Inputs:
        ;   ZP_ENEMY_A_STATE    --- $00 off; +steady (animates); -drift (stance).
        ;   ZP_ENEMY_A_POS      --- 16-bit world X for enemy-A.
        ;   ZP_ENEMY_A_ROW      --- Body-sprite starting screen row.
        ;   ZP_PLAYER_Y ($4A)   --- Player Y (index into perspective tables).
        ;   ZP_PLAYER_COL ($06) --- Player column (collision X reference).
        ;   ZP_SPRITE_XREF ($4C) --- Level-fixed X reference.
        ;   ZP_FRAME_COUNTER ($FD) --- Frame-counter source for walk gate.
        ;   PERSPECTIVE_XOFF_LO/HI --- Y-to-X transform tables.
        ;   SPRITE_TABLE_A_BODY_LO/HI   --- Body-sprite pointer table.
        ;   SPRITE_TABLE_A_FEET_LO/HI   --- Stance-feet pointer table.
        ;   SPRITE_TABLE_A_STEP1_LO/HI  --- Walk feet variant 1 (phase $03).
        ;   SPRITE_TABLE_A_STEP2_LO/HI  --- Walk feet variant 2 (phase $01).
        ;
        ; Behavior:
        ;   1. State gate: $00 exits.
        ;   2. Clip: compute screen-relative X into ZP_CLIP_X_LO/HI;
        ;      exit if high byte non-zero or low byte >= $9A.
        ;   3. Set up common sprite params: $5D = screen col,
        ;      $56 = 3, $57 = $13 (body dims).
        ;   4. State-polarity dispatch: positive -> .walk_phase
        ;      (animation scan); negative -> fall through to .stance.
        ;   5. .stance (also reached when walk_phase = 0 or 2):
        ;      draw body at ZP_ENEMY_A_ROW from SPRITE_TABLE_A_BODY;
        ;      draw $03x$03 feet at row+$13 from SPRITE_TABLE_A_FEET;
        ;      JMP to hit test.
        ;   6. .walk_phase: extract ZP_FRAME_COUNTER & $06 >> 1 into A;
        ;      if 0 or 2 jump to .stance; else stash in
        ;      ZP_ENEMY_A_LEG_PHASE and draw body at row-1 from
        ;      SPRITE_TABLE_A_BODY, then a $03x$04 walking-feet
        ;      sprite at row+$12 chosen by the stashed phase
        ;      (phase 3 = STEP1 / $B010; phase 1 = STEP2 / $B01E).
        ;   7. Hit test: ZP_CLIP_X_LO in [$42, $4F) AND
        ;      ZP_ENEMY_A_ROW in [player-$14, player+$10].
        ;   8. On hit (.hit): $00 -> ZP_ENEMY_A_STATE (deactivate
        ;      immediately; no drift), $07 -> ZP_ENEMY_A_SND_CTR
        ;      (one death click), DEC ZP_GAME_OVER, award +$0300
        ;      BCD via SCORE_ADD, RTS.
        ;
        ; Modifies:
        ;   ZP_CLIP_X_LO/HI, ZP_ENEMY_A_LEG_PHASE, ZP_SAVE_X,
        ;   sprite-param ZPs ($56/$57/$5B/$5D), ZP_SCORE_ADD_LO/HI,
        ;   ZP_ENEMY_A_STATE, ZP_ENEMY_A_SND_CTR, ZP_GAME_OVER,
        ;   SMC_DS_SRC_LO/HI.
        ; Clobbers: A, X, Y

; --- State gate: $00 -> exit ---
        LDA ZP_ENEMY_A_STATE
        BNE .active                     ; $00: slot inactive
        RTS

; --- Clip: compute screen-relative X from world X ---
.active:
        LDX ZP_PLAYER_Y
        LDA PERSPECTIVE_XOFF_LO,X       ; Y-indexed X offset (low)
        SEC
        SBC ZP_SPRITE_XREF              ; ... minus fixed X-reference
        STA ZP_CLIP_X_LO
        LDA PERSPECTIVE_XOFF_HI,X       ; (high byte propagation)
        SBC #$00
        STA ZP_CLIP_X_HI
        SEC
        LDA ZP_ENEMY_A_POS              ; Subtract from enemy world X
        SBC ZP_CLIP_X_LO
        STA ZP_CLIP_X_LO                ; ZP_CLIP_X_LO = screen-relative X (lo)
        LDA ZP_ENEMY_A_POS+1
        SBC ZP_CLIP_X_HI
        BEQ .in_bounds                  ; hi diff == 0: on-screen
.exit:
        RTS                             ; hi diff != 0: off-screen, exit
.in_bounds:
        LDA ZP_CLIP_X_LO
        CMP #$9A
        BCS .exit                       ; clipped X >= $9A: off right edge

; --- Common sprite-parameter setup (body dimensions) ---
        TAX                             ; X := clipped screen-X
        LDA PROJ_SCREEN_COL,X           ; -> screen column index
        STA ZP_SPRITE_X
        LDA PROJ_FRAME_IDX,X            ; -> sprite frame index
        TAX                             ; X := frame index
        LDA #$03
        STA ZP_SPRITE_W                 ; Body width = 3 bytes
        LDA #$13
        STA ZP_SPRITE_H                 ; Body height = $13 rows

; --- State-polarity dispatch: +steady animates; -drift = stance ---
        LDA ZP_ENEMY_A_STATE
        BPL .walk_phase                 ; positive: try walking animation
;       fall through to .stance         ; negative: no animation

; --- Stance draw: body at row + 03x03 feet at row+$13 (no animation) ---
.stance:
        LDA ZP_ENEMY_A_ROW
        STA ZP_SPRITE_Y                 ; Body row = enemy row
        LDA SPRITE_TABLE_A_BODY_LO,X    ; Patch DRAW_SPRITE src (body lo)
        STA SMC_DS_SRC_LO
        LDA SPRITE_TABLE_A_BODY_HI,X    ; Patch DRAW_SPRITE src (body hi)
        STA SMC_DS_SRC_HI
        STX ZP_SAVE_X                   ; Preserve frame idx across JSR
        JSR DRAW_SPRITE                 ; Blit body

        LDA #$03
        STA ZP_SPRITE_W                 ; Feet width = 3 bytes
        STA ZP_SPRITE_H                 ; Feet height = 3 rows
        LDX ZP_CLIP_X_LO                ; Re-derive screen column
        LDA PROJ_SCREEN_COL,X
        STA ZP_SPRITE_X
        LDA ZP_ENEMY_A_ROW
        CLC
        ADC #$13
        STA ZP_SPRITE_Y                 ; Feet row = body row + $13
        LDX ZP_SAVE_X                   ; Restore frame idx
        LDA SPRITE_TABLE_A_FEET_LO,X    ; Patch src (stance feet lo)
        STA SMC_DS_SRC_LO
        LDA SPRITE_TABLE_A_FEET_HI,X    ; Patch src (stance feet hi)
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE                 ; Blit stance feet
        JMP .hit_test

; --- Walking animation phase gate: $FD bits 1-2 -> {0,1,2,3} ---
.walk_phase:
        LDA ZP_FRAME_COUNTER
        AND #$06                        ; Keep bits 2,1 -> {0,2,4,6}
        LSR                             ; -> phase in {0,1,2,3}
        BEQ .stance                     ; phase 0: use stance frame
        CMP #$02
        BEQ .stance                     ; phase 2: use stance frame
        STA ZP_ENEMY_A_LEG_PHASE        ; phase 1 or 3: animate

; --- Animated walking: body at row-1 + 03x04 feet at row+$12 ---
        LDA ZP_ENEMY_A_ROW
        SEC
        SBC #$01
        STA ZP_SPRITE_Y                 ; Body row = enemy row - 1
        LDA SPRITE_TABLE_A_BODY_LO,X    ; Same body base as stance
        STA SMC_DS_SRC_LO
        LDA SPRITE_TABLE_A_BODY_HI,X
        STA SMC_DS_SRC_HI
        STX ZP_SAVE_X                   ; Preserve frame idx
        JSR DRAW_SPRITE                 ; Blit body

        LDA #$03
        STA ZP_SPRITE_W                 ; Walking feet width = 3 bytes
        LDA #$04
        STA ZP_SPRITE_H                 ; Walking feet height = 4 rows
        LDX ZP_CLIP_X_LO                ; Re-derive screen column
        LDA PROJ_SCREEN_COL,X
        STA ZP_SPRITE_X
        LDA ZP_ENEMY_A_ROW
        CLC
        ADC #$12
        STA ZP_SPRITE_Y                 ; Feet row = body row + $12
        LDY ZP_ENEMY_A_LEG_PHASE        ; Phase: 1 or 3
        CPY #$01
        BEQ .walk_step2                 ; phase 1 -> STEP2 table ($B01E)
        LDX ZP_SAVE_X                   ; phase 3 -> STEP1 table ($B010)
        LDA SPRITE_TABLE_A_STEP1_LO,X
        STA SMC_DS_SRC_LO
        LDA SPRITE_TABLE_A_STEP1_HI,X
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE                 ; Blit walk variant 1
        JMP .hit_test
.walk_step2:
        LDX ZP_SAVE_X
        LDA SPRITE_TABLE_A_STEP2_LO,X
        STA SMC_DS_SRC_LO
        LDA SPRITE_TABLE_A_STEP2_HI,X
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE                 ; Blit walk variant 2

; --- Player-hit test: narrow X window + wide Y band ---
.hit_test:
        LDA ZP_CLIP_X_LO
        CMP #$42
        BCC .no_hit                     ; clipped X < $42: no overlap
        CMP #$4F
        BCS .no_hit                     ; clipped X >= $4F: no overlap
        LDA ZP_PLAYER_COL
        SEC
        SBC #$14
        CMP ZP_ENEMY_A_ROW
        BCS .no_hit                     ; enemy-row < player-$14: no overlap
        CLC
        ADC #$24                        ; (player-$14) + $24 = player+$10
        CMP ZP_ENEMY_A_ROW
        BCC .no_hit                     ; enemy-row >= player+$10: no overlap

; --- Hit: deactivate A, rearm death click, DEC $39, +$0300 BCD ---
.hit:
        LDA #$00
        STA ZP_ENEMY_A_STATE            ; Immediate deactivation (not drift)
        LDA #$07
        STA ZP_ENEMY_A_SND_CTR          ; One last death click
        DEC ZP_GAME_OVER                ; Consume a player-hit credit
        LDA #$00
        STA ZP_SCORE_ADD_LO             ; addend lo = $00
        LDA #$03
        STA ZP_SCORE_ADD_HI             ; addend hi = $03 ($0300 BCD = 300)
        JSR SCORE_ADD                   ; ... score += 300
.no_hit:
        RTS
@ %def ENEMY_A_DRAW ZP_ENEMY_A_LEG_PHASE
@ %def SPRITE_TABLE_A_BODY_LO SPRITE_TABLE_A_BODY_HI
@ %def SPRITE_TABLE_A_STEP1_LO SPRITE_TABLE_A_STEP1_HI
@ %def SPRITE_TABLE_A_FEET_LO SPRITE_TABLE_A_FEET_HI
@ %def SPRITE_TABLE_A_STEP2_LO SPRITE_TABLE_A_STEP2_HI

\section{Enemy-B advance timer}

[[ENEMY_B_ADVANCE]] at \$1536 is the per-frame tick for the second of
three ``moving hazard'' slots.  It completes the triplet with
[[ENEMY_A_ADVANCE]] (\$13D6) and [[ENEMY_C_ADVANCE]] (\$1646), but has
fundamentally different cadence semantics: it is a slow
\emph{up}-counting slot, gated on the player's animation counter
[[ZP_ANIM_COUNTER]] (\$1F), not a downward-counting phase variable.
The slot uses the B-record [[ZP_ENEMY_B_STATE]] (\$E0),
[[ZP_ENEMY_B_POS]] (\$E1/\$E2), [[ZP_ENEMY_B_ROW]] (\$E3), and the
independent sound counter [[ZP_ENEMY_B_SND_CTR]] (\$E4).  See \S
Enemy-A advance timer for the shared click+gate+rearm template; this
section documents only the differences.

\paragraph{Sound.}  Same shape as enemy-A's [[SFX_TONE]] click
(duration~\$0A), but reading [[SND_PITCH_TBL_B]] at \$0231 and using
the independent [[ZP_ENEMY_B_SND_CTR]] (\$E4, not \$B7/\$B8 shared with
A/C).

\paragraph{Tick direction is inverted.}  Enemy-A and enemy-C subtract
[[ZP_ADVANCE_RATE]] (\$40, set by [[DIFFICULTY_UPDATE]] to 1/2/3) from
the 16-bit counter each frame.  Enemy-B does the opposite: it
\emph{adds} a small value to [[ZP_ENEMY_B_POS]] each frame, counting up
toward a rearm threshold.  The per-frame add value is not
[[ZP_ADVANCE_RATE]] at all but the \emph{player animation counter}
[[ZP_ANIM_COUNTER]] itself, loaded via \emph{self-modifying code} at
[[SMC_ENEMY_B_ADD]] (\$1551, the immediate operand byte of the
\texttt{ADC~\#\$01} at \$1550).  The initial on-disk value of the
operand is \$01, and the only values ever written back are \$01 or
\$03 (see gate below), so B still counts strictly upward by a small
increment each frame.

\paragraph{Animation-counter gate with SMC patch.}  After the 16-bit
add, enemy-B inspects [[ZP_ANIM_COUNTER]] (\$1F):

\begin{enumerate}
\item If \$1F~$\geq$~\$04: exit without patching --- the counter is out
  of the gated range.
\item If \$1F~=~\$00, \$02: exit without patching --- these two values
  are treated as ``pause'' states and do not advance the tick rate.
\item Otherwise (\$1F $\in$ \{\$01, \$03\}): write the current value of
  \$1F into [[SMC_ENEMY_B_ADD]], patching the \texttt{ADC} operand so
  the \emph{next} frame adds 1 or 3 instead of the previous amount,
  then exit.
\end{enumerate}

The practical effect is that enemy-B's counter accelerates during
certain player-animation frames (\$1F~=~\$03, tripling the per-frame
add) and runs at the baseline (\$01) otherwise.  Since [[ZP_ANIM_COUNTER]]
is also the low byte of the PRNG state (\emph{see} [[PRNG]]) and is
separately used as the player climb/descend pause index (\emph{see}
[[ATTRACT_ANIM_3]] which pauses at \$1F~=~5), the gate has a
pseudorandom flavour but is anchored to actual animation-frame
transitions, not a free-running timer.

The high byte check at \$155A (\texttt{CMP \#\$03; BCS \$1570}) splits
the routine: until [[ZP_ENEMY_B_POS]]$+1$ reaches \$03, each frame only
runs the animation-gated SMC patch.  Once it reaches \$03 the routine
instead falls through to the rearm attempt.

\paragraph{Rearm.}  When [[ZP_ENEMY_B_POS]]$+1$~$\geq$~\$03, the
routine re-examines the low byte: if \$E1~$<$~\$5A it exits (still
counting up within the window), otherwise the counter is reloaded to
\$003E, the row is reseated from the four-entry anchor table at
\$84--\$87 (addressed as \$84,X with $X=\text{\$1F}~\&~3$), and the
routine returns with [[ZP_ENEMY_B_STATE]] \emph{unchanged}.  Unlike
enemy-A's rearm, B's rearm does \emph{not} wake another slot; unlike
enemy-C's rearm, it does \emph{not} deactivate itself.  B's slot
self-deactivation (into drift mode, where it then counts out via the
256-frame drift-path wrap) happens inside the \emph{draw} routine
[[ENEMY_B_DRAW]] at \$15FE when B overlaps the player
(\$FF~$\rightarrow$~[[ZP_ENEMY_B_STATE]]).  This is \emph{not} a
B$\rightarrow$\{A,C\} handshake: B only writes its own state byte
\$E0, not \$D4 or \$DC.

\paragraph{Drift path: count up to overflow, then deactivate.}  If
[[ZP_ENEMY_B_STATE]] is negative (drift mode), the routine jumps to
\$1588: it \texttt{INC}s [[ZP_ENEMY_B_POS]] (lo only) each frame and
on lo-byte wrap writes \$00 to [[ZP_ENEMY_B_STATE]]
--- deactivating the slot.  So drift-mode B fires 256 frames after
activation (~4.3s at 60Hz).

\paragraph{Row table reuse.}  Enemy-B reads from \$84,X with X $\in
\{0,1,2,3\}$, so all four entries of the anchor table at
\$84--\$87 can select its row.  Enemy-C uses the same table but only
the three entries at \$85--\$87 (X $\in \{1,2,3\}$).  The base \$84 is
shared with [[LEVEL_INTRO_TICK]]'s per-level intro Y seed.

\paragraph{Cross-references.}  [[ZP_ADVANCE_RATE]] is \emph{not}
consumed here, so B does not share the difficulty-controlled advance
rate of A and C.  The draw counterpart [[ENEMY_B_DRAW]] at \$1591
reads [[ZP_ENEMY_B_STATE]], [[ZP_ENEMY_B_POS]] and
[[ZP_ENEMY_B_ROW]], and its collision path at \$15FE writes \$FF to
[[ZP_ENEMY_B_STATE]] (putting B into drift mode for self-deactivation)
when B's screen sprite overlaps the player hit-box.  The \$D4/\$DC
writes at \$1757-\$1763 belong to [[ENEMY_C_DRAW]] (enemy-C draw),
not to [[ENEMY_B_DRAW]] --- enemy-C's collision path is what
broadcasts \$FF to both neighbours.

<<enemy b defines>>=

; --- Zero-page (enemy-B advance slot) ---
ZP_ENEMY_B_STATE   = $E0        ; Control: $00 off; +=steady; -=drift (count-up)
ZP_ENEMY_B_POS     = $E1        ; 16-bit advance counter ($E1/$E2), counts UP
ZP_ENEMY_B_ROW     = $E3        ; Sprite starting row
ZP_ENEMY_B_SND_CTR = $E4        ; Sound-click counter (BMI = idle)
; Sound pitch table for enemy-B, packed inside SCREEN_ROW_HELPER.
SND_PITCH_TBL_B    = $0231      ; Pitch bytes indexed by ZP_ENEMY_B_SND_CTR
; (ENEMY_C_ROW_TBL at $84 is reused here with X in {0,1,2,3}.)

<<enemy b advance>>=

        ORG $1536
ENEMY_B_ADVANCE:
        SUBROUTINE
        ; Per-frame tick for the enemy-B slot.  Structurally similar
        ; to ENEMY_A_ADVANCE / ENEMY_C_ADVANCE but counts UP toward a
        ; rearm threshold and is gated on ZP_ANIM_COUNTER rather than
        ; ZP_ADVANCE_RATE.  The per-frame add amount is self-modified
        ; to be ZP_ANIM_COUNTER itself when $1F in {1, 3}.  Rearm
        ; reloads counter to $003E, reseats row from $84+(\$1F&3),
        ; and leaves state unchanged (no handshake --- see
        ; ENEMY_B_DRAW at $15FE where B writes $FF to its own state
        ; on player-overlap, deferring deactivation through the
        ; drift-path wrap).  Drift mode (state bit 7) counts up on lo
        ; only and self-deactivates on lo-byte wrap.
        ;
        ; Inputs:
        ;   ZP_ENEMY_B_SND_CTR  --- click-pitch index (BMI = idle).
        ;   ZP_ENEMY_B_STATE    --- $00 off / +steady / -drift.
        ;   ZP_ENEMY_B_POS      --- 16-bit counter (counts UP).
        ;   ZP_ANIM_COUNTER     --- gates tick rate; writes SMC byte.
        ;   ENEMY_C_ROW_TBL     --- 4-entry row table $84..$87.
        ;
        ; Behavior:
        ;   1. Emit a click from SND_PITCH_TBL_B[ZP_ENEMY_B_SND_CTR]
        ;      via SFX_TONE; skip when the counter is negative.
        ;   2. Exit if state is $00.  Steady ($+$): fall through.
        ;      Drift ($-$): jump to .drift_tick.
        ;   3. ADD SMC_ENEMY_B_ADD to ZP_ENEMY_B_POS (16-bit).
        ;   4. If new hi byte >= $03, try rearm at .rearm_attempt.
        ;   5. Otherwise gate on ZP_ANIM_COUNTER: if $1F < $04 and
        ;      $1F not in {0, 2}, patch SMC_ENEMY_B_ADD := \$1F.
        ;
        ; Modifies:
        ;   ZP_ENEMY_B_SND_CTR, ZP_ENEMY_B_STATE, ZP_ENEMY_B_POS,
        ;   ZP_ENEMY_B_ROW, SMC_ENEMY_B_ADD (self-modified code byte)
        ; Clobbers: A, X

; --- Emit click from pitch table ---
        LDX ZP_ENEMY_B_SND_CTR
        BMI .after_click                ; Negative = idle
        LDA SND_PITCH_TBL_B,X           ; Pitch byte
        LDX #$0A                        ; Duration = 10 clicks
        JSR SFX_TONE
        DEC ZP_ENEMY_B_SND_CTR
.after_click:

; --- State gate: $00 idle, $+$ steady, $-$ drift ---
        LDA ZP_ENEMY_B_STATE
        BEQ .exit                       ; $00 = inactive
        BPL .steady                     ; Positive = steady up-count
        JMP .drift_tick                 ; Negative = drift (self-destruct)

; --- Steady tick: 16-bit ADD with SMC-patched increment ---
.steady:
        CLC
        LDA ZP_ENEMY_B_POS
SMC_ENEMY_B_ADD = *+1                   ; ADC operand byte (patched below)
        ADC #$01                        ; Initial increment = $01
        STA ZP_ENEMY_B_POS
        LDA ZP_ENEMY_B_POS+1
        ADC #$00
        STA ZP_ENEMY_B_POS+1
        CMP #$03                        ; hi reached $03?
        BCS .rearm_attempt              ; yes: try rearm

; --- Gate on animation counter; patch SMC increment if $1F in {1,3} ---
        LDA ZP_ANIM_COUNTER
        CMP #$04
        BCS .exit                       ; $1F >= 4: out of range
        CMP #$00
        BEQ .exit                       ; $1F = 0: pause state
        CMP #$02
        BEQ .exit                       ; $1F = 2: pause state
        STA SMC_ENEMY_B_ADD             ; $1F in {1,3}: patch ADC #imm
.exit:
        RTS

; --- Rearm: reload counter to $003E, reseat row from $84,X ---
.rearm_attempt:
        LDA ZP_ENEMY_B_POS
        CMP #$5A
        BCC .exit                       ; lo < $5A: still counting up
        LDA #$00
        STA ZP_ENEMY_B_POS+1            ; hi := 0
        LDA #$3E
        STA ZP_ENEMY_B_POS              ; lo := $3E (counter := $003E)
        LDA ZP_ANIM_COUNTER
        AND #$03
        TAX                             ; X = $1F & 3, range 0..3
        LDA ENEMY_C_ROW_TBL,X           ; $84/$85/$86/$87
        STA ZP_ENEMY_B_ROW
        RTS

; --- Drift path: count up on lo only; on wrap, self-deactivate ---
.drift_tick:
        INC ZP_ENEMY_B_POS
        BNE .exit                       ; No wrap: exit
        LDA #$00
        STA ZP_ENEMY_B_STATE            ; Wrap: state := $00 (deactivate)
        RTS
@ %def ENEMY_B_ADVANCE SMC_ENEMY_B_ADD
@ %def ZP_ENEMY_B_STATE ZP_ENEMY_B_POS ZP_ENEMY_B_ROW ZP_ENEMY_B_SND_CTR
@ %def SND_PITCH_TBL_B

\section{Enemy-B draw and player-collision}

[[ENEMY_B_DRAW]] at \$1591 is the draw+hit routine for the enemy-B
slot, and the third member of the sprite-draw family that mirrors
[[ENEMY_A_DRAW]] (enemy-A) and [[ENEMY_C_DRAW]] (enemy-C).  It is
called from [[MAIN_LOOP]] every frame after [[ENEMY_B_ADVANCE]] has
ticked the slot; the two routines together implement the enemy-B
cycle.

\paragraph{Shape.}  A short state gate -- drift dispatch -- clip --
main draw -- player-collision body, followed by a separate
drift-mode draw tail.  The overall layout is:
\begin{enumerate}
\item If [[ZP_ENEMY_B_STATE]] is~\$00, exit.
\item If it is \emph{negative} (drift mode, set by the collision
  body below), jump to the drift-mode draw at \$1623.
\item Otherwise (steady mode) compute a screen-relative X from the
  16-bit position [[ZP_ENEMY_B_POS]] via a perspective lookup
  indexed by [[ZP_PLAYER_Y]], clip against a \$9C column bound, and
  draw a \$05$\times$\$11 sprite from [[SPRITE_TABLE_LO]]+\$25 /
  [[SPRITE_TABLE_HI]]+\$25 indexed by [[PROJ_FRAME_IDX]].
\item Player-collision test: if the clipped X is in the window
  [\$42,\$55) and [[ZP_ENEMY_B_ROW]] lies in a
  $[{\rm player\_col}-\$0E,\,{\rm player\_col}+\$0D]$ band
  (\$1B wide), the enemy has overlapped the player.
\item On overlap: write \$FF to [[ZP_ENEMY_B_STATE]] (put B into
  drift mode so it self-deactivates via the 256-frame drift-wrap in
  [[ENEMY_B_ADVANCE]]), rewind [[ZP_ENEMY_B_POS]] to
  $(\$AF-\$03)\cdot\$100 + \$D0$, bump [[ZP_ENEMY_B_ROW]] by 2, rearm
  the click counter ([[ZP_ENEMY_B_SND_CTR]]~=~\$05), award 300~BCD
  points via [[SCORE_ADD]], and decrement the game-over flag \$39.
  The draw call itself is skipped on this path.
\item The drift-mode branch at \$1623 draws a smaller \$02$\times$\$06
  ``puff'' sprite from the level-data pointer pair at \$755A/\$765A
  (inside the per-level swappable region).
\end{enumerate}

\paragraph{Per-frame hit cost.}  The \texttt{DEC \$39} inside the
overlap body is the same shape as the one inside
[[ENEMY_A_DRAW]] (at \$1528).  \$39 is initialized to \$01 by
[[INIT_LEVEL_STATE]] and reset to \$01 by the player-reincarnation
code at \$5EC3 (see [[MAIN_LOOP]]'s game-over check at \$6832).  Each
enemy-A or enemy-B overlap decrements \$39; once it goes negative the
main-loop tail branches to [[GAME_OVER]].  So B's overlap body is the
``player-hit'' half of the enemy-B cycle and matches A's behaviour
structurally --- though the way B absorbs the hit differs from A's:
A writes \$00 to [[ZP_ENEMY_A_STATE]] immediately, while B writes \$FF
to enter drift mode and lets the drift-path wrap in
[[ENEMY_B_ADVANCE]] complete the deactivation.

\paragraph{Screen-relative X via perspective lookup.}  Both
[[ENEMY_A_DRAW]] and [[ENEMY_B_DRAW]] compute
$$
  X_{\rm screen} = {\rm pos\_lo} - ({\rm PERSPECTIVE\_XOFF\_LO}[{\rm player\_Y}] - {\rm ZP\_SPRITE\_XREF}),
$$
with the high byte similarly propagated to \$B0.  If the high-byte
difference in \$B0 is non-zero after the subtract, the enemy is
off-screen horizontally and the routine returns without drawing.
Otherwise the low byte is the screen-relative X ($0$--$\$9B$) used as
the index into three parallel tables:
[[PROJ_SCREEN_COL]] (\$1C34) for the screen column,
[[PROJ_FRAME_IDX]] (\$1B8F) for the sprite-frame index within the
sprite family.  These are the same tables used by [[HAZARD_CHECK]]
for projectile rendering, so the enemy sprites share the
horizontal-position $\to$ sprite-frame mapping with projectiles.

\paragraph{Sprite family at index \$25.}  The steady-mode draw
indexes [[SPRITE_TABLE_LO]] / [[SPRITE_TABLE_HI]] at base \$25
(addresses \$B025 / \$B0A5).  Indexed by the sprite frame from
[[PROJ_FRAME_IDX]], this selects one of seven enemy-B body sprites
(7 frames per sprite family at this base index); compare
[[ENEMY_A_DRAW]] which uses bases \$09, \$10, \$17, \$1E for
enemy-A's multiple sprite variants (body / walk-1 / stance-feet /
walk-2).

\paragraph{Drift-mode puff at \$755A/\$765A.}  When
[[ZP_ENEMY_B_STATE]] is negative the draw path jumps to the short
drift-tail at \$1623 which patches [[SMC_DS_SRC_LO]] /
[[SMC_DS_SRC_HI]] to the 16-bit pointer pair at \$755A / \$765A
--- inside the per-level swappable region \$7500-\$7AFF --- and
draws a \$02$\times$\$06 sprite.  The pointer is therefore
\emph{level-specific}: each level's data contributes its own
enemy-B drift-puff sprite.  This is different from the steady-mode
draw which reads from the persistent [[SPRITE_TABLE_LO]] / [[SPRITE_TABLE_HI]]
tables at \$B000.

<<enemy b draw defines>>=

; --- Zero-page used by enemy-B draw (shared with ENEMY_A_DRAW) ---
; $AF / $B0 are 16-bit scratch for the screen-clip subtract.  They
; hold the perspective-corrected low/high bytes of the enemy's
; world X minus the perspective-X reference, and after the subtract
; against ZP_ENEMY_B_POS they hold the screen-relative X.
ZP_CLIP_X_LO    = $AF           ; Screen-clip scratch low byte
ZP_CLIP_X_HI    = $B0           ; Screen-clip scratch high byte

; $4C is a level-fixed X-reference (INIT_LEVEL_STATE writes $02).
; It is subtracted from PERSPECTIVE_XOFF to produce the world-X
; origin that enemy positions are measured against.
ZP_SPRITE_XREF  = $4C           ; World-X reference (level-fixed = $02)

; --- Perspective-X lookup tables, indexed by ZP_PLAYER_Y ($4A) ---
; $1A8F holds the low byte and $198F holds the high byte of a Y-to-X
; transform.  The low-byte table is (roughly) $(Y>>1)\cdot 7$, so
; deeper floor positions translate to a larger horizontal offset.
; The high byte is all zero for on-screen Y values.
PERSPECTIVE_XOFF_LO = $1A8F     ; Y -> screen-X offset, low byte
PERSPECTIVE_XOFF_HI = $198F     ; Y -> screen-X offset, high byte

; --- Sprite family offsets into SPRITE_TABLE_LO / SPRITE_TABLE_HI ---
; Enemy-B's steady-mode sprite set starts at base index $25 in the
; two 128-entry parallel tables at $B000 (lo) / $B080 (hi).
SPRITE_TABLE_B_LO = $B025       ; Enemy-B body sprite pointers, low
SPRITE_TABLE_B_HI = $B0A5       ; Enemy-B body sprite pointers, high

; --- Per-level drift-mode puff sprite pointer pair ---
; Inside the swappable level-data region $7500-$7AFF.  The two bytes
; form the 16-bit address that SMC_DS_SRC_LO/HI are patched to on
; B's drift-mode draw path.
ENEMY_B_PUFF_LO = $755A         ; Drift-mode puff sprite pointer, low byte
ENEMY_B_PUFF_HI = $765A         ; Drift-mode puff sprite pointer, high byte

; --- Game-over/hit-remaining flag ($39) ---
; Initialized to $01 by INIT_LEVEL_STATE and reset to $01 by the
; player-reincarnation code at $5EC3.  Each overlap-hit in
; ENEMY_A_DRAW / ENEMY_B_DRAW decrements this counter; once it
; goes negative the main-loop tail branches to GAME_OVER.
ZP_GAME_OVER    = $39           ; Game-over / hits-remaining counter

@

<<enemy b draw>>=

        ORG $1591
ENEMY_B_DRAW:
        SUBROUTINE
        ; Per-frame draw + player-collision for the enemy-B slot.
        ; Dispatches on ZP_ENEMY_B_STATE: $00 exits; positive does the
        ; full steady-mode draw and hit-test; negative takes the
        ; drift-mode tail that draws a smaller puff sprite using a
        ; level-specific sprite-pointer pair at $755A/$765A.
        ;
        ; Inputs:
        ;   ZP_ENEMY_B_STATE    --- $00 off; +steady; -drift.
        ;   ZP_ENEMY_B_POS      --- 16-bit world X for this enemy.
        ;   ZP_ENEMY_B_ROW      --- Sprite starting screen row.
        ;   ZP_PLAYER_Y ($4A)   --- Player Y (index into perspective tables).
        ;   ZP_PLAYER_COL ($06) --- Player column (collision X reference).
        ;   ZP_SPRITE_XREF ($4C) --- Level-fixed X reference.
        ;   PERSPECTIVE_XOFF_LO/HI --- Y-to-X transform tables.
        ;   SPRITE_TABLE_B_LO/HI  --- Body-sprite pointer table base.
        ;   ENEMY_B_PUFF_LO/HI    --- Level-specific drift-puff sprite.
        ;
        ; Behavior:
        ;   1. State gate: $00 exits; negative jumps to .drift_draw.
        ;   2. Clip: compute screen-relative X into ZP_CLIP_X_LO/HI;
        ;      exit if high byte non-zero or low byte >= $9C.
        ;   3. Set sprite params ($5D = screen col, $56 = 5, $57 = $11,
        ;      $5B = ZP_ENEMY_B_ROW), patch DRAW_SPRITE src to
        ;      SPRITE_TABLE_B_{LO,HI}[PROJ_FRAME_IDX], JSR DRAW_SPRITE.
        ;   4. Player-overlap test: ZP_CLIP_X_LO in [$42,$55) AND
        ;      ZP_ENEMY_B_ROW in [player-$0E, player+$0D].
        ;   5. On overlap (.hit): write $FF to ZP_ENEMY_B_STATE (drift),
        ;      rewrite counter to $D0+(ZP_CLIP_X_LO-$03)*$100, bump row
        ;      by 2, reset sound counter, award +$0300 BCD via
        ;      SCORE_ADD, DEC ZP_GAME_OVER, exit.
        ;   6. Drift-mode draw tail: draw $02x$06 puff sprite using
        ;      level-specific pointer pair at $755A/$765A.
        ;
        ; Modifies:
        ;   ZP_CLIP_X_LO/HI, sprite-param ZPs ($56/$57/$5B/$5D),
        ;   ZP_SCORE_ADD_LO/HI, ZP_GAME_OVER, ZP_ENEMY_B_STATE,
        ;   ZP_ENEMY_B_POS, ZP_ENEMY_B_ROW, ZP_ENEMY_B_SND_CTR,
        ;   SMC_DS_SRC_LO/HI (patched operand bytes of DRAW_SPRITE).
        ; Clobbers: A, X

; --- State dispatch: $00 exit, +steady, -drift ---
        LDA ZP_ENEMY_B_STATE
        BEQ .exit                       ; $00: slot inactive
        BPL .steady                     ; positive: steady-mode draw
        JMP .drift_draw                 ; negative: drift-mode draw tail

; --- Clip: compute screen-relative X from world X ---
.steady:
        LDX ZP_PLAYER_Y
        LDA PERSPECTIVE_XOFF_LO,X       ; Y-indexed X offset (low)
        SEC
        SBC ZP_SPRITE_XREF              ; ... minus fixed X-reference
        STA ZP_CLIP_X_LO
        LDA PERSPECTIVE_XOFF_HI,X       ; (high byte propagation)
        SBC #$00
        STA ZP_CLIP_X_HI
        SEC
        LDA ZP_ENEMY_B_POS              ; Subtract from enemy world X
        SBC ZP_CLIP_X_LO
        STA ZP_CLIP_X_LO                ; ZP_CLIP_X_LO = screen-relative X (lo)
        LDA ZP_ENEMY_B_POS+1
        SBC ZP_CLIP_X_HI
        BEQ .in_bounds                  ; hi diff == 0: on-screen
.exit:
        RTS                             ; hi diff != 0: off-screen, exit
.in_bounds:
        LDA ZP_CLIP_X_LO
        CMP #$9C
        BCS .exit                       ; clipped X >= $9C: off right edge

; --- Main sprite draw (steady mode) ---
        TAX                             ; X := clipped screen-X
        LDA PROJ_SCREEN_COL,X           ; -> screen column index
        STA ZP_SPRITE_X
        LDA PROJ_FRAME_IDX,X            ; -> sprite frame index
        TAX                             ; X := frame index
        LDA #$05
        STA ZP_SPRITE_W                 ; Sprite width = 5 bytes
        LDA #$11
        STA ZP_SPRITE_H                 ; Sprite height = 17 rows
        LDA ZP_ENEMY_B_ROW
        STA ZP_SPRITE_Y                 ; Sprite row = enemy-B row
        LDA SPRITE_TABLE_B_LO,X         ; Patch DRAW_SPRITE source-ptr (lo)
        STA SMC_DS_SRC_LO
        LDA SPRITE_TABLE_B_HI,X         ; Patch DRAW_SPRITE source-ptr (hi)
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE                 ; Blit the enemy-B body sprite

; --- Player-overlap test: narrow X window + Y-band ---
        LDA ZP_CLIP_X_LO
        CMP #$42
        BCC .no_hit                     ; clipped X < $42: no overlap
        CMP #$55
        BCS .no_hit                     ; clipped X >= $55: no overlap
        LDA ZP_PLAYER_COL               ; player col (ZP $06)
        SEC
        SBC #$0E
        CMP ZP_ENEMY_B_ROW
        BCS .no_hit                     ; enemy-row < player-$0E: no overlap
        CLC
        ADC #$1B                        ; (player-$0E) + $1B = player+$0D
        CMP ZP_ENEMY_B_ROW
        BCC .no_hit                     ; enemy-row >= player+$0D: no overlap

; --- Overlap: put B into drift mode + award score + count hit ---
.hit:
        LDA #$FF
        STA ZP_ENEMY_B_STATE            ; drift mode (deferred deactivation)
        LDA ZP_CLIP_X_LO
        SEC
        SBC #$03
        STA ZP_ENEMY_B_POS+1            ; counter hi := clip_X - 3
        LDA #$D0
        STA ZP_ENEMY_B_POS              ; counter lo := $D0
        INC ZP_ENEMY_B_ROW              ; row += 2 (shift puff down)
        INC ZP_ENEMY_B_ROW
        LDA #$05
        STA ZP_ENEMY_B_SND_CTR          ; re-arm sound counter
        LDA #$00
        STA ZP_SCORE_ADD_LO             ; addend lo = $00
        LDA #$03
        STA ZP_SCORE_ADD_HI             ; addend hi = $03 ($0300 BCD = 300)
        JSR SCORE_ADD                   ; ... so score += 300
        DEC ZP_GAME_OVER                ; consume one hit-credit
.no_hit:
        RTS

; --- Drift-mode draw tail: $02x$06 puff from level-data pointer pair ---
.drift_draw:
        LDA #$02
        STA ZP_SPRITE_W                 ; Puff width = 2 bytes
        LDA #$06
        STA ZP_SPRITE_H                 ; Puff height = 6 rows
        LDA ZP_ENEMY_B_ROW
        STA ZP_SPRITE_Y                 ; Row = enemy-B row
        LDX ZP_ENEMY_B_POS+1            ; Use counter hi as X-col index
        LDA PROJ_SCREEN_COL,X
        STA ZP_SPRITE_X
        LDA ENEMY_B_PUFF_LO             ; Patch DRAW_SPRITE src with the
        STA SMC_DS_SRC_LO               ; level-specific puff pointer
        LDA ENEMY_B_PUFF_HI
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE
        RTS
@ %def ENEMY_B_DRAW
@ %def ZP_CLIP_X_LO ZP_CLIP_X_HI ZP_SPRITE_XREF ZP_GAME_OVER
@ %def PERSPECTIVE_XOFF_LO PERSPECTIVE_XOFF_HI
@ %def SPRITE_TABLE_B_LO SPRITE_TABLE_B_HI
@ %def ENEMY_B_PUFF_LO ENEMY_B_PUFF_HI

\section{Enemy-C advance timer}

[[ENEMY_C_ADVANCE]] at \$1646 is the per-frame tick for the
``ground-companion'' enemy slot in the contiguous entity block
\$D4--\$EC.  It is the third member of the
[[ENEMY_A_ADVANCE]]/[[ENEMY_B_ADVANCE]] family --- structurally
parallel but distinct in three notable ways.  See \S Enemy-A advance
timer for the shared template; this section documents only the
differences.

\paragraph{Slot mapping.}  Where enemy-A uses
[[ZP_ENEMY_A_SND_CTR]]~=~\$B8, [[ZP_ENEMY_A_STATE]]~=~\$DC,
[[ZP_ENEMY_A_POS]]~=~\$DD/\$DE and [[ZP_ENEMY_A_ROW]]~=~\$DF, enemy-C
uses [[ZP_ENEMY_C_SND_CTR]]~=~\$B7, [[ZP_ENEMY_C_STATE]]~=~\$D4,
[[ZP_ENEMY_C_POS]]~=~\$D5/\$D6 and [[ZP_ENEMY_C_ROW]]~=~\$D7.  The
sound-pitch table is [[SND_PITCH_TBL_C]] at \$0224 (8 entries) and
the click is emitted with duration~\$08 via [[SND_DELAY_DOWN]] at
\$1091 --- \emph{not} via [[SFX_TONE]] like enemy-A and enemy-B.  The
descending-tone delay produces a softer, lower-pitched percussive
chirp distinguishable from enemy-A's sharp click.

\paragraph{Drift mode is a vertical bobble, not a PRNG gate.}  Enemy-A
and enemy-B treat ``drift mode'' (state bit~7 set) as a probability
gate that simply skips the tick most frames.  Enemy-C interprets
drift mode entirely differently:

\begin{enumerate}
\item On the drift path, the routine inspects [[ZP_FRAME_COUNTER]]
  ($\$$FD): on the 1-in-4 frames where the low two bits are both set,
  it nudges [[ZP_ENEMY_C_ROW]] up by one row when bit~4 of \$FD is
  clear, or down by one row when bit~4 is set.  This makes the
  on-screen sprite bob vertically by one row at a $\sim$1-Hz cadence
  (bit~4 flips every 16 frames).
\item The 16-bit advance counter then ticks normally on the steady
  path (subtracting [[ZP_ADVANCE_RATE]]).
\item There is a separate drift entry at \$16A5 reached via
  [[JMP]]~\$16A5 from the drift dispatch: it \emph{adds} 1 to
  [[ZP_ENEMY_C_POS]] each frame and on overflow falls into the rearm
  reload code at \$1688 (skipping the \$3C-window check).  This is a
  slow upward count rather than the fast downward count used in
  steady mode.
\end{enumerate}

\paragraph{Rearm does not wake another slot.}  Enemy-A's rearm writes
\$01 to [[ZP_ENEMY_C_STATE]], waking enemy-C (the cross-slot
A$\rightarrow$C handshake).  Enemy-C's rearm instead writes \$00 to
[[ZP_ENEMY_C_STATE]]~--- \emph{deactivating itself}.  Enemy-C's own
\emph{draw} routine [[ENEMY_C_DRAW]] at \$1757--\$1763 is what
broadcasts \$FF to both \$D4 and \$DC (when C hits a floor-enemy
slot) --- so C's topology edges all live in its draw, not in
[[ENEMY_B_ADVANCE]] or any other neighbour.  This confirms a
\emph{three-slot} entity model with the topology
A$\rightarrow$C (via A's rearm) and C$\rightarrow$\{A,C\} (via C's
hit path), with B having no outgoing handshake.

\paragraph{Other constants.}  The reload value is \$0352 (vs.\ enemy-A's
\$0361), the rearm window is \$0000..\$003B (vs.\ \$0000..\$003D), and
the row reload reads from a three-slot table at \$85/\$86/\$87
(addressed as $\$$84,X with X derived from [[ZP_PRNG_A]]).  The index
is computed as $X = ({\rm PRNG\_A}~\&~3)$ if non-zero, else $X = 1$~---
so X $\in \{1,2,3\}$ with X~=~1 selected~$2/4$ of the time and X~=~2
or 3 each~$1/4$ of the time.  The row is then $\$84,X - $\$0A.  Slots
\$83--\$87 are also used by [[LEVEL_INTRO_TICK]] (per-level intro Y
seed at \$84) and by [[BEAM_TARGET_DRAW]] (per-floor Y threshold
[[FLOOR_THRESH]] at \$83): enemy-C reuses three of these scenery-anchor
Y rows as spawn-row choices.

\paragraph{Cross-references.}  [[ZP_ADVANCE_RATE]] is shared with
[[ENEMY_A_ADVANCE]] (and presumably [[ENEMY_B_ADVANCE]]).  The draw
counterpart [[ENEMY_C_DRAW]] at \$16AC reads [[ZP_ENEMY_C_STATE]],
[[ZP_ENEMY_C_POS]] and [[ZP_ENEMY_C_ROW]] directly.  External
producers of [[ZP_ENEMY_C_STATE]] are: [[ENEMY_A_ADVANCE]]
($\$1411$, writes~\$01 = steady-mode activation) and
[[ENEMY_C_DRAW]]'s own hit path ($\$1759$, writes~\$FF = drift-mode
self-animation, paired with a \$FF write to [[ZP_ENEMY_A_STATE]] if
that slot was active).

<<enemy c defines>>=

; --- Zero-page (enemy-C advance slot) ---
ZP_ENEMY_C_SND_CTR = $B7        ; 8-step sound-click counter (BMI = idle)
ZP_ENEMY_C_POS     = $D5        ; 16-bit advance counter ($D5/$D6)
; (ZP_ENEMY_C_STATE = $D4 and ZP_ENEMY_C_ROW = $D7 are exported by enemy-A.)
; Sound pitch table for enemy-C, packed inside SCREEN_ROW_HELPER.
SND_PITCH_TBL_C    = $0224      ; 8 pitch bytes indexed by ZP_ENEMY_C_SND_CTR
; Three-entry Y-anchor table read as $84,X with X in {1,2,3}; subtract $0A.
; The base $84 is also used as the per-level intro Y seed (LEVEL_INTRO_TICK)
; and adjacent slots at $83/$85/$86/$87 are FLOOR_THRESH and other per-level
; scenery anchors --- enemy-C reuses three of those rows as spawn anchors.
ENEMY_C_ROW_TBL    = $84        ; Read as $84,X with X in {1,2,3}

<<enemy c advance>>=

        ORG $1646
ENEMY_C_ADVANCE:
        SUBROUTINE
        ; Per-frame tick for the enemy-C ``ground companion'' slot.
        ; Mirrors ENEMY_A_ADVANCE's tick+rearm template with three
        ; key differences (see \S Enemy-C advance timer):
        ;   1. Click is SND_DELAY_DOWN (descending), not SFX_TONE.
        ;   2. Drift mode bobs ZP_ENEMY_C_ROW vertically using the
        ;      frame-counter bit-4 phase, not a PRNG skip gate.
        ;   3. Rearm deactivates the slot (writes $00 to state) and
        ;      reseats the row from the two-entry $83/$84 table ---
        ;      it does NOT wake another slot.
        ;
        ; Inputs:
        ;   ZP_ENEMY_C_SND_CTR  --- click-pitch index (BMI = idle).
        ;   ZP_ENEMY_C_STATE    --- $00 off / +steady / -drift.
        ;   ZP_ENEMY_C_POS      --- 16-bit counter.
        ;   ZP_ADVANCE_RATE     --- per-frame decrement ($01/$02/$03).
        ;   ZP_FRAME_COUNTER    --- drives drift-mode row bobble.
        ;   ZP_PRNG_A           --- selects which row anchor on rearm.
        ;   ENEMY_C_ROW_TBL     --- 3-entry row anchor table at $85/$86/$87
        ;                          (addressed as $84,X for X in {1,2,3}).
        ;
        ; Behavior:
        ;   1. Emit a click from SND_PITCH_TBL_C[ZP_ENEMY_C_SND_CTR]
        ;      via SND_DELAY_DOWN with duration $08; skip when idle.
        ;   2. Exit if state is $00.  Steady ($+$): tick now.  Drift
        ;      ($-$): jump to .drift_tick and INC the lo counter only.
        ;   3. Steady tick: 1-in-4 frames (FD&3==3), nudge ROW $\pm$1
        ;      based on FD bit~4; then SBC ZP_ADVANCE_RATE on the
        ;      16-bit counter; rearm only if $D5 < $3C and $D6 == 0.
        ;   4. Rearm: reload counter to $0352, pick X = (PRNG_A&3)
        ;      if non-zero else 1, set ROW := $84,X - $0A, write $00
        ;      to state.
        ;
        ; Modifies:
        ;   ZP_ENEMY_C_SND_CTR, ZP_ENEMY_C_STATE, ZP_ENEMY_C_POS,
        ;   ZP_ENEMY_C_ROW
        ; Clobbers: A, X, Y

; --- Emit click from pitch table ---
        LDX ZP_ENEMY_C_SND_CTR
        BMI .after_click                ; Negative = idle
        LDA SND_PITCH_TBL_C,X           ; Pitch byte
        LDX #$08                        ; Duration = 8 clicks
        JSR SND_DELAY_DOWN
        DEC ZP_ENEMY_C_SND_CTR
.after_click:

; --- State gate: $00 idle, $+$ steady, $-$ drift ---
        LDA ZP_ENEMY_C_STATE
        BEQ .exit                       ; $00 = inactive (RTS at $1681)
        BPL .steady                     ; Positive = steady tick
        JMP .drift_tick                 ; Negative = drift tick (counter +1)

; --- Steady path: drift-mode row bobble runs on 1-in-4 frames ---
.steady:
        LDA ZP_FRAME_COUNTER
        AND #$03
        CMP #$03
        BNE .tick                       ; Other 3/4 frames: skip bobble
        LDA ZP_FRAME_COUNTER
        AND #$10                        ; Phase: bit 4 flips every 16 frames
        BNE .row_dec
        INC ZP_ENEMY_C_ROW              ; Phase 0: bobble down
        JMP .tick
.row_dec:
        DEC ZP_ENEMY_C_ROW              ; Phase 1: bobble up

; --- 16-bit decrement; rearm only on the narrow $0000..$003B band ---
.tick:
        LDA ZP_ENEMY_C_POS
        SEC
        SBC ZP_ADVANCE_RATE
        STA ZP_ENEMY_C_POS
        LDA ZP_ENEMY_C_POS+1
        SBC #$00
        STA ZP_ENEMY_C_POS+1
        BEQ .check_lo                   ; hi == 0: maybe rearm
.exit:
        RTS                             ; hi != 0: still ticking, exit
.check_lo:
        LDA ZP_ENEMY_C_POS
        CMP #$3C
        BCS .exit                       ; lo >= $3C: not yet in window

; --- Rearm: reload counter, pick row anchor, deactivate self ---
.rearm:
        LDA #$52
        STA ZP_ENEMY_C_POS              ; Reload lo to $52
        LDA #$03
        STA ZP_ENEMY_C_POS+1            ; Reload hi to $03 (counter = $0352)
        LDA ZP_PRNG_A
        AND #$03
        BNE .have_idx                   ; PRNG&3 != 0: X := 1, 2, or 3
        LDA #$01                        ; PRNG&3 == 0: force X := 1
.have_idx:
        TAX                             ; X in {1, 2, 3}
        LDA ENEMY_C_ROW_TBL,X           ; $85, $86, or $87: row anchor
        SEC
        SBC #$0A
        STA ZP_ENEMY_C_ROW              ; Row := anchor - $0A
        LDA #$00
        STA ZP_ENEMY_C_STATE            ; Deactivate self (state := $00)
        RTS

; --- Drift path: counter counts UP; on lo-byte overflow fall to .rearm ---
.drift_tick:
        INC ZP_ENEMY_C_POS
        BNE .exit                       ; No overflow: exit
        JMP .rearm                      ; Lo wrapped: jump to rearm reload
@ %def ENEMY_C_ADVANCE
@ %def ZP_ENEMY_C_SND_CTR ZP_ENEMY_C_POS SND_PITCH_TBL_C ENEMY_C_ROW_TBL

\section{Enemy-C draw and enemy-slot collision}

[[ENEMY_C_DRAW]] at \$16AC is the draw+hit routine for the enemy-C
slot --- the third member of the sprite-draw family alongside
[[ENEMY_A_DRAW]] (enemy-A) and [[ENEMY_B_DRAW]] (enemy-B).
Called from [[MAIN_LOOP]] immediately after [[ENEMY_C_ADVANCE]] has
ticked the slot.  (Previously mislabeled \texttt{PLAYER\_RENDER} in
the stub; that name was a misnomer and is retired here --- this
routine does not draw the player at all.)

\paragraph{Shape.}  Same state-gate / perspective-clip / main-draw /
hit-test / drift-draw-tail shape as [[ENEMY_B_DRAW]], with three
substantive differences:
\begin{enumerate}
\item \textbf{Body sprite is smaller.}  [[ENEMY_B_DRAW]] draws a
  $\$05\times\$11$ body; enemy-C's body is a narrow $\$02\times\$0B$
  sprite read from [[SPRITE_TABLE_C_LO]] / [[SPRITE_TABLE_C_HI]] at
  \$AFE1/\$B061 (indexed by [[PROJ_FRAME_IDX]]).  The column bound
  is \$94 rather than \$9C, so enemy-C clips slightly sooner at the
  right edge.
\item \textbf{Secondary ``tail'' sprite below the body.}  Immediately
  after the main draw, enemy-C issues a \emph{second} [[DRAW_SPRITE]]
  call for a $\$01\times\$07$ sprite at (clip\_X$-$1, row $+$ \$0B),
  reading from the level-specific pointer pair
  [[ENEMY_C_TAIL_LO]]/[[ENEMY_C_TAIL_HI]] at \$7549/\$7649 (also
  indexed by [[PROJ_FRAME_IDX]]).  The tail lives in the per-level
  swappable region \$7500--\$7AFF so each level contributes its own
  tail art.  A \texttt{BCS} at \$1706 skips both the second draw and
  the hit test if the shifted X underflowed (i.e.\ clip\_X was \$00).
\item \textbf{Hit target is a 4-slot enemy table, not the player.}
  The hit test at \$1730--\$1755 walks the four-slot floor-enemy
  table at \$9B/\$9F/\$A3 (the same slots the beam targets), scanning
  X~=~3..0 for the first active flag.  The test compares enemy-C's
  screen-X ([[ZP_CLIP_X_LO]]) against [[ZP_ENEMY_COL]] and its row
  ([[ZP_ENEMY_C_ROW]]) against [[ZP_ENEMY_Y]].  On a match,
  enemy-C \emph{consumes} the floor-enemy slot.
\end{enumerate}

\paragraph{Hit action (\$1757--\$1782): the C$\rightarrow$\{A,C\}
broadcast.}  On a hit:
\begin{enumerate}
\item Write \$FF to [[ZP_ENEMY_C_STATE]] (put self into drift mode,
  triggering the vertical bobble animation in [[ENEMY_C_ADVANCE]]).
\item If [[ZP_ENEMY_A_STATE]] is non-zero, write \$FF to it too ---
  putting enemy-A into PRNG-gated drift mode.  This is the
  \emph{cross-slot broadcast}: C's hit animates both itself and A.
\item Reload [[ZP_ENEMY_C_POS]] to ($\$$AF,$\$$D0) (hi~=~clip\_X,
  lo~=~\$D0) and bump [[ZP_ENEMY_C_ROW]] by 2.
\item Clear the floor-enemy slot: \texttt{STA \$9B,X} with A~=~\$00
  retires the same slot the beam would retire on a laser kill.
\item Rearm the click counter ([[ZP_ENEMY_C_SND_CTR]] \$B7~=~\$04).
\item Award \textbf{100~BCD} points via [[SCORE_ADD]] (addend
  \$0100).  Note: unlike [[ENEMY_B_DRAW]], enemy-C does
  \emph{not} decrement [[ZP_GAME_OVER]] --- this hit path is not a
  player-life event.
\end{enumerate}

\paragraph{Hit-box.}  Screen-X window is (clip\_X$-$\$08, clip\_X]
(enemy-C's X $\pm$ 4 pixels of the target's column); Y window is
(row$-$\$04, row$+$\$0A) (a 13-row band centred four rows above
enemy-C's top).  Only the \emph{first} active slot (highest X with
the flag set) is tested per frame.

\paragraph{Drift-mode tail at \$1783.}  Reached when
[[ZP_ENEMY_C_STATE]] is negative (set by the hit path above, or
externally by [[ENEMY_A_ADVANCE]]'s rearm at \$1411 which writes
\$01 --- wait, only hits write \$FF; A's rearm writes \$01 for
steady mode).  The drift-mode draw emits a single $\$02\times\$06$
``puff'' sprite at [[ZP_ENEMY_C_POS]]$+1$'s column index, reading
from [[ENEMY_C_PUFF_LO]]/[[ENEMY_C_PUFF_HI]] at \$7559/\$7659 ---
a different level-specific pointer pair from [[ENEMY_B_DRAW]]'s
\$755A/\$765A puff (one byte earlier).

\paragraph{Contrast with [[ENEMY_B_DRAW]]:}

\begin{center}
\begin{tabular}{lll}
                        & Enemy-B                        & Enemy-C               \\ \hline
Slot state              & \$E0                          & \$D4                  \\
16-bit pos              & \$E1/\$E2                     & \$D5/\$D6             \\
Row                     & \$E3                          & \$D7                  \\
Main sprite size        & $\$05\times\$11$              & $\$02\times\$0B$      \\
Main sprite table       & \$B025/\$B0A5 (SPRITE\_B)     & \$AFE1/\$B061 (SPRITE\_C) \\
Right X clip            & \$9C                          & \$94                  \\
Secondary sprite        & \emph{none}                   & $\$01\times\$07$ tail at \$7549/\$7649 \\
Hit target              & player (\$06/\$4A)            & 4-slot enemy (\$9F/\$A3) \\
Hit X window            & [\$42, \$55)                  & (clip\_X$-$8, clip\_X] \\
Hit Y window            & $[\textrm{player}-\$0E, \textrm{player}+\$0D]$ & $[\textrm{row}-\$03, \textrm{row}+\$09]$ \\
Score awarded           & +\$0300 (300)                 & +\$0100 (100)         \\
Game-over decrement     & yes                           & \emph{no}             \\
Post-hit state writes   & \$E0~$\leftarrow$~\$FF        & \$D4~$\leftarrow$~\$FF; \$DC~$\leftarrow$~\$FF (if non-zero); \$9B,X~$\leftarrow$~\$00 \\
Sound counter reload    & \$E4~$\leftarrow$~\$05        & \$B7~$\leftarrow$~\$04 \\
Drift-mode puff src     & \$755A/\$765A                 & \$7559/\$7659         \\
\end{tabular}
\end{center}

\paragraph{Topology restated.}  The C$\rightarrow$\{A,C\} broadcast
in this routine is triggered by enemy-C striking a floor-enemy, not
by striking the player.  Combined with enemy-A's rearm writing
\$01 to \$D4 (A$\rightarrow$C wake), the three-slot handshake graph
is: A wakes C on its own rearm; C arms both itself and A into drift
mode when it kills a floor-enemy; B has no outgoing handshake and
only affects its own state.

<<enemy c draw defines>>=

; --- Enemy-C sprite tables (persistent, $A000-$B0FF region) ---
SPRITE_TABLE_C_LO = $AFE1       ; Enemy-C body sprite pointers, low
SPRITE_TABLE_C_HI = $B061       ; Enemy-C body sprite pointers, high

; --- Enemy-C level-specific sprites (inside swappable $7500-$7AFF) ---
; Steady-mode ``tail'' sprite indexed by PROJ_FRAME_IDX (X).
ENEMY_C_TAIL_LO = $7549         ; Tail sprite pointers, low (indexed)
ENEMY_C_TAIL_HI = $7649         ; Tail sprite pointers, high (indexed)
; Drift-mode single puff pointer (not indexed).
ENEMY_C_PUFF_LO = $7559         ; Drift-mode puff sprite pointer, low
ENEMY_C_PUFF_HI = $7659         ; Drift-mode puff sprite pointer, high

