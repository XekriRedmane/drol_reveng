<<stage stack>>=

        ORG $5C00
STAGE_STACK:
        SUBROUTINE
        ; Duplicate of SCREEN_ROW_COPY ($0100-$012A) parked in the
        ; staging-buffers region.  Doubles as the install-time source
        ; for the stack page ($5C00-$5CEF is copied to $0100-$01EF by
        ; FIRST_BOOT) and as the loader's screen-wipe callback
        ; invoked by SCREEN_PRE_RESTORE --- the $0100 copy would be
        ; corrupted by stack use by then, so the loader jumps here.
        ;
        ; See SCREEN_ROW_COPY ($0100) for behavior; the code here is
        ; byte-identical up through the RTS at $5C2A.
        ;
        ; Inputs:
        ;   ZP_PAGE_FLAG ($00) --- positive skips the display flip.
        ;   ROW_COPY_BUFFER ($024C) --- 40-byte row pattern to paint.
        ;
        ; Modifies:
        ;   Hi-res page 1 ($2000-$3FFF), ZP $29/$2A, pitch scratch in
        ;   ZP_SAVE_X (via ROW_COPY_CLICK).
        ; Clobbers: A, X, Y

; --- Conditional page flip ---
        LDA ZP_PAGE_FLAG
        BMI .skip_flip
        JSR DISPLAY_PAGE_FLIP

.skip_flip:
; --- Row loop ---
        LDX #$00
.row_loop:
        LDA SCREEN_ROW_ADDR_LO,X        ; row base address, low
        STA ZP_HGR_SRC
        LDA SCREEN_ROW_ADDR_HI,X        ; row base address, high
        STA ZP_HGR_SRC+1
        LDY #$27                        ; 40 bytes per row
.copy_byte:
        LDA ROW_COPY_BUFFER,Y
        STA (ZP_HGR_SRC),Y
        DEY
        BPL .copy_byte
        LDA #$20
        JSR MON_WAIT                    ; brief delay
        JSR ROW_COPY_CLICK              ; per-row speaker click
        INX
        CPX #$C0                        ; 192 rows
        BNE .row_loop
        RTS
@ %def STAGE_STACK

<<stage stack dead tail>>=

