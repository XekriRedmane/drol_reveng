<<interlace blit defines>>=

; --- INTERLACE_BLIT_{P1,P2} zero-page I/O ---
; The blit helpers walk X from ZP_BLIT_X_START (rightmost column,
; inclusive) down to ZP_BLIT_X_END (left terminator, exclusive: the
; column where X == END is NOT painted).  Source bytes come from
; (ZP_BLIT_SRC),Y with Y incrementing 35 times per painted column.
; The three ZP bytes are scratch for this subsystem; they have no other
; documented use in drol.bin.
ZP_BLIT_X_END   = $58           ; Left terminator (exclusive: loop exits
                                ;   when X == ZP_BLIT_X_END)
ZP_BLIT_X_START = $59           ; Rightmost paint column (inclusive)
ZP_BLIT_SRC     = $FE           ; Source pointer lo; +1 is hi byte
                                ;   (indirect via LDA (ZP_BLIT_SRC),Y)
@

<<interlace blit p1>>=

        ORG $054E
INTERLACE_BLIT_P1:
        SUBROUTINE
        ; Blit a column-major sprite into hi-res page 1's 3-band
        ; perspective playfield (rows 72-106, 112-146, 152-186).  The
        ; streaming analogue of INTERLACE_FILL_P1: for each screen
        ; column X in [ZP_BLIT_X_END+1 .. ZP_BLIT_X_START], pull 35
        ; source bytes from (ZP_BLIT_SRC),Y (Y walks forward across
        ; the whole call) and paint each byte into all three bands at
        ; the same relative row.  Y is never reset, so the source
        ; layout is a flat 35-byte-per-column stream, rightmost
        ; column first, with column N's bytes at (ZP_BLIT_SRC)+N*35.
        ;
        ; Inputs:
        ;   ZP_BLIT_SRC/+1  --- pointer to the column-major sprite.
        ;   ZP_BLIT_X_START --- rightmost paint column (inclusive).
        ;   ZP_BLIT_X_END --- left terminator (exclusive).
        ;
        ; Behavior:
        ;   Y := 0; X := ZP_BLIT_X_START.  While X != ZP_BLIT_X_END:
        ;     if X >= $28, skip this column's paint but still advance
        ;     Y by 35 (keeps source/column alignment for callers that
        ;     start offscreen).
        ;     else, unroll 35 groups of:
        ;       A := (ZP_BLIT_SRC),Y
        ;       STA row[k]-band-0,X
        ;       STA row[k]-band-1,X   (+40 rows)
        ;       STA row[k]-band-2,X   (+80 rows)
        ;       Y := Y + 1
        ;   then X := X - 1; loop.
        ;
        ; Callers:
        ;   REFRESH_RIGHT_WALL shared tail at $625F (page 1 path).
        ;   REFRESH_LEFT_WALL  shared tail at $62BF (page 1 path,
        ;                                            page-2 JSR at $62C6).
        ;   REFRESH_PILLARS    per-slot paint at $630F (page 1 path,
        ;                                              page-2 JSR at $6317).
        ;   Each site uses a BIT ZP_PAGE_FLAG / BMI gate to pick this
        ;   (page 1, ZP_PAGE_FLAG positive) or INTERLACE_BLIT_P2
        ;   (page 2, ZP_PAGE_FLAG negative).
        ;
        ; Clobbers: A, X, Y
        LDY #$00                        ; start at source byte 0
        LDX ZP_BLIT_X_START             ; X = rightmost column
.check:
        CPX #$28                        ; X off the screen?
        BCC .paint                      ; no -> paint it
        TYA                             ; yes -> skip, Y += 35
        CLC
        ADC #$23
        TAY
