FLOOR_BASE_ROW_PAD:
        ; 5-byte pre-pad before FLOOR_BASE_ROW.  Indices 0..4 of the
        ; virtual table are never read: every caller uses X >= $05.
        HEX 00 00 00 00 00
@ %def FLOOR_BASE_ROW_PAD

