; --- Scratch ZP used only by the walking-frame animation ---
; Holds the LSR'd two-bit phase (value in {$01, $03}) that selects
; which walking-feet sprite base to use for the current frame.
ZP_ENEMY_A_LEG_PHASE = $0F      ; Walking phase scratch (ENEMY_A_DRAW)

; --- Enemy-A sprite families (within SPRITE_TABLE_LO/HI) ---
; All four families are indexed by PROJ_FRAME_IDX (X after the clip).
SPRITE_TABLE_A_BODY_LO  = $B009 ; Main body pointers, low
SPRITE_TABLE_A_BODY_HI  = $B089 ; Main body pointers, high
SPRITE_TABLE_A_STEP1_LO = $B010 ; Walking feet variant 1 (phase $03), low
SPRITE_TABLE_A_STEP1_HI = $B090 ; Walking feet variant 1, high
SPRITE_TABLE_A_FEET_LO  = $B017 ; Stance feet pointers, low (drift / phase $00/$02)
SPRITE_TABLE_A_FEET_HI  = $B097 ; Stance feet, high
SPRITE_TABLE_A_STEP2_LO = $B01E ; Walking feet variant 2 (phase $01), low
SPRITE_TABLE_A_STEP2_HI = $B09E ; Walking feet variant 2, high

