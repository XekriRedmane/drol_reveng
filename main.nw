; --- Zero-page (enemy-C advance slot) ---
ZP_ENEMY_C_SND_CTR = $B7        ; 8-step sound-click counter (BMI = idle)
ZP_ENEMY_C_POS     = $D5        ; 16-bit advance counter ($D5/$D6)
; (ZP_ENEMY_C_STATE = $D4 and ZP_ENEMY_C_ROW = $D7 are exported by enemy-A.)
; Sound pitch table for enemy-C, packed inside SCREEN_ROW_HELPER.
SND_PITCH_TBL_C    = $0224      ; 8 pitch bytes indexed by ZP_ENEMY_C_SND_CTR
; Three-entry Y-anchor table read as ENEMY_C_ROW_TBL,X with X in {1,2,3}; subtract $0A.
; The base $84 is also used as the per-level intro Y seed (LEVEL_INTRO_TICK)
; and adjacent slots at $83/$85/$86/$87 are FLOOR_THRESH and other per-level
; scenery anchors --- enemy-C reuses three of those rows as spawn anchors.
ENEMY_C_ROW_TBL    = $84        ; Read as $84,X with X in {1,2,3}

