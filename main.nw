<<special draw defines>>=

; --- Zero-page (special slot, draw side) ---
; (ZP_SPECIAL_STATE, ZP_SPECIAL_POS, ZP_SPECIAL_ROW, ZP_SPECIAL_HP,
;  ZP_SPECIAL_SND_CTR are declared in special-tick-defines and
;  draw-entities-defines.)
ZP_SPECIAL_SND_CTR_B = $B6      ; Defeat/catch jingle counter (BMI = idle)
ZP_SCREEN_X     = $AF           ; Transformed screen X scratch (body/puff)
ZP_SCREEN_X_HI  = $B0           ; High byte of transformed screen X

; --- Page-2 sound pitch table for ZP_SPECIAL_SND_CTR_B ---
SND_PITCH_TBL_SPECIAL_B = $021F ; 4+ pitch bytes indexed by ZP_SPECIAL_SND_CTR_B

; --- Sprite-pointer tables ---
; SPRITE_TABLE_LO/HI is the main sprite-pointer table;
; the special slot uses a family at offset KEY_DESCEND / $5A (i.e.\
; $AFDA/$B05A) indexed by the perspective-frame index. This
; family covers the drift-phase ``puff'' pointers, one pair per
; scale-factor, so the puff shrinks with distance.
SPECIAL_PUFF_LO = $AFDA         ; Drift-puff pointer table, low bytes
SPECIAL_PUFF_HI = $B05A         ; Drift-puff pointer table, high bytes

; --- Walk-cycle body sprite base pointers ---
; Four poses in the per-level sprite table.. $758D/$768D
; indexed by Y (perspective-frame index from PROJ_FRAME_IDX).  The six
; SMC handlers visit them in order {0, 1, 2, 3, 2, 1} then cycle.
SPECIAL_BODY_POSE0_LO = $7578   ; Pose 0 pointer table, low
SPECIAL_BODY_POSE0_HI = $7678
SPECIAL_BODY_POSE1_LO = $757F   ; Pose 1 (offset +7)
SPECIAL_BODY_POSE1_HI = $767F
SPECIAL_BODY_POSE2_LO = $7586   ; Pose 2 (offset +14)
SPECIAL_BODY_POSE2_HI = $7686
SPECIAL_BODY_POSE3_LO = $758D   ; Pose 3 (offset +21)
SPECIAL_BODY_POSE3_HI = $768D

; --- Inactive-phase marker sprite (single pointer) ---
; One byte after ENEMY_C_PUFF and one before ENEMY_B_PUFF
;; a per-level pointer to the small ZP_ACTION_DIRx$06 ``peek''
; sprite drawn while the slot is counting down to spawn.
SPECIAL_PEEK_LO = $755B         ; Inactive-phase peek sprite pointer, low
SPECIAL_PEEK_HI = $765B         ; Inactive-phase peek sprite pointer, high
@

<<special draw>>=

        ORG $6B39
SPECIAL_DRAW:
        SUBROUTINE
        ; Per-frame draw + collision handler for the ``special''
        ; bonus-creature slot; direct draw partner of SPECIAL_TICK.
        ; Three-way dispatch on ZP_SPECIAL_STATE:
        ;   $00  inactive --> tail JMP to SPECIAL_INACTIVE_DRAW
        ;   $01+ active   --> perspective transform, 4-slot
        ;                     floor-enemy kill-box, JMP through
        ;                     SMC ring to one of six body-walk handlers.
        ;   $80+ drift    --> perspective transform, draw puff from
        ;                     SPECIAL_PUFF table, test player catch,
        ;                     award +$0500 BCD on catch and reset slot.
        ;
        ; Inputs:
        ;   ZP_SPECIAL_STATE, ZP_SPECIAL_POS (16-bit), ZP_SPECIAL_ROW
        ;   ZP_SPECIAL_HP, ZP_SPECIAL_SND_CTR_B
        ;   ZP_PLAYER_Y, ZP_PLAYER_COL, ZP_SPRITE_XREF
        ;   Floor-enemy slots KEY_ESC / $9F / $A3 (4 slots each)
        ;
        ; Behavior:
        ;   1. Emit a SFX_TONE click (duration $08) indexed by
        ;      SND_PITCH_TBL_SPECIAL_B[$B6] if $B6 >= 0; dec $B6.
        ;   2. $AB == 0 --> JMP SPECIAL_INACTIVE_DRAW.
        ;   3. Perspective-transform $AC/$AD against player world-X into
        ;      $AF (lo) / $B0 (hi).  RTS if off-screen (hi != 0 or
        ;      lo >= $A0).
        ;   4. Prepare sprite column from PROJ_SCREEN_COL[X], sprite
        ;      frame Y from PROJ_FRAME_IDX[X] (for sprite-table indexing).
        ;   5. If $AB < 0 (drift): JMP .drift_puff at $6BEB.
        ;   6. Else (active): draw 6x20 body, kill-box test against
        ;      floor-enemies, maybe trigger defeat, JMP .dispatch_body.
        ;
        ; Modifies:
        ;   ZP_SCREEN_X, ZP_SCREEN_X_HI, ZP_SPRITE_W/H/X/Y, $9B[X], $08,
        ;   ZP_SPECIAL_STATE, ZP_SPECIAL_SND_CTR, ZP_SPECIAL_ROW,
        ;   SMC_SPECIAL_BODY_LO/HI, SMC_DS_SRC_LO/HI, $1E (hit flag).
        ; Clobbers: A, X, Y

; --- Emit catch/defeat-jingle click ---
        LDX ZP_SPECIAL_SND_CTR_B
        BMI .after_click                ; Negative = idle
        LDA SND_PITCH_TBL_SPECIAL_B,X   ; Pitch byte
        LDX #$08                        ; Duration = 8 clicks
        JSR SFX_TONE
        DEC ZP_SPECIAL_SND_CTR_B
.after_click:

; --- State dispatch on $AB ---
        LDA ZP_SPECIAL_STATE
        BNE .active_or_drift            ; Non-zero = draw somehow
        JMP SPECIAL_INACTIVE_DRAW       ; $00 = inactive marker draw
.active_or_drift:

; --- Perspective transform: screen_X = creature_pos - player_world_x ---
        LDX ZP_PLAYER_Y                 ; $4A -> perspective-table index
        LDA PERSPECTIVE_XOFF_LO,X       ; Y -> world-X offset (lo)
        SEC
        SBC ZP_SPRITE_XREF              ; - level's X reference
        STA ZP_SCREEN_X                 ; ZP_SCREEN_X = player world-X (lo)
        LDA PERSPECTIVE_XOFF_HI,X       ; Y -> world-X offset (hi)
        SBC #$00                        ; (borrow from lo)
        STA ZP_SCREEN_X_HI              ; ZP_SCREEN_X_HI = player world-X (hi)
        SEC
        LDA ZP_SPECIAL_POS              ; $AC
        SBC ZP_SCREEN_X                 ; - player world-X (lo)
        STA ZP_SCREEN_X
        LDA ZP_SPECIAL_POS+1            ; $AD
        SBC ZP_SCREEN_X_HI              ; - player world-X (hi)
        BEQ .on_screen                  ; hi == 0 = on screen
.off_screen:
        RTS                             ; off-screen: early RTS (shared)
.on_screen:
        LDA ZP_SCREEN_X
        CMP #$A0                        ; >= $A0 = too far right
        BCS .off_screen                 ; take the early RTS
        TAX                             ; X = screen X for PROJ tables

; --- Common sprite-parameter setup ---
        LDA ZP_SPECIAL_ROW              ; $AE
        STA ZP_SPRITE_Y                 ; Sprite row
        LDA PROJ_SCREEN_COL,X
        STA ZP_SPRITE_X                 ; Sprite column
        LDA PROJ_FRAME_IDX,X
        TAY                             ; Y = sprite-frame index

; --- Branch to drift if ZP_SPECIAL_A < 0 ---
        LDA ZP_SPECIAL_STATE
        BMI .drift_puff                 ; Drift -> puff branch

; --- Active body path: prepare body-sprite size, run kill-box test ---
        LDA #$06                        ; Body: W = 6
        STA ZP_SPRITE_W
        LDA #$14                        ; Body: H = 20
        STA ZP_SPRITE_H
        LDX #$03                        ; Walk 4-slot enemy table X = 3..0
.find_enemy:
        LDA ZP_ENEMY_FLAG,X             ; ZP_ENEMY_FLAG[X] --- active?
        BNE .check_box                  ;   non-zero = try kill-box
.try_next_enemy:
        DEX
        BPL .find_enemy                 ;   continue X = 3..0
        JMP .no_kill                    ; no active enemy: skip kill-box
.check_box:
; Kill-box: X-range [pos-$0F, pos) AND Y-range [row-$0F, row) on enemy slot
        LDA ZP_SCREEN_X
        CMP ZP_ENEMY_COL,X              ; ZP_ENEMY_COL[X]
        BCC .try_next_enemy             ;   X < enemy_x
        SEC
        SBC #$0F                        ;   pos - $0F
        CMP ZP_ENEMY_COL,X
        BCS .try_next_enemy             ;   X - $0F >= enemy_x (too far)
        LDA ZP_SPECIAL_ROW
        CMP ZP_ENEMY_Y,X                ; ZP_ENEMY_Y[X]
        BCS .try_next_enemy             ;   Y >= enemy_y (below)
        CLC
        ADC #$0F
        CMP ZP_ENEMY_Y,X
        BCC .try_next_enemy             ;   Y + $0F < enemy_y (above)
; Kill: clear enemy slot, dec HP, maybe trigger defeat
        LDA #$00
        STA ZP_ENEMY_FLAG,X             ; ZP_ENEMY_FLAG[X] = 0 (kill floor enemy)
        DEC ZP_SPECIAL_HP               ; $08
        BNE .dispatch_body              ; HP != 0: skip defeat + catch
; Defeat edge: enter drift, arm defeat jingle, bump row
        LDA #$FF
        STA ZP_SPECIAL_STATE            ; $AB = $FF -> drift mode
        LDA #$06
        STA ZP_SPECIAL_SND_CTR          ; Arm ascending-tone jingle
        LDA ZP_SPECIAL_ROW
        CLC
        ADC #$03
        STA ZP_SPECIAL_ROW              ; Row += 3 (fall start)
        ; Fall through into the catch box below (defeat edge only).
.no_kill:

; --- Body-phase player-catch box (triggers hit-flag only) ---
; Note: only reached on .no_kill fall-through (no-active-enemy case)
; or after defeat-edge fall-through (HP reached 0 this frame).  HP>0
; kills skip straight to .dispatch_body to bypass this test.
        LDA ZP_SCREEN_X
        CMP #$40
        BCC .dispatch_body              ; X < $40
        CMP #$56
        BCS .dispatch_body              ; X >= $56
        LDA ZP_PLAYER_COL               ; $06
        SEC
        SBC #$13                        ; player_col - $13
        CMP ZP_SPECIAL_ROW
        BCS .dispatch_body              ; row <= player_col-$13
        CLC
        ADC #$25                        ; -> player_col + $12
        CMP ZP_SPECIAL_ROW
        BCC .dispatch_body              ; row > player_col+$12
        LDA #$FF
        STA $1E                         ; Hit flag = $FF
.dispatch_body:
        JMP SPECIAL_BODY_STEP1          ; SMC: operand bytes rewritten
SMC_SPECIAL_BODY_LO = *-2               ;   by handlers+ to walk
SMC_SPECIAL_BODY_HI = *-1               ;   the 6-step palindromic cycle.

; --- Drift-phase puff draw + player-catch (award +$0500 BCD) ---
.drift_puff:
        LDA #$04
        STA ZP_SPRITE_W                 ; Puff: W = 4
        LDA #$0F
        STA ZP_SPRITE_H                 ; Puff: H = 15
        LDA SPECIAL_PUFF_LO,Y           ; Y-indexed per-scale puff pointer
        STA SMC_DS_SRC_LO
        LDA SPECIAL_PUFF_HI,Y
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE                 ; Transparent OR blit
; Drift-phase catch box: X in [$40, $53), Y in [player_col-$0E, +$12]
        LDA ZP_SCREEN_X
        CMP #$40
        BCC .drift_done                  ; X < $40
        CMP #$53
        BCS .drift_done                  ; X >= $53
        LDA ZP_PLAYER_COL               ; $06
        SEC
        SBC #$0E                        ; player_col - $0E
        CMP ZP_SPECIAL_ROW
        BCS .drift_done
        CLC
        ADC #$20                        ; -> player_col + $12
        CMP ZP_SPECIAL_ROW
        BCC .drift_done
; Catch: clear slot, arm catch-jingle, award +$0500 BCD
        LDA #$00
        STA ZP_SPECIAL_STATE            ; Back to inactive
        LDA #$04
        STA ZP_SPECIAL_SND_CTR_B        ; Arm catch tone (4 clicks)
        LDA #$00
        STA ZP_SCORE_ADD_LO             ; +$0500 BCD
        LDA #$05
        STA ZP_SCORE_ADD_HI
        JSR SCORE_ADD
        LDA #$D0
        STA ZP_SPECIAL_POS              ; Reseed 8-bit inactive timer
        LDA ZP_SCREEN_X
        SEC
        SBC #$02
        STA ZP_SPECIAL_POS+1            ; Seed $AD (carried through)
        INC ZP_SPECIAL_ROW              ; Bump row by 2 (fall-through look)
        INC ZP_SPECIAL_ROW
.drift_done:
        RTS
@ %def SPECIAL_DRAW SMC_SPECIAL_BODY_LO SMC_SPECIAL_BODY_HI ZP_SPECIAL_SND_CTR_B SND_PITCH_TBL_SPECIAL_B SPECIAL_PUFF_LO SPECIAL_PUFF_HI SPECIAL_BODY_POSE0_LO SPECIAL_BODY_POSE0_HI SPECIAL_BODY_POSE1_LO SPECIAL_BODY_POSE1_HI SPECIAL_BODY_POSE2_LO SPECIAL_BODY_POSE2_HI SPECIAL_BODY_POSE3_LO SPECIAL_BODY_POSE3_HI ZP_SCREEN_X ZP_SCREEN_X_HI

<<special body draw steps>>=

        ORG $6C3F
; ---------------------------------------------------------------------
; Six SMC-chained body-walk handlers for SPECIAL_DRAW.
;
; The active-path JMP at $6BE8 has operand bytes $6BE9/$6BEA
; (SMC_SPECIAL_BODY_LO/HI) patched by each handler to point to the NEXT
; handler in the cycle.  On-disk initial value is $6C3F (STEP1).  Each
; handler:
;
;   1. Writes the lo/hi of the next step's address into
;      SMC_SPECIAL_BODY_LO/HI (the $6BE8 JMP operand).
;   2. Patches SMC_DS_SRC_LO/HI (the DRAW_SPRITE source pointer
;      operand) with its pose's level-data sprite
;      pointer, indexed by Y (perspective-frame index).
;   3. JSR DRAW_SPRITE, then RTS back to SPECIAL_DRAW's caller.
;
; The six poses visit sprite-table offsets {0, 7, 14, 21, 14, 7}, a
; palindromic cycle (0 -> 1 -> 2 -> 3 -> 2 -> 1 -> 0 -> ...) giving
; a 6-frame walking animation from four distinct poses.  The cycle
; point persists across activations because nothing resets the SMC
; bytes at rearm --- after defeat/restart, drawing resumes from
; wherever the last cycle left off.
; ---------------------------------------------------------------------

SPECIAL_BODY_STEP1:
        ; Pose 0 (offset 0); next = STEP2
        LDA #<SPECIAL_BODY_STEP2
        STA SMC_SPECIAL_BODY_LO
        LDA #>SPECIAL_BODY_STEP2
        STA SMC_SPECIAL_BODY_HI
        LDA SPECIAL_BODY_POSE0_LO,Y
        STA SMC_DS_SRC_LO
        LDA SPECIAL_BODY_POSE0_HI,Y
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE
        RTS

SPECIAL_BODY_STEP2:
        ; Pose 1 (offset 7); next = STEP3
        LDA #<SPECIAL_BODY_STEP3
        STA SMC_SPECIAL_BODY_LO
        LDA #>SPECIAL_BODY_STEP3
        STA SMC_SPECIAL_BODY_HI
        LDA SPECIAL_BODY_POSE1_LO,Y
        STA SMC_DS_SRC_LO
        LDA SPECIAL_BODY_POSE1_HI,Y
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE
        RTS

SPECIAL_BODY_STEP3:
        ; Pose 2 (offset 14); next = STEP4
        LDA #<SPECIAL_BODY_STEP4
        STA SMC_SPECIAL_BODY_LO
        LDA #>SPECIAL_BODY_STEP4
        STA SMC_SPECIAL_BODY_HI
        LDA SPECIAL_BODY_POSE2_LO,Y
        STA SMC_DS_SRC_LO
        LDA SPECIAL_BODY_POSE2_HI,Y
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE
        RTS

SPECIAL_BODY_STEP4:
        ; Pose 3 (offset 21); next = STEP5 (cycle apex)
        LDA #<SPECIAL_BODY_STEP5
        STA SMC_SPECIAL_BODY_LO
        LDA #>SPECIAL_BODY_STEP5
        STA SMC_SPECIAL_BODY_HI
        LDA SPECIAL_BODY_POSE3_LO,Y
        STA SMC_DS_SRC_LO
        LDA SPECIAL_BODY_POSE3_HI,Y
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE
        RTS

SPECIAL_BODY_STEP5:
        ; Pose 2 again (mirror of STEP3); next = STEP6
        LDA #<SPECIAL_BODY_STEP6
        STA SMC_SPECIAL_BODY_LO
        LDA #>SPECIAL_BODY_STEP6
        STA SMC_SPECIAL_BODY_HI
        LDA SPECIAL_BODY_POSE2_LO,Y
        STA SMC_DS_SRC_LO
        LDA SPECIAL_BODY_POSE2_HI,Y
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE
        RTS

SPECIAL_BODY_STEP6:
        ; Pose 1 again (mirror of STEP2); next = STEP1 (wrap)
        LDA #<SPECIAL_BODY_STEP1
        STA SMC_SPECIAL_BODY_LO
        LDA #>SPECIAL_BODY_STEP1
        STA SMC_SPECIAL_BODY_HI
        LDA SPECIAL_BODY_POSE1_LO,Y
        STA SMC_DS_SRC_LO
        LDA SPECIAL_BODY_POSE1_HI,Y
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE
        RTS
@ %def SPECIAL_BODY_STEP1 SPECIAL_BODY_STEP2 SPECIAL_BODY_STEP3 SPECIAL_BODY_STEP4 SPECIAL_BODY_STEP5 SPECIAL_BODY_STEP6

<<special inactive draw>>=

        ORG $6CDB
SPECIAL_INACTIVE_DRAW:
        SUBROUTINE
        ; Small $02x$06 ``peek'' marker drawn while the special slot
        ; is in its inactive countdown phase ($AB == 0).  The tick is
        ; cycling $AC as an 8-bit counter and $AD stays (seeded
        ; by SPECIAL_REARM), so the sprite's screen position is
        ; effectively fixed by the slot's row-anchor $AE plus the
        ; perspective-transformed index in ZP_SPECIAL_Y.  Tail-jumped to from
        ; SPECIAL_DRAW's $6B4B.
        ;
        ; Inputs:
        ;   ZP_SPECIAL_ROW, ZP_SPECIAL_POS+1
        ;   SPECIAL_PEEK_LO/HI --- per-level sprite pointer
        ;
        ; Modifies:
        ;   ZP_SPRITE_W/H/X/Y, SMC_DS_SRC_LO/HI.
        ; Clobbers: A, X

        LDA #$02
        STA ZP_SPRITE_W                 ; W = 2
        LDA #$06
        STA ZP_SPRITE_H                 ; H = 6
        LDA ZP_SPECIAL_ROW              ; $AE
        STA ZP_SPRITE_Y                 ; Sprite row = row anchor
        LDX ZP_SPECIAL_POS+1            ; $AD (stays 0 during inactive)
        LDA PROJ_SCREEN_COL,X
        STA ZP_SPRITE_X                 ; Sprite col via PROJ table
        LDA SPECIAL_PEEK_LO             ; Un-indexed
        STA SMC_DS_SRC_LO
        LDA SPECIAL_PEEK_HI
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE
        RTS
@ %def SPECIAL_INACTIVE_DRAW SPECIAL_PEEK_LO SPECIAL_PEEK_HI

\section{Companion slot: per-frame tick + draw}

[[COMPANION_UPDATE]] at [[$6CFE]] is the per-frame tick-plus-draw routine
for a \emph{pair} of ``companion'' slots (indices 0 and 1) --- the
hostile walker-creatures that patrol the perspective floor,
occasionally climb to another floor, and damage the player on contact.
Despite the name inherited from [[DRAW_ENTITIES]] phase~4 (which draws
a small [[$01]]x[[$02]] marker for each slot), these slots do \emph{not}
help the player; the draw inside this routine renders the full body
sprite, runs a player-catch hit-box that sets [[ZP_HIT_FLAG]],
and contains an entity-proximity gate that triggers the floor-climb
drift phase.

\paragraph{Gate.}  The whole routine is gated on
[[ZP_COMPANION_GATE]]:
[[BPL]]-guarded, so only the positive value [[$01]] (set by
[[DIFFICULTY_UPDATE]] at any tier above minimum) allows the slots to
run.  The minimum tier and [[DIFFICULTY_RESET]] both set [[$33]] to
[[$FF]] ([[BMI]]), suppressing the subsystem.  % TODO-SYM: $FF

\paragraph{Two parallel slots.}  The outer loop runs X=1, then X=0,
over parallel per-slot byte arrays in zero page:

\begin{center}
\begin{tabular}{l|l|l|l}
ZP byte & Slot 0 & Slot 1 & Meaning \\
\hline
[[$B3,X]] & [[$B3]] & [[$B4]] & State: [[$00]] inactive, [[$01]]..[[$7F]] active, [[$FF]] drift \\  % TODO-SYM: $B4 $7F $FF
[[$B1,X]] & [[$B1]] & [[$B2]] & Direction: [[$01]] right, [[$FF]] left, [[$00]] treated as right \\  % TODO-SYM: $B2 $FF
[[$11,X]] & [[$11]] & [[$12]] & World-X low byte (16-bit, 0..[[$0352]]) \\  % TODO-SYM: $12 $0352
[[$13,X]] & [[$13]] & [[$14]] & World-X high byte (stays in 0..[[$03]]) \\  % TODO-SYM: $14
[[$15,X]] & [[$15]] & [[$16]] & Floor-row Y anchor \\  % TODO-SYM: $16
\end{tabular}
\end{center}

The same bytes are the [[ZP_COMPANION_COL]]/[[OFF]]/[[ROW]] arrays
read by [[DRAW_ENTITIES]] phase~4; see the cross-reference note
below.

\paragraph{Three-state slot machine.}  On entry to the per-slot body:
[[$B3,X == 0]] (inactive) re-activates the slot by writing [[$01]] and
falls through to the draw preamble at [[$6D93]]; [[$B3,X < 0]] (drift)  % TODO-SYM: $6D93
jumps to the floor-climb handler at [[$6F24]]; [[$B3,X > 0]] (active)  % TODO-SYM: $6F24
decrements or increments the 16-bit world-X by 3 per frame depending
on the direction byte, with a $\sim$5\% PRNG-gated chance of flipping
direction each frame.  When the counter wraps past [[$0352]] (positive  % TODO-SYM: $0352
direction) or below [[$003E]] (negative direction), the slot  % TODO-SYM: $003E
\emph{rearms}: direction flips, and the row reseats to the player's
current-floor threshold [[FLOOR_THRESH]]\([[$0A]]\) \(+\) [[$0B]].

\paragraph{Drift phase = floor-climb.}  Reaching one of the three
floor-anchor Y rows [[$63]]/[[$8B]]/[[$B3]] triggers the transition back to  % TODO-SYM: $63
active: the row backs off by 4, the 16-bit world-X shifts by 3 in
the current direction (so the companion ``emerges'' at a slightly
different world-X on the new floor), state becomes [[$01]].  While in
drift (state [[$FF]]) the companion's row advances by 4 pixels per frame  % TODO-SYM: $FF
(no PRNG gate, no direction flips, no player-catch test), giving a
clean monotonic climb.

\paragraph{Entity-proximity drift trigger.}  The active-phase tick
walks the hit-entity active table [[ENTITY_HIT_STATE]] ([[$8D]],X,
bounded by [[ZP_HIT_MAX]] [[$41]]) looking for the first positive entry,
and compares its [[ENTITY_HIT_ROW]] ([[$72]],X) \(-\) [[$08]] against the
companion's own row.  When both match \emph{and} the companion's
screen-X (perspective-transformed through
[[PERSPECTIVE_XOFF_LO/HI]]) falls in [[$40]]..[[$46]], the companion  % TODO-SYM: $46
enters drift (row \(+\)= 4, state = [[$FF]]).  Outside that centre  % TODO-SYM: $FF
band, a direction-specific \emph{deactivation} window
([[$30]]..[[$37]] for +direction, [[$50]]..[[$57]] for -direction) sets state  % TODO-SYM: $30 $37
to [[$00]], ending the patrol.

\paragraph{SMC-chained 3-pose walk cycle.}  The active-phase body
draw uses two separate SMC chains (one per direction), each cycling
through three sprite pointer tables.  A trampoline [[JMP]] at [[$6E30]]
(positive direction) or [[$6EA9]] (negative direction) dispatches to
the next pose; each pose's handler patches the trampoline's operand
bytes to point to the successor, loads the pose pointer from a
per-level sprite table at [[$75A2]]/[[$75A9]]/[[$75B0]] (for \-direction) or
[[$75B7]]/[[$75BE]]/[[$75C5]] (for \+direction), patches
[[SMC_DS_SRC_LO]]/[[HI]] inside [[DRAW_SPRITE]], and [[JSR]]s.  On
a cold start the on-disk trampoline values are [[JMP $6E33]] and
[[JMP $6EAC]] (pose 1 for each direction).

\paragraph{Player-catch.}  After drawing, the routine tests the
companion's screen-X against the [[$40]]..[[$4F]] window and the player's  % TODO-SYM: $4F
row [[ZP_PLAYER_COL]] against the companion's row
[[$15]],X in a [[$1A]]-tall band; overlap writes [[$FF]] to [[ZP_HIT_FLAG]]  % TODO-SYM: $FF
([[$1E]]), signalling a player hit.  Drift-mode draws skip the
player-catch, so climbing companions are safe to pass.

\paragraph{Cross-reference to [[DRAW_ENTITIES]] phase~4.}  The same
ZP bytes [[$11]]/[[$13]]/[[$15]] that this routine treats as 16-bit world-X
and row are re-interpreted by phase~4 of the entity-draw dispatcher
as a perspective-projection index and a [[$B9]]-table offset, drawing a
small [[$01]]x[[$02]] marker sprite from [[$75CC]] at the companion's  % TODO-SYM: $75CC
projected screen position.  Phase~4's [[ZP_COMPANION_COL]],
[[ZP_COMPANION_OFF]] and [[ZP_COMPANION_ROW]] are
therefore aliases of this routine's [[ZP_COMPANION_POS_LO]],
[[_HI]] and [[_ROW]].

\paragraph{Activation is unconditional.}  The state-[[$00]] inactive
path simply writes [[$01]] to [[$B3,X]] and falls into the draw
preamble, so both slots self-activate on the first frame that
[[$33]] \(\ge\) 0.  Nothing in this routine ever clears state back to
[[$00]] except the direction-specific deactivation window during the
entity-proximity check; thus companions are effectively always
present once the score-tier unlocks them.

\paragraph{Sprite art.}  Figure~\ref{fig:companion_sprites} shows all
42 companion body frames: six pose/direction combinations (the three
negative-direction poses [[N1]]/[[N2]]/[[N3]] in rows~1--3, then the
three positive-direction poses [[P1]]/[[P2]]/[[P3]] in rows~4--6),
each with seven perspective frames.  The body sprite is $[[$04]]\times
[[$08]]$ bytes ([[ZP_SPRITE_W]]~=~[[$03]], [[ZP_SPRITE_H]]~=~[[$08]]) with 32
bytes per frame.  The SMC walk cycle at [[$6E33]]/[[$6EAC]] visits poses
1 $\to$ 2 $\to$ 3 $\to$ 1 on successive frames for whichever
direction the slot is moving.  Sprite bytes live at
[[$9DB1]]--[[$A2F0]] in the swappable level-data region.  % TODO-SYM: $9DB1 $A2F0

\begin{figure}[H]
\centering
\includegraphics[width=0.95\textwidth]{images/companion_sprites.png}
\caption{Companion body sprite frames.  Rows top-to-bottom:
[[COMPANION_NEG_POSE1]], [[COMPANION_NEG_POSE2]], [[COMPANION_NEG_POSE3]],
[[COMPANION_POS_POSE1]], [[COMPANION_POS_POSE2]],
[[COMPANION_POS_POSE3]].  Seven perspective frames per row indexed
by Y~=~[[PROJ_FRAME_IDX]]; the palette flips from purple/violet at
the near end to green at the far end.}
\label{fig:companion_sprites}
\end{figure}

<<companion update defines>>=

; --- Zero-page (companion slots) ---
; $B3/$B4, $B1/$B2, $11..$16 are per-slot parallel arrays addressed
; as $BASE,X with X in {0,1}.
ZP_COMPANION_STATE = $B3        ; Slot state: $00 off, +active, $FF drift
ZP_COMPANION_DIR   = $B1        ; Direction: +right, -left, 0=right
ZP_COMPANION_POS_LO = $11       ; World-X low byte (alias of ZP_COMPANION_COL)
ZP_COMPANION_POS_HI = $13       ; World-X high byte (alias of ZP_COMPANION_OFF)
; (ZP_COMPANION_ROW $15, ZP_COMPANION_GATE $33, ZP_HIT_MAX $41,
;  ZP_DRAW_LOOP_IDX $5C, ZP_PLAYER_COL $06, ZP_PLAYER_FLOOR $0A,
;  ZP_PLAYER_Y $4A, ZP_SPRITE_XREF $4C, ZP_SPRITE_W/H/Y/X $56/$57/$5B/$5D,
;  ZP_SCREEN_X $AF, ZP_SCREEN_X_HI $B0, ZP_HIT_FLAG $1E, FLOOR_THRESH $83,
;  ENTITY_HIT_STATE $8D, ENTITY_HIT_ROW $72,
;  PERSPECTIVE_XOFF_LO/HI, PROJ_SCREEN_COL, PROJ_FRAME_IDX are
;  defined elsewhere.)
ZP_PLAYER_FLOOR    = $0A        ; Current player floor index (0..3)
ENTITY_HIT_ROW     = $72        ; Hit-entity row attribute ($72,X)

; --- Per-level sprite pointer tables (indexed by Y = perspective-frame) ---
; Positive-direction body, 3-pose cycle at offsets 0, 7, 14 into these
; tables (each entry is a pointer pair LO/HI across the two tables).
COMPANION_POS_POSE1_LO = $75B7  ; +dir pose 1 (stride 7 per pose)
COMPANION_POS_POSE1_HI = $76B7
COMPANION_POS_POSE2_LO = $75BE  ; +dir pose 2
COMPANION_POS_POSE2_HI = $76BE
COMPANION_POS_POSE3_LO = $75C5  ; +dir pose 3
COMPANION_POS_POSE3_HI = $76C5

; Negative-direction body, 3-pose cycle at offsets 0, 7, 14.
COMPANION_NEG_POSE1_LO = $75A2  ; -dir pose 1
COMPANION_NEG_POSE1_HI = $76A2
COMPANION_NEG_POSE2_LO = $75A9  ; -dir pose 2
COMPANION_NEG_POSE2_HI = $76A9
COMPANION_NEG_POSE3_LO = $75B0  ; -dir pose 3
COMPANION_NEG_POSE3_HI = $76B0

<<companion update>>=

        ORG $6CFE
COMPANION_UPDATE:
        SUBROUTINE
        ; Per-frame tick + draw for the two-slot ``companion'' walker
        ; subsystem.  Iterates over slot X in {1, 0} and runs a
        ; three-state machine per slot (inactive / active / drift),
        ; drawing the body sprite through an SMC-chained 3-pose walk
        ; cycle and testing the player-catch hit-box.  See
        ; Companion slot: per-frame tick + draw for the full
        ; behaviour.
        ;
        ; Inputs:
        ;   ZP_COMPANION_GATE  --- subsystem gate ($FF disables).
        ;   ZP_COMPANION_STATE,X     --- per-slot state machine byte.
        ;   ZP_COMPANION_DIR,X       --- per-slot direction ($01/-1/0).
        ;   ZP_COMPANION_POS_LO/HI,X --- 16-bit per-slot world-X.
        ;   ZP_COMPANION_ROW,X       --- per-slot row Y.
        ;   ZP_PLAYER_Y, ZP_SPRITE_XREF, ZP_PLAYER_COL,
        ;   ZP_PLAYER_FLOOR, ZP_HIT_MAX,
        ;   ENTITY_HIT_STATE ($8D,X), ENTITY_HIT_ROW ($72,X),
        ;   FLOOR_THRESH ($83,X), PERSPECTIVE_XOFF_LO/HI, PROJ_SCREEN_COL,
        ;   PROJ_FRAME_IDX.
        ;
        ; Behavior:
        ;   1. Gate on $33 BPL-taken (run only when active).
        ;   2. For each slot X=1, X=0:
        ;      a. If state == 0: activate (state := $01), fall into draw.
        ;      b. If state < 0: JMP to drift handler (row += 4 until
        ;         hitting a floor-anchor, then re-arm to active).
        ;      c. Else active: advance 16-bit pos by +/-3 (PRNG may flip
        ;         direction), re-arm at crossing, fall into draw.
        ;   3. Draw preamble: perspective-transform world-X into screen-X,
        ;      clip at $9A, run the entity-proximity drift trigger, draw
        ;      the body through the direction-specific SMC chain, then
        ;      run the player-catch hit-box.
        ;
        ; Modifies:
        ;   ZP_COMPANION_STATE/DIR/POS/ROW, ZP_HIT_FLAG (on player hit),
        ;   ZP_SCREEN_X/HI, ZP_SPRITE_W/H/X/Y, ZP_DRAW_LOOP_IDX,
        ;   SMC trampoline operands and $6EAA/$6EAB,
        ;   SMC_DS_SRC_LO/HI (via the pose handlers).
        ; Clobbers: A, X, Y

; --- Subsystem gate ---
        LDA ZP_COMPANION_GATE           ; $33
        BPL .slot_loop_init
        RTS

.slot_loop_init:
        LDX #$01                        ; Iterate X=1, X=0

.slot_body:
        LDA ZP_COMPANION_STATE,X        ; ZP_COMPANION_STATE[X]
        BEQ .slot_activate              ;   $00 -> activate
        BMI .slot_drift                 ;   $FF -> drift handler
        LDA ZP_COMPANION_DIR,X          ; ZP_COMPANION_DIR[X]: direction
        BMI .active_neg                 ;   $FF: left-walker
        BPL .active_pos                 ;   $00/$01: right-walker

; --- Inactive slot: activate and drop into draw ---
.slot_activate:
        LDA #$01
        STA ZP_COMPANION_STATE,X        ; ZP_COMPANION_STATE[X] := $01
        JMP .draw_preamble

; --- Drift (climbing) slot: hand off to drift handler ---
.slot_drift:
        JMP .drift_handler

; --- Slot-loop tail (re-entered from all per-slot paths) ---
.slot_next:
        DEX
        BPL .slot_body
        RTS

; --- Active, left-walker: pos -= 3, PRNG direction flip, re-arm on wrap ---
.active_neg:
        JSR PRNG
        CMP #$05
        BCS .neg_move                   ; skip 95% of the time
        LDA #$01
        STA ZP_COMPANION_DIR,X          ; ZP_COMPANION_DIR[X] := $01 (flip to right)
.neg_move:
        SEC
        LDA ZP_COMPANION_POS_LO,X
        SBC #$03
        STA ZP_COMPANION_POS_LO,X       ; lo -= 3
        LDA ZP_COMPANION_POS_HI,X
        SBC #$00
        STA ZP_COMPANION_POS_HI,X       ; propagate borrow
        BEQ .neg_check_rearm            ; hi == 0: check re-arm
        JMP .draw_preamble
.neg_check_rearm:
        LDA ZP_COMPANION_POS_LO,X
        CMP #$3E
        BCC .neg_rearm                  ; lo < $3E: re-arm
        JMP .draw_preamble
.neg_rearm:
        LDA #$01
        STA ZP_COMPANION_DIR,X          ; flip to +dir
        STX ZP_DRAW_LOOP_IDX            ; $5C: save slot X
        LDX ZP_PLAYER_FLOOR             ; $0A
        LDA FLOOR_THRESH,X              ; FLOOR_THRESH[X]
        CLC
        ADC #$0B
        LDX ZP_DRAW_LOOP_IDX            ; restore slot X
        STA ZP_COMPANION_ROW,X          ; row := threshold + $0B
        JMP .slot_next

; --- Active, right-walker: pos += 3, PRNG direction flip, re-arm on wrap ---
.active_pos:
        JSR PRNG
        CMP #$05
        BCS .pos_move
        LDA #$FF
        STA ZP_COMPANION_DIR,X          ; flip to left
.pos_move:
        CLC
        LDA ZP_COMPANION_POS_LO,X
        ADC #$03
        STA ZP_COMPANION_POS_LO,X
        LDA ZP_COMPANION_POS_HI,X
        ADC #$00
        STA ZP_COMPANION_POS_HI,X
        CMP #$03
        BEQ .pos_check_rearm            ; hi == 3: check re-arm
        BNE .draw_preamble               ; else fall through to draw
.pos_check_rearm:
        LDA ZP_COMPANION_POS_LO,X
        CMP #$52
        BCS .pos_rearm                  ; lo >= $52: re-arm
        BCC .draw_preamble               ; else fall through to draw
.pos_rearm:
        LDA #$FF
        STA ZP_COMPANION_DIR,X          ; flip to -dir
        STX ZP_DRAW_LOOP_IDX
        LDX ZP_PLAYER_FLOOR
        LDA FLOOR_THRESH,X
        CLC
        ADC #$0B
        LDX ZP_DRAW_LOOP_IDX
        STA ZP_COMPANION_ROW,X
        JMP .slot_next

; --- Draw preamble: perspective transform + clip + entity-proximity check ---
.draw_preamble:
        STX ZP_DRAW_LOOP_IDX            ; $5C: save slot X
        LDY ZP_PLAYER_Y                 ; $4A
        LDA PERSPECTIVE_XOFF_LO,Y       ; PERSPECTIVE_XOFF_LO[Y]
        SEC
        SBC ZP_SPRITE_XREF              ; $4C
        STA ZP_SCREEN_X                 ; $AF
        LDA PERSPECTIVE_XOFF_HI,Y       ; PERSPECTIVE_XOFF_HI[Y]
        SBC #$00
        STA ZP_SCREEN_X_HI              ; $B0
        SEC
        LDA ZP_COMPANION_POS_LO,X
        SBC ZP_SCREEN_X
        STA ZP_SCREEN_X                 ; screen-X lo
        LDA ZP_COMPANION_POS_HI,X
        SBC ZP_SCREEN_X_HI
        BEQ .in_view                    ; result hi == 0: on-screen
.slot_next_jmp:
        JMP .slot_next                  ; off-screen: next slot (shared by BCS below)
.in_view:
        LDA ZP_SCREEN_X
        CMP #$9A
        BCS .slot_next_jmp              ; screen-X >= $9A: clip off-right
        LDX ZP_HIT_MAX                  ; $41: scan hit-entity table
.entity_scan:
        LDA ENTITY_HIT_STATE,X          ; ENTITY_HIT_STATE[X]
        BPL .entity_check_row           ; active ($00 or $01): check row match
        DEX
        BPL .entity_scan
        LDX ZP_DRAW_LOOP_IDX            ; no active entity: restore slot X
        JMP .body_draw                  ; skip proximity check
.entity_check_row:
        LDA ENTITY_HIT_ROW,X            ; ENTITY_HIT_ROW[X]: entity row attribute
        SEC
        SBC #$08
        LDX ZP_DRAW_LOOP_IDX            ; restore slot X
        CMP ZP_COMPANION_ROW,X
        BNE .body_draw                  ; no row match: skip proximity
; Entity is on the same floor as this companion:
        LDA ZP_SCREEN_X
        CMP #$40
        BCC .prox_deact_check           ; < $40: check deactivation window
        CMP #$47
        BCS .prox_deact_check           ; >= $47: check deactivation window
; screen-X in [$40, $47): enter drift (climb)
        LDA #$FF
        STA ZP_COMPANION_STATE,X        ; state := drift
        LDA ZP_COMPANION_ROW,X
        CLC
        ADC #$04
        STA ZP_COMPANION_ROW,X          ; row += 4 (start climb)
        JMP .body_draw
.prox_deact_check:
        LDA ZP_COMPANION_DIR,X
        BMI .prox_deact_neg             ; negative direction
; positive direction: deactivate window [$30, $38)
        LDA ZP_SCREEN_X
        CMP #$38
        BCS .body_draw
        CMP #$30
        BCC .body_draw
        LDA #$00
        STA ZP_COMPANION_STATE,X        ; state := inactive
        JMP .body_draw
.prox_deact_neg:
; negative direction: deactivate window [$50, $58)
        LDA ZP_SCREEN_X
        CMP #$50
        BCC .body_draw
        CMP #$58
        BCS .body_draw
        LDA #$00
        STA ZP_COMPANION_STATE,X        ; state := inactive

; --- Body draw: select direction chain and set sprite params ---
.body_draw:
        LDA ZP_COMPANION_DIR,X
        BMI .body_neg                   ; -direction chain at $6E8D
; +direction:
        LDA ZP_COMPANION_ROW,X
        STA ZP_SPRITE_Y
        LDA ZP_SCREEN_X
        TAY
        LDA PROJ_SCREEN_COL,Y           ; PROJ_SCREEN_COL[Y]
        STA ZP_SPRITE_X
        LDA PROJ_FRAME_IDX,Y            ; PROJ_FRAME_IDX[Y]
        TAY                             ; Y = perspective-frame index
        LDA #$03
        STA ZP_SPRITE_W
        LDA #$08
        STA ZP_SPRITE_H
        LDA ZP_COMPANION_STATE,X
        BEQ .pos_draw_nocycle           ; state == 0: draw without advancing SMC
COMPANION_POS_TRAMP:
        ; SMC trampoline: operand bytes rewritten by each pose handler.
        ; On-disk initial target: COMPANION_POS_POSE1.
        JMP COMPANION_POS_POSE1
SMC_COMPANION_POS_LO = *-2
SMC_COMPANION_POS_HI = *-1

COMPANION_POS_POSE1:
        ; +dir pose 1 (next: POSE2)
        LDA #<COMPANION_POS_POSE2
        STA SMC_COMPANION_POS_LO
        LDA #>COMPANION_POS_POSE2
        STA SMC_COMPANION_POS_HI
.pos_draw_nocycle:
        ; Entry when state == 0: load current pose 1 pointers and draw.
        LDA COMPANION_POS_POSE1_LO,Y    ; COMPANION_POS_POSE1_LO[Y]
        STA SMC_DS_SRC_LO
        LDA COMPANION_POS_POSE1_HI,Y    ; COMPANION_POS_POSE1_HI[Y]
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE
        LDX ZP_DRAW_LOOP_IDX
        JMP .player_catch

COMPANION_POS_POSE2:
        ; +dir pose 2 (next: POSE3)
        LDA #<COMPANION_POS_POSE3
        STA SMC_COMPANION_POS_LO
        LDA #>COMPANION_POS_POSE3
        STA SMC_COMPANION_POS_HI
        LDA COMPANION_POS_POSE2_LO,Y    ; COMPANION_POS_POSE2_LO[Y]
        STA SMC_DS_SRC_LO
        LDA COMPANION_POS_POSE2_HI,Y    ; COMPANION_POS_POSE2_HI[Y]
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE
        LDX ZP_DRAW_LOOP_IDX
        JMP .player_catch

COMPANION_POS_POSE3:
        ; +dir pose 3 (next: POSE1, wraps cycle)
        LDA #<COMPANION_POS_POSE1
        STA SMC_COMPANION_POS_LO
        LDA #>COMPANION_POS_POSE1
        STA SMC_COMPANION_POS_HI
        LDA COMPANION_POS_POSE3_LO,Y    ; COMPANION_POS_POSE3_LO[Y]
        STA SMC_DS_SRC_LO
        LDA COMPANION_POS_POSE3_HI,Y    ; COMPANION_POS_POSE3_HI[Y]
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE
        LDX ZP_DRAW_LOOP_IDX
        JMP .player_catch

.body_neg:
; -direction body preamble (duplicates +dir preamble)
        LDA ZP_COMPANION_ROW,X
        STA ZP_SPRITE_Y
        LDA ZP_SCREEN_X
        TAY
        LDA PROJ_SCREEN_COL,Y
        STA ZP_SPRITE_X
        LDA PROJ_FRAME_IDX,Y
        TAY
        LDA #$03
        STA ZP_SPRITE_W
        LDA #$08
        STA ZP_SPRITE_H
        LDA ZP_COMPANION_STATE,X
        BEQ .neg_draw_nocycle
COMPANION_NEG_TRAMP:
        ; SMC trampoline for -direction; initial target POSE1.
        JMP COMPANION_NEG_POSE1
SMC_COMPANION_NEG_LO = *-2
SMC_COMPANION_NEG_HI = *-1

COMPANION_NEG_POSE1:
        ; -dir pose 1 (next: POSE2)
        LDA #<COMPANION_NEG_POSE2
        STA SMC_COMPANION_NEG_LO
        LDA #>COMPANION_NEG_POSE2
        STA SMC_COMPANION_NEG_HI
.neg_draw_nocycle:
        LDA COMPANION_NEG_POSE1_LO,Y    ; COMPANION_NEG_POSE1_LO[Y]
        STA SMC_DS_SRC_LO
        LDA COMPANION_NEG_POSE1_HI,Y    ; COMPANION_NEG_POSE1_HI[Y]
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE
        LDX ZP_DRAW_LOOP_IDX
        JMP .player_catch

COMPANION_NEG_POSE2:
        ; -dir pose 2 (next: POSE3)
        LDA #<COMPANION_NEG_POSE3
        STA SMC_COMPANION_NEG_LO
        LDA #>COMPANION_NEG_POSE3
        STA SMC_COMPANION_NEG_HI
        LDA COMPANION_NEG_POSE2_LO,Y    ; COMPANION_NEG_POSE2_LO[Y]
        STA SMC_DS_SRC_LO
        LDA COMPANION_NEG_POSE2_HI,Y    ; COMPANION_NEG_POSE2_HI[Y]
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE
        LDX ZP_DRAW_LOOP_IDX
        JMP .player_catch

COMPANION_NEG_POSE3:
        ; -dir pose 3 (next: POSE1, wraps cycle)
        LDA #<COMPANION_NEG_POSE1
        STA SMC_COMPANION_NEG_LO
        LDA #>COMPANION_NEG_POSE1
        STA SMC_COMPANION_NEG_HI
        LDA COMPANION_NEG_POSE3_LO,Y    ; COMPANION_NEG_POSE3_LO[Y]
        STA SMC_DS_SRC_LO
        LDA COMPANION_NEG_POSE3_HI,Y    ; COMPANION_NEG_POSE3_HI[Y]
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE
        LDX ZP_DRAW_LOOP_IDX

; --- Player-catch hit-box ---
.player_catch:
        LDA ZP_SCREEN_X
        CMP #$40
        BCC .catch_done                 ; < $40: no catch
        CMP #$50
        BCS .catch_done                 ; >= $50: no catch
        LDA ZP_PLAYER_COL               ; $06
        SEC
        SBC #$08
        CMP ZP_COMPANION_ROW,X
        BCS .catch_done                 ; player_col - 8 >= row: above
        CLC
        ADC #$1A
        CMP ZP_COMPANION_ROW,X
        BCC .catch_done                 ; player_col + $12 < row: below
        LDA #$FF
        STA ZP_HIT_FLAG                 ; $1E: signal player hit
.catch_done:
        JMP .slot_next

; --- Drift (climb) handler ---
.drift_handler:
        STX ZP_DRAW_LOOP_IDX
        LDA ZP_COMPANION_ROW,X          ; row
        CMP #$63
        BEQ .drift_rearm                ; at floor-1 anchor
        CMP #$8B
        BEQ .drift_rearm                ; at floor-2 anchor
        CMP #$B3
        BEQ .drift_rearm                ; at floor-3 anchor
; not at anchor: keep climbing
        CLC
        ADC #$04
        STA ZP_COMPANION_ROW,X
        STA ZP_SPRITE_Y                 ; sprite Y follows row
        JMP .drift_draw

.drift_rearm:
; Row matches one of the anchors: switch back to active, nudge pos.
        SEC
        SBC #$04
        STA ZP_SPRITE_Y                 ; sprite Y = row - 4 (one frame back)
        LDA #$01
        STA ZP_COMPANION_STATE,X        ; state := active
        LDA ZP_COMPANION_DIR,X
        BMI .drift_rearm_neg            ; negative direction
; positive direction: pos += 3
        CLC
        LDA ZP_COMPANION_POS_LO,X
        ADC #$03
        STA ZP_COMPANION_POS_LO,X
        LDA ZP_COMPANION_POS_HI,X
        ADC #$00
        STA ZP_COMPANION_POS_HI,X
        JMP .drift_draw
.drift_rearm_neg:
; negative direction: pos -= 3
        SEC
        LDA ZP_COMPANION_POS_LO,X
        SBC #$03
        STA ZP_COMPANION_POS_LO,X
        LDA ZP_COMPANION_POS_HI,X
        SBC #$00
        STA ZP_COMPANION_POS_HI,X

; --- Drift draw: perspective transform and hand off to active SMC chain ---
.drift_draw:
        LDY ZP_PLAYER_Y
        LDA PERSPECTIVE_XOFF_LO,Y
        SEC
        SBC ZP_SPRITE_XREF
        STA ZP_SCREEN_X
        LDA PERSPECTIVE_XOFF_HI,Y
        SBC #$00
        STA ZP_SCREEN_X_HI
        SEC
        LDA ZP_COMPANION_POS_LO,X
        SBC ZP_SCREEN_X
        STA ZP_SCREEN_X                 ; (hi-byte check omitted in drift)
        TAY
        LDA PROJ_SCREEN_COL,Y
        STA ZP_SPRITE_X
        LDA PROJ_FRAME_IDX,Y
        TAY                             ; Y = perspective-frame index
        LDA #$03
        STA ZP_SPRITE_W
        LDA #$08
        STA ZP_SPRITE_H
        LDA ZP_COMPANION_DIR,X
        BMI .drift_to_neg
        JMP COMPANION_POS_TRAMP         ; enter +direction SMC chain
.drift_to_neg:
        JMP COMPANION_NEG_TRAMP         ; enter -direction SMC chain

@ %def COMPANION_UPDATE ZP_COMPANION_STATE ZP_COMPANION_DIR ZP_COMPANION_POS_LO ZP_COMPANION_POS_HI ZP_PLAYER_FLOOR ENTITY_HIT_ROW COMPANION_POS_POSE1_LO COMPANION_POS_POSE1_HI COMPANION_POS_POSE2_LO COMPANION_POS_POSE2_HI COMPANION_POS_POSE3_LO COMPANION_POS_POSE3_HI COMPANION_NEG_POSE1_LO COMPANION_NEG_POSE1_HI COMPANION_NEG_POSE2_LO COMPANION_NEG_POSE2_HI COMPANION_NEG_POSE3_LO COMPANION_NEG_POSE3_HI SMC_COMPANION_POS_LO SMC_COMPANION_POS_HI SMC_COMPANION_NEG_LO SMC_COMPANION_NEG_HI COMPANION_POS_TRAMP COMPANION_POS_POSE1 COMPANION_POS_POSE2 COMPANION_POS_POSE3 COMPANION_NEG_TRAMP COMPANION_NEG_POSE1 COMPANION_NEG_POSE2 COMPANION_NEG_POSE3

\section{Rescue-child entity tick (20 slots)}

[[RESCUE_UPDATE]] at [[$6F9C]] is the per-frame tick routine for the
20-slot ``rescue child'' entity subsystem --- the small walking figures
that appear on the perspective floors and become the player's scoring
objective.  It pairs with the sibling draw-plus-collision routine
[[RESCUE_DRAW]] at [[$0C98]] (now its own ORG chunk) and with
[[DRAW_ENTITIES]] phase~5 (which handles the marker sprite at the
receding-floor perspective projection).  The routine exists in the
main-loop slot immediately after [[COMPANION_UPDATE]] and immediately
before [[RESCUE_DRAW]].

\paragraph{Slot record.}  The 20-slot subsystem uses seven parallel
per-slot byte arrays, indexed by Y $\in [0, [[$13]]]$:

\begin{center}
\begin{tabular}{l|l|l}
Table & Address & Meaning \\
\hline
[[ENTITY_ACTIVE]]      & [[$03A8]],Y & State: [[$00]] inactive, [[$01]]..[[$7F]] active walking, [[$FE]] exit animation, other negative = drift countdown \\  % TODO-SYM: $7F $FE
[[ENTITY_FLOOR_COL]]   & [[$0358]],Y & World-X low byte (also repurposed as exit-anim counter and drift rearm seed) \\
[[ENTITY_XOFF_IDX]]    & [[$036C]],Y & World-X high byte (xoff index, carry propagates from ENTITY\_FLOOR\_COL) \\
[[ENTITY_FLOOR_POS]]   & [[$0380]],Y & Row (Y-position along the floor, bobbled by the step table) \\
[[RESCUE_DIR]]         & [[$0394]],Y & Walk direction: [[$01]] right, [[$FF]] left \\  % TODO-SYM: $FF
[[RESCUE_ANIM]]        & [[$03BC]],Y & Step animation counter (8..1, 0 = ready for next step) \\
[[RESCUE_FLOOR]]       & [[$03D0]],Y & Assigned floor index (static; picks which floor this slot lives on) \\
[[RESCUE_COUNTDOWN]]   & [[$03E4]],Y & Drift-mode rearm countdown (4 every-other-frame ticks $\to$ exit anim) \\
\end{tabular}
\end{center}

The first four are the same tables [[DRAW_ENTITIES]] phase~5 reads;
the last four are private to this routine and its sibling draw.  The
phase~5 draw only reads [[$03A8]] / [[$0358]] / [[$036C]] / [[$0380]] and hides the
slot whenever [[$03A8]],Y is zero \emph{or} negative --- so drift-phase and
exit-anim slots are invisible on the perspective-grid map, becoming
visible only when the slot is actively walking.

\paragraph{Five slot states.}  The per-slot body dispatches four ways
on [[$03A8]],Y:

\begin{itemize}
\item [[$00]] (\emph{inactive}): attempt to spawn.  A PRNG-gated
  slot-iteration counter [[ZP_RESCUE_SPAWN_CTR]] ($[[$4D]]$) advances once
  per processed slot (persists across frames, no reset), and spawn
  eligibility requires \emph{both} the per-frame PRNG ([[PRNG]] at
  [[$6674]]) to return [[$01]] (1/256) \emph{and} the [[$4D]] counter to be a
  multiple-of-4 residue [[$03]].  In addition to the PRNG path there is a
  \emph{player-floor trigger}: if the slot's assigned floor
  [[RESCUE_FLOOR]] equals the current player floor [[ZP_PLAYER_FLOOR]], and the animation counter [[ZP_ANIM_COUNTER]] is
  $<$ [[$10]], a spawn is forced on that slot.  The player-floor trigger
  fires at most once per frame because of an inline BIT-to-JMP opcode
  patch at [[$705F]] (see below).  Spawn direction alternates with slot  % TODO-SYM: $705F
  index parity: odd slots spawn facing right (dir = [[$01]]) at
  world-X [[$003E]] (left edge of playfield); even slots spawn facing  % TODO-SYM: $003E
  left (dir = [[$FF]]) at world-X [[$035C]].  Spawn row reseats to  % TODO-SYM: $FF $035C
  [[FLOOR_THRESH]]\([[RESCUE_FLOOR]]\) \(-\) [[$07]].
\item [[$01]]..[[$7F]] (\emph{active walking}): advance along the floor in  % TODO-SYM: $7F
  the current direction and animate the step.  Sub-dispatches on
  whether the player is on the same floor --- see below.
\item [[$FE]] (\emph{exit animation}): increment [[ENTITY_FLOOR_COL]]  % TODO-SYM: $FE
  each frame; on 8-bit wrap to [[$00]], deactivate the slot (state :=
  [[$00]]).  This is the ``run off the edge of the screen'' terminal
  animation after the drift countdown expires.
\item other negative ([[$80]]..[[$FD]] / [[$FF]], \emph{drift}): every other  % TODO-SYM: $80 $FF
  frame (gated on [[$FD]] bit~0), decrement [[RESCUE_COUNTDOWN]]; on zero,
  seed [[ENTITY_FLOOR_COL]] with the difficulty-tier value
  [[ZP_DIFF_THRESH_A]] and transition state to [[$FE]].  % TODO-SYM: $FE
\end{itemize}

The drift state ([[$FF]]) and its [[$04]] countdown are written by the  % TODO-SYM: $FF
sibling draw-plus-collision at [[$0C98]]--[[$0E0F]]: either by a floor-enemy  % TODO-SYM: $0E0F
overlap at [[$0DD4]] (clears the floor-enemy slot, awards [[$0035]] BCD via  % TODO-SYM: $0DD4
[[SCORE_ADD]]), or by a player-overlap hit-box at [[$0DF0]]--[[$0E11]]  % TODO-SYM: $0DF0 $0E11
(screen-X in [[$40]]..[[$50]] and player row in the
[player\_col~$-$~[[$19]], player\_col~$+$~[[$12]]] band, writes [[$FF]] to  % TODO-SYM: $12 $FF
[[ZP_HIT_FLAG]] [[$1E]] and awards the same [[$0035]] BCD).  Both paths
converge on the common block at [[$0DD8]] that sets  % TODO-SYM: $0DD8
[[ENTITY_ACTIVE]],Y to [[$FF]] and [[RESCUE_COUNTDOWN]],Y to [[$04]].  % TODO-SYM: $FF
So ``rescue'' is the player walking onto the same floor as a walking
child and intercepting them in the centre X band --- awarding
[[$0035]]~BCD (35 decimal points).

\paragraph{Active-walk dispatch.}  The walking body first checks
whether the player is on the slot's floor ([[ZP_PLAYER_FLOOR]] [[$0C]]
$=$ [[RESCUE_FLOOR]],Y): if so, the \emph{meet-player} branch runs to
steer the child toward the player; otherwise the \emph{normal-walk}
branch runs.

\emph{Normal walk.}  Advance the step: if the step anim counter is
non-zero, decrement it and apply one step (floor-col $\pm$ [[$3]], row
$\pm$ from the 7-entry bobble table [[RESCUE_BOBBLE]] at [[$BD]]).  If the
anim counter is zero, first test the playfield boundary (right: +dir
runs past [[$0352]], left: -dir runs past [[$003F]]) --- deactivate the  % TODO-SYM: $0352 $003F
slot on out-of-bounds.  Next, 1-in-32 PRNG-gate ([[Y XOR $5F]] or
[[Y XOR $1F]], [[CMP #$05]]) to enter the drift phase without a hit
--- sets state to [[$FF]], anim counter to [[$08]], flips direction.  If  % TODO-SYM: $FF
neither boundary-deactivate nor drift-enter, load step size [[$08]] and
run one step.  The bobble table at [[$BD]] is 7~signed bytes (bit~7 = sign,
low 7 bits = magnitude); index X $\in [1, 7]$ picks the row delta,
giving the child's characteristic vertical bobble as it walks.

\emph{Meet-player.}  If the anim counter is mid-step, finish the step.
Otherwise compute the entity's screen-space position
[[FLOOR_BASE_ROW]]([[ENTITY_FLOOR_COL]]) \(+\) [[$B9]]([[ENTITY_XOFF_IDX]])
and compare it to the player's [[ZP_PLAYER_Y]].  If entity $<$
player, set direction [[$01]] (walk right); if entity $=$ or $>$ player,
set direction [[$FF]] (walk left).  If the direction is already correct,  % TODO-SYM: $FF
take one step in that direction; if wrong, flip direction and reset
the anim counter to [[$08]] to stall for one step-cycle.  This is the
classic ``chase the player'' AI and is what makes the child appear to
run up to the player on the shared floor so they can be picked up.

\paragraph{One-shot player-floor trigger (BIT/JMP opcode patch).}  The
instruction at [[$705F]] is [[$2C]] on the disk image --- \texttt{BIT abs}  % TODO-SYM: $705F
with operand [[$6FA8]].  The first time the player-floor spawn-trigger  % TODO-SYM: $6FA8
fires in a pass, the byte is rewritten to [[$4C]] (\texttt{JMP abs}) so
subsequent slots whose [[RESCUE_FLOOR]] matches the player take the
JMP-to-next-slot early exit.  At the end of each pass, after the
[[BPL]] that exits the outer loop, the byte is restored to [[$2C]].  This
limits the per-frame player-floor spawn triggers to one per pass.

\paragraph{Private slot-iteration counter [[$4D]].}  The byte at [[$4D]] is
incremented once per processed slot (by the [[INC]] at the tail of the
slot-body) and is \emph{never} explicitly cleared anywhere in the
game, so it is a free-running modulo-256 counter.  It is read only
inside this routine (both spawn paths depend on its low 2 or 1 bits),
so it is effectively a private scratch --- we call it
[[ZP_RESCUE_SPAWN_CTR]].

\paragraph{Cross-reference to [[DRAW_ENTITIES]] phase~5 and the
sibling draw.}  [[DRAW_ENTITIES]] phase~5 at [[$694E]] draws the  % TODO-SYM: $694E
marker-sprite for each active slot at the perspective-grid floor
position, using only the four shared tables [[$03A8]]/[[$0358]]/[[$036C]]/[[$0380]]
(it uses the [[$B9]],X indirection to map the 16-bit world-X to a
screen column).  The body-sprite draw and all hit-test logic live in
the sibling draw-plus-collision at [[$0C98]], which reads the same four
shared tables (plus [[RESCUE_DIR]] and [[RESCUE_ANIM]] to pick the
walk-cycle sprite frame).  This [[$6F9C]] routine is purely the tick --- it
moves, spawns, rearms and exits slots, but never itself draws.

<<rescue update defines>>=

; --- Zero-page (rescue-child subsystem) ---
ZP_RESCUE_SPAWN_CTR = $4D       ; Free-running slot-iteration counter
                                ; (inc'd once per processed slot; mod-256)
ZP_PLAYER_FLOOR_CUR = $0C       ; Per-frame working copy of ZP_PLAYER_FLOOR
                                ; (seeded by $6A9D: STA $0C from ZP_PLAYER_FLOOR).
PERSPECTIVE_XOFF_BYTE = $B9     ; Byte-domain perspective X-offset table
                                ; (7..8 entries; same table DRAW_ENTITIES
                                ;  phases 3/4/5 read as "$B9,X" to map the
                                ;  xoff index to a screen-column offset.)
; (ZP_ANIM_COUNTER $1F, ZP_DIFF_THRESH_A $34, ZP_PLAYER_Y $4A,
;  ZP_DRAW_LOOP_IDX $5C, ZP_PRNG_A $5F, FLOOR_THRESH $83,
;  ZP_FRAME_COUNTER $FD, ZP_HIT_FLAG $1E are defined elsewhere.)

; --- Parallel 20-slot arrays (private to this routine + sibling draw) ---
; ENTITY_ACTIVE/FLOOR_COL/XOFF_IDX/FLOOR_POS/$036C/$0380
; are defined in <<draw entities defines>>; the remaining four are:
RESCUE_DIR       = $0394        ; Walk direction: $01 right, $FF left
RESCUE_ANIM      = $03BC        ; Step anim counter (8..1; 0 triggers next step)
RESCUE_FLOOR     = $03D0        ; Assigned floor index (static per slot)
RESCUE_COUNTDOWN = $03E4        ; Drift-mode rearm countdown (4 every-other-frame ticks)

; --- 7-byte bobble table (read as $BD,X with X = anim counter) ---
; Signed values: bit 7 = sign (0 ascend, 1 descend), bits 0..6 = |delta|.
; Stored as RESCUE_BOBBLE..$C3 in the KEY_LEFT..$B4 staging-copy buffer; the on-disk
; initial values come from $02DF..$02E5 and get copied by INIT_LEVEL_STATE.
RESCUE_BOBBLE    = $BD          ; Step-Y delta table (7 signed bytes)

@

<<rescue update>>=

        ORG $6F9C
RESCUE_UPDATE:
        SUBROUTINE
        ; Per-frame tick for the 20-slot ``rescue child'' entity
        ; subsystem --- the small walking figures that appear on the
        ; perspective floors and are the player's scoring objective.
        ; Sibling draw-plus-collision lives (still inside
        ; the $03A8 HEX blob); marker sprite draw in DRAW_ENTITIES
        ; phase 5 at $694E.  See section Rescue-child entity tick (20
        ; slots) for the full state-machine description.
        ;
        ; Inputs:
        ;   ENTITY_ACTIVE,Y      --- per-slot state byte.
        ;   ENTITY_FLOOR_COL,Y   --- per-slot world-X low.
        ;   ENTITY_XOFF_IDX,Y    --- per-slot world-X high.
        ;   ENTITY_FLOOR_POS,Y   --- per-slot row Y.
        ;   RESCUE_DIR,Y         --- per-slot direction.
        ;   RESCUE_ANIM,Y        --- per-slot step anim counter.
        ;   RESCUE_FLOOR,Y       --- per-slot assigned floor.
        ;   RESCUE_COUNTDOWN,Y   --- per-slot drift countdown.
        ;   ZP_PLAYER_FLOOR        --- current player floor.
        ;   ZP_ANIM_COUNTER        --- player anim counter (gate).
        ;   ZP_DIFF_THRESH_A       --- difficulty seed for exit-anim.
        ;   ZP_PLAYER_Y            --- player world-X (for chase).
        ;   ZP_PRNG_A              --- low byte of PRNG state.
        ;   FLOOR_THRESH,X         --- per-floor row anchor (on spawn).
        ;   RESCUE_BOBBLE,X        --- 7-byte signed step-Y delta.
        ;   ZP_FRAME_COUNTER b0    --- drift every-other-frame gate.
        ;   PRNG                 --- 8-bit PRNG, spawn gate.
        ;
        ; Behavior:
        ;   Iterates Y=$13 down to 0.  Dispatches per-slot on ENTITY_ACTIVE,Y:
        ;     $00 -> spawn check (PRNG+phase or player-floor trigger)
        ;     $FE -> exit anim (INC floor-col, deactivate on wrap)
        ;     other -ve -> drift countdown, transition to ZP_BLIT_SRC
        ;     +ve -> active walk; if player on same floor, meet-player
        ;            chase AI, else normal-walk (step + drift gate +
        ;            boundary-deactivate).
        ;   The inline opcode patch at .spawn_trigger_opcode ($705F)
        ;   makes the player-floor spawn fire at most once per frame:
        ;   $2C (BIT) on first hit becomes $4C (JMP) for the rest of
        ;   the pass; restored to OPCODE_BIT at the loop exit.
        ;
        ; Modifies:
        ;   ENTITY_ACTIVE/FLOOR_COL/XOFF_IDX/FLOOR_POS, RESCUE_DIR,
        ;   RESCUE_ANIM, RESCUE_COUNTDOWN, ZP_RESCUE_SPAWN_CTR,
        ;   ZP_DRAW_LOOP_IDX ($5C), self-modified opcode at $705F.
        ; Clobbers: A, X, Y

        LDY #$13                        ; 20 slots
.slot_loop:
        LDA ENTITY_ACTIVE,Y
        BEQ .spawn_check                ;   $00 inactive: try to spawn
        BMI .neg_state                  ;   -ve: drift countdown or exit anim
        JMP .active_walk                ;   +ve: active walking
.slot_next:
        INC ZP_RESCUE_SPAWN_CTR         ; $4D++ (free-running mod-256)
        DEY
        BPL .slot_loop                  ; next slot
        LDA #$2C                        ; Restore BIT opcode at .spawn_trigger_opcode
        STA .spawn_trigger_opcode       ;   so next frame starts with BIT (skip trick).
        RTS

; --- Negative state dispatch: $FE exit-anim, else drift countdown ---
.neg_state:
        CMP #$FE
        BEQ .exit_anim                  ;   == $FE -> exit animation
; (fall through: any other negative state = drift countdown)
        LDA ZP_FRAME_COUNTER            ; $FD
        AND #$01
        BNE .slot_next                  ;   skip odd frames (tick every 2 frames)
        LDA RESCUE_COUNTDOWN,Y
        SEC
        SBC #$01
        STA RESCUE_COUNTDOWN,Y
        BNE .slot_next                  ;   still counting
; Countdown expired: transition drift -> exit anim.
        LDA ZP_DIFF_THRESH_A            ; $34: difficulty-tier seed for terminal walk
        STA ENTITY_FLOOR_COL,Y
        LDA #$FE
        STA ENTITY_ACTIVE,Y             ; state := $FE
        JMP .slot_next

; --- $FE state: walk-off-edge exit animation ---
.exit_anim:
        LDA ENTITY_FLOOR_COL,Y
        CLC
        ADC #$01                        ; floor-col ++
        STA ENTITY_FLOOR_COL,Y
        BNE .slot_next                  ;   not wrapped: continue
        STA ENTITY_ACTIVE,Y             ; wrapped: deactivate (A is $00)
        JMP .slot_next

; --- $00 state: spawn check (PRNG-gated + player-floor override) ---
.spawn_check:
        LDA RESCUE_FLOOR,Y
        CMP ZP_PLAYER_FLOOR_CUR         ; $0C
        BEQ .spawn_trigger              ; floor match: forced spawn (one-shot)
        STY ZP_DRAW_LOOP_IDX            ; save Y (PRNG clobbers A; Y needs to survive)
        JSR PRNG                        ; 8-bit PRNG, returns in A
        CMP #$01
        BEQ .spawn_prng_ok              ; 1/256 chance
        LDY ZP_DRAW_LOOP_IDX
        JMP .slot_next
.spawn_prng_ok:
        LDA ZP_RESCUE_SPAWN_CTR         ; $4D
        AND #$03
        CMP #$03
        BEQ .spawn_phase_ok             ; every 4th slot in this pass
        LDY ZP_DRAW_LOOP_IDX
        JMP .slot_next
.spawn_phase_ok:
        TYA
        AND #$01
        BEQ .spawn_neg_dir              ; even slot: spawn facing -dir
;       fall through to +dir spawn
.spawn_pos_dir:
        LDY ZP_DRAW_LOOP_IDX            ; restore slot index
        LDA #$01
        STA ENTITY_ACTIVE,Y             ; state := active
        STA RESCUE_DIR,Y                ; direction := +1 (right)
        LDA #$3E
        STA ENTITY_FLOOR_COL,Y          ; world-X lo = $3E (left-edge spawn)
        LDA #$00
        STA ENTITY_XOFF_IDX,Y           ; world-X hi = 0
        LDA #$00
        STA RESCUE_ANIM,Y               ; anim counter = 0 (ready to step)
        LDA RESCUE_FLOOR,Y
        TAX
        LDA FLOOR_THRESH,X              ; per-floor row anchor
        SEC
        SBC #$07                        ; - 7 (lift off the threshold)
        STA ENTITY_FLOOR_POS,Y
        JMP .slot_next

.spawn_neg_dir:
        LDY ZP_DRAW_LOOP_IDX
        LDA #$FF
        STA RESCUE_DIR,Y                ; direction := -1 (left)
        LDA #$03
        STA ENTITY_XOFF_IDX,Y           ; world-X hi = 3 (right-edge spawn)
        LDA #$5C
        STA ENTITY_FLOOR_COL,Y          ; world-X lo = $5C (so 16-bit = $035C)
        LDA #$00
        STA RESCUE_ANIM,Y
        LDA #$01
        STA ENTITY_ACTIVE,Y             ; state := active
        LDA RESCUE_FLOOR,Y
        TAX
        LDA FLOOR_THRESH,X
        SEC
        SBC #$07
        STA ENTITY_FLOOR_POS,Y
        JMP .slot_next

; --- Player-floor spawn trigger (fires at most once per frame) ---
.spawn_trigger:
        DC.B $2C                        ; BIT opcode: initial value from disk image
.spawn_trigger_opcode = *-1             ; (rewritten to ZP_SPRITE_XREF JMP after first fire;
                                        ;  restored to OPCODE_BIT at loop exit)
        DC.W .slot_next                 ; BIT/JMP operand (reads or jumps to .slot_next)
        LDA #$4C                        ; JMP opcode
        STA .spawn_trigger_opcode       ; patch BIT -> JMP for rest of pass
        LDA ZP_ANIM_COUNTER             ; $1F
        CMP #$10
        BCC .spawn_go
        JMP .slot_next                  ;   anim too high: suppress spawn
.spawn_go:
        STY ZP_DRAW_LOOP_IDX
        LDA ZP_RESCUE_SPAWN_CTR         ; $4D
        AND #$01
        BEQ .spawn_pos_dir              ;   even counter: +dir spawn
        JMP .spawn_neg_dir              ;   odd  counter: -dir spawn

; --- Active-walk dispatch ---
.active_walk:
        LDA ZP_PLAYER_FLOOR_CUR         ; $0C
        CMP RESCUE_FLOOR,Y
        BNE .walk_normal                ;   player elsewhere: normal walk
        JMP .meet_player                ;   player on same floor: chase AI
.walk_normal:
        LDA RESCUE_DIR,Y
        BPL .walk_pos                   ;   +dir
        JMP .walk_neg                   ;   -dir

; --- +dir (walk right) ---
.walk_pos:
        LDA RESCUE_ANIM,Y
        BNE .step_pos                   ;   mid-step: continue
        LDA ENTITY_XOFF_IDX,Y
        CMP #$03
        BNE .drift_gate_pos             ;   xoff != 3: not at right boundary
        LDA ENTITY_FLOOR_COL,Y
        CMP #$52
        BCC .drift_gate_pos             ;   lo < $52: not at boundary
; Right boundary ($0352) reached: deactivate.
        LDA #$00
        STA ENTITY_ACTIVE,Y
        JMP .slot_next
.drift_gate_pos:
        TYA
        EOR ZP_PRNG_A                   ; $5F
        CMP #$05
        BNE .step_pos_preload           ;   not 5: no drift trigger
; Drift trigger (no-hit path): state := drift, anim = 8, flip dir.
        LDA #$08
        STA RESCUE_ANIM,Y
        LDA #$FF
        STA RESCUE_DIR,Y
        JMP .slot_next
.step_pos_preload:
        LDA #$08                        ; step size = 8 (anim counter preload)
; Fall through with A = anim counter.
.step_pos:
        SEC
        SBC #$01
        STA RESCUE_ANIM,Y               ; anim counter --
        TAX
        CLC
        LDA ENTITY_FLOOR_COL,Y
        ADC #$03                        ; world-X += 3
        STA ENTITY_FLOOR_COL,Y
        LDA ENTITY_XOFF_IDX,Y
        ADC #$00                        ; carry into hi
        STA ENTITY_XOFF_IDX,Y
; Apply bobble table to row.
.apply_bobble:
        LDA RESCUE_BOBBLE,X             ; RESCUE_BOBBLE[X] = signed step-Y delta
        ASL                             ; bit 7 -> carry
        BCC .bobble_sub                 ;   bit7=0: ascend (add magnitude)
        LSR                             ; restore low 7 bits as magnitude
        CLC
        ADC ENTITY_FLOOR_POS,Y          ; row += magnitude
        STA ENTITY_FLOOR_POS,Y
        JMP .slot_next
.bobble_sub:
        LSR                             ; restore magnitude
        STA ZP_DRAW_LOOP_IDX
        SEC
        LDA ENTITY_FLOOR_POS,Y
        SBC ZP_DRAW_LOOP_IDX            ; row -= magnitude
        STA ENTITY_FLOOR_POS,Y
        JMP .slot_next

; --- -dir (walk left) ---
.walk_neg:
        LDA RESCUE_ANIM,Y
        BNE .step_neg                   ;   mid-step: continue
        LDA ENTITY_XOFF_IDX,Y
        BNE .drift_gate_neg             ;   xoff != 0: not at left boundary
        LDA ENTITY_FLOOR_COL,Y
        CMP #$3F
        BCS .drift_gate_neg             ;   lo >= $3F: not at boundary
; Left boundary ($003F) reached: deactivate.
        LDA #$00
        STA ENTITY_ACTIVE,Y
        JMP .slot_next
.drift_gate_neg:
        TYA
        EOR ZP_ANIM_COUNTER             ; $1F (different PRNG source than +dir gate)
        CMP #$05
        BNE .step_neg_preload
; Drift trigger (no-hit path): state := drift, anim = 8, flip dir.
        LDA #$08
        STA RESCUE_ANIM,Y
        LDA #$01
        STA RESCUE_DIR,Y
        JMP .slot_next
.step_neg_preload:
        LDA #$08                        ; step size = 8
.step_neg:
        SEC
        SBC #$01
        STA RESCUE_ANIM,Y
        TAX
        SEC
        LDA ENTITY_FLOOR_COL,Y
        SBC #$03                        ; world-X -= 3
        STA ENTITY_FLOOR_COL,Y
        LDA ENTITY_XOFF_IDX,Y
        SBC #$00
        STA ENTITY_XOFF_IDX,Y
        JMP .apply_bobble               ; (share bobble-apply with +dir)

; --- Meet-player: chase AI when player is on slot's floor ---
.meet_player:
        LDA RESCUE_DIR,Y
        BMI .meet_dir_neg
; +dir: finish any mid-step, else compute chase direction.
        LDA RESCUE_ANIM,Y
        BEQ .meet_compute
        JMP .step_pos
.meet_dir_neg:
        LDA RESCUE_ANIM,Y
        BEQ .meet_compute
        JMP .step_neg
.meet_compute:
; Compute entity screen-space X:
;   A = FLOOR_BASE_ROW[floor_col] + $B9[xoff_idx]
; Then compare against ZP_PLAYER_Y:
;   A < $13            -> entity way to the left -> flip to +dir
;   (A - $13) < $4A    -> entity before player    -> +dir (or step if already)
;   (A - $13) >= $4A   -> entity at/past player   -> -dir (or step if already)
        LDA ENTITY_FLOOR_COL,Y
        TAX
        LDA FLOOR_BASE_ROW,X            ; FLOOR_BASE_ROW[X]
        PHA
        LDA ENTITY_XOFF_IDX,Y
        TAX
        PLA
        CLC
        ADC PERSPECTIVE_XOFF_BYTE,X     ; PERSPECTIVE_XOFF_BYTE[X]: byte-domain perspective offset
        CMP #$13
        BCC .flip_to_pos                ;   < $13: far left, turn right
        SEC
        SBC #$13
        CMP ZP_PLAYER_Y                 ; $4A
        BCC .meet_before_player         ;   < player: entity to left of player
; >= player: entity at or past player.
        LDA RESCUE_DIR,Y
        BPL .flip_to_neg                ;   currently +dir: flip to -dir
; Already -dir: take one -dir step.
        LDA #$08
        JMP .step_neg
.flip_to_neg:
        LDA #$FF
        STA RESCUE_DIR,Y
        LDA #$08
        STA RESCUE_ANIM,Y               ; stall one step-cycle
        JMP .slot_next
.meet_before_player:
        LDA RESCUE_DIR,Y
        BMI .flip_to_pos                ;   currently -dir: flip to +dir
; Already +dir: take one +dir step.
        LDA #$08
        JMP .step_pos
.flip_to_pos:
        LDA #$01
        STA RESCUE_DIR,Y
        LDA #$08
        STA RESCUE_ANIM,Y               ; stall one step-cycle
        JMP .slot_next

