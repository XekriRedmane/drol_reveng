FLOOR_LINES_P1:
        SUBROUTINE
        ; Paint 40 bytes of pixel data into four evenly-spaced hi-res
        ; page~1 rows: row 67 ($2C28), row 107 ($2EA8), row 147 ($2D50),
        ; and row 187 ($2FD0).  Each source byte is replicated to the
        ; same column on all four rows, so the four rows display the
        ; same 40-column pattern.
        ;
        ; Inputs:
        ;   ZP_BLIT_SRC ($FE/$FF) --- source pointer to 40-byte row
        ;                             (points into a 12-frame animation
        ;                             table at FLOOR_SPR_LO/HI; in the
        ;                             shipped Drol levels every frame
        ;                             is all-zero, so the four rows get
        ;                             cleared each call).
        ;
        ; Behavior:
        ;   Y counts 0..39, X counts 39..0 in parallel.  For each step
        ;   load (ZP_BLIT_SRC),Y and STA to row-base + X at four rows.
        ;   The reversed X index means source byte 0 lands at column
        ;   39 and source byte 39 lands at column 0.
        ;
        ; Modifies:
        ;   Hi-res page 1 at rows 67, 107, 147, 187 (columns 0..39).
        ; Clobbers: A, X, Y

        LDY #$00
        LDX #$27
.row:
        LDA (ZP_BLIT_SRC),Y
        STA $2C28,X                     ; row 67
        STA $2EA8,X                     ; row 107
        STA $2D50,X                     ; row 147
        STA $2FD0,X                     ; row 187
        INY
        DEX
        BPL .row
        RTS
