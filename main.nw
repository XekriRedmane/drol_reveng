<<enemy b draw defines>>=

; --- Zero-page used by enemy-B draw (shared with ENEMY_A_DRAW) ---
; $AF / $B0 are 16-bit scratch for the screen-clip subtract.  They
; hold the perspective-corrected low/high bytes of the enemy's
; world X minus the perspective-X reference, and after the subtract
; against ZP_ENEMY_B_POS they hold the screen-relative X.
ZP_CLIP_X_LO    = $AF           ; Screen-clip scratch low byte
ZP_CLIP_X_HI    = $B0           ; Screen-clip scratch high byte

; $4C is a level-fixed X-reference (INIT_LEVEL_STATE writes ZP_ACTION_DIR).
; It is subtracted from PERSPECTIVE_XOFF to produce the world-X
; origin that enemy positions are measured against.
ZP_SPRITE_XREF  = $4C           ; World-X reference (level-fixed = $02)

; --- Perspective-X lookup tables, indexed by ZP_PLAYER_Y ---
; $1A8F holds the low byte and $198F holds the high byte of a Y-to-X
; transform.  The low-byte table is (roughly) $(Y>>1)* 7$, so
; deeper floor positions translate to a larger horizontal offset.
; The high byte is all zero for on-screen Y values.
PERSPECTIVE_XOFF_LO = $1A8F     ; Y -> screen-X offset, low byte
PERSPECTIVE_XOFF_HI = $198F     ; Y -> screen-X offset, high byte

; --- Sprite family offsets into SPRITE_TABLE_LO / SPRITE_TABLE_HI ---
; Enemy-B's steady-mode sprite set starts at base index $25 in the
; two 128-entry parallel tables (lo) / $B080 (hi).
SPRITE_TABLE_B_LO = $B025       ; Enemy-B body sprite pointers, low
SPRITE_TABLE_B_HI = $B0A5       ; Enemy-B body sprite pointers, high

; --- Per-level drift-mode puff sprite pointer pair ---
; Inside the swappable level-data region $7500-$7AFF.  The two bytes
; form the 16-bit address that SMC_DS_SRC_LO/HI are patched to on
; B's drift-mode draw path.
ENEMY_B_PUFF_LO = $755A         ; Drift-mode puff sprite pointer, low byte
ENEMY_B_PUFF_HI = $765A         ; Drift-mode puff sprite pointer, high byte

; --- Game-over/hit-remaining flag ---
; Initialized to ZP_LAST_DIR by INIT_LEVEL_STATE and reset to ZP_LAST_DIR by the
; player-reincarnation code at $5EC3.  Each overlap-hit in
; ENEMY_A_DRAW / ENEMY_B_DRAW decrements this counter; once it
; goes negative the main-loop tail branches to GAME_OVER.
ZP_GAME_OVER    = $39           ; Game-over / hits-remaining counter

@

<<enemy b draw>>=

        ORG $1591
ENEMY_B_DRAW:
        SUBROUTINE
        ; Per-frame draw + player-collision for the enemy-B slot.
        ; Dispatches on ZP_ENEMY_B_STATE: $00 exits; positive does the
        ; full steady-mode draw and hit-test; negative takes the
        ; drift-mode tail that draws a smaller puff sprite using a
        ; level-specific sprite-pointer pair.
        ;
        ; Inputs:
        ;   ZP_ENEMY_B_STATE    --- $00 off; +steady; -drift.
        ;   ZP_ENEMY_B_POS      --- 16-bit world X for this enemy.
        ;   ZP_ENEMY_B_ROW      --- Sprite starting screen row.
        ;   ZP_PLAYER_Y   --- Player Y (index into perspective tables).
        ;   ZP_PLAYER_COL --- Player column (collision X reference).
        ;   ZP_SPRITE_XREF --- Level-fixed X reference.
        ;   PERSPECTIVE_XOFF_LO/HI --- Y-to-X transform tables.
        ;   SPRITE_TABLE_B_LO/HI  --- Body-sprite pointer table base.
        ;   ENEMY_B_PUFF_LO/HI    --- Level-specific drift-puff sprite.
        ;
        ; Behavior:
        ;   1. State gate: $00 exits; negative jumps to .drift_draw.
        ;   2. Clip: compute screen-relative X into ZP_CLIP_X_LO/HI;
        ;      exit if high byte non-zero or low byte >= $9C.
        ;   3. Set sprite params ($5D = screen col, $56 = 5, $57 = $11,
        ;      $5B = ZP_ENEMY_B_ROW), patch DRAW_SPRITE src to
        ;      SPRITE_TABLE_B_{LO,HI}[PROJ_FRAME_IDX], JSR DRAW_SPRITE.
        ;   4. Player-overlap test: ZP_CLIP_X_LO in [$42,$55) AND
        ;      ZP_ENEMY_B_ROW in [player-$0E, player+$0D].
        ;   5. On overlap (.hit): write $FF to ZP_ENEMY_B_STATE (drift),
        ;      rewrite counter to $D0+(ZP_CLIP_X_LO-$03)*$100, bump row
        ;      by 2, reset sound counter, award +$0300 BCD via
        ;      SCORE_ADD, DEC ZP_GAME_OVER, exit.
        ;   6. Drift-mode draw tail: draw $02x$06 puff sprite using
        ;      level-specific pointer pair.
        ;
        ; Modifies:
        ;   ZP_CLIP_X_LO/HI, sprite-param ZPs ($56/$57/$5B/$5D),
        ;   ZP_SCORE_ADD_LO/HI, ZP_GAME_OVER, ZP_ENEMY_B_STATE,
        ;   ZP_ENEMY_B_POS, ZP_ENEMY_B_ROW, ZP_ENEMY_B_SND_CTR,
        ;   SMC_DS_SRC_LO/HI (patched operand bytes of DRAW_SPRITE).
        ; Clobbers: A, X

; --- State dispatch: $00 exit, +steady, -drift ---
        LDA ZP_ENEMY_B_STATE
        BEQ .exit                       ; $00: slot inactive
        BPL .steady                     ; positive: steady-mode draw
        JMP .drift_draw                 ; negative: drift-mode draw tail

; --- Clip: compute screen-relative X from world X ---
.steady:
        LDX ZP_PLAYER_Y
        LDA PERSPECTIVE_XOFF_LO,X       ; Y-indexed X offset (low)
        SEC
        SBC ZP_SPRITE_XREF              ; ... minus fixed X-reference
        STA ZP_CLIP_X_LO
        LDA PERSPECTIVE_XOFF_HI,X       ; (high byte propagation)
        SBC #$00
        STA ZP_CLIP_X_HI
        SEC
        LDA ZP_ENEMY_B_POS              ; Subtract from enemy world X
        SBC ZP_CLIP_X_LO
        STA ZP_CLIP_X_LO                ; ZP_CLIP_X_LO = screen-relative X (lo)
        LDA ZP_ENEMY_B_POS+1
        SBC ZP_CLIP_X_HI
        BEQ .in_bounds                  ; hi diff == 0: on-screen
.exit:
        RTS                             ; hi diff != 0: off-screen, exit
.in_bounds:
        LDA ZP_CLIP_X_LO
        CMP #$9C
        BCS .exit                       ; clipped X >= $9C: off right edge

; --- Main sprite draw (steady mode) ---
        TAX                             ; X := clipped screen-X
        LDA PROJ_SCREEN_COL,X           ; -> screen column index
        STA ZP_SPRITE_X
        LDA PROJ_FRAME_IDX,X            ; -> sprite frame index
        TAX                             ; X := frame index
        LDA #$05
        STA ZP_SPRITE_W                 ; Sprite width = 5 bytes
        LDA #$11
        STA ZP_SPRITE_H                 ; Sprite height = 17 rows
        LDA ZP_ENEMY_B_ROW
        STA ZP_SPRITE_Y                 ; Sprite row = enemy-B row
        LDA SPRITE_TABLE_B_LO,X         ; Patch DRAW_SPRITE source-ptr (lo)
        STA SMC_DS_SRC_LO
        LDA SPRITE_TABLE_B_HI,X         ; Patch DRAW_SPRITE source-ptr (hi)
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE                 ; Blit the enemy-B body sprite

; --- Player-overlap test: narrow X window + Y-band ---
        LDA ZP_CLIP_X_LO
        CMP #$42
        BCC .no_hit                     ; clipped X < $42: no overlap
        CMP #$55
        BCS .no_hit                     ; clipped X >= $55: no overlap
        LDA ZP_PLAYER_COL               ; player col (ZP $06)
        SEC
        SBC #$0E
        CMP ZP_ENEMY_B_ROW
        BCS .no_hit                     ; enemy-row < player-$0E: no overlap
        CLC
        ADC #$1B                        ; (player-$0E) + $1B = player+$0D
        CMP ZP_ENEMY_B_ROW
        BCC .no_hit                     ; enemy-row >= player+$0D: no overlap

; --- Overlap: put B into drift mode + award score + count hit ---
.hit:
        LDA #$FF
        STA ZP_ENEMY_B_STATE            ; drift mode (deferred deactivation)
        LDA ZP_CLIP_X_LO
        SEC
        SBC #$03
        STA ZP_ENEMY_B_POS+1            ; counter hi := clip_X - 3
        LDA #$D0
        STA ZP_ENEMY_B_POS              ; counter lo := $D0
        INC ZP_ENEMY_B_ROW              ; row += 2 (shift puff down)
        INC ZP_ENEMY_B_ROW
        LDA #$05
        STA ZP_ENEMY_B_SND_CTR          ; re-arm sound counter
        LDA #$00
        STA ZP_SCORE_ADD_LO             ; addend lo = $00
        LDA #$03
        STA ZP_SCORE_ADD_HI             ; addend hi = $03 ($0300 BCD = 300)
        JSR SCORE_ADD                   ; ... so score += 300
        DEC ZP_GAME_OVER                ; consume one hit-credit
.no_hit:
        RTS

; --- Drift-mode draw tail: $02x$06 puff from level-data pointer pair ---
.drift_draw:
        LDA #$02
        STA ZP_SPRITE_W                 ; Puff width = 2 bytes
        LDA #$06
        STA ZP_SPRITE_H                 ; Puff height = 6 rows
        LDA ZP_ENEMY_B_ROW
        STA ZP_SPRITE_Y                 ; Row = enemy-B row
        LDX ZP_ENEMY_B_POS+1            ; Use counter hi as X-col index
        LDA PROJ_SCREEN_COL,X
        STA ZP_SPRITE_X
        LDA ENEMY_B_PUFF_LO             ; Patch DRAW_SPRITE src with the
        STA SMC_DS_SRC_LO               ; level-specific puff pointer
        LDA ENEMY_B_PUFF_HI
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE
        RTS
@ %def ENEMY_B_DRAW
@ %def ZP_CLIP_X_LO ZP_CLIP_X_HI ZP_SPRITE_XREF ZP_GAME_OVER
@ %def PERSPECTIVE_XOFF_LO PERSPECTIVE_XOFF_HI
@ %def SPRITE_TABLE_B_LO SPRITE_TABLE_B_HI
@ %def ENEMY_B_PUFF_LO ENEMY_B_PUFF_HI

\section{Enemy-C advance timer}

[[ENEMY_C_ADVANCE]] at [[$1646]] is the per-frame tick for the
``ground-companion'' enemy slot in the contiguous entity block
[[$D4]]--[[$EC]].  It is the third member of the  % TODO-SYM: $EC
[[ENEMY_A_ADVANCE]]/[[ENEMY_B_ADVANCE]] family --- structurally
parallel but distinct in three notable ways.  See \S Enemy-A advance
timer for the shared template; this section documents only the
differences.

\paragraph{Slot mapping.}  Where enemy-A uses
[[ZP_ENEMY_A_SND_CTR]]~=~[[$B8]], [[ZP_ENEMY_A_STATE]]~=~[[$DC]],
[[ZP_ENEMY_A_POS]]~=~[[$DD]]/[[$DE]] and [[ZP_ENEMY_A_ROW]]~=~[[$DF]], enemy-C  % TODO-SYM: $DE
uses [[ZP_ENEMY_C_SND_CTR]]~=~[[$B7]], [[ZP_ENEMY_C_STATE]]~=~[[$D4]],
[[ZP_ENEMY_C_POS]]~=~[[$D5]]/[[$D6]] and [[ZP_ENEMY_C_ROW]]~=~[[$D7]].  The  % TODO-SYM: $D6
sound-pitch table is [[SND_PITCH_TBL_C]] at [[$0224]] (8 entries) and
the click is emitted with duration~[[$08]] via [[SND_DELAY_DOWN]] at
[[$1091]] --- \emph{not} via [[SFX_TONE]] like enemy-A and enemy-B.  The
descending-tone delay produces a softer, lower-pitched percussive
chirp distinguishable from enemy-A's sharp click.

\paragraph{Drift mode is a vertical bobble, not a PRNG gate.}  Enemy-A
and enemy-B treat ``drift mode'' (state bit~7 set) as a probability
gate that simply skips the tick most frames.  Enemy-C interprets
drift mode entirely differently:

\begin{enumerate}
\item On the drift path, the routine inspects [[ZP_FRAME_COUNTER]]
  ($\$$FD): on the 1-in-4 frames where the low two bits are both set,
  it nudges [[ZP_ENEMY_C_ROW]] up by one row when bit~4 of [[$FD]] is
  clear, or down by one row when bit~4 is set.  This makes the
  on-screen sprite bob vertically by one row at a $\sim$1-Hz cadence
  (bit~4 flips every 16 frames).
\item The 16-bit advance counter then ticks normally on the steady
  path (subtracting [[ZP_ADVANCE_RATE]]).
\item There is a separate drift entry at [[$16A5]] reached via  % TODO-SYM: $16A5
  [[JMP]]~[[$16A5]] from the drift dispatch: it \emph{adds} 1 to  % TODO-SYM: $16A5
  [[ZP_ENEMY_C_POS]] each frame and on overflow falls into the rearm
  reload code at [[$1688]] (skipping the [[$3C]]-window check).  This is a  % TODO-SYM: $1688
  slow upward count rather than the fast downward count used in
  steady mode.
\end{enumerate}

\paragraph{Rearm does not wake another slot.}  Enemy-A's rearm writes
[[$01]] to [[ZP_ENEMY_C_STATE]], waking enemy-C (the cross-slot
A$\rightarrow$C handshake).  Enemy-C's rearm instead writes [[$00]] to
[[ZP_ENEMY_C_STATE]]~--- \emph{deactivating itself}.  Enemy-C's own
\emph{draw} routine [[ENEMY_C_DRAW]] at [[$1757]]--[[$1763]] is what  % TODO-SYM: $1757 $1763
broadcasts [[$FF]] to both [[$D4]] and [[$DC]] (when C hits a floor-enemy  % TODO-SYM: $FF
slot) --- so C's topology edges all live in its draw, not in
[[ENEMY_B_ADVANCE]] or any other neighbour.  This confirms a
\emph{three-slot} entity model with the topology
A$\rightarrow$C (via A's rearm) and C$\rightarrow$\{A,C\} (via C's
hit path), with B having no outgoing handshake.

\paragraph{Other constants.}  The reload value is [[$0352]] (vs.\ enemy-A's  % TODO-SYM: $0352
[[$0361]]), the rearm window is [[$0000]]..[[$003B]] (vs.\ [[$0000]]..[[$003D]]), and  % TODO-SYM: $0361 $003B $003D
the row reload reads from a three-slot table at [[$85]]/[[$86]]/[[$87]]  % TODO-SYM: $85 $86 $87
(addressed as $\$$84,X with X derived from [[ZP_PRNG_A]]).  The index
is computed as $X = ({\rm PRNG\_A}~\&~3)$ if non-zero, else $X = 1$~---
so X $\in \{1,2,3\}$ with X~=~1 selected~$2/4$ of the time and X~=~2
or 3 each~$1/4$ of the time.  The row is then $[[$84]],X - $[[$0A]].  Slots
[[$83]]--[[$87]] are also used by [[LEVEL_INTRO_TICK]] (per-level intro Y  % TODO-SYM: $87
seed at [[$84]]) and by [[BEAM_TARGET_DRAW]] (per-floor Y threshold
[[FLOOR_THRESH]] at [[$83]]): enemy-C reuses three of these scenery-anchor
Y rows as spawn-row choices.

\paragraph{Cross-references.}  [[ZP_ADVANCE_RATE]] is shared with
[[ENEMY_A_ADVANCE]] (and presumably [[ENEMY_B_ADVANCE]]).  The draw
counterpart [[ENEMY_C_DRAW]] at [[$16AC]] reads [[ZP_ENEMY_C_STATE]],
[[ZP_ENEMY_C_POS]] and [[ZP_ENEMY_C_ROW]] directly.  External
producers of [[ZP_ENEMY_C_STATE]] are: [[ENEMY_A_ADVANCE]]
($[[$1411]]$, writes~[[$01]] = steady-mode activation) and  % TODO-SYM: $1411
[[ENEMY_C_DRAW]]'s own hit path ($[[$1759]]$, writes~[[$FF]] = drift-mode  % TODO-SYM: $1759 $FF
self-animation, paired with a [[$FF]] write to [[ZP_ENEMY_A_STATE]] if  % TODO-SYM: $FF
that slot was active).

