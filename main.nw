; --- Zero-page (player sprite renderer) ---
ZP_ACTION_DIR   = $02           ; Action flag: $00=idle, $01=ascend, $FF=descend
ZP_PLAYER_STANCE = $03          ; Player stance / floor index (clamped $03..$09)
; ZP_PLAYER_COL, ZP_HIT_FLAG, $FD (frame counter) are defined elsewhere.

; --- Main-player sprite pointer tables (indexed by ZP_PLAYER_STANCE) ---
PLAYER_SPR_IDLE_LO   = $7527    ; Idle-path sprite pointer low bytes
PLAYER_SPR_IDLE_HI   = $7627    ; Idle-path sprite pointer high bytes
PLAYER_SPR_ACTIVE_LO = $7531    ; Active/elevator-path sprite pointer low
PLAYER_SPR_ACTIVE_HI = $7631    ; Active/elevator-path sprite pointer high

; --- Pseudo-random static source inside DRAW_PLAYER's own code image ---
; Used for the teleport/flicker effect at the top and bottom floors.
; The two tables overlap the routine itself ($6500-$66FF), so no data
; fixture is needed.
PLAYER_STATIC_LO = $6500        ; Low byte of flicker sprite pointer (by ZP_FRAME_COUNTER)
PLAYER_STATIC_HI = $6600        ; High byte (ANDed with $7F) of flicker pointer

; --- Self-modifying operand aliases inside DRAW_PLAYER ---
; Both bytes are patched by LEVEL_INTRO_TICK (intro countdown, fading)
; and LEVEL_COMPLETE (restore defaults after the transition animation).
SMC_SR_HEIGHT   = $64F6         ; Immediate operand of "LDA #$13" --- sprite height
SMC_SR_YSRC     = $64FA         ; ZP operand of "LDA $06" --- sprite Y source

@

<<draw player>>=

        ORG $64DF
DRAW_PLAYER:
        SUBROUTINE
        ; Main-loop player sprite renderer (called from MAIN_LOOP's
        ; JSR SPRITE_RENDER slot, SMC-toggled $20/$2C).  Draws
        ; the big centre-screen player sprite at column $14.  Two code
        ; paths, selected by the action flag ZP_ACTION_DIR:
        ;
        ; Inputs:
        ;   ZP_ACTION_DIR       --- $00 idle, $01 ascend, $FF descend.
        ;   ZP_PLAYER_STANCE    --- stance/floor index ($03..$09);
        ;                                 $03 = top floor, $09 = bottom floor.
        ;   ZP_PLAYER_COL       --- sprite Y row (via SMC_SR_YSRC).
        ;   ZP_HIT_FLAG         --- $00 intro / $80..$FF hit: skip
        ;                                 the action-path flicker draw.
        ;   $FD                       --- frame counter, indexes the
        ;                                 flicker's pseudo-random static source.
        ;   PLAYER_SPR_IDLE_LO/HI     --- idle sprite pointers.
        ;   PLAYER_SPR_ACTIVE_LO/HI   --- active sprite pointers.
        ;   SMC_SR_HEIGHT     --- live height immediate (may be
        ;                                 shrunk by LEVEL_INTRO_TICK).
        ;   SMC_SR_YSRC       --- live ZP source for sprite Y
        ;                                 (normally $06 = ZP_PLAYER_COL,
        ;                                 $17 = ZP_INTRO_Y during intro).
        ;
        ; Behavior:
        ;   Idle ($02 == 0): pick sprite from PLAYER_SPR_IDLE tables,
        ;     width $03, height (SMC_SR_HEIGHT, default $13), Y from
        ;     (SMC_SR_YSRC, default ZP_PLAYER_COL), X column $14, then
        ;     JSR DRAW_SPRITE; RTS.
        ;   Active ($02 != 0): if $1E > 0 and the stance is $03 or $09,
        ;     first draw a $00 x $06 teleport-flicker sprite using
        ;     bytes of this routine's own code image as static, masked
        ;     by AND #$83 or AND #$B0 via the live SMC slot
        ;     SMC_SPRITE_MASK_OP/ARG inside DRAW_SPRITE.  Then draw the
        ;     main body from PLAYER_SPR_ACTIVE tables at width ZP_PLAYER_STANCE,
        ;     height $14, falling through into the idle path's
        ;     column/Y-source/JSR.
        ;
        ; Modifies:
        ;   SMC_DS_SRC_LO/HI,
        ;   SMC_SPRITE_MASK_OP/ARG,
        ;   ZP_SPRITE_W/H, ZP_SPRITE_Y/X,
        ;   hi-res page framebuffer.
        ; Clobbers: A, X, Y

; --- Gate on action flag ---
        LDA ZP_ACTION_DIR               ; $02
        BNE .action_path                ;   non-zero = elevator in motion

; --- Idle path: single body sprite from PLAYER_SPR_IDLE tables ---
.idle_path:
        LDX ZP_PLAYER_STANCE            ; $03
        LDA PLAYER_SPR_IDLE_LO,X        ; Sprite pointer low byte
        STA SMC_DS_SRC_LO
        LDA PLAYER_SPR_IDLE_HI,X        ; Sprite pointer high byte
        STA SMC_DS_SRC_HI
        LDA #$03
        STA ZP_SPRITE_W                 ; Width = 3 bytes
        LDA #$13                        ; Default height = $13
                                        ; (#$13 byte at SMC_SR_HEIGHT=$64F6,
                                        ;  patched by LEVEL_INTRO_TICK)
        STA ZP_SPRITE_H
.share_tail:
        LDA ZP_PLAYER_COL               ; Y source = $06 (at SMC_SR_YSRC=$64FA,
                                        ; patched to ZP_INTRO_Y=ZP_INTRO_Y by
                                        ; LEVEL_INTRO_TICK during intro)
        STA ZP_SPRITE_Y
        LDA #$14
        STA ZP_SPRITE_X                 ; X column = $14 (screen centre)
        JSR DRAW_SPRITE
        RTS

; --- Action path: optional flicker + main body ---
.action_path:
        LDA ZP_HIT_FLAG                 ; $1E
        BMI .body_from_active           ;   hit: body only, no flicker
        BEQ .body_from_active           ;   intro: body only, no flicker

; --- Check stance against floor-extreme values $03 / $09 ---
        LDA ZP_PLAYER_STANCE            ; $03
        CMP #$03                        ; Top floor?
        BNE .check_bottom
        LDA #$14                        ; Flicker X column = $14 (top)
        STA ZP_SPRITE_X
        LDA #$83                        ; Flicker mask = AND #$83
        STA SMC_SPRITE_MASK_ARG
        JMP .flicker_setup
.check_bottom:
        CMP #$09                        ; Bottom floor?
        BNE .body_from_active           ;   neither: skip flicker
        LDA #$11                        ; Flicker X column = $11 (bottom)
        STA ZP_SPRITE_X
        LDA #$B0                        ; Flicker mask = AND #$B0
        STA SMC_SPRITE_MASK_ARG

; --- Flicker draw: static from code image, masked by AND imm ---
.flicker_setup:
        LDA #$29                        ; $29 = AND #imm opcode
        STA SMC_SPRITE_MASK_OP          ;   patch live SMC slot in DRAW_SPRITE
        LDA ZP_PLAYER_COL               ; $06
        CLC
        ADC #$0D                        ;   + $0D
        STA ZP_SPRITE_Y                 ; Y = player_col + $0D
        LDA #$00
        STA ZP_SPRITE_W                 ; Width = 0+1 byte
        LDA #$06
        STA ZP_SPRITE_H                 ; Height = 6 rows
        LDY $FD                         ; Frame counter
        LDA PLAYER_STATIC_LO,Y          ; Pseudo-random low from own code
        STA SMC_DS_SRC_LO
        LDA PLAYER_STATIC_HI,Y          ; Pseudo-random high ...
        AND #$7F                        ;   masked into INPUT_DISPATCH-$66FF range
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE
        LDA #$24                        ; $24 = BIT zp opcode (2-byte NOP)
        STA SMC_SPRITE_MASK_OP          ;   restore normal draw path

; --- Main body draw from PLAYER_SPR_ACTIVE tables ---
.body_from_active:
        LDX ZP_PLAYER_STANCE            ; $03
        LDA PLAYER_SPR_ACTIVE_LO,X      ; Pointer low
        STA SMC_DS_SRC_LO
        LDA PLAYER_SPR_ACTIVE_HI,X      ; Pointer high
        STA SMC_DS_SRC_HI
        LDA #$03
        STA ZP_SPRITE_W                 ; Width = 3 bytes
        LDA #$14
        STA ZP_SPRITE_H                 ; Height = $14 (one taller than idle)
        JMP .share_tail                 ; Share idle-path tail at $64F9:
                                        ;   loads ZP_PLAYER_COL, sets
                                        ;   X=$14, JSR DRAW_SPRITE, RTS.
@ %def DRAW_PLAYER PLAYER_SPR_IDLE_LO PLAYER_SPR_IDLE_HI
@ %def PLAYER_SPR_ACTIVE_LO PLAYER_SPR_ACTIVE_HI
@ %def PLAYER_STATIC_LO PLAYER_STATIC_HI
@ %def SMC_SR_HEIGHT SMC_SR_YSRC ZP_ACTION_DIR ZP_PLAYER_STANCE

\section{Sprite draw (transparent blit)}

[[DRAW_SPRITE]] at [[$656F]] is the game's main sprite draw routine --- it
is called from about 40 places (projectiles, entities, UI sprites, the
attract logo, extra-life animation). It OR-blits a rectangular sprite
onto the currently-hidden hi-res page, using
[[ZP_PAGE_FLAG]] (bit~7) to choose between page~1 (addresses
[[$2000]]-[[$3FFF]], row-high table at [[SCREEN_ROW_ADDR_HI]] = [[$72C0]]) and  % TODO-SYM: $3FFF
page~2 (addresses [[$4000]]-[[$5FFF]], row-high table at  % TODO-SYM: $5FFF
[[SCREEN_ROW_ADDR_HI2]] = [[$7440]]). Row-low bytes always come from
[[SCREEN_ROW_ADDR_LO]] at [[$7380]].

Inputs are the usual sprite-parameter quartet:
\begin{itemize}
\item [[ZP_SPRITE_W]] --- width in bytes.
\item [[ZP_SPRITE_H]] --- height in rows.
\item [[ZP_SPRITE_Y]] --- starting screen row.
\item [[ZP_SPRITE_X]] --- starting column (right edge).
\item [[SPRITE_PTR_LO]]/[[SPRITE_PTR_HI]] ([[$65B3]]/[[$65B4]],
  self-modifying operand bytes of the sprite-data fetch) --- source
  pointer into sprite data.
\end{itemize}

The routine is heavily self-modifying. On entry it patches three
absolute-address operands with the current screen row address:
\begin{itemize}
\item The [[LDA xxxx,X]] at [[$6592]] selects the row-high-byte table  % TODO-SYM: $6592
  ([[$72C0]] or~[[$7440]]), based on [[ZP_PAGE_FLAG]].
\item The [[ORA xxxx,X]] at [[$65B9]] and [[STA xxxx,X]] at [[$65BC]] both  % TODO-SYM: $65B9 $65BC
  get patched with the current row's base screen address on every
  outer-loop iteration.
\end{itemize}

The outer loop (one iteration per row) walks the sprite data byte-by-byte
using Y. The inner loop walks X from the right edge of the sprite
toward the left, decrementing the byte counter in ZP~[[$5A]]. For each
byte: if the destination column is out of range ([[X >= $28]]), the
sprite byte is skipped but Y is still advanced. Otherwise the sprite
byte is fetched; if it is zero the source byte is skipped (transparency);
otherwise the byte is OR'd into the screen memory at the row/column
position.

\paragraph{Live flicker slot at [[$65B7]] / [[$65B8]].}  Immediately before
the inner-loop [[ORA]] instruction there are two bytes --- [[$24 $00]]
--- that on the disk image encode [[BIT $00]] and act as a 2-byte NOP
in the normal draw path.  This is \emph{not} dead padding: at runtime
[[LEVEL_INTRO_TICK]] patches these two bytes to [[AND
\#<flicker>]] ([[$29 <imm>]]) for every frame of the intro countdown so
that the sprite byte is AND-masked against the low bit of the frame
counter before being OR'd into the screen.  This makes the intro
sprite flash on every other frame without needing a separate draw
routine.  After each intro draw the two bytes are restored to [[$24
$00]] so the regular draw path sees a 2-byte NOP again.  The two slots
are labelled [[SMC_SPRITE_MASK_OP]] ([[$65B7]], opcode byte) and
[[SMC_SPRITE_MASK_ARG]] ([[$65B8]], operand byte) and are declared in the
level-intro defines chunk.

There is a short dead-code tail at [[$65CC]]-[[$65D4]] that is only reachable  % TODO-SYM: $65CC $65D4
from an unreachable [[CPX #$00 / BCS]] fall-through at [[$65AE]]-[[$65B1]]  % TODO-SYM: $65AE $65B1
(the [[BCS]] is always taken because X is unsigned). The bytes are kept
verbatim so that the binary stays byte-perfect.

<<draw sprite defines>>=

; --- Zero-page (sprite draw parameters) ---
ZP_SPRITE_W     = $56           ; Sprite width (bytes per row)
ZP_SPRITE_H     = $57           ; Sprite height (rows)
ZP_SPRITE_ROW_REMAIN = $5A      ; Inner-loop byte-countdown scratch
ZP_SPRITE_Y     = $5B           ; Sprite starting screen row
ZP_SPRITE_X     = $5D           ; Sprite starting column (right edge)

; --- Self-mod operand placeholder ---
; Disk-image value for the four self-modifying absolute operands in
; DRAW_SPRITE.  $9000 is outside the game's memory map and serves only
; as a harmless initial pattern; all four are overwritten before the
; instructions are executed.
SPRITE_SMC_INIT = $9000
@

<<draw sprite>>=

        ORG $656F
DRAW_SPRITE:
        SUBROUTINE
        ; Sprite draw --- transparent (OR) blit to the hidden hi-res page.
        ;
        ; Inputs:
        ;   ZP_SPRITE_W      --- width in bytes per row
        ;   ZP_SPRITE_H      --- height in rows
        ;   ZP_SPRITE_Y      --- starting screen row (0..191)
        ;   ZP_SPRITE_X      --- starting column (right edge)
        ;   SPRITE_PTR_LO/HI       --- source pointer (self-mod operand of
        ;                              the LDA abs,Y at $65B2)
        ;   ZP_PAGE_FLAG b7  --- selects page 1 (clear) or page 2
        ;                              (set) as the draw target.
        ;
        ; Behavior:
        ;   Patches its own row-address-table operand based on
        ;   ZP_PAGE_FLAG.  Outer loop (ZP_SPRITE_H iterations) walks
        ;   rows; for each row it refreshes the ORA/STA operands with
        ;   the row's base screen address.  Inner loop walks
        ;   ZP_SPRITE_W bytes from the right edge leftward: columns
        ;   off the right edge and zero source bytes are transparent,
        ;   otherwise the byte is OR'd into screen RAM.
        ;
        ; Modifies:
        ;   Self (operands, $65BA/$65BB, $65BD/$65BE),
        ;   ZP_SPRITE_ROW_REMAIN, ZP_SPRITE_Y (post-increment).
        ;
        ; Note: the [[BIT $00]] ([[SMC_SPRITE_MASK_OP]] /
        ; [[SMC_SPRITE_MASK_ARG]]) is a *live* self-modifying slot --- it
        ; acts as a 2-byte NOP during normal draws, but LEVEL_INTRO_TICK
        ; patches it to [[AND #<flicker>]] for each countdown frame to
        ; flash the intro sprite on every other frame.  It is restored
        ; before this routine is entered by non-intro callers.
        ; Clobbers: A, X, Y

; --- Select row-high table based on ZP_PAGE_FLAG ---
        BIT ZP_PAGE_FLAG
        BMI .page2
        LDA #<SCREEN_ROW_ADDR_HI  ; $C0 --- low of SCREEN_ROW_ADDR_HI (page 1)
        STA SMC_ROW_HI_LO
        LDA #>SCREEN_ROW_ADDR_HI  ; $72
        STA SMC_ROW_HI_HI
        JMP .outer_entry
.page2:
        LDA #<SCREEN_ROW_ADDR_HI2 ; $40 --- low of SCREEN_ROW_ADDR_HI2 (page 2)
        STA SMC_ROW_HI_LO
        LDA #>SCREEN_ROW_ADDR_HI2 ; $74
        STA SMC_ROW_HI_HI

; --- Entry into the draw loop: initialise sprite-data index ---
.outer_entry:
        LDY #$00

; --- Outer loop: one iteration per sprite row ---
.next_row:
        LDA ZP_SPRITE_W
        STA ZP_SPRITE_ROW_REMAIN  ; Inner-loop byte counter
        LDX ZP_SPRITE_Y           ; Current screen row (0..191)
SMC_ROW_HI_LO = *+1               ; Low of LDA abs,X operand --- patched
SMC_ROW_HI_HI = *+2               ; High of LDA abs,X operand --- patched
        LDA SPRITE_SMC_INIT,X     ; Runtime: LDA $72C0,X or LDA $7440,X
        STA SMC_ORA_HI            ; Patch ORA operand (high byte)
        STA SMC_STA_HI            ; Patch STA operand (high byte)
        LDA SCREEN_ROW_ADDR_LO,X  ; Row-low (fixed SCREEN_ROW_ADDR_LO table)
        STA SMC_ORA_LO            ; Patch ORA operand (low byte)
        STA SMC_STA_LO            ; Patch STA operand (low byte)

; --- Inner loop: one iteration per sprite byte on this row ---
        LDX ZP_SPRITE_X           ; Destination column
.col_loop:
        CPX #$28                  ; Column >= 40 (off right edge)?
        BCS .col_skip             ;   yes --- transparent
        CPX #$00                  ; (Dead: X unsigned, BCS always taken)
        BCS .fetch_src
        INY                       ; (unreachable) advance and skip
        JMP .dead_tail            ; (unreachable) jump to dead tail
.fetch_src:
SPRITE_PTR_LO = *+1               ; Low of LDA abs,Y operand --- caller sets
SPRITE_PTR_HI = *+2               ; High of LDA abs,Y operand --- caller sets
        LDA SPRITE_SMC_INIT,Y     ; Runtime: LDA (sprite_ptr),Y
        BEQ .col_skip             ; Zero pixel --- transparent
; SMC_SPRITE_MASK_OP / SMC_SPRITE_MASK_ARG: live SMC slot.
; Disk-image bytes $24 $00 encode BIT $00, which is a 2-byte NOP for
; normal callers.  LEVEL_INTRO_TICK patches to AND #imm for intro
; flicker frames, then restores $24 $00 before returning.
SMC_SPRITE_MASK_OP  = *           ; SMC_SPRITE_MASK_OP--- opcode byte (BIT zp / AND imm)
SMC_SPRITE_MASK_ARG = *+1         ; SMC_SPRITE_MASK_ARG--- operand byte (ZP addr / AND imm)
        DC.B $24, $00             ; BIT $00 --- flicker-mask SMC slot
SMC_ORA_LO = *+1                  ; Low of ORA abs,X operand --- patched
SMC_ORA_HI = *+2                  ; High of ORA abs,X operand --- patched
        ORA SPRITE_SMC_INIT,X     ; OR with screen byte (SMC operand)
SMC_STA_LO = *+1                  ; Low of STA abs,X operand --- patched
SMC_STA_HI = *+2                  ; High of STA abs,X operand --- patched
        STA SPRITE_SMC_INIT,X     ; Store back (SMC operand)
.col_skip:
        INY                       ; Next sprite byte
        DEX                       ; Move left one column
        DEC ZP_SPRITE_ROW_REMAIN
        BPL .col_loop             ; More bytes on this row?

; --- Advance to next row ---
.advance_row:                     ; -- BMI target from dead tail
        INC ZP_SPRITE_Y           ; Next screen row
        DEC ZP_SPRITE_H           ; Rows remaining?
        BNE .next_row
        RTS

; --- Dead-code tail ($65CC-$65D4, 9 bytes) ---
; Reached only from the unreachable "INY / JMP" at $65AE-$65B1
; (since [[CPX #$00 / BCS]] is always taken).  Retained verbatim
; for byte-faithful assembly.
.dead_tail:
        DEX
        DEC ZP_SPRITE_ROW_REMAIN
        BMI .advance_row          ; -- target $65C5
        INY
        JMP .dead_tail
@ %def DRAW_SPRITE SPRITE_PTR_LO SPRITE_PTR_HI

\section{Sprite draw (playfield, HUD-clipped)}

[[DRAW_SPRITE_PLAYFIELD]] at [[$65D5]] is a sibling of [[DRAW_SPRITE]] that performs an identical transparent OR-blit onto the
hidden hi-res page, but with a \emph{narrower} column-acceptance
window.  It is called only from [[DRAW_ENTITIES]] --- its four sites
draw the player, the ``special'' sprite, the two companion slots and
the 20-slot entity list --- so every gameplay sprite that moves over
the playfield goes through this routine rather than through
[[DRAW_SPRITE]].

The two routines share almost every byte: the same row-high-table
selection based on [[ZP_PAGE_FLAG]], the same outer row loop, the
same self-modifying [[ORA]]/[[STA]] operands on the inner write, the
same sprite-parameter quartet ([[ZP_SPRITE_W]]/[[\_H]]/[[\_Y]]/[[\_X]]
at [[$56]]/[[$57]]/[[$5B]]/[[$5D]]).  They differ only in the inner-loop column
check and in what tail code they carry.

\paragraph{Column clip window.}  Where [[DRAW_SPRITE]] accepts every
column $0 \le X < 40$ (reject $X \ge [[$28]]$), this routine rejects  % TODO-SYM: $28
\emph{three} sets of columns:

\begin{itemize}
\item $X = [[$0B]]$ --- the left playfield wall column.  A
  [[CPX #$0B / BEQ]] explicitly singles it out.
\item $X \ge [[$1C]]$ --- any column to the right of the playfield.  % TODO-SYM: $1C
  Columns [[$1C]]--[[$27]] are the right-hand HUD strip (the HISCORE panel  % TODO-SYM: $1C
  and digits); the implicit wrap also covers columns $\ge [[$28]]$ (off  % TODO-SYM: $28
  the right edge of the screen).
\item Zero source byte --- same transparency rule as [[DRAW_SPRITE]].
\end{itemize}

The accepted window is therefore cols [[$00]]--[[$0A]] and [[$0C]]--[[$1B]]
(27~columns), which is exactly the gameplay region of the screen.
See the HUD frame image: the [[SCORE]] panel (cols [[$00]]--[[$09]]) is  % TODO-SYM: $09
\emph{inside} the accepted window --- so score digits drawn through
regular HUD code land there, but gameplay sprites momentarily passing
through the same columns will also draw on top of the score panel.
Only col~[[$0B]] (the left vertical wall of the top playfield strip) and
the entire right HISCORE region are protected.

\paragraph{No flicker SMC slot.}  [[DRAW_SPRITE]] has a live
self-modifying [[BIT $00]] slot at [[$65B7]] (patched to [[AND \#imm]]
by [[LEVEL_INTRO_TICK]] for intro flicker frames).  This routine does
\emph{not} --- the inner OR is unconditional.  The intro flicker
mechanism only applies to the intro sprite drawn via [[DRAW_SPRITE]]
from [[LEVEL_INTRO_TICK]], not to playfield entities.

\paragraph{No dead tail.}  [[DRAW_SPRITE]] has an unreachable 9-byte
[[INY / JMP]] tail at [[$65CC]]--[[$65D4]] left over from an earlier draft.  % TODO-SYM: $65CC $65D4
This routine has no such tail --- it is 87~bytes of live code
([[$65D5]]--[[$662B]]).  % TODO-SYM: $662B

\paragraph{Source-pointer SMC.}  The [[LDA $9000,Y]] at [[$6614]] is  % TODO-SYM: $6614
patched by [[DRAW_ENTITIES]] with the per-sprite source-data address
before each call.  The operand bytes are named [[SMC_PFB_SRC_LO]] and [[SMC_PFB_SRC_HI]], exported for the callers.
Disk-image initial value is [[$9000]] --- a harmless pattern outside the
game's memory map, overwritten before the first execution.

<<draw sprite playfield>>=

        ORG $65D5
DRAW_SPRITE_PLAYFIELD:
        SUBROUTINE
        ; Transparent (OR) blit with HUD-column clipping.
        ; Sibling of DRAW_SPRITE: identical structure, but the
        ; inner column check rejects col $0B (left playfield wall) and
        ; cols >=$1C (right HISCORE HUD panel + offscreen) instead of
        ; the simple >=$28 offscreen check.  There is no flicker SMC
        ; slot and no dead-code tail.
        ;
        ; Inputs:
        ;   ZP_SPRITE_W      --- width in bytes per row
        ;   ZP_SPRITE_H      --- height in rows
        ;   ZP_SPRITE_Y      --- starting screen row (0..191)
        ;   ZP_SPRITE_X      --- starting column (right edge)
        ;   SMC_PFB_SRC_LO/HI      --- source pointer (self-mod operand
        ;                              of the LDA abs,Y at $6614),
        ;                              patched by DRAW_ENTITIES.
        ;   ZP_PAGE_FLAG b7  --- selects page 1 (clear) or page 2
        ;                              (set) as the draw target.
        ;
        ; Behavior:
        ;   Outer loop walks ZP_SPRITE_H rows.  For each row, patches
        ;   the ORA/STA operands with the row's base screen address
        ;   (high byte from SCREEN_ROW_ADDR_HI or $7440 via the row-high SMC operand,
        ;   low byte from SCREEN_ROW_ADDR_LO).  Inner loop walks
        ;   ZP_SPRITE_W bytes from the right edge leftward: rejects
        ;   col $0B, rejects cols >=$1C, rejects zero source bytes;
        ;   otherwise OR's the sprite byte into screen RAM.
        ;
        ; Modifies:
        ;   Self (operands at SMC_PFB_ROW_HI_LO/HI, SMC_PFB_ORA_LO/HI,
        ;   SMC_PFB_STA_LO/HI), ZP_SPRITE_ROW_REMAIN,
        ;   ZP_SPRITE_Y (post-increment).
        ; Clobbers: A, X, Y

; --- Select row-high table based on ZP_PAGE_FLAG ---
        BIT ZP_PAGE_FLAG
        BMI .page2
        LDA #<SCREEN_ROW_ADDR_HI  ; $C0 --- low of SCREEN_ROW_ADDR_HI (page 1)
        STA SMC_PFB_ROW_HI_LO
        LDA #>SCREEN_ROW_ADDR_HI  ; $72
        STA SMC_PFB_ROW_HI_HI
        JMP .outer_entry
.page2:
        LDA #<SCREEN_ROW_ADDR_HI2 ; $40 --- low of SCREEN_ROW_ADDR_HI2 (page 2)
        STA SMC_PFB_ROW_HI_LO
        LDA #>SCREEN_ROW_ADDR_HI2 ; $74
        STA SMC_PFB_ROW_HI_HI

; --- Entry into the draw loop: initialise sprite-data index ---
.outer_entry:
        LDY #$00

; --- Outer loop: one iteration per sprite row ---
.next_row:
        LDA ZP_SPRITE_W
        STA ZP_SPRITE_ROW_REMAIN  ; Inner-loop byte counter
        LDX ZP_SPRITE_Y           ; Current screen row (0..191)
SMC_PFB_ROW_HI_LO = *+1           ; Low of LDA abs,X operand --- patched
SMC_PFB_ROW_HI_HI = *+2           ; High of LDA abs,X operand --- patched
        LDA SPRITE_SMC_INIT,X     ; Runtime: LDA $72C0,X or LDA $7440,X
        STA SMC_PFB_ORA_HI        ; Patch ORA operand (high byte)
        STA SMC_PFB_STA_HI        ; Patch STA operand (high byte)
        LDA SCREEN_ROW_ADDR_LO,X  ; Row-low (fixed SCREEN_ROW_ADDR_LO table)
        STA SMC_PFB_ORA_LO        ; Patch ORA operand (low byte)
        STA SMC_PFB_STA_LO        ; Patch STA operand (low byte)

; --- Inner loop: one iteration per sprite byte on this row ---
        LDX ZP_SPRITE_X           ; Destination column
.col_loop:
        CPX #$0B                  ; Left playfield wall column?
        BEQ .col_skip             ;   yes --- transparent
        CPX #$1C                  ; HISCORE HUD panel or offscreen right?
        BCS .col_skip             ;   yes --- transparent
SMC_PFB_SRC_LO = *+1              ; Low of LDA abs,Y operand --- caller sets
SMC_PFB_SRC_HI = *+2              ; High of LDA abs,Y operand --- caller sets
        LDA SPRITE_SMC_INIT,Y     ; Runtime: LDA (sprite_ptr),Y
        BEQ .col_skip             ; Zero pixel --- transparent
SMC_PFB_ORA_LO = *+1              ; Low of ORA abs,X operand --- patched
SMC_PFB_ORA_HI = *+2              ; High of ORA abs,X operand --- patched
        ORA SPRITE_SMC_INIT,X     ; OR with screen byte (SMC operand)
SMC_PFB_STA_LO = *+1              ; Low of STA abs,X operand --- patched
SMC_PFB_STA_HI = *+2              ; High of STA abs,X operand --- patched
        STA SPRITE_SMC_INIT,X     ; Store back (SMC operand)
.col_skip:
        INY                       ; Next sprite byte
        DEX                       ; Move left one column
        DEC ZP_SPRITE_ROW_REMAIN
        BPL .col_loop             ; More bytes on this row?

; --- Advance to next row ---
        INC ZP_SPRITE_Y           ; Next screen row
        DEC ZP_SPRITE_H           ; Rows remaining?
        BNE .next_row
        RTS
@ %def DRAW_SPRITE_PLAYFIELD SMC_PFB_SRC_LO SMC_PFB_SRC_HI

\section{Sprite draw (opaque)}

[[DRAW_SPRITE_OPAQUE]] at [[$662C]] is the third member of Drol's
sprite-blitter triplet --- sibling of [[DRAW_SPRITE]] and
[[DRAW_SPRITE_PLAYFIELD]].  Where the other two use an
[[ORA]]/[[STA]] pair to \emph{overlay} the sprite on top of whatever
is already on the hi-res page (transparent blit), this routine uses a
plain [[STA]] that \emph{overwrites} the screen byte unconditionally
(opaque blit).  Every source byte is written, including zero bytes ---
there is no source-transparency test.

The routine shares the same sprite-parameter quartet
([[ZP_SPRITE_W]]/[[\_H]]/[[\_Y]]/[[\_X]] at [[$56]]/[[$57]]/[[$5B]]/[[$5D]]) and
the same [[ZP_PAGE_FLAG]]-driven row-high-table selection, so all
three blitters are drop-in compatible from the caller's point of
view.  They differ only in (1) the inner column-clip check, (2)
whether a zero source byte is skipped, and (3) whether an [[ORA]]
is performed before the [[STA]]:

\begin{center}
\begin{tabular}{lccc}
\hline
                              & [[DRAW_SPRITE]]  & [[DRAW_SPRITE_PLAYFIELD]] & [[DRAW_SPRITE_OPAQUE]] \\ \hline
Reject col $\ge [[$28]]$         & yes              & implicit (via $\ge[[$1C]]$)  & yes \\  % TODO-SYM: $28 $1C
Reject col $=[[$0B]]$            & no               & yes                       & no \\
Reject col $\ge [[$1C]]$         & no               & yes                       & no \\  % TODO-SYM: $1C
Skip zero source byte         & yes              & yes                       & \textbf{no} \\
OR with screen before store   & yes              & yes                       & \textbf{no} \\
Flicker SMC slot              & yes ([[$65B7]])     & no                        & no \\
Dead-code tail                & yes (9 bytes)    & no                        & no \\
Live size                     & 102 bytes        & 87 bytes                  & 72 bytes \\ \hline
\end{tabular}
\end{center}

\paragraph{Callers.}  Only two routines call [[DRAW_SPRITE_OPAQUE]]:

\begin{itemize}
\item [[DISPLAY_UPDATE]] --- draws the timer animation tile
  at column~[[$09]], row~[[$16]] (a 1$\times$6 sprite in the SCORE HUD  % TODO-SYM: $09 $16
  strip).  Source comes from [[TIMER_FRAME_LO]]/[[HI]] at
  [[$6800]]/[[$6900]].
\item [[DRAW_DIGIT]] --- draws a single BCD digit tile
  (1$\times$6) at a caller-chosen column.  Source comes from
  [[DIGIT_TILE_LO]]/[[HI]] at [[$AFF6]]/[[$B076]].
  [[POST_FRAME]] calls this seven times per frame --- five
  score nibbles plus two level-state digits.
\end{itemize}

Every caller draws at fixed HUD positions where whatever was on screen
previously (the previous digit, or the previous timer frame) must be
completely replaced.  An OR blit would leave the old digit's pixels
visible underneath the new one, turning a ``0'' drawn over ``8'' into
an ``8''.  The opaque STA blit solves this by unconditionally
overwriting --- which also means the caller is responsible for
clearing any region the new sprite does not cover (the digit and
timer tiles are designed as rectangular 1$\times$6 bounding boxes that
tile cleanly).

\paragraph{Source-pointer SMC.}  The [[LDA $9000,Y]] at [[$6661]] is  % TODO-SYM: $6661
patched by the callers with the per-tile source-data address.  The
operand bytes are named [[SMC_TILE_SRC_LO]] and
[[SMC_TILE_SRC_HI]], exported for the callers.  Disk-image
initial value is [[$9000]] --- a harmless pattern outside the game's
memory map, overwritten before the first execution.

<<draw sprite opaque>>=

        ORG $662C
DRAW_SPRITE_OPAQUE:
        SUBROUTINE
        ; Opaque (STA) blit to the hidden hi-res page.
        ; Third member of the sprite-blitter triplet --- sibling of
        ; DRAW_SPRITE ($656F, OR + source-zero skip) and
        ; DRAW_SPRITE_PLAYFIELD ($65D5, OR + source-zero skip + HUD
        ; column clip).  Unlike those two, this routine has NO
        ; source-zero transparency test and NO ORA step: every source
        ; byte is stored unconditionally, overwriting whatever was on
        ; the screen.  Column clip is the simple >=$28 offscreen
        ; check, same as DRAW_SPRITE.  Used for HUD tiles (timer
        ; animation, score/hiscore/level digits) where the previous
        ; frame's pixels must be replaced, not OR'd on top of.
        ;
        ; Inputs:
        ;   ZP_SPRITE_W      --- width in bytes per row
        ;   ZP_SPRITE_H      --- height in rows
        ;   ZP_SPRITE_Y      --- starting screen row (0..191)
        ;   ZP_SPRITE_X      --- starting column (right edge)
        ;   SMC_TILE_SRC_LO/HI     --- source pointer (self-mod operand
        ;                              of the LDA abs,Y at $6661),
        ;                              patched by each caller.
        ;   ZP_PAGE_FLAG b7  --- selects page 1 (clear) or page 2
        ;                              (set) as the draw target.
        ;
        ; Behavior:
        ;   Outer loop walks ZP_SPRITE_H rows.  For each row, patches
        ;   the STA operand with the row's base screen address (high
        ;   byte from SCREEN_ROW_ADDR_HI or $7440 via the row-high SMC operand, low
        ;   byte from SCREEN_ROW_ADDR_LO).  Inner loop walks
        ;   ZP_SPRITE_W bytes from the right edge leftward: rejects
        ;   cols >=$28 (offscreen), otherwise unconditionally STA's
        ;   the source byte to screen RAM.
        ;
        ; Modifies:
        ;   Self (operands at SMC_OPQ_ROW_HI_LO/HI,
        ;   SMC_TILE_SRC_LO/HI, SMC_OPQ_STA_LO/HI),
        ;   ZP_SPRITE_ROW_REMAIN, ZP_SPRITE_Y (post-increment).
        ; Clobbers: A, X, Y

; --- Select row-high table based on ZP_PAGE_FLAG ---
        BIT ZP_PAGE_FLAG
        BMI .page2
        LDA #<SCREEN_ROW_ADDR_HI  ; $C0 --- low of SCREEN_ROW_ADDR_HI (page 1)
        STA SMC_OPQ_ROW_HI_LO
        LDA #>SCREEN_ROW_ADDR_HI  ; $72
        STA SMC_OPQ_ROW_HI_HI
        JMP .outer_entry
.page2:
        LDA #<SCREEN_ROW_ADDR_HI2 ; $40 --- low of SCREEN_ROW_ADDR_HI2 (page 2)
        STA SMC_OPQ_ROW_HI_LO
        LDA #>SCREEN_ROW_ADDR_HI2 ; $74
        STA SMC_OPQ_ROW_HI_HI

; --- Entry into the draw loop: initialise sprite-data index ---
.outer_entry:
        LDY #$00

; --- Outer loop: one iteration per sprite row ---
.next_row:
        LDA ZP_SPRITE_W
        STA ZP_SPRITE_ROW_REMAIN  ; Inner-loop byte counter
        LDX ZP_SPRITE_Y           ; Current screen row (0..191)
SMC_OPQ_ROW_HI_LO = *+1           ; Low of LDA abs,X operand --- patched
SMC_OPQ_ROW_HI_HI = *+2           ; High of LDA abs,X operand --- patched
        LDA SPRITE_SMC_INIT,X     ; Runtime: LDA $72C0,X or LDA $7440,X
        STA SMC_OPQ_STA_HI        ; Patch STA operand (high byte)
        LDA SCREEN_ROW_ADDR_LO,X  ; Row-low (fixed SCREEN_ROW_ADDR_LO table)
        STA SMC_OPQ_STA_LO        ; Patch STA operand (low byte)

; --- Inner loop: one iteration per sprite byte on this row ---
        LDX ZP_SPRITE_X           ; Destination column
.col_loop:
        CPX #$28                  ; Column >= 40 (off right edge)?
        BCS .col_skip             ;   yes --- transparent
SMC_TILE_SRC_LO = *+1             ; Low of LDA abs,Y operand --- caller sets
SMC_TILE_SRC_HI = *+2             ; High of LDA abs,Y operand --- caller sets
        LDA SPRITE_SMC_INIT,Y     ; Runtime: LDA (tile_src),Y
SMC_OPQ_STA_LO = *+1              ; Low of STA abs,X operand --- patched
SMC_OPQ_STA_HI = *+2              ; High of STA abs,X operand --- patched
        STA SPRITE_SMC_INIT,X     ; Store (opaque --- no OR, no zero skip)
.col_skip:
        INY                       ; Next sprite byte
        DEX                       ; Move left one column
        DEC ZP_SPRITE_ROW_REMAIN
        BPL .col_loop             ; More bytes on this row?

; --- Advance to next row ---
        INC ZP_SPRITE_Y           ; Next screen row
        DEC ZP_SPRITE_H           ; Rows remaining?
        BNE .next_row
        RTS
@ %def DRAW_SPRITE_OPAQUE SMC_TILE_SRC_LO SMC_TILE_SRC_HI

