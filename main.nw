<<floor to row data>>=

        ORG $1D47
FLOOR_TO_ROW_DATA:
        SUBROUTINE
        ; FLOOR_TO_ROW payload ($1D47-$1DFF, 185 bytes).
        ;
        ; Tail of the FLOOR_TO_ROW table.  FLOOR_TO_ROW is exported as
        ; the EQU $1D40 (seven bytes before this label) because the
        ; callers index it as FLOOR_TO_ROW[X] where X is always >= $07
        ; in practice (player/special/companion/entity floor-row index
        ; plus a per-phase centre-adjust).  The skipped bytes $1D40-
        ; $1D46 are inter-chunk dasm gap fill (FF) and are never read
        ; by the game.
        ;
        ; For indices 7..25 the table is all zero (high sky = row 0);
        ; indices 26..255 ramp up to row $21 (33) in 5-wide plateaus
        ; that widen toward the horizon to simulate foreshortening.
        ; Consumed by DRAW_ENTITIES phases 2-5 to turn a floor-position
        ; index into a hi-res row number for DRAW_SPRITE_PLAYFIELD.

        HEX 00 00 00 00 00 00 00 00     ; $1D47..$1D4E: sky rows (row 0)
        HEX 00 00 00 00 00 00 00 00     ; $1D4F..$1D56
        HEX 00 00 00 00 00 00 00 00     ; $1D57..$1D5E
        HEX 00 00 01 01 01 02 02 02     ; $1D5F..$1D66: horizon begins
        HEX 02 02 03 03 03 03 03 04     ; $1D67..$1D6E
        HEX 04 04 04 04 05 05 05 05     ; $1D6F..$1D76
        HEX 05 06 06 06 06 06 07 07     ; $1D77..$1D7E
        HEX 07 07 07 08 08 08 08 08     ; $1D7F..$1D86
        HEX 09 09 09 09 09 0A 0A 0A     ; $1D87..$1D8E
        HEX 0A 0A 0B 0B 0B 0B 0B 0C     ; $1D8F..$1D96
        HEX 0C 0C 0C 0C 0D 0D 0D 0D     ; $1D97..$1D9E
        HEX 0D 0E 0E 0E 0E 0E 0F 0F     ; $1D9F..$1DA6
        HEX 0F 0F 0F 10 10 10 10 10     ; $1DA7..$1DAE
        HEX 11 11 11 11 11 12 12 12     ; $1DAF..$1DB6
        HEX 12 12 13 13 13 13 13 14     ; $1DB7..$1DBE
        HEX 14 14 14 14 15 15 15 15     ; $1DBF..$1DC6
