<<player tick handlers>>=

        ORG $614B
PLAYER_TICK_MOVE_LEFT:
        SUBROUTINE
        ; Per-frame tick handler invoked by [[PLAYER_MOVE_TICK]] when
        ; [[ZP_MOVE_DIR]] is negative (player walking left).  Animates
        ; one step of the walk cycle --- decrementing [[ZP_PLAYER_Y]] on
        ; four of every seven sub-frames and advancing the two walking
        ; animation counters [[ZP_WALK_FRAME]] and [[ZP_SPRITE_XREF]]
        ; --- then falls through into [[PLAYER_TICK_IDLE]] to run the
        ; full playfield-refresh chain for this frame.
        ;
        ; Inputs:
        ;   ZP_PLAYER_Y       --- player world-Y (low clamp: $01).
        ;   ZP_WALK_FRAME     --- walking-frame counter (10-step cycle,
        ;                          values 0,2,4,6,8,1,3,5,7,9).
        ;   ZP_SPRITE_XREF    --- sub-frame pacing counter (7-step
        ;                          cycle 2,4,6,1,3,5,0; Y decrements
        ;                          on states {2,3,5,6}).
        ;
        ; Behavior:
        ;   1. If ZP_PLAYER_Y < $01 (already at low clamp), skip the
        ;      animation and enter PLAYER_TICK_IDLE directly.
        ;   2. Dispatch on ZP_SPRITE_XREF:
        ;        state 2 or 3       : DEC ZP_PLAYER_Y; next state = A+2
        ;        state 5            : DEC ZP_PLAYER_Y; next state = 0
        ;                             (via LDA #$FE + ADC #$02 wrap)
        ;        state 6            : DEC ZP_PLAYER_Y; next state = 1
        ;                             (via LDA #$FF + ADC #$02 wrap)
        ;        other (0,1,4,7)   : no Y change; next state = A+2
        ;                             (except 4 -> 6 and 7 -> 9 which
        ;                             leaves the main cycle; 0->2, 1->3)
        ;   3. Advance ZP_WALK_FRAME: if $0A wrap to 1, if $09 wrap to
        ;      0, else += 2.  (The $FF/$FE LDX pre-loads encode the
        ;      wrap target in the same two INX's used for the normal
        ;      +2 step.)
        ;   4. Fall through into PLAYER_TICK_IDLE.
        ;
        ; Modifies: ZP_PLAYER_Y, ZP_SPRITE_XREF, ZP_WALK_FRAME.
        ; Clobbers: A, X.

        LDA ZP_PLAYER_Y
        CMP #$01
        BCC PLAYER_TICK_IDLE            ; Y < $01 -> skip animation

; --- Sub-frame pacing: decide whether ZP_PLAYER_Y decrements this frame ---
        LDA ZP_SPRITE_XREF
        CMP #$03
        BEQ .dec_y                      ; state 3 -> DEC Y
        CMP #$02
        BEQ .dec_y                      ; state 2 -> DEC Y
        CMP #$05
        BNE .not_5
        LDA #$FE                        ; state 5 -> wrap next state to 0
        BMI .dec_y                      ; (A=$FE, BMI always taken)
.not_5:
        CMP #$06
        BNE .advance_xref               ; state 4 or 7 -> advance without DEC Y
        LDA #$FF                        ; state 6 -> wrap next state to 1
.dec_y:
        DEC ZP_PLAYER_Y                 ; one pixel left

; --- Advance ZP_SPRITE_XREF (A holds new-state seed) ---
.advance_xref:
        CLC
        ADC #$02
        STA ZP_SPRITE_XREF              ; next sub-frame state

; --- Advance ZP_WALK_FRAME (10-step cycle via two-INX + pre-load wrap) ---
        LDX ZP_WALK_FRAME
        CPX #$0A
        BNE .not_10_left
        LDX #$FF                        ; frame $0A -> wrap to $01
        BMI .store_frame_left           ; always (X=$FF)
.not_10_left:
        CPX #$09
        BNE .store_frame_left
        LDX #$FE                        ; frame $09 -> wrap to $00
.store_frame_left:
        INX
        INX                             ; +2 (or wrap to $00/$01)
        STX ZP_WALK_FRAME

; --- Fall through into PLAYER_TICK_IDLE ($6184) ---

PLAYER_TICK_IDLE:
        ; Per-frame tick chain invoked by [[PLAYER_MOVE_TICK]] when
        ; [[ZP_MOVE_DIR]] is zero (player idle) and also reached by
        ; [[PLAYER_TICK_MOVE_LEFT]] fall-through.  Runs the seven
        ; per-frame playfield-refresh routines in their canonical
        ; order and returns.
        ;
        ; The walls are painted LEFT then RIGHT here (opposite of
        ; [[PLAYER_TICK_MOVE_RIGHT]] below, which swaps them so the
        ; right wall paints first when the player is walking right ---
        ; a painter's-algorithm choice so the trailing wall overwrites
        ; the leading wall's stripe).
        ;
        ; Clobbers: A, X, Y (via the called routines)

        JSR CLEAR_DRAW_PAGE             ; zero the hidden hi-res page
        JSR TEXT_ROW_DISPATCH           ; top-center HUD strip
        JSR REFRESH_LEFT_WALL           ; left-edge wall sprite
        JSR REFRESH_RIGHT_WALL          ; right-edge wall sprite
        JSR REFRESH_FLOOR_LINES         ; four reserved floor rows
        JSR REFRESH_PILLARS             ; six landmark pillars (no-op in shipped levels)
        JSR REFRESH_HIT_ENTITIES        ; active hit-entity slots
        RTS

PLAYER_TICK_MOVE_RIGHT:
        ; Per-frame tick handler invoked by [[PLAYER_MOVE_TICK]] when
        ; [[ZP_MOVE_DIR]] is positive nonzero (player walking right).
        ; Mirror of [[PLAYER_TICK_MOVE_LEFT]]: INC ZP_PLAYER_Y on four
        ; of seven sub-frames, advance ZP_WALK_FRAME in the opposite
        ; direction, then run an inline tick chain that swaps the two
        ; wall refreshes before rejoining [[PLAYER_TICK_IDLE]]'s tail
        ; at REFRESH_FLOOR_LINES.
        ;
        ; Inputs:
        ;   ZP_PLAYER_Y       --- player world-Y (high clamp: $D6).
        ;   ZP_WALK_FRAME     --- walking-frame counter (same cycle,
        ;                          stepped by -2).
        ;   ZP_SPRITE_XREF    --- sub-frame pacing counter (7-step
        ;                          cycle; Y increments on states
        ;                          {4,5,0,1}).
        ;
        ; Modifies: ZP_PLAYER_Y, ZP_SPRITE_XREF, ZP_WALK_FRAME.
        ; Clobbers: A, X.

        LDA ZP_PLAYER_Y
        CMP #$D7
        BCC .inc_dispatch               ; Y <  $D7 -> normal animation
        BCS .move_right_tick            ; Y >= $D7 -> skip to tick tail

; --- Sub-frame pacing: decide whether ZP_PLAYER_Y increments ---
.inc_dispatch:
        LDA ZP_SPRITE_XREF
        CMP #$04
        BEQ .inc_y                      ; state 4 -> INC Y
        CMP #$05
        BEQ .inc_y                      ; state 5 -> INC Y
        CMP #$01
        BNE .not_1
        LDA #$08                        ; state 1 -> wrap next state to 6
        BPL .inc_y                      ; (A=$08, BPL always taken)
.not_1:
        CMP #$00
        BNE .retreat_xref               ; state 2/3/6/7 -> retreat only
        LDA #$07                        ; state 0 -> wrap next state to 5
.inc_y:
        INC ZP_PLAYER_Y                 ; one pixel right

; --- Retreat ZP_SPRITE_XREF (A holds new-state seed) ---
.retreat_xref:
        SEC
        SBC #$02
        STA ZP_SPRITE_XREF              ; next sub-frame state

; --- Retreat ZP_WALK_FRAME (-2 with wrap via two-DEX + pre-load) ---
        LDX ZP_WALK_FRAME
        CPX #$00
        BNE .not_0_right
        LDX #$0B                        ; frame $00 -> wrap to $09
        BPL .store_frame_right          ; always (X=$0B)
.not_0_right:
        CPX #$01
        BNE .store_frame_right
        LDX #$0C                        ; frame $01 -> wrap to $0A
.store_frame_right:
        DEX
        DEX                             ; -2 (or wrap to $09/$0A)
        STX ZP_WALK_FRAME

; --- Inline tick chain (swaps wall order, then rejoins IDLE's tail) ---
.move_right_tick:
        JSR CLEAR_DRAW_PAGE             ; zero the hidden hi-res page
        JSR TEXT_ROW_DISPATCH           ; top-center HUD strip
        JSR REFRESH_RIGHT_WALL          ; right wall paints FIRST (mirror of IDLE)
        JSR REFRESH_LEFT_WALL           ; left wall paints SECOND
        JMP PLAYER_IDLE_TICK_TAIL       ; rejoin IDLE's REFRESH_FLOOR_LINES onward

@ %def PLAYER_TICK_MOVE_LEFT PLAYER_TICK_IDLE PLAYER_TICK_MOVE_RIGHT

<<clear draw page>>=

        ORG $61E4
        ; PLAYER_IDLE_TICK_TAIL is the REFRESH_FLOOR_LINES call inside
        ; PLAYER_TICK_IDLE ($6190).  Named here because
        ; PLAYER_TICK_MOVE_RIGHT's JMP at $61E1 targets it.
PLAYER_IDLE_TICK_TAIL = $6190

CLEAR_DRAW_PAGE:
        SUBROUTINE
        ; Page-flag-gated wrapper around [[CLEAR_PAGE1]]/[[CLEAR_PAGE2]]:
        ; zeroes whichever hi-res page is currently the \emph{drawing}
        ; page (i.e. the hidden one), leaving the displayed page alone.
        ; Called once per frame from each [[PLAYER_TICK_*]] handler as
        ; the first step of the playfield-refresh chain.
        ;
        ; Inputs:
        ;   ZP_PAGE_FLAG --- bit 7 selects page (0 = page 1, 1 = page 2).
        ;
        ; Clobbers: A, X, Y (via CLEAR_PAGE1/CLEAR_PAGE2).

        BIT ZP_PAGE_FLAG
        BMI .page2
        JSR CLEAR_PAGE1
        RTS
.page2:
        JSR CLEAR_PAGE2
        RTS
@ %def CLEAR_DRAW_PAGE PLAYER_IDLE_TICK_TAIL

\section{Right-edge wall refresh}

[[REFRESH_RIGHT_WALL]] is the first of three
\emph{playfield-refresh} routines carved out of the game-engine-A
blob: each per-frame tick call restores the text-area stripe beneath
the wall and re-paints a perspective-band sprite on top, so moving
sprites (player, enemies, projectiles) leave no trails.  The paired
[[INTERLACE_RESTORE_P1]]/[[INTERLACE_BLIT_P1]] (respectively the
page-2 twins) are called back-to-back, gated on [[ZP_PAGE_FLAG]].

\paragraph{World-position gate.}  The routine is a no-op unless the
player is near the \emph{right} edge of the world.  With
[[ZP_PLAYER_Y]] as the 8-bit player world-Y (valid range
[[$00]]--[[$EF]]), the on-screen column of the right wall is
$\Delta=\mathtt{\$EF}-[\mathtt{\$4A}]$.  If $\Delta<0$ (player-Y
past [[$EF]]) or $\Delta\ge\mathtt{\$2C}$ (player-Y [[<=\$C3]]) the
routine RTSes without painting.  Otherwise $\Delta$ is the on-screen
column where the wall should appear.

\paragraph{Four column-range cases.}  Having computed $\Delta$, the
routine picks one of four cases based on exact value, and updates
both [[HUD_LIVES_COL]] --- the shared right-bound
variable read by [[BEAM_UPDATE]] --- and the restore/blit column
bounds:

\begin{itemize}
\item $\Delta=\mathtt{\$2B}$ (wall just entering from the right):
      [[HUD_LIVES_COL]] $\gets\mathtt{\$2C}$ ([[$2B]]+[[$01]]),
      [[ZP_CLEAR_COL]] $\gets\mathtt{\$27}$ ([[$2B]]-[[$04]]),
      [[ZP_BLIT_X_END]] $\gets\mathtt{\$27}$,
      [[ZP_SCORE_0]]/[[ZP_SCORE_1]] both $\gets\mathtt{\$27}$
      (narrow restore strip at col~39).
\item $\Delta=\mathtt{\$2A}$ (wall almost on-screen):
      [[HUD_LIVES_COL]] $\gets\mathtt{\$28}$ ($\Delta-\mathtt{\$02}$),
      [[ZP_CLEAR_COL]] $\gets\mathtt{\$27}$,
      [[ZP_SCORE_1]]/[[ZP_BLIT_X_END]] per the ``= [[$27]]'' branch
      at [[$622C]]--[[$6238]].
\item All other valid $\Delta$ (not [[$2B]], not [[$2A]]):
      [[HUD_LIVES_COL]] $\gets\Delta-\mathtt{\$01}$,
      [[ZP_CLEAR_COL]] $\gets\Delta-\mathtt{\$02}$, then
      [[ZP_SCORE_1]] $\gets\Delta-\mathtt{\$01}$ and
      [[ZP_BLIT_X_END]] $\gets\Delta-\mathtt{\$03}$ (``paint one
      column, restore a one-column strip'').
\item The [[ZP_SCORE_0]]/[[ZP_SCORE_1]] terminator pair starts at
      [[$27]]/[[$27]] (both equal --- restore no-op), and the
      branches above adjust [[ZP_SCORE_1]] to widen the strip when
      the wall straddles multiple columns.
\end{itemize}

\paragraph{Shared tail.}  All four cases fall through to [[$624C]],
the shared three-instruction tail that loads the wall sprite pointer
from the level-data tables at [[WALL_SPR_LO]] (lo) and [[WALL_SPR_HI]] (hi)
indexed by [[ZP_SPRITE_XREF]] (the walking-animation / X-reference
slot), then page-gates the paired restore+blit on [[ZP_PAGE_FLAG]].

<<playfield refresh defines>>=

; --- Sprite-pointer tables for the three playfield-refresh routines ---
; All three tables live in the level-data region $7500-$76FF.  Each
; table is indexed by ZP ZP_SPRITE_XREF (the walking-animation / X-reference slot,
; initialized to ZP_ACTION_DIR by INIT_LEVEL_STATE and cycled through ZP_ACTION_DIR..$07
; by PLAYER_TICK_MOVE_LEFT/RIGHT).  The lo-byte table is at page $75
; and the hi-byte table is at page $76 at the same offset.

@

<<refresh right wall>>=

        ORG $61F0
REFRESH_RIGHT_WALL:
        SUBROUTINE
        ; Per-frame refresh of the right-edge playfield wall.  Called
        ; once per tick by PLAYER_TICK_IDLE / PLAYER_TICK_MOVE_RIGHT
        ; from game-engine-A.  Paints a wall sprite at screen column
        ; ($EF - ZP_PLAYER_Y) when that falls in [$00..$2B]; no-op
        ; otherwise.  Updates HUD_LIVES_COL (the playfield right bound
        ; read by BEAM_UPDATE) and the INTERLACE_RESTORE/INTERLACE_BLIT
        ; column-bounds scratch in ZP.
        ;
        ; Inputs:
        ;   ZP_PLAYER_Y --- player world-Y ($00..$EF).
        ;   ZP_PAGE_FLAG --- drawing-page selector (BMI = page 2).
        ;   $4C                   --- sprite-pointer index into the
        ;                             $7520/$7620 wall-animation tables.
        ;   WALL_SPR_LO/HI --- per-frame sprite pointers.
        ;
        ; Behavior:
        ;   Compute delta = $EF - ZP_PLAYER_Y.  If delta overflowed
        ;   or delta >= $2C, RTS.  Otherwise store delta as the blit
        ;   rightmost paint column (ZP_BLIT_X_START), seed
        ;   ZP_SCORE_0/ZP_SCORE_1 both to DEST_PAGE (restore no-op), then:
        ;     delta == $2B      ->  .edge_2B (narrow-strip case)
        ;     delta == $2A      ->  fall-through (edge case, narrow edge)
        ;     else               ->  .general
        ;   Each case writes HUD_LIVES_COL, ZP_CLEAR_COL, ZP_BLIT_X_END,
        ;   and (sometimes) ZP_SCORE_1, then falls through to
        ;   .shared_tail.
        ;
        ;   .shared_tail: LDY ZP_SPRITE_XREF; load sprite pointer
        ;   from WALL_SPR_LO/WALL_SPR_HI into ZP_BLIT_SRC; BIT ZP_PAGE_FLAG; if
        ;   positive, JSR INTERLACE_RESTORE_P1 + JSR INTERLACE_BLIT_P1;
        ;   if negative, JSR INTERLACE_RESTORE_P2 + JSR INTERLACE_BLIT_P2.
        ;
        ; Modifies:
        ;   ZP_BLIT_X_START, ZP_BLIT_X_END,
        ;   ZP_BLIT_SRC ($FE/$FF),
        ;   ZP_SCORE_0, ZP_SCORE_1, ZP_CLEAR_COL,
        ;   HUD_LIVES_COL,
        ;   hi-res page 1/2 framebuffer (via the paired RESTORE+BLIT).
        ; Clobbers: A, X, Y

; --- World-position gate: compute delta = $EF - ZP_PLAYER_Y ---
        LDA #$EF
        SEC
        SBC ZP_PLAYER_Y                 ; A = $EF - player-Y
        BCC .exit                       ; underflow -> off-screen
        CMP #$2C
        BCS .exit                       ; delta >= $2C -> off-screen
        STA ZP_BLIT_X_START             ; delta = rightmost paint col
        LDY #$27                        ; seed restore range at col 39
        STY ZP_SCORE_0                  ; (inclusive col start)
        STY ZP_SCORE_1                  ; (== start -> restore no-op)

; --- Dispatch: exact-match edge cases vs general case ---
        CMP #$2B                        ; wall just entering?
        BEQ .edge_2B
        CMP #$2A                        ; one column in from edge?
        BNE .general

; --- Case delta == $2A: narrow edge, offset by 2/1 ---
        SEC
        SBC #$02
        STA HUD_LIVES_COL               ; right-bound = delta-2
        SEC
        SBC #$01                        ; A = delta-3
        JMP .store_clear_col            ; > $6220

; --- Case general: HUD_LIVES_COL = delta-1 ---
.general:
        SEC
        SBC #$01
        STA HUD_LIVES_COL               ; right-bound = delta-1
        SEC
        SBC #$02                        ; A = delta-3

; --- Store ZP_CLEAR_COL, then branch on (delta-3) == $27 ---
.store_clear_col:
        STA ZP_CLEAR_COL
        CMP #$27                        ; at col 39?
        BEQ .one_col_strip
        CLC
        ADC #$01                        ; A = delta-2
        STA ZP_SCORE_1                  ; widen restore strip
        SEC
        SBC #$02
        STA ZP_BLIT_X_END               ; left terminator = delta-4
        JMP .shared_tail

.one_col_strip:
        SEC
        SBC #$01                        ; A = delta-4
        STA ZP_BLIT_X_END
        JMP .shared_tail

; --- Case delta == $2B: narrowest strip at the far right ---
.edge_2B:
        SEC
        SBC #$04                        ; A = $27
        STA ZP_BLIT_X_END
        STA ZP_CLEAR_COL
        CLC
        ADC #$01                        ; A = $28
        STA HUD_LIVES_COL               ; right-bound = $28 (off-screen by 1)
        JMP .shared_tail

.exit:
        RTS

; --- Shared tail: load sprite pointer, page-gate, call RESTORE+BLIT ---
.shared_tail:
        LDY ZP_SPRITE_XREF              ; sprite-animation index
        LDA WALL_SPR_HI,Y               ; WALL_SPR_HI[Y] -> ZP_BLIT_SRC+1
        STA ZP_BLIT_SRC+1
        LDA WALL_SPR_LO,Y               ; WALL_SPR_LO[Y] -> ZP_BLIT_SRC
        STA ZP_BLIT_SRC
        BIT ZP_PAGE_FLAG
        BMI .page2                      ; page 2 path
        JSR INTERLACE_RESTORE_P1
        JSR INTERLACE_BLIT_P1
        RTS
.page2:
        JSR INTERLACE_RESTORE_P2
        JSR INTERLACE_BLIT_P2
        RTS
@ %def REFRESH_RIGHT_WALL

\section{Left-edge wall refresh}

[[REFRESH_LEFT_WALL]] is the mirror of
[[REFRESH_RIGHT_WALL]] for the \emph{left} edge of the world.  The
world-position gate fires when $\Delta=\mathtt{\$11}-[\mathtt{\$4A}]$
is non-negative (i.e.\ [[ZP_PLAYER_Y]] $\le\mathtt{\$11}$).  The
routine updates [[HUD_SCORE_COL]] --- the playfield
\emph{left} bound --- and the matching [[INTERLACE_RESTORE]]/
[[INTERLACE_BLIT]] column bounds.

The column range computation is a three-case dispatch with the
symmetrically opposite polarity from the right-edge routine:
[[ZP_SCORE_0]] is seeded to [[$00]] and [[ZP_SCORE_1]] to [[$FF]]
(so the restore strip has a high terminator beyond the playable
area), and [[ZP_SCORE_2]] / [[HUD_SCORE_COL]] get the computed left
bound.

\paragraph{Shared tail.}  At [[$62AC]] the routine loads the wall
sprite pointer from the level-data tables at [[WALL_L_SPR_LO]] (lo) /
[[WALL_L_SPR_HI]] (hi) indexed by [[ZP_SPRITE_XREF]], then page-gates
the paired [[INTERLACE_RESTORE]] + [[INTERLACE_BLIT]] call on
[[ZP_PAGE_FLAG]].
The [[WALL_L_SPR_LO]]/[[WALL_L_SPR_HI]] table is immediately before the [[WALL_SPR_LO]]/
[[WALL_SPR_HI]] table used by the right-wall path; the [[$07]]-byte offset
between them suggests two adjacent animation-frame banks in the same
level-data region.

<<refresh left wall>>=

        ORG $626A
REFRESH_LEFT_WALL:
        SUBROUTINE
        ; Per-frame refresh of the left-edge playfield wall.  Mirror
        ; of REFRESH_RIGHT_WALL: paints a wall sprite at screen column
        ; ($11 - ZP_PLAYER_Y) when player-Y is near the left edge
        ; (ZP_PLAYER_Y <= $11); no-op otherwise.  Updates HUD_SCORE_COL
        ; (the playfield left bound read by BEAM_UPDATE).
        ;
        ; Inputs:
        ;   ZP_PLAYER_Y --- player world-Y ($00..$EF).
        ;   ZP_PAGE_FLAG --- drawing-page selector (BMI = page 2).
        ;   ZP_SPRITE_XREF        --- sprite-pointer index into the
        ;                             WALL_L_SPR_LO/HI wall-animation tables.
        ;   WALL_L_SPR_LO/HI      --- per-frame sprite pointers.
        ;
        ; Behavior:
        ;   Compute delta = $11 - ZP_PLAYER_Y.  If delta < 0, RTS.
        ;   Otherwise store delta as ZP_BLIT_X_START, seed
        ;   ZP_SCORE_0 <- #$00 and ZP_SCORE_1 <- #$FF (restore terminator
        ;   past playable area), then dispatch on delta:
        ;     delta == $00           ->  .delta_zero (1-col wide)
        ;     delta == $01 (via BEQ) ->  .delta_one
        ;     else                    ->  general fall-through
        ;   Each case writes HUD_SCORE_COL, ZP_SCORE_2, ZP_BLIT_X_END,
        ;   and (sometimes) ZP_SCORE_0, then falls through to
        ;   .shared_tail.
        ;
        ;   .shared_tail: same shape as REFRESH_RIGHT_WALL, but the
        ;   sprite pointer is loaded from WALL_L_SPR_LO/WALL_L_SPR_HI
        ;   (indexed by ZP_SPRITE_XREF), and the paired RESTORE/BLIT
        ;   is selected on ZP_PAGE_FLAG.
        ;
        ; Modifies:
        ;   ZP_BLIT_X_START, ZP_BLIT_X_END,
        ;   ZP_BLIT_SRC ($FE/$FF),
        ;   ZP_SCORE_0, ZP_SCORE_1, ZP_SCORE_2,
        ;   HUD_SCORE_COL,
        ;   hi-res page 1/2 framebuffer (via the paired RESTORE+BLIT).
        ; Clobbers: A, X, Y

; --- World-position gate: compute delta = $11 - ZP_PLAYER_Y ---
        LDA #$11
        SEC
        SBC ZP_PLAYER_Y                 ; A = $11 - player-Y
        BCC .exit                       ; underflow -> off-screen
        STA ZP_BLIT_X_START             ; delta = rightmost paint col
        LDY #$00
        STY ZP_SCORE_0                  ; (inclusive col start = 0)
        LDY #$FF
        STY ZP_SCORE_1                  ; (high terminator = $FF)

; --- Dispatch on delta exact match ---
        CMP #$00                        ; at the extreme left?
        BEQ .delta_zero

; --- Case delta != 0: general ---
        SEC
        SBC #$01
        STA ZP_SCORE_2
        STA HUD_SCORE_COL               ; left-bound = delta-1
        BEQ .delta_one                  ; was delta==1?
        SEC
        SBC #$01                        ; A = delta-2
        STA ZP_SCORE_0                  ; widen restore strip from ZP_PAGE_FLAG
        SEC
        SBC #$02                        ; A = delta-4
        STA ZP_BLIT_X_END
        JMP .shared_tail

.delta_one:
        SEC
        SBC #$03                        ; A = delta-4 = -3 (wraps)
        STA ZP_BLIT_X_END
        JMP .shared_tail

; --- Case delta == 0: wall at col 0 ---
.delta_zero:
        STA ZP_SCORE_2                  ; (A was 0)
        STA HUD_SCORE_COL               ; left-bound = $00
        SEC
        SBC #$04                        ; A = $FC (-4)
        STA ZP_BLIT_X_END
        JMP .shared_tail

.exit:
        RTS

; --- Shared tail: load sprite pointer, page-gate, call RESTORE+BLIT ---
.shared_tail:
        LDY ZP_SPRITE_XREF              ; sprite-animation index
        LDA WALL_L_SPR_HI,Y             ; WALL_L_SPR_HI[Y] -> ZP_BLIT_SRC+1
        STA ZP_BLIT_SRC+1
        LDA WALL_L_SPR_LO,Y             ; WALL_L_SPR_LO[Y] -> ZP_BLIT_SRC
        STA ZP_BLIT_SRC
        BIT ZP_PAGE_FLAG
        BMI .page2                      ; page 2 path
        JSR INTERLACE_RESTORE_P1
        JSR INTERLACE_BLIT_P1
        RTS
.page2:
        JSR INTERLACE_RESTORE_P2
        JSR INTERLACE_BLIT_P2
        RTS
@ %def REFRESH_LEFT_WALL

\section{Floor-line refresh}

[[REFRESH_FLOOR_LINES]] is a fourth playfield-refresh
callee, sandwiched in [[PLAYER_TICK_IDLE]] between
[[REFRESH_RIGHT_WALL]] and [[REFRESH_PILLARS]].  Unlike its three
neighbours it does \emph{not} call [[INTERLACE_BLIT]] /
[[INTERLACE_RESTORE]] --- instead it paints 40~bytes onto four
fixed hi-res rows (rows [[67]], [[107]], [[147]], [[187]]) using
[[FLOOR_LINES_P1]] / [[FLOOR_LINES_P2]] as the page-selected row
painter.  The source is a 12-frame animation table at
[[FLOOR_SPR_LO]]/[[FLOOR_SPR_HI]] indexed by
[[ZP_WALK_FRAME]] --- the same walking-animation counter that
cycles [[ZP_SPRITE_XREF]] for the wall/pillar sprites.

\paragraph{What the four rows are.}  The four destination rows sit
one row above each of [[INTERLACE_BLIT_P1]]'s three perspective bands
(band~0: rows 72--79, band~1: rows 112--119, band~2: rows 152--159)
plus a fourth row near the bottom of the screen.  Rows 67, 107, 147,
and 187 are the only bytes in all of [[drol.bin]] that are written
by [[FLOOR_LINES_P1]]/[[FLOOR_LINES_P2]] --- no other code touches
any of the four hi-res row bases at [[$2C28]]/[[$2EA8]]/[[$2D50]]/%
[[$2FD0]] or their page-2 twins.  They are effectively ``reserved''
rows maintained every frame by this routine.

\paragraph{Why the sprite table is all zero.}  The 12 pointers at
[[FLOOR_SPR_LO]]/[[FLOOR_SPR_HI]] resolve to a 12$\times$40 source
table occupying [[$7BEC]]--[[$7DCB]] (stride [[$28]] bytes per
frame), with all 480~bytes set to [[$00]] in all four shipped Drol
levels.  The net effect is that this routine \emph{clears} those
four rows every frame --- it behaves as a per-frame spot-clean of
reserved floor-reference lines, overwriting whatever sprite or
tracer ink may have bled onto them in the previous frame.  The
animation-indexed table is a generic level-data hook that happens to
be unused by the shipped levels; it would paint a 40-byte
repeating pattern cycling through 12 frames if level overlays
populated it.

\paragraph{Page gate.}  The [[BIT ZP_PAGE_FLAG]] / [[BMI]] pair
selects [[FLOOR_LINES_P2]] when [[ZP_PAGE_FLAG]] is negative (the
even-frame page~2 path) and [[FLOOR_LINES_P1]] otherwise --- same
gating convention used by every other playfield-refresh callee.

<<refresh floor lines>>=

        ORG $62CA
REFRESH_FLOOR_LINES:
        SUBROUTINE
        ; Per-frame repaint of four reserved hi-res floor rows
        ; (67, 107, 147, 187) from a 12-frame animation table
        ; indexed by ZP_WALK_FRAME.  Paints on hi-res page 1 or
        ; page 2 depending on ZP_PAGE_FLAG.
        ;
        ; Inputs:
        ;   ZP_WALK_FRAME       --- walking-animation frame
        ;                                 (0..11, cycled by
        ;                                 PLAYER_TICK_MOVE_LEFT/RIGHT).
        ;   FLOOR_SPR_LO/HI --- 12-entry 16-bit
        ;                                 pointer table; indexed
        ;                                 entry points to a 40-byte
        ;                                 source row.
        ;   ZP_PAGE_FLAG       --- drawing-page selector
        ;                                 (BMI = page 2).
        ;
        ; Behavior:
        ;   Load the indexed sprite pointer into ZP_BLIT_SRC, then
        ;   tail-call FLOOR_LINES_P1 or FLOOR_LINES_P2 to broadcast
        ;   the 40-byte row to the four destination rows.
        ;
        ; Modifies:
        ;   ZP_BLIT_SRC ($FE/$FF), hi-res page 1 or page 2 at
        ;   rows 67, 107, 147, 187 (columns 0..39).
        ; Clobbers: A, X, Y

        LDY ZP_WALK_FRAME               ; walking-anim frame index
        LDA FLOOR_SPR_HI,Y              ; FLOOR_SPR_HI[Y] -> ZP_BLIT_SRC+1
        STA ZP_BLIT_SRC+1
        LDA FLOOR_SPR_LO,Y              ; FLOOR_SPR_LO[Y] -> ZP_BLIT_SRC
        STA ZP_BLIT_SRC
        BIT ZP_PAGE_FLAG
        BMI .page2
        JSR FLOOR_LINES_P1
        RTS
.page2:
        JSR FLOOR_LINES_P2
        RTS
@ %def REFRESH_FLOOR_LINES

\section{Landmark-pillar refresh}

[[REFRESH_PILLARS]] is the third
[[INTERLACE_BLIT]]-calling playfield-refresh routine.  It iterates
through the 6-slot table [[PILLAR_SLOT_Y]] ([[$60]]--[[$65]]) of fixed
world-Y pillar positions; for each entry it checks whether the pillar's
screen column (delta~=~[[PILLAR_SLOT_Y]]$[X]$~-~[[ZP_PLAYER_Y]]) is
on-screen (in [[$00]]..[[$2A]]) and, if so, paints a 4-column-wide
pillar sprite centred at that column.

Unlike [[REFRESH_LEFT_WALL]] and [[REFRESH_RIGHT_WALL]], this
routine does \emph{not} call [[INTERLACE_RESTORE]] --- each loop
iteration writes sprite pixels without first repainting the text-
strip beneath.  The wall routines need the restore because their
sprite may partially overlap [[BEAM_UPDATE]]'s tracer-drawing area;
the pillars are always well inside the playable column range, so
[[CLEAR_DRAW_PAGE]]'s page-zero pass has already cleaned the
background for them.

\paragraph{Sprite-pointer table.}  The per-frame sprite is loaded
from [[PILLAR_SPR_LO]]/[[PILLAR_SPR_HI]]
indexed by [[ZP_SPRITE_XREF]] (the walking-animation / X-reference
slot, same as the wall routines).  Each loaded sprite is then used for
\emph{all six} slots in a single pass --- the loop reloads
[[ZP_BLIT_SRC]] inside the outer per-slot gate, but the 4-column
width produces the same artwork at each of the 6 screen columns.

\paragraph{Sprite artwork.}  Figure~\ref{fig:playfield-refresh}
renders frames [[$02]]--[[$07]] of all three tables.  The PILLAR
table (row~1) holds a classical Greek-style ornamental column with a
stepped capital, a shaft with fluting, and a base plinth; the
walking-animation frames cycle palette bit, rotating the pillar's
colour through violet/green on odd frames and blue/orange on even
frames (this is exactly the NTSC palette-bit trick Drol uses
everywhere for ``flicker-free'' animated artwork).  The WALL\_L and
WALL\_R tables (rows~2--3) hold T-shaped ``torches'' or light-fixture
sprites for the left and right edges of the world.  Frame [[$07]]
runs past the 4-column stride boundary for PILLAR and WALL\_R (the
table stride changes to [[$28]] bytes per entry starting at
index~[[$08]]), so its decoded bytes partially overlap the next
table and render as garbage --- in practice the walking-animation
state machine at [[PLAYER_TICK_MOVE_LEFT]]/[[PLAYER_TICK_MOVE_RIGHT]]
clamps [[ZP_SPRITE_XREF]] to [[$02]]--[[$07]], which suggests
index~[[$07]] may represent a shorter 1-column sprite variant rather
than a genuine 4-column frame.

\begin{figure}
\centering
\includegraphics[width=0.8\textwidth]{images/playfield_refresh_sprites.png}
\caption{Sprite artwork consumed by the three playfield-refresh
routines: [[PILLAR_SPR_LO]]/[[PILLAR_SPR_HI]] ([[REFRESH_PILLARS]]),
[[WALL_L_SPR_LO]]/[[WALL_L_SPR_HI]] ([[REFRESH_LEFT_WALL]]),
[[WALL_R_SPR_LO]]/[[WALL_R_SPR_HI]] ([[REFRESH_RIGHT_WALL]]).  Each
tile is a 4-column $\times$ 35-row column-major sprite decoded to
band~0 of hi-res page~1.  Columns are the frame index stored in
[[ZP_SPRITE_XREF]] (the walking-animation slot, range [[$02]]--[[$07]]).
See also Figure~\ref{fig:interlace-blit-demo} for how the single-band
artwork is replicated into the 3-band perspective playfield.}
\label{fig:playfield-refresh}
\end{figure}

\paragraph{The six slots in [[PILLAR_SLOT_Y]].}  ZP [[$60]]--[[$65]]
are never written by any code in [[drol.bin]] or [[level1.bin]]; they
are either left-over from post-boot ZP state (the [[ZP_SAVE]] cold
image) or set by one of the level-data overlays during setup.
Functionally they define six world-Y landmark positions where the
pillar sprite should appear; each loop iteration paints at most one
pillar, and invalid slots (where $\Delta < 0$ or $\Delta \ge$
[[$2B]]) are skipped.

<<refresh pillars defines>>=

; --- Landmark-pillar slot table (ZP $60-$65, 6 bytes) ---
; Six world-Y landmark positions where REFRESH_PILLARS paints its
; 4-column pillar sprite.  Read-only from the engine's point of view ---
; the live drol.bin / level1.bin binaries never write these slots.  The
; resident values (inherited from the loader's cold-start ZP image at
; ZP_SAVE) place the landmarks in the playfield frame.  REFRESH_PILLARS
; reads each slot, subtracts ZP_PLAYER_Y to get the screen column, and
; paints the pillar sprite there if the column is in $00..$2A.
PILLAR_SLOT_Y   = $60           ; 6-byte landmark world-Y slots (read-only)
@ %def PILLAR_SLOT_Y

<<refresh pillars>>=

        ORG $62E2
REFRESH_PILLARS:
        SUBROUTINE
        ; Per-frame refresh of 6 fixed-position pillar sprites.  For
        ; each of the 6 world-Y slots at ZP $60..$65, paint a
        ; 4-column-wide pillar sprite at screen column
        ;     delta = [$60,X] - ZP_PLAYER_Y
        ; when delta is in [$00..$2A].  No INTERLACE_RESTORE --- the
        ; per-frame CLEAR_DRAW_PAGE pass has already zeroed the
        ; drawing page.
        ;
        ; Inputs:
        ;   ZP_PLAYER_Y       --- player world-Y.
        ;   ZP_PAGE_FLAG      --- drawing-page selector (BMI = page 2).
        ;   ZP_SPRITE_XREF    --- sprite-pointer index.
        ;   PILLAR_SLOT_Y[0..5] --- 6 world-Y landmark positions.
        ;   PILLAR_SPR_LO/HI    --- sprite-pointer tables.
        ;
        ; Behavior:
        ;   X := 5; loop:
        ;     delta := PILLAR_SLOT_Y[X] - ZP_PLAYER_Y
        ;     if delta < 0 or delta >= $2B, skip paint.
        ;     else store delta as ZP_BLIT_X_START, set
        ;         ZP_BLIT_X_END := delta - 4 (4-column-wide paint),
        ;         save X in ZP_DRAW_LOOP_IDX, load sprite pointer from
        ;         PILLAR_SPR_LO/HI[ZP_SPRITE_XREF] into ZP_BLIT_SRC,
        ;         BIT ZP_PAGE_FLAG, JSR INTERLACE_BLIT_P1 or P2, reload X.
        ;     X := X - 1; if X >= 0, loop.
        ;
        ; Modifies:
        ;   ZP_BLIT_X_START, ZP_BLIT_X_END,
        ;   ZP_BLIT_SRC, ZP_DRAW_LOOP_IDX,
        ;   hi-res page 1/2 framebuffer (via INTERLACE_BLIT_P*).
        ; Clobbers: A, X, Y

        LDX #$05                        ; start at top slot
.slot_loop:
        LDA PILLAR_SLOT_Y,X             ; world-Y of pillar slot X
        SEC
        SBC ZP_PLAYER_Y                 ; A = world-Y - player-Y
        BCC .next                       ; slot behind player -> skip
        CMP #$2B                        ; slot off right edge?
        BCS .next
        STA ZP_BLIT_X_START             ; rightmost paint col
        SEC
        SBC #$04                        ; left terminator = delta-4
        STA ZP_BLIT_X_END
        JMP .paint                      ; > $62FD
.next:
        DEX
        BPL .slot_loop
        RTS

; --- Paint: save X, load sprite ptr, page-gate, JSR BLIT ---
.paint:
        STX ZP_DRAW_LOOP_IDX            ; save loop index
        LDY ZP_SPRITE_XREF              ; sprite-animation index
        LDA PILLAR_SPR_HI,Y             ; PILLAR_SPR_HI[Y] -> ZP_BLIT_SRC+1
        STA ZP_BLIT_SRC+1
        LDA PILLAR_SPR_LO,Y             ; PILLAR_SPR_LO[Y] -> ZP_BLIT_SRC
        STA ZP_BLIT_SRC
        BIT ZP_PAGE_FLAG
        BMI .page2
        JSR INTERLACE_BLIT_P1
.paint_resume:
        LDX ZP_DRAW_LOOP_IDX            ; restore loop index
        JMP .next                       ; > $62F9
.page2:
        JSR INTERLACE_BLIT_P2
        JMP .paint_resume               ; > $6312 (shared tail)
@ %def REFRESH_PILLARS

\section{Hit-entity refresh}

[[REFRESH_HIT_ENTITIES]] is the fifth and last
playfield-refresh routine carved out of the game-engine-A tail.
Where [[REFRESH_PILLARS]] walks a fixed 6-slot world-Y list and
[[REFRESH_LEFT_WALL]]/[[REFRESH_RIGHT_WALL]]/[[REFRESH_FLOOR_LINES]]
paint fixed-position playfield elements, this routine redraws the
currently-active \emph{hit entities} --- the 12-slot array at
[[ENTITY_HIT_STATE]] whose parallel Y (world-Y) and row (screen-row)
attributes live at [[ENTITY_HIT_Y]] and [[ENTITY_HIT_ROW]].  The
routine is called per frame from
[[PLAYER_TICK_IDLE]] and [[PLAYER_TICK_MOVE_LEFT]] in the game-engine-A
tick chain, after the [[CLEAR_DRAW_PAGE]] pass has zeroed the drawing
page.  Unlike the three playfield-refresh siblings which use
[[INTERLACE_BLIT_P1]]/[[INTERLACE_BLIT_P2]] (3-band perspective
replication), this routine paints one band with
[[DRAW_SPRITE_OPAQUE]] --- the same opaque blitter used by the HUD
digit tiles, because the entity draws onto a cleared page with no
transparency requirement.

\paragraph{World-to-screen gate.}  For each active slot~X (X counts
down from [[ZP_HIT_MAX]] to~0), the routine computes
$\Delta = $ [[ENTITY_HIT_Y]],X $-$ [[ZP_PLAYER_Y]].  If $\Delta<0$
(entity behind player) or $\Delta\ge\mathtt{\$2F}$ (entity past the
right edge of the visible playfield) the slot is skipped.  Otherwise
$\Delta$ is the on-screen column where the entity's sprite should be
drawn.

\paragraph{Facing direction.}  [[ENTITY_HIT_STATE]],X is both an
active flag (non-zero = active) and a facing direction (bit~7 =
inverted variant).  Positive state values select the sprite pointer
table pair [[HIT_SPR_POS_LO]]/[[HIT_SPR_POS_HI]] and negative values
select [[HIT_SPR_NEG_LO]]/[[HIT_SPR_NEG_HI]].  Both
pointer pairs live in the swappable level-data region and are indexed
by [[ZP_SPRITE_XREF]] (the 0..7 walking-frame index shared
with the other playfield-refresh routines).  The loaded pointer is
written directly into [[SMC_TILE_SRC_LO]]/[[SMC_TILE_SRC_HI]]
--- the self-modifying source operand inside
[[DRAW_SPRITE_OPAQUE]].

\paragraph{Sprite dimensions.}  All hit-entity sprites are
[[ZP_SPRITE_W]]~=~[[$07]] (eight 7-pixel cells per row, 56~px wide:
the [[DRAW_SPRITE_OPAQUE]] inner loop runs [[W+1]] iterations) and
[[ZP_SPRITE_H]]~=~[[$05]]~rows tall, planted at screen row
[[ENTITY_HIT_ROW]],X.  Each frame therefore occupies exactly
[[$28]] ([[40]]) bytes --- which matches the [[$28]]-byte stride
between consecutive pointers in both [[HIT_SPR_POS_LO]] and
[[HIT_SPR_NEG_LO]].

\paragraph{Sprite artwork.}  Figure~\ref{fig:hit_sprites} shows the
fourteen frames (seven per direction) decoded with the standard hi-res
palette.  The sprites are wide-and-short trail/stripe-style motifs
rather than character bodies: every frame is the same vertical-bar
pattern shifted horizontally and progressively truncated from one
side (the [[$7F]] / [[$55]] / [[$2A]] / [[$3F]] byte values in the
hex dump are the exposed palette-bit variants of the solid-bar
pattern).  Across the 7-frame cycle the bars walk one byte-column
per frame, producing a horizontal streak visible for exactly as long
as the rescue entity is in flight.  The positive table (top row,
plotted in blue/orange because every source byte has bit~7 set) and
the negative table (bottom row, violet/green because bit~7 is clear)
differ only in palette bit --- the binary structure is the same.  The
animation index [[ZP_SPRITE_XREF]] is shared with the walking-frame
counter used by [[REFRESH_PILLARS]] / [[REFRESH_LEFT_WALL]] /
[[REFRESH_RIGHT_WALL]] so the hit-entity streak syncs to the
player's footfall cadence.

\begin{figure}[H]
\centering
\includegraphics[width=0.98\textwidth]{images/hit_sprites_pos.png}
\\[4pt]
\includegraphics[width=0.98\textwidth]{images/hit_sprites_neg.png}
\caption{Hit-entity sprite frames consumed by
[[REFRESH_HIT_ENTITIES]].  Top row: positive-facing
([[HIT_SPR_POS_LO]]/[[HIT_SPR_POS_HI]], [[$8AC0]]--[[$8BD7]] in the
persistent game-code bank, 7 frames).  Bottom row: negative-facing
([[HIT_SPR_NEG_LO]]/[[HIT_SPR_NEG_HI]], [[$7AD4]]--[[$7BEB]]; frame~0
lives at the tail of the swappable level-1 region [[$7500]]--[[$7AFF]]
and frames~1..6 spill into the persistent bank [[$7B00]]--[[$8BFF]]).
Each frame is [[$28]] bytes (8 bytes/row $\times$ 5 rows);
consecutive pointers advance by the same [[$28]] stride.}
\label{fig:hit_sprites}
\end{figure}

<<refresh hit entities defines>>=

; --- Hit-entity sprite-pointer tables (level-data) ---
; Two 8-entry pointer tables indexed by ZP_SPRITE_XREF (the 0..7
; walking-animation slot).  The routine patches the SMC source
; operand of DRAW_SPRITE_OPAQUE with whichever pair matches the
; slot's facing direction (ENTITY_HIT_STATE,X bit 7).

; (ENTITY_HIT_Y ($66) is defined in <<drol input defines>> since
;  INPUT_DO_ASCEND / INPUT_DO_DESCEND at $6000 read it before
;  REFRESH_HIT_ENTITIES here.)


<<refresh hit entities>>=

        ORG $631D
        SUBROUTINE
HIT_DRAW_TAIL:
        ; Internal loop tail: decrement the slot index and re-enter
        ; the per-slot body.  Reached via "JMP HIT_DRAW_TAIL" at the
        ; end of REFRESH_HIT_ENTITIES and via BCC/BCS branches when
        ; a slot is off-screen.  Must appear at $631D so the BPL
        ; target at $631E reaches HIT_DRAW_BODY ($6323) with a
        ; 3-byte forward offset.
        DEX
        BPL HIT_DRAW_BODY
        RTS

REFRESH_HIT_ENTITIES:
        ; Per-frame redraw of all active hit-entity slots
        ; (ENTITY_HIT_STATE 12-slot table).  Called from
        ; PLAYER_TICK_IDLE / PLAYER_TICK_MOVE_LEFT in the game-engine-A
        ; tick chain, after CLEAR_DRAW_PAGE has zeroed the draw page.
        ; Iterates slot index X = ZP_HIT_MAX down to 0, testing each
        ; slot for on-screen visibility and then opaque-blitting the
        ; slot's walking-frame sprite onto the current draw page.
        ;
        ; Inputs:
        ;   ZP_HIT_MAX              --- top slot index ($41).
        ;   ZP_PLAYER_Y             --- player world-Y ($4A).
        ;   ZP_SPRITE_XREF          --- walking-frame animation idx ($4C).
        ;   ENTITY_HIT_Y,X          --- per-slot world-Y ($66,X).
        ;   ENTITY_HIT_ROW,X        --- per-slot screen-row ($72,X).
        ;   ENTITY_HIT_STATE,X      --- active + facing ($8D,X);
        ;                               bit 7 selects sprite table pair.
        ;   HIT_SPR_POS_LO/HI,Y     --- positive-state sprite ptrs.
        ;   HIT_SPR_NEG_LO/HI,Y     --- negative-state sprite ptrs.
        ;
        ; Behavior:
        ;   For each slot (top-down):
        ;     delta := ENTITY_HIT_Y,X - ZP_PLAYER_Y
        ;     skip if delta < 0 or delta >= $2F
        ;     ZP_SPRITE_X := delta; ZP_SPRITE_W := 7; ZP_SPRITE_H := 5
        ;     pick HIT_SPR_POS/NEG pair by ENTITY_HIT_STATE,X sign
        ;     patch SMC_TILE_SRC_LO/SMC_TILE_SRC_HI inside DRAW_SPRITE_OPAQUE
        ;     ZP_SPRITE_Y := ENTITY_HIT_ROW,X
        ;     JSR DRAW_SPRITE_OPAQUE
        ;
        ; Modifies:
        ;   ZP_SPRITE_W, ZP_SPRITE_H, ZP_SPRITE_Y, ZP_SPRITE_X,
        ;   ZP_DRAW_LOOP_IDX (saved X across the blitter call),
        ;   SMC_TILE_SRC_LO / SMC_TILE_SRC_HI operand bytes
        ;   inside DRAW_SPRITE_OPAQUE, hi-res page 1/2 framebuffer.
        ; Clobbers: A, X, Y

        LDX ZP_HIT_MAX                  ; top slot index
HIT_DRAW_BODY:
        LDA ENTITY_HIT_Y,X              ; world-Y for slot X
        SEC
        SBC ZP_PLAYER_Y                 ; delta = world-Y - player-Y
        BCC HIT_DRAW_TAIL               ; delta < 0 -> skip
        CMP #$2F                        ; past right edge?
        BCS HIT_DRAW_TAIL               ; delta >= $2F -> skip
        STA ZP_SPRITE_X                 ; ZP_SPRITE_X <- delta
        SEC
        SBC #$08                        ; delta - 8 (unused remainder in A)
        LDY #$07
        STY ZP_SPRITE_W                 ; ZP_SPRITE_W <- #$07 (7 bytes/row)
        LDY #$05
        STY ZP_SPRITE_H                 ; ZP_SPRITE_H <- #$05 (5 rows)
        STX ZP_DRAW_LOOP_IDX            ; save slot index across JSR
        LDA ENTITY_HIT_STATE,X          ; active flag + facing (bit 7)
        BMI .facing_neg                 ; state negative -> NEG table
        LDY ZP_SPRITE_XREF              ; walking-frame index
        LDA HIT_SPR_POS_HI,Y            ; HIT_SPR_POS_HI[Y] -> SMC_TILE_SRC_HI
        STA SMC_TILE_SRC_HI
        LDA HIT_SPR_POS_LO,Y            ; HIT_SPR_POS_LO[Y] -> SMC_TILE_SRC_LO
        STA SMC_TILE_SRC_LO
        JMP .paint
.facing_neg:
        LDY ZP_SPRITE_XREF              ; walking-frame index
        LDA HIT_SPR_NEG_HI,Y            ; HIT_SPR_NEG_HI[Y] -> SMC_TILE_SRC_HI
        STA SMC_TILE_SRC_HI
        LDA HIT_SPR_NEG_LO,Y            ; HIT_SPR_NEG_LO[Y] -> SMC_TILE_SRC_LO
        STA SMC_TILE_SRC_LO
.paint:
        LDA ENTITY_HIT_ROW,X            ; per-slot screen row
        STA ZP_SPRITE_Y                 ; ZP_SPRITE_Y <- row
        JSR DRAW_SPRITE_OPAQUE
        LDX ZP_DRAW_LOOP_IDX            ; restore slot index
        JMP HIT_DRAW_TAIL               ; next slot
@ %def REFRESH_HIT_ENTITIES HIT_DRAW_TAIL HIT_DRAW_BODY

<<text row dispatch>>=

        ORG $636C
TEXT_ROW_DISPATCH:
        SUBROUTINE
        ; Page-gated wrapper around PAINT_HUD_STRIP_P1 / PAINT_HUD_STRIP_P2:
        ; paints the top-center HUD strip onto whichever hi-res page is
        ; currently the draw page, then RTS.  Called once per frame from
        ; each of the three PLAYER_TICK_* movement handlers, after
        ; CLEAR_DRAW_PAGE and before the playfield-refresh chain.
        ;
        ; Inputs:
        ;   ZP_PAGE_FLAG ($00)  --- bit 7 selects page (0 = page 1,
        ;                           1 = page 2).
        ;
        ; Clobbers: A, X, Y (via the called helper)
        BIT ZP_PAGE_FLAG                ; test bit 7 of $00
        BMI .page2
        JSR PAINT_HUD_STRIP_P1
        RTS
.page2:
        JSR PAINT_HUD_STRIP_P2
        RTS
@ %def TEXT_ROW_DISPATCH

\section{Movement action handlers}

The game-engine-A tail at [[DO_ASCEND]]--[[$64CA]] (339 bytes) contains the four
per-frame movement action handlers that are patched into [[MAIN_LOOP]]'s four
SMC slots ([[SMC_ASCEND]], [[SMC_DESCEND]], [[SMC_MOVE_LEFT]],
[[SMC_MOVE_RIGHT]]) by the input dispatcher.  When a direction key is held
the corresponding SMC byte is [[$20]] ([[JSR]]) so the handler runs every
frame; when the key is not held the byte is [[$2C]] ([[BIT]]) and the handler
is skipped (a 3-byte NOP that reads the target address harmlessly).

The four handlers are:

\begin{itemize}
\item [[DO_ASCEND]]: per-frame ascent step while `A' is held.
\item [[DO_DESCEND]]: per-frame descent step while `Z' is held.
\item [[DO_MOVE_RIGHT]]: per-frame walk-right step while right-arrow
  is held.
\item [[DO_MOVE_LEFT]]: per-frame walk-left step while left-arrow
  is held.
\end{itemize}

The four routines share the common [[ZP_PLAYER_STANCE]] walk-animation cycle
(constants [[$03]]..[[$09]]) and are interleaved in address order: [[DO_ASCEND]]'s
``at-ceiling'' tail precedes [[DO_DESCEND]]'s body, and [[DO_DESCEND]]'s
``step-down / landed-clear'' tail physically sits \emph{between} the two
halves of [[DO_MOVE_RIGHT]].  The shared [[DESC_LANDED_CLEAR]] tail at
[[$643C]] is reached only via [[BEQ]] from inside [[DO_DESCEND]]'s step-down
code; it is physically adjacent to [[DO_MOVE_RIGHT]]'s second half
([[MR_WALK_STEP]]) but not part of it.

\paragraph{[[DO_ASCEND]].}  Reads the ascent-target floor index from
[[ZP_ASC_FLOOR]] ([[$0B]], set earlier by [[INPUT_DO_ASCEND]]) into~X.  If
[[ZP_PLAYER_COL]] already equals [[FLOOR_CEIL]][X] (ceiling reached) it plays
the landing tone via [[SFX_TONE]] and returns.  Otherwise it steps
[[ZP_PLAYER_COL]] up by~4 pixels.  If the step lands exactly on
[[FLOOR_CEIL]][X] (new floor reached, ceiling side), motion clears and it
falls through to play the tone.  If the step lands exactly on
[[FLOOR_THRESH]][X] (new floor reached, floor side), the routine writes~X
to the other three floor-mirror slots
([[ZP_BEAM_SEED_FLOOR]]/[[ZP_FLOOR_MIRROR]]/[[ZP_DSC_FLOOR]]), sets
[[ZP_ENT_RESCUED]] ([[$1D]]) to [[$FF]], and wipes all 12 hit-entity slots
([[ENTITY_HIT_STATE]],X for X down from [[ZP_HIT_MAX]] to~0) to [[$FF]]
(inactive, bit~7 set).  In any other case it just emits a two-click rising
slide via [[SND_DELAY_UP]] and returns.

\paragraph{[[DO_DESCEND]].}  Reads the descent-target floor index from
[[ZP_DSC_FLOOR]] ([[$0C]], set by [[INPUT_DO_DESCEND]]).  If
[[ZP_PLAYER_COL]] equals [[FLOOR_THRESH]][X] (already on the target floor)
it runs the ``landed'' cleanup: writes~X to the three other floor mirrors,
sets [[ZP_DSC_DIR]] ([[$0D]]) to [[$01]], reseeds [[ZP_BEAM_TICK]] from the
difficulty threshold [[ZP_DIFF_THRESH_B]] ([[$35]]), marks all 12
hit-entity slots inactive, clears [[ZP_ACTION_DIR]], patches
[[SMC_DESCEND]] back to [[BIT]] ([[$2C]]) so descend stops firing, and
finally probes the [[SMC_MOVE_LEFT]] / [[SMC_MOVE_RIGHT]] opcode bytes to
refresh [[ZP_LAST_DIR]] ([[$01]]) with the currently-held horizontal key
([[KEY_LEFT]] if left-arrow, [[KEY_RIGHT]] if right-arrow) so the walk
animation resumes correctly.  Otherwise it advances [[ZP_PLAYER_COL]] by~4; if the
step lands exactly on [[FLOOR_THRESH]][X] (reached floor during this tick)
it clears [[ZP_MOVE_DIR]] and returns; otherwise it emits a two-click
falling slide via [[SND_DELAY_DOWN]] and returns.

\paragraph{[[DO_MOVE_RIGHT]].}  Checks the current key ([[ZP_KEY_CODE]]
[[$07]]) against the remembered direction ([[ZP_LAST_DIR]] [[$01]]):
same key $\to$ continue motion, no key $\to$ just advance the stance, new
key $\to$ remember it and clear motion.  The stance update at
[[MR_STANCE_UPDATE]] clamps [[ZP_PLAYER_STANCE]] into the [[$03]]..[[$09]]
walk-cycle range, then returns.  The ``same key'' branch at
[[MR_SAME_KEY]] checks [[ZP_PLAYER_Y]]: at~$\geq$[[$D7]] (right wall) it
clears [[ZP_MOVE_DIR]] and falls through to the stance-only update;
otherwise [[MR_WALK_STEP]] advances the stance and, when [[ZP_ACTION_DIR]]
is zero (no vertical action in progress), sets [[ZP_MOVE_DIR]] to [[$01]]
and advances [[ZP_PLAYER_STANCE]] on alternate frames (gated by
[[ZP_FRAME_COUNTER]] AND [[$01]]) wrapping [[$0C]] back to [[$08]].  When
[[ZP_ACTION_DIR]] is non-zero, [[MR_HIT_SLIDE]] optionally forces
[[ZP_MOVE_DIR]] to [[$01]] if [[ZP_ENT_RESCUED]] is negative
(post-rescue/post-hit slide).

\paragraph{[[DO_MOVE_LEFT]].}  Mirror of [[DO_MOVE_RIGHT]]: the stance
range is [[$03]]..[[$0A]] cycling down, the wrap is [[$00]] $\to$ [[$04]], the
wall check is [[ZP_PLAYER_Y]]$<$[[$01]] (left wall), and [[ZP_MOVE_DIR]] is
set to [[$FF]] instead of [[$01]].

\paragraph{Floor-mirror writes on landing.}  Four zero-page bytes at
[[$09]]/[[$0A]]/[[$0B]]/[[$0C]] all store the current floor index.  They
are \emph{not} aliases of each other --- each is read by a different
subsystem ([[ZP_BEAM_SEED_FLOOR]] by the beam controller, [[ZP_ASC_FLOOR]]
by [[DO_ASCEND]], [[ZP_DSC_FLOOR]] by [[DO_DESCEND]]).  On landing, the
handler that completed the transition writes the new floor index into
\emph{all three other} mirrors (plus its own is already current) so the
whole game state agrees on which floor the player is now standing on.

<<movement handlers defines>>=

; --- Main-loop SMC operand addresses (probed by DO_DESCEND's landed path) ---
SMC_DESCEND_OP     = $67DA      ; Opcode byte of MAIN_LOOP's SMC_DESCEND slot
SMC_MOVE_LEFT_OP   = $67DD      ; Opcode byte of MAIN_LOOP's SMC_MOVE_LEFT slot
SMC_MOVE_RIGHT_OP  = $67E0      ; Opcode byte of MAIN_LOOP's SMC_MOVE_RIGHT slot

; (KEY_LEFT / KEY_RIGHT and the ZP_ASC_FLOOR / ZP_FLOOR_MIRROR /
;  ZP_DSC_FLOOR / ZP_DSC_DIR / ZP_ENT_RESCUED EQUs are defined in
;  <<drol input defines>> since INPUT_DO_ASCEND / INPUT_DO_DESCEND
;  at $6000 seed them before DO_ASCEND / DO_DESCEND here consume them.)

@ %def SMC_DESCEND_OP SMC_MOVE_LEFT_OP SMC_MOVE_RIGHT_OP

<<movement action handlers>>=

        ORG $6378
DO_ASCEND:
        SUBROUTINE
        ; Per-frame ascent step; patched into SMC_ASCEND while `A' is held.
        ;
        ; Inputs:
        ;   ZP_ASC_FLOOR        --- ascent-target floor index (X value).
        ;   ZP_PLAYER_COL       --- current player vertical position.
        ;   FLOOR_CEIL,X        --- per-floor ceiling Y.
        ;   FLOOR_THRESH,X      --- per-floor floor Y.
        ;   ZP_HIT_MAX          --- top hit-entity slot index.
        ;   ZP_DIFF_THRESH_B    --- difficulty reseed for ZP_BEAM_TICK
        ;                           (read from the DO_DESCEND twin, not here).
        ;
        ; Behavior:
        ;   If already at the ceiling row, fall into .at_ceiling.
        ;   Otherwise step ZP_PLAYER_COL up by 4 (one scanline pair).
        ;   If the step lands on FLOOR_CEIL[X], clear ZP_MOVE_DIR and play
        ;   the landing tone.  If it lands on FLOOR_THRESH[X] (the opposite
        ;   floor of the same slot), propagate the floor index to the other
        ;   mirrors, set ZP_ENT_RESCUED, wipe all 12 ENTITY_HIT_STATE slots.
        ;   Otherwise emit a rising two-click slide and return.
        ;
        ; Modifies:
        ;   ZP_PLAYER_COL, ZP_MOVE_DIR (via .zero_mdir), ZP_FLOOR_MIRROR,
        ;   ZP_BEAM_SEED_FLOOR, ZP_DSC_FLOOR, ZP_ENT_RESCUED,
        ;   ENTITY_HIT_STATE[0..ZP_HIT_MAX], ZP_BEAM_TICK.
        ; Clobbers: A, X

        LDX ZP_ASC_FLOOR                ; ascent-target floor index
        LDA ZP_PLAYER_COL
        CMP FLOOR_CEIL,X                ; already at ceiling?
        BEQ .at_ceiling
        SEC
        SBC #$04                        ; step up by 4
        STA ZP_PLAYER_COL
        CMP FLOOR_CEIL,X                ; landed exactly on ceiling?
        BEQ .zero_mdir
        CMP FLOOR_THRESH,X              ; landed exactly on floor?
        BNE .play_click                 ; no: just emit the click
        STX ZP_BEAM_SEED_FLOOR          ; yes: propagate floor index
        STX ZP_FLOOR_MIRROR
        STX ZP_DSC_FLOOR
        LDA #$FF
        STA ZP_ENT_RESCUED              ; mark rescue/hit seen
        LDX ZP_HIT_MAX                  ; top slot index
.clear_hit:
        STA ENTITY_HIT_STATE,X          ; mark slot inactive (bit 7 set)
        DEX
        BPL .clear_hit
.play_click:
        LDA #$04                        ; rising slide: start pitch
        LDX #$08                        ;               step count
        JSR SND_DELAY_UP
        RTS
.zero_mdir:
        LDA #$00
        STA ZP_MOVE_DIR
        ; fall through into .at_ceiling
.at_ceiling:
        LDA #$05                        ; landing tone: pitch value
        LDX #$04                        ;               iteration count
        JSR SFX_TONE
        DEC ZP_BEAM_TICK                ; tick the beam subsystem
        RTS

DO_DESCEND:
        SUBROUTINE
        ; Per-frame descent step; patched into SMC_DESCEND while `Z' is held.
        ;
        ; Inputs:
        ;   ZP_DSC_FLOOR        --- descent-target floor index (X value).
        ;   ZP_PLAYER_COL       --- current player vertical position.
        ;   FLOOR_THRESH,X      --- per-floor floor Y.
        ;   ZP_HIT_MAX          --- top hit-entity slot index.
        ;   ZP_DIFF_THRESH_B    --- difficulty-derived beam-tick reseed.
        ;   SMC_MOVE_LEFT_OP    --- probed to detect held left-arrow.
        ;   SMC_MOVE_RIGHT_OP   --- probed to detect held right-arrow.
        ;
        ; Behavior:
        ;   If already on the target floor (ZP_PLAYER_COL == FLOOR_THRESH[X]):
        ;     - propagate X to ZP_BEAM_SEED_FLOOR / ZP_FLOOR_MIRROR / ZP_ASC_FLOOR
        ;     - set ZP_DSC_DIR = $01 (just-landed marker)
        ;     - reseed ZP_BEAM_TICK from ZP_DIFF_THRESH_B
        ;     - wipe all 12 ENTITY_HIT_STATE slots to $FF, set ZP_ENT_RESCUED
        ;     - clear ZP_ACTION_DIR, patch SMC_DESCEND back to BIT (NOP)
        ;     - probe SMC_MOVE_LEFT_OP / SMC_MOVE_RIGHT_OP and refresh
        ;       ZP_LAST_DIR with KEY_LEFT_ARROW / KEY_RIGHT_ARROW
        ;   Otherwise fall through into .step_down.
        ;
        ; Modifies:
        ;   ZP_PLAYER_COL, ZP_DSC_DIR, ZP_BEAM_TICK, ZP_ENT_RESCUED,
        ;   ENTITY_HIT_STATE[0..ZP_HIT_MAX], ZP_ACTION_DIR, SMC_DESCEND_OP
        ;   (patched to BIT), ZP_LAST_DIR.
        ; Clobbers: A, X

        LDX ZP_DSC_FLOOR                ; descent-target floor index
        LDA ZP_PLAYER_COL
        CMP FLOOR_THRESH,X              ; already on target floor?
        BNE .step_down
        ; --- Landed branch: one-shot cleanup ---
        STX ZP_BEAM_SEED_FLOOR          ; propagate floor index
        STX ZP_FLOOR_MIRROR
        STX ZP_ASC_FLOOR
        LDA #$01
        STA ZP_DSC_DIR                  ; mark "just landed"
        LDA ZP_DIFF_THRESH_B
        STA ZP_BEAM_TICK                ; reseed beam controller
        LDX ZP_HIT_MAX
        LDA #$FF
        STA ZP_ENT_RESCUED              ; mark rescue/hit seen
.clear_hit_d:
        STA ENTITY_HIT_STATE,X          ; mark slot inactive
        DEX
        BPL .clear_hit_d
        LDA #$00
        STA ZP_ACTION_DIR               ; vertical action done
        LDA #OPCODE_BIT
        STA SMC_DESCEND_OP              ; disable SMC_DESCEND (BIT = NOP)
        ; Refresh ZP_LAST_DIR from whichever horizontal key is still active.
        LDA SMC_MOVE_LEFT_OP
        CMP #OPCODE_JSR                 ; left-arrow active?
        BNE .check_right_active
        LDA #KEY_LEFT
        STA ZP_LAST_DIR
        RTS
.check_right_active:
        LDA SMC_MOVE_RIGHT_OP
        CMP #OPCODE_JSR                 ; right-arrow active?
        BNE .done_desc
        LDA #KEY_RIGHT
        STA ZP_LAST_DIR
.done_desc:
        RTS
.step_down:
        CLC
        LDA ZP_PLAYER_COL
        ADC #$04                        ; step down by 4
        STA ZP_PLAYER_COL
        CMP FLOOR_THRESH,X              ; landed on target floor?
        BEQ DESC_LANDED_CLEAR
        LDA #$09                        ; falling slide: start pitch
        LDX #$08                        ;                step count
        JSR SND_DELAY_DOWN
        RTS

DO_MOVE_RIGHT:
        SUBROUTINE
        ; Per-frame walk-right step; patched into SMC_MOVE_RIGHT while
        ; right-arrow is held.
        ;
        ; Inputs:
        ;   ZP_KEY_CODE ($07)   --- most recent key code.
        ;   ZP_LAST_DIR ($01)   --- remembered direction-key code.
        ;   ZP_PLAYER_STANCE    --- walk-cycle state ($03..$09).
        ;   ZP_PLAYER_Y         --- player world-Y (wall check).
        ;   ZP_ACTION_DIR       --- $00 = no vertical action.
        ;   ZP_ENT_RESCUED      --- post-rescue/post-hit marker.
        ;   ZP_FRAME_COUNTER    --- frame parity for animation gating.
        ;
        ; Behavior:
        ;   If same key held: MR_SAME_KEY tests the right-wall clamp
        ;   (ZP_PLAYER_Y >= $D7) and either stops motion or falls into
        ;   MR_WALK_STEP.  If no key: clamp and advance stance only.
        ;   If new key: remember it, clear motion, fall into the stance
        ;   update.
        ;
        ; Modifies:
        ;   ZP_LAST_DIR, ZP_MOVE_DIR, ZP_KEY_CODE, ZP_PLAYER_STANCE.
        ; Clobbers: A, X

        LDA ZP_KEY_CODE
        CMP ZP_LAST_DIR                 ; same direction key as before?
        BEQ MR_SAME_KEY
        CMP #$00                        ; no key at all?
        BEQ MR_STANCE_UPDATE
        ; New direction key: remember it and reset horizontal state.
        STA ZP_LAST_DIR
        LDA #$00
        STA ZP_MOVE_DIR
        STA ZP_KEY_CODE
        ; fall through into MR_STANCE_UPDATE

MR_STANCE_UPDATE:
        ; Clamp ZP_PLAYER_STANCE to $03..$09 and step it forward.
        LDX ZP_PLAYER_STANCE
        CPX #$03
        BCC .clamp_low
        CPX #$09
        BCC .inc_stance_clamped
        LDA #$09
        STA ZP_PLAYER_STANCE            ; clamp high
        RTS
.clamp_low:
        LDX #$02                        ; will be INX'd to $03
.inc_stance_clamped:
        INX
        STX ZP_PLAYER_STANCE
        RTS

MR_SAME_KEY:
        ; Right-key still held: walk or hit the wall.
        LDA ZP_PLAYER_Y
        CMP #$D7                        ; right-wall clamp
        BCC MR_WALK_STEP
        LDA #$00
        STA ZP_MOVE_DIR                 ; at wall: stop moving
        BEQ MR_STANCE_UPDATE            ; A == 0 -> always taken

DESC_LANDED_CLEAR:
        ; Shared "landed on floor via step-down" tail: reached only from
        ; DO_DESCEND's .step_down via BEQ.  Clears ZP_MOVE_DIR and returns.
        LDA #$00
        STA ZP_MOVE_DIR
        RTS
        NOP                             ; pad to $6442

MR_WALK_STEP:
        LDX ZP_PLAYER_STANCE
        CPX #$09                        ; stance already at top?
        BCS MR_STANCE_AT_TOP
        INX
        STX ZP_PLAYER_STANCE
        RTS
MR_STANCE_AT_TOP:
        LDA ZP_ACTION_DIR
        BNE MR_HIT_SLIDE                ; vertical action in progress
        LDA #$01
        STA ZP_MOVE_DIR                 ; ZP_MOVE_DIR <- #$01 (right)
        CPX #$0C                        ; stance hit the wrap point?
        BNE .no_wrap_r
        LDX #$08                        ; wrap $0C -> $08
.no_wrap_r:
        LDA ZP_FRAME_COUNTER
        AND #$01                        ; gate: advance only on odd frames
        BNE .done_walk_r
        INX
        STX ZP_PLAYER_STANCE
.done_walk_r:
        RTS
MR_HIT_SLIDE:
        LDA ZP_ENT_RESCUED              ; $FF after rescue / hit?
        BPL .ret_r
        LDA #$01
        STA ZP_MOVE_DIR                 ; force moving right during slide
.ret_r:
        RTS

DO_MOVE_LEFT:
        SUBROUTINE
        ; Per-frame walk-left step; patched into SMC_MOVE_LEFT while
        ; left-arrow is held.  Mirror of DO_MOVE_RIGHT:
        ;   stance range $03..$0A cycling down (wrap $00 -> $04),
        ;   wall check ZP_PLAYER_Y < $01 (left wall),
        ;   ZP_MOVE_DIR set to $FF (left) instead of $01.

        LDA ZP_KEY_CODE
        CMP ZP_LAST_DIR                 ; same direction key?
        BEQ ML_SAME_KEY
        CMP #$00                        ; no key at all?
        BEQ ML_STANCE_UPDATE
        STA ZP_LAST_DIR
        LDA #$00
        STA ZP_MOVE_DIR
        STA ZP_KEY_CODE
        ; fall through into ML_STANCE_UPDATE

ML_STANCE_UPDATE:
        ; Clamp ZP_PLAYER_STANCE into the mirror walk-cycle range.
        LDX ZP_PLAYER_STANCE
        CPX #$0A
        BCS .clamp_high_l
        CPX #$04
        BCS .dec_stance_clamped
        LDA #$03
        STA ZP_PLAYER_STANCE            ; clamp low
        RTS
.clamp_high_l:
        LDX #$0A                        ; will be DEX'd to $09
.dec_stance_clamped:
        DEX
        STX ZP_PLAYER_STANCE
        RTS

ML_SAME_KEY:
        LDA ZP_PLAYER_Y
        CMP #$01                        ; left-wall clamp
        BCC ML_AT_WALL
        LDX ZP_PLAYER_STANCE
        CPX #$04
        BCC ML_WALK_STEP
        DEX
        STX ZP_PLAYER_STANCE
        RTS
ML_WALK_STEP:
        LDA ZP_ACTION_DIR
        BNE ML_HIT_SLIDE
        LDA #$FF
        STA ZP_MOVE_DIR                 ; ZP_MOVE_DIR <- #$FF (left)
        CPX #$00                        ; stance hit the wrap point?
        BNE .no_wrap_l
        LDX #$04                        ; wrap $00 -> $04
.no_wrap_l:
        LDA ZP_FRAME_COUNTER
        AND #$01                        ; gate: advance only on odd frames
        BNE .done_walk_l
        DEX
        STX ZP_PLAYER_STANCE
.done_walk_l:
        RTS
ML_AT_WALL:
        LDA #$00
        STA ZP_MOVE_DIR                 ; at wall: stop moving
        BEQ ML_STANCE_UPDATE            ; A == 0 -> always taken
ML_HIT_SLIDE:
        LDA ZP_ENT_RESCUED              ; $FF after rescue / hit?
        BPL .ret_l
        LDA #$FF
        STA ZP_MOVE_DIR                 ; force moving left during slide
.ret_l:
        RTS
@ %def DO_ASCEND DO_DESCEND DO_MOVE_RIGHT DO_MOVE_LEFT
@ %def DESC_LANDED_CLEAR
@ %def MR_STANCE_UPDATE MR_SAME_KEY MR_WALK_STEP MR_STANCE_AT_TOP MR_HIT_SLIDE
@ %def ML_STANCE_UPDATE ML_SAME_KEY ML_WALK_STEP ML_AT_WALL ML_HIT_SLIDE

\section{Player movement tick dispatcher}

[[PLAYER_MOVE_TICK]] is the first routine called from
[[MAIN_LOOP]] each frame (formerly stubbed as [[COLLISION_DETECT]]
--- the name was a misnomer: the routine is a tri-state dispatcher, not a
collision check).  It reads the player's horizontal movement state from
[[ZP_MOVE_DIR]] and routes to one of three per-frame tick handlers at
[[PLAYER_TICK_MOVE_LEFT]], [[PLAYER_TICK_IDLE]], and
[[PLAYER_TICK_MOVE_RIGHT]]:

\begin{itemize}
\item [[PLAYER_TICK_IDLE]]: seven per-frame subroutine calls
  --- executed on every frame regardless of motion.
\item [[PLAYER_TICK_MOVE_LEFT]]: when [[ZP_MOVE_DIR]] is
  negative, the player is moving left.  If [[ZP_PLAYER_Y]] is
  already at the low clamp ($<$[[$01]]), fall through into
  [[PLAYER_TICK_IDLE]] without animating; otherwise decrement
  [[ZP_PLAYER_Y]] on four of every seven sub-frames (gated by
  [[ZP_SPRITE_XREF]] --- see below) and advance both walking
  counters [[ZP_WALK_FRAME]] (mod~10, stepping by~$+2$) and
  [[ZP_SPRITE_XREF]], then fall through into [[PLAYER_TICK_IDLE]].
\item [[PLAYER_TICK_MOVE_RIGHT]]: when [[ZP_MOVE_DIR]] is
  positive nonzero, the player is moving right.  If [[ZP_PLAYER_Y]]
  is already at the high clamp ($\geq$[[$D7]]), jump directly to
  the per-frame update tail; otherwise increment [[ZP_PLAYER_Y]] on
  four of seven sub-frames and advance [[ZP_WALK_FRAME]] (mod~10,
  stepping by~$-2$) and [[ZP_SPRITE_XREF]] in the reverse direction,
  then run an inline tick chain that paints [[REFRESH_RIGHT_WALL]]
  before [[REFRESH_LEFT_WALL]] (opposite of the idle order) and
  [[JMP]]s to [[PLAYER_IDLE_TICK_TAIL]] to reuse
  [[PLAYER_TICK_IDLE]]'s [[REFRESH_FLOOR_LINES]] onward.
\end{itemize}

\paragraph{Sub-frame pacing via [[ZP_SPRITE_XREF]].}  The same
zero-page byte that elsewhere indexes the walking-sprite tables is
reused here as a 7-step pacing counter that controls how often
[[ZP_PLAYER_Y]] changes.  Seeded to [[$02]] by [[INIT_LEVEL_STATE]],
it cycles through $\{2,4,6,1,3,5,0\}$ on left-walk frames (via the
$(\mathtt{A}+\mathtt{\$02})$ advance and the [[$FE]]/[[$FF]]
wrap-seeds at states $5$/$6$) and $\{0,5,3,1,6,4,2\}$ on right-walk
frames (via the $(\mathtt{A}-\mathtt{\$02})$ retreat and the
[[$07]]/[[$08]] wrap-seeds at states $0$/$1$).  Four of the seven
states trigger a [[ZP_PLAYER_Y]] [[DEC]]/[[INC]]: for left-walk,
states $\{2,3,5,6\}$ move; for right-walk, states $\{4,5,0,1\}$
move.  The remaining three states update the counter without moving,
which paces horizontal motion at $4/7$ of the frame rate.

\paragraph{Who writes [[ZP_MOVE_DIR]].}  [[ZP_MOVE_DIR]] is set to [[$01]] (moving
right) by the [[DO_MOVE_RIGHT]] input handler (two write sites
in the right-walk step), and to [[$FF]] (moving left) by
[[DO_MOVE_LEFT]] (two write sites in the left-walk step).
It is cleared to~0 when direction changes or motion is clamped at
either edge (five sites inside the four movement action handlers),
and also by [[INPUT_DO_ASCEND]] / [[INPUT_DO_DESCEND]] on a
successful entity find, by [[INIT_LEVEL_STATE]], and during
[[LEVEL_INTRO_TICK]] initialization.

\paragraph{Interaction with [[HAZARD_CHECK]].}  The same [[ZP_MOVE_DIR]] byte is
read by [[HAZARD_CHECK]] as a parallax cue: left-moving projectiles
speed up by~2 pixels when [[ZP_MOVE_DIR]] is positive (player moving right), and
right-moving projectiles speed up by~2 when [[ZP_MOVE_DIR]] is negative (player
moving left), producing a pseudo-parallax effect.

<<player move tick>>=

        ORG $64CB
PLAYER_MOVE_TICK:
        SUBROUTINE
        ; Per-frame player-movement dispatcher.  Tri-state on ZP_MOVE_DIR:
        ; routes to the idle, move-left, or move-right tick handler.
        ;
        ; Inputs:
        ;   ZP_MOVE_DIR --- $00 idle, $01 moving right, $FF moving left.
        ;
        ; Behavior:
        ;   $04 == $00  --> JSR PLAYER_TICK_IDLE
        ;   $04 <  0    --> JSR PLAYER_TICK_MOVE_LEFT
        ;   $04 >  0    --> JSR PLAYER_TICK_MOVE_RIGHT
        ;
        ; Clobbers: A (plus whatever the chosen handler clobbers)

        LDA ZP_MOVE_DIR
        BEQ .idle               ; zero: no motion
        LDA ZP_MOVE_DIR
        BMI .move_left          ; negative: moving left
        JSR PLAYER_TICK_MOVE_RIGHT
        RTS
.move_left:
        JSR PLAYER_TICK_MOVE_LEFT
        RTS
.idle:
        JSR PLAYER_TICK_IDLE
        RTS
@ %def PLAYER_MOVE_TICK

\section{Player sprite renderer}

[[DRAW_PLAYER]] is the main-loop routine that draws the player
character onto the hidden hi-res page every frame.  It is the
[[JSR SPRITE_RENDER]] slot in [[MAIN_LOOP]] --- the
[[SMC_RENDER]] self-modifying byte is toggled between
[[JSR]] ([[$20]]) and [[BIT]] ([[$2C]]) to enable/disable the call
during attract mode and level transitions.  Despite being called from
the \emph{main loop} rather than from [[DRAW_ENTITIES]], [[DRAW_PLAYER]]
is the only routine in the game that actually draws the big centre-screen
player sprite, using the sprite-pointer tables
[[PLAYER_SPR_IDLE_LO]]/[[PLAYER_SPR_IDLE_HI]] and
[[PLAYER_SPR_ACTIVE_LO]]/[[PLAYER_SPR_ACTIVE_HI]], which
are distinct from the small-perspective sprite tables at
[[PLAYER_GRID_SPR_A_LO]]/[[PLAYER_GRID_SPR_B_LO]] consumed by
[[DRAW_ENTITIES]] phase~2.

\paragraph{Two draw paths.}  The routine is gated on the action flag
[[ZP_ACTION_DIR]] (set by [[INPUT_DO_ASCEND]] to [[$01]] and
[[INPUT_DO_DESCEND]] to [[$FF]]) and the stance/floor-state byte
[[ZP_PLAYER_STANCE]] (clamped to [[$03]]..[[$09]] by the same input
handlers):

\begin{itemize}
\item \textbf{Idle path ([[ZP_ACTION_DIR]] == 0).}  The player is between floors or
  stationary.  Fetch a sprite pointer from
  [[PLAYER_SPR_IDLE_LO]]/[[PLAYER_SPR_IDLE_HI]] indexed by
  [[ZP_PLAYER_STANCE]], set [[$03]]$\times$[[$13]] (width$\times$height), Y from
  [[ZP_PLAYER_COL]] via [[SMC_SR_YSRC]] operand, X column~[[$14]],
  then [[JSR DRAW_SPRITE]].
\item \textbf{Action path ([[ZP_ACTION_DIR]] != 0).}  The player is mid-ascent or
  mid-descent.  If [[ZP_HIT_FLAG]] indicates gameplay-in-progress (positive),
  then for the two extremal stance values ([[$03]] = top floor, [[$09]] =
  bottom floor) an additional ``teleport flicker'' sprite is drawn
  first: a [[$00]]$\times$[[$06]] (zero-width-plus-one $\times$ six rows)
  pattern is OR-blitted at column~[[$14]] / [[$11]] with its source pointer
  fetched from the routine's own code image at [[$6500]],[[ZP_FRAME_COUNTER]] /
  [[$6600]],[[ZP_FRAME_COUNTER]] AND~[[$7F]] --- a cheap way to get pseudo-random static
  bytes without a dedicated animation table.  The flicker draw uses the
  live SMC slot at [[SMC_SPRITE_MASK_OP]]/[[SMC_SPRITE_MASK_ARG]] ---
  temporarily patching the [[BIT $00]] NOP in [[DRAW_SPRITE]] to
  [[AND #$83]] or [[AND #$B0]] so the random bytes are masked before
  being OR'd into the screen.  After the flicker draw the
  [[SMC_SPRITE_MASK_OP]] byte is restored to [[$24]] (BIT) for the main
  body draw.  Then the main body is drawn from
  [[PLAYER_SPR_ACTIVE_LO]]/[[PLAYER_SPR_ACTIVE_HI]]$\times$[[$14]] (one row taller than idle), falling through the
  idle-path's JSR so the same column~[[$14]] and [[SMC_SR_YSRC]] apply.
\end{itemize}

\paragraph{[[ZP_HIT_FLAG]] skip of the flicker.}  In the action path the flicker
layer is guarded by the intro/hit-state byte [[ZP_HIT_FLAG]]:
if [[ZP_HIT_FLAG]] is zero (intro still running) or negative (player just
hit), the routine jumps straight to the main body draw, suppressing
the flicker during intro and the death-drop.

\paragraph{Self-modifying operands patched here.}
\begin{itemize}
\item [[SMC_DS_SRC_LO]]/[[SMC_DS_SRC_HI]] ([[$65B3]]/[[$65B4]], inside
  [[DRAW_SPRITE]]): source-pointer operand bytes.  Patched by
  [[DRAW_PLAYER]] twice per action-path frame (once for flicker,
  once for main body), and on each idle-path frame.
\item [[SMC_SPRITE_MASK_OP]]/[[SMC_SPRITE_MASK_ARG]]:
  mask-opcode and mask-operand bytes inside [[DRAW_SPRITE]]'s inner
  loop (normally the ``[[BIT $00]]'' 2-byte NOP).  Patched to
  [[AND #$83]] or [[AND #$B0]] for the flicker, then restored to
  [[BIT $00]] ($24 $00) before the main body draw.
\end{itemize}

\paragraph{Self-modifying operands patched from elsewhere.}
\begin{itemize}
\item [[SMC_SR_HEIGHT]]: the immediate operand of the
  ``[[LDA #$13]]'' that seeds [[ZP_SPRITE_H]] on the idle path.
  [[LEVEL_INTRO_TICK]] decrements this every frame of the countdown to
  shrink the sprite, and [[LEVEL_COMPLETE]] resets it to [[$13]].
\item [[SMC_SR_YSRC]]: the ZP operand of the ``[[LDA $06]]''
  that reads [[ZP_PLAYER_COL]] as the sprite Y row.
  [[LEVEL_INTRO_TICK]] patches it to [[$17]] ([[ZP_INTRO_Y]]) during the
  intro animation and restores it to [[$06]] on activation;
  [[LEVEL_COMPLETE]] also resets it to [[$06]] on level transitions.
\end{itemize}

\paragraph{Not to be confused with [[DRAW_ENTITIES]] phase~2.}
Phase~2 of [[DRAW_ENTITIES]] also draws a sprite
at the player's floor position, but via the \emph{perspective-grid}
path: it reads [[FLOOR_SPRITE_IDX]]/[[FLOOR_SCREEN_COL]] indexed by
[[ZP_PLAYER_Y]]+[[$10]] to produce a narrow $1\times4$ sprite at a
column that shifts along the perspective-receding floor.  That is the
player's representation in the \emph{depth} axis (which floor they are
on).  [[DRAW_PLAYER]], by contrast, always draws at column~[[$14]] (screen
centre) with a much larger $3\times[[$13]]$ (idle) or $3\times[[$14]]$
(active) body sprite indexed by the stance byte [[ZP_PLAYER_STANCE]].

\paragraph{Sprite art.}  The seven used stances of the idle-path body
([[PLAYER_SPR_IDLE_LO]]/[[PLAYER_SPR_IDLE_HI]][[[$03]]..[[$09]]]) and the active-path body
([[PLAYER_SPR_ACTIVE_LO]]/[[PLAYER_SPR_ACTIVE_HI]][[[$03]]..[[$09]]]) are shown in
Figure~\ref{fig:player_sprites_idle} and
Figure~\ref{fig:player_sprites_active}.  Both tables point into
[[$8500]]--[[$8ABF]] inside [[drol.bin]] (persistent data), so no level
swapping is required to render them.  Remember that
[[DRAW_SPRITE]]'s [[ZP_SPRITE_W]] is one less than the actual bytes
per row --- here [[W]]~=~[[$03]] means each row occupies four bytes of
sprite data (28 pixel columns), and rows are stored rightmost-byte-
first so the decoder reverses each row before rendering.

