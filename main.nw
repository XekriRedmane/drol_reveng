<<enemy b draw defines>>=

; --- Zero-page used by enemy-B draw (shared with ENEMY_A_DRAW) ---
; $AF / $B0 are 16-bit scratch for the screen-clip subtract.  They
; hold the perspective-corrected low/high bytes of the enemy's
; world X minus the perspective-X reference, and after the subtract
; against ZP_ENEMY_B_POS they hold the screen-relative X.
ZP_CLIP_X_LO    = $AF           ; Screen-clip scratch low byte
ZP_CLIP_X_HI    = $B0           ; Screen-clip scratch high byte

; $4C is a level-fixed X-reference (INIT_LEVEL_STATE writes ZP_ACTION_DIR).
; It is subtracted from PERSPECTIVE_XOFF to produce the world-X
; origin that enemy positions are measured against.
ZP_SPRITE_XREF  = $4C           ; World-X reference (level-fixed = $02)

; --- Perspective-X lookup tables, indexed by ZP_PLAYER_Y ---
; PERSPECTIVE_XOFF_LO at $1A8F and PERSPECTIVE_XOFF_HI at $198F are
; defined as labels in their ORG chunks inside the perspective-grid
; data region.  The low-byte table is (roughly) $(Y>>1)* 7$, so
; deeper floor positions translate to a larger horizontal offset.
; The high byte is all zero for on-screen Y values.

; --- Sprite family offsets into SPRITE_TABLE_LO / SPRITE_TABLE_HI ---
; Enemy-B's steady-mode sprite set starts at base index $25 in the
; two 128-entry parallel tables (lo) / $B080 (hi).
SPRITE_TABLE_B_LO = $B025       ; Enemy-B body sprite pointers, low
SPRITE_TABLE_B_HI = $B0A5       ; Enemy-B body sprite pointers, high

; --- Per-level drift-mode puff sprite pointer pair ---
; Inside the swappable level-data region $7500-$7AFF.  The two bytes
; form the 16-bit address that SMC_DS_SRC_LO/HI are patched to on
; B's drift-mode draw path.

; --- Game-over/hit-remaining flag ---
; Initialized to ZP_LAST_DIR by INIT_LEVEL_STATE and reset to ZP_LAST_DIR by the
; player-reincarnation code at $5EC3.  Each overlap-hit in
; ENEMY_A_DRAW / ENEMY_B_DRAW decrements this counter; once it
; goes negative the main-loop tail branches to GAME_OVER.
ZP_GAME_OVER    = $39           ; Game-over / hits-remaining counter

@

<<enemy b draw>>=

        ORG $1591
ENEMY_B_DRAW:
        SUBROUTINE
        ; Per-frame draw + player-collision for the enemy-B slot.
        ; Dispatches on ZP_ENEMY_B_STATE: $00 exits; positive does the
        ; full steady-mode draw and hit-test; negative takes the
        ; drift-mode tail that draws a smaller puff sprite using a
        ; level-specific sprite-pointer pair.
        ;
        ; Inputs:
        ;   ZP_ENEMY_B_STATE    --- $00 off; +steady; -drift.
        ;   ZP_ENEMY_B_POS      --- 16-bit world X for this enemy.
        ;   ZP_ENEMY_B_ROW      --- Sprite starting screen row.
        ;   ZP_PLAYER_Y   --- Player Y (index into perspective tables).
        ;   ZP_PLAYER_COL --- Player column (collision X reference).
        ;   ZP_SPRITE_XREF --- Level-fixed X reference.
        ;   PERSPECTIVE_XOFF_LO/HI --- Y-to-X transform tables.
        ;   SPRITE_TABLE_B_LO/HI  --- Body-sprite pointer table base.
        ;   ENEMY_B_PUFF_LO/HI    --- Level-specific drift-puff sprite.
        ;
        ; Behavior:
        ;   1. State gate: $00 exits; negative jumps to .drift_draw.
        ;   2. Clip: compute screen-relative X into ZP_CLIP_X_LO/HI;
        ;      exit if high byte non-zero or low byte >= $9C.
        ;   3. Set sprite params ($5D = screen col, $56 = 5, ZP_SPRITE_H <- #$11,
        ;      $5B = ZP_ENEMY_B_ROW), patch DRAW_SPRITE src to
        ;      SPRITE_TABLE_B_{LO,HI}[PROJ_FRAME_IDX], JSR DRAW_SPRITE.
        ;   4. Player-overlap test: ZP_CLIP_X_LO in [$42,$55) AND
        ;      ZP_ENEMY_B_ROW in [player-$0E, player+$0D].
        ;   5. On overlap (.hit): write $FF to ZP_ENEMY_B_STATE (drift),
        ;      rewrite counter to $D0+(ZP_CLIP_X_LO-$03)*$100, bump row
        ;      by 2, reset sound counter, award +$0300 BCD via
        ;      SCORE_ADD, DEC ZP_GAME_OVER, exit.
        ;   6. Drift-mode draw tail: draw $02x$06 puff sprite using
        ;      level-specific pointer pair.
        ;
        ; Modifies:
        ;   ZP_CLIP_X_LO/HI, sprite-param ZPs ($56/$57/$5B/$5D),
        ;   ZP_SCORE_ADD_LO/HI, ZP_GAME_OVER, ZP_ENEMY_B_STATE,
        ;   ZP_ENEMY_B_POS, ZP_ENEMY_B_ROW, ZP_ENEMY_B_SND_CTR,
        ;   SMC_DS_SRC_LO/HI (patched operand bytes of DRAW_SPRITE).
        ; Clobbers: A, X

; --- State dispatch: $00 exit, +steady, -drift ---
        LDA ZP_ENEMY_B_STATE
        BEQ .exit                       ; $00: slot inactive
        BPL .steady                     ; positive: steady-mode draw
        JMP .drift_draw                 ; negative: drift-mode draw tail

; --- Clip: compute screen-relative X from world X ---
.steady:
        LDX ZP_PLAYER_Y
        LDA PERSPECTIVE_XOFF_LO,X       ; Y-indexed X offset (low)
        SEC
        SBC ZP_SPRITE_XREF              ; ... minus fixed X-reference
        STA ZP_CLIP_X_LO
        LDA PERSPECTIVE_XOFF_HI,X       ; (high byte propagation)
        SBC #$00
        STA ZP_CLIP_X_HI
        SEC
        LDA ZP_ENEMY_B_POS              ; Subtract from enemy world X
        SBC ZP_CLIP_X_LO
        STA ZP_CLIP_X_LO                ; ZP_CLIP_X_LO = screen-relative X (lo)
        LDA ZP_ENEMY_B_POS+1
        SBC ZP_CLIP_X_HI
        BEQ .in_bounds                  ; hi diff == 0: on-screen
.exit:
        RTS                             ; hi diff != 0: off-screen, exit
.in_bounds:
        LDA ZP_CLIP_X_LO
        CMP #$9C
        BCS .exit                       ; clipped X >= $9C: off right edge

; --- Main sprite draw (steady mode) ---
        TAX                             ; X := clipped screen-X
        LDA PROJ_SCREEN_COL,X           ; -> screen column index
        STA ZP_SPRITE_X
        LDA PROJ_FRAME_IDX,X            ; -> sprite frame index
        TAX                             ; X := frame index
        LDA #$05
        STA ZP_SPRITE_W                 ; Sprite width = 5 bytes
        LDA #$11
        STA ZP_SPRITE_H                 ; Sprite height = 17 rows
        LDA ZP_ENEMY_B_ROW
        STA ZP_SPRITE_Y                 ; Sprite row = enemy-B row
        LDA SPRITE_TABLE_B_LO,X         ; Patch DRAW_SPRITE source-ptr (lo)
        STA SMC_DS_SRC_LO
        LDA SPRITE_TABLE_B_HI,X         ; Patch DRAW_SPRITE source-ptr (hi)
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE                 ; Blit the enemy-B body sprite

; --- Player-overlap test: narrow X window + Y-band ---
        LDA ZP_CLIP_X_LO
        CMP #$42
        BCC .no_hit                     ; clipped X < $42: no overlap
        CMP #$55
        BCS .no_hit                     ; clipped X >= $55: no overlap
        LDA ZP_PLAYER_COL               ; player col (ZP $06)
        SEC
        SBC #$0E
        CMP ZP_ENEMY_B_ROW
        BCS .no_hit                     ; enemy-row < player-$0E: no overlap
        CLC
        ADC #$1B                        ; (player-$0E) + $1B = player+$0D
        CMP ZP_ENEMY_B_ROW
        BCC .no_hit                     ; enemy-row >= player+$0D: no overlap

; --- Overlap: put B into drift mode + award score + count hit ---
.hit:
        LDA #$FF
        STA ZP_ENEMY_B_STATE            ; drift mode (deferred deactivation)
        LDA ZP_CLIP_X_LO
        SEC
        SBC #$03
        STA ZP_ENEMY_B_POS+1            ; counter hi := clip_X - 3
        LDA #$D0
        STA ZP_ENEMY_B_POS              ; counter lo := $D0
        INC ZP_ENEMY_B_ROW              ; row += 2 (shift puff down)
        INC ZP_ENEMY_B_ROW
        LDA #$05
        STA ZP_ENEMY_B_SND_CTR          ; re-arm sound counter
        LDA #$00
        STA ZP_SCORE_ADD_LO             ; addend lo = $00
        LDA #$03
        STA ZP_SCORE_ADD_HI             ; addend hi = $03 ($0300 BCD = 300)
        JSR SCORE_ADD                   ; ... so score += 300
        DEC ZP_GAME_OVER                ; consume one hit-credit
.no_hit:
        RTS

; --- Drift-mode draw tail: $02x$06 puff from level-data pointer pair ---
.drift_draw:
        LDA #$02
        STA ZP_SPRITE_W                 ; Puff width = 2 bytes
        LDA #$06
        STA ZP_SPRITE_H                 ; Puff height = 6 rows
        LDA ZP_ENEMY_B_ROW
        STA ZP_SPRITE_Y                 ; Row = enemy-B row
        LDX ZP_ENEMY_B_POS+1            ; Use counter hi as X-col index
        LDA PROJ_SCREEN_COL,X
        STA ZP_SPRITE_X
        LDA ENEMY_B_PUFF_LO             ; Patch DRAW_SPRITE src with the
        STA SMC_DS_SRC_LO               ; level-specific puff pointer
        LDA ENEMY_B_PUFF_HI
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE
        RTS
@ %def ENEMY_B_DRAW
@ %def ZP_CLIP_X_LO ZP_CLIP_X_HI ZP_SPRITE_XREF ZP_GAME_OVER
@ %def SPRITE_TABLE_B_LO SPRITE_TABLE_B_HI

\section{Enemy-C advance timer}

[[ENEMY_C_ADVANCE]] is the per-frame tick for the
``ground-companion'' enemy slot in the contiguous entity block
[[ZP_ENTITY_BLOCK]].  It is the third member of the
[[ENEMY_A_ADVANCE]]/[[ENEMY_B_ADVANCE]] family --- structurally
parallel but distinct in three notable ways.  See \S Enemy-A advance
timer for the shared template; this section documents only the
differences.

\paragraph{Slot mapping.}  Where enemy-A uses
[[ZP_ENEMY_A_SND_CTR]], [[ZP_ENEMY_A_STATE]],
[[ZP_ENEMY_A_POS]] (16-bit) and [[ZP_ENEMY_A_ROW]], enemy-C
uses [[ZP_ENEMY_C_SND_CTR]], [[ZP_ENEMY_C_STATE]],
[[ZP_ENEMY_C_POS]] (16-bit) and [[ZP_ENEMY_C_ROW]].  The
sound-pitch table is [[SND_PITCH_TBL_C]] (8 entries) and
the click is emitted with duration~[[$08]] via [[SND_DELAY_DOWN]]
--- \emph{not} via [[SFX_TONE]] like enemy-A and enemy-B.  The
descending-tone delay produces a softer, lower-pitched percussive
chirp distinguishable from enemy-A's sharp click.

\paragraph{Drift mode is a vertical bobble, not a PRNG gate.}  Enemy-A
and enemy-B treat ``drift mode'' (state bit~7 set) as a probability
gate that simply skips the tick most frames.  Enemy-C interprets
drift mode entirely differently:

\begin{enumerate}
\item On the drift path, the routine inspects [[ZP_FRAME_COUNTER]]:
  on the 1-in-4 frames where the low two bits are both set,
  it nudges [[ZP_ENEMY_C_ROW]] up by one row when bit~4 of [[ZP_FRAME_COUNTER]] is
  clear, or down by one row when bit~4 is set.  This makes the
  on-screen sprite bob vertically by one row at a $\sim$1-Hz cadence
  (bit~4 flips every 16 frames).
\item The 16-bit advance counter then ticks normally on the steady
  path (subtracting [[ZP_ADVANCE_RATE]]).
\item There is a separate drift entry inside [[ENEMY_C_ADVANCE]] reached via
  [[JMP]] from the drift dispatch: it \emph{adds} 1 to
  [[ZP_ENEMY_C_POS]] each frame and on overflow falls into the rearm
  reload code (skipping the [[$3C]]-window check).  This is a
  slow upward count rather than the fast downward count used in
  steady mode.
\end{enumerate}

\paragraph{Rearm does not wake another slot.}  Enemy-A's rearm writes
[[$01]] to [[ZP_ENEMY_C_STATE]], waking enemy-C (the cross-slot
A$\rightarrow$C handshake).  Enemy-C's rearm instead writes [[$00]] to
[[ZP_ENEMY_C_STATE]]~--- \emph{deactivating itself}.  Enemy-C's own
\emph{draw} routine [[ENEMY_C_DRAW]]'s hit path is what
broadcasts [[$FF]] to both [[ZP_ENEMY_C_STATE]] and [[ZP_ENEMY_A_STATE]] (when C hits a floor-enemy
slot) --- so C's topology edges all live in its draw, not in
[[ENEMY_B_ADVANCE]] or any other neighbour.  This confirms a
\emph{three-slot} entity model with the topology
A$\rightarrow$C (via A's rearm) and C$\rightarrow$\{A,C\} (via C's
hit path), with B having no outgoing handshake.

\paragraph{Other constants.}  The reload value is [[$0352]] (vs.\ enemy-A's
[[$0361]]), the rearm window is [[$0000]]..[[$003B]] (vs.\ [[$0000]]..[[$003D]]), and
the row reload reads from a three-slot table at [[$85]]/[[$86]]/[[$87]]
(addressed as $\$$84,X with X derived from [[ZP_PRNG_A]]).  The index
is computed as $X = ({\rm PRNG\_A}~\&~3)$ if non-zero, else $X = 1$~---
so X $\in \{1,2,3\}$ with X~=~1 selected~$2/4$ of the time and X~=~2
or 3 each~$1/4$ of the time.  The row is then $[[$84]],X - $[[$0A]].  Slots
[[$83]]--[[$87]] are also used by [[LEVEL_INTRO_TICK]] (per-level intro Y
seed at [[$84]]) and by [[BEAM_TARGET_DRAW]] (per-floor Y threshold
[[FLOOR_THRESH]]): enemy-C reuses three of these scenery-anchor
Y rows as spawn-row choices.

\paragraph{Cross-references.}  [[ZP_ADVANCE_RATE]] is shared with
[[ENEMY_A_ADVANCE]] (and presumably [[ENEMY_B_ADVANCE]]).  The draw
counterpart [[ENEMY_C_DRAW]] reads [[ZP_ENEMY_C_STATE]],
[[ZP_ENEMY_C_POS]] and [[ZP_ENEMY_C_ROW]] directly.  External
producers of [[ZP_ENEMY_C_STATE]] are: [[ENEMY_A_ADVANCE]]
(writes~[[$01]] = steady-mode activation in its rearm tail) and
[[ENEMY_C_DRAW]]'s own hit path (writes~[[$FF]] = drift-mode
self-animation, paired with a [[$FF]] write to [[ZP_ENEMY_A_STATE]] if
that slot was active).

<<enemy c defines>>=

; --- Zero-page (enemy-C advance slot) ---
ZP_ENEMY_C_SND_CTR = $B7        ; 8-step sound-click counter (BMI = idle)
ZP_ENEMY_C_POS     = $D5        ; 16-bit advance counter ($D5/$D6)
; (ZP_ENEMY_C_STATE = $D4 and ZP_ENEMY_C_ROW = $D7 are exported by enemy-A.)
; Sound pitch table for enemy-C, packed inside initial-data-tables ($0200-$02B6).
SND_PITCH_TBL_C    = $0224      ; 8 pitch bytes indexed by ZP_ENEMY_C_SND_CTR
; Three-entry Y-anchor table read as ENEMY_C_ROW_TBL,X with X in {1,2,3}; subtract $0A.
; The base $84 is also used as the per-level intro Y seed (LEVEL_INTRO_TICK)
; and adjacent slots at $83/$85/$86/$87 are FLOOR_THRESH and other per-level
; scenery anchors --- enemy-C reuses three of those rows as spawn anchors.
ENEMY_C_ROW_TBL    = $84        ; Read as $84,X with X in {1,2,3}

<<enemy c advance>>=

        ORG $1646
ENEMY_C_ADVANCE:
        SUBROUTINE
        ; Per-frame tick for the enemy-C ``ground companion'' slot.
        ; Mirrors ENEMY_A_ADVANCE's tick+rearm template with three
        ; key differences (see section Enemy-C advance timer):
        ;   1. Click is SND_DELAY_DOWN (descending), not SFX_TONE.
        ;   2. Drift mode bobs ZP_ENEMY_C_ROW vertically using the
        ;      frame-counter bit-4 phase, not a PRNG skip gate.
        ;   3. Rearm deactivates the slot (writes ZP_PAGE_FLAG to state) and
        ;      reseats the row from the two-entry FLOOR_THRESH/ENEMY_C_ROW_TBL table ---
        ;      it does NOT wake another slot.
        ;
        ; Inputs:
        ;   ZP_ENEMY_C_SND_CTR  --- click-pitch index (BMI = idle).
        ;   ZP_ENEMY_C_STATE    --- $00 off / +steady / -drift.
        ;   ZP_ENEMY_C_POS      --- 16-bit counter.
        ;   ZP_ADVANCE_RATE     --- per-frame decrement ($01/$02/$03).
        ;   ZP_FRAME_COUNTER    --- drives drift-mode row bobble.
        ;   ZP_PRNG_A           --- selects which row anchor on rearm.
        ;   ENEMY_C_ROW_TBL     --- 3-entry row anchor table at $85/$86/$87
        ;                          (addressed as $84,X for X in {1,2,3}).
        ;
        ; Behavior:
        ;   1. Emit a click from SND_PITCH_TBL_C[ZP_ENEMY_C_SND_CTR]
        ;      via SND_DELAY_DOWN with duration $08; skip when idle.
        ;   2. Exit if state is $00.  Steady ($+$): tick now.  Drift
        ;      ($-$): jump to .drift_tick and INC the lo counter only.
        ;   3. Steady tick: 1-in-4 frames (FD&3==3), nudge ROW $+/-$1
        ;      based on FD bit~4; then SBC ZP_ADVANCE_RATE on the
        ;      16-bit counter; rearm only if $D5 < $3C and $D6 == 0.
        ;   4. Rearm: reload counter to $0352, pick X = (PRNG_A&3)
        ;      if non-zero else 1, set ROW <- #$84,X - $0A, write $00
        ;      to state.
        ;
        ; Modifies:
        ;   ZP_ENEMY_C_SND_CTR, ZP_ENEMY_C_STATE, ZP_ENEMY_C_POS,
        ;   ZP_ENEMY_C_ROW
        ; Clobbers: A, X, Y

; --- Emit click from pitch table ---
        LDX ZP_ENEMY_C_SND_CTR
        BMI .after_click                ; Negative = idle
        LDA SND_PITCH_TBL_C,X           ; Pitch byte
        LDX #$08                        ; Duration = 8 clicks
        JSR SND_DELAY_DOWN
        DEC ZP_ENEMY_C_SND_CTR
.after_click:

; --- State gate: $00 idle, $+$ steady, $-$ drift ---
        LDA ZP_ENEMY_C_STATE
        BEQ .exit                       ; $00 = inactive (RTS at $1681)
        BPL .steady                     ; Positive = steady tick
        JMP .drift_tick                 ; Negative = drift tick (counter +1)

; --- Steady path: drift-mode row bobble runs on 1-in-4 frames ---
.steady:
        LDA ZP_FRAME_COUNTER
        AND #$03
        CMP #$03
        BNE .tick                       ; Other 3/4 frames: skip bobble
        LDA ZP_FRAME_COUNTER
        AND #$10                        ; Phase: bit 4 flips every 16 frames
        BNE .row_dec
        INC ZP_ENEMY_C_ROW              ; Phase 0: bobble down
        JMP .tick
.row_dec:
        DEC ZP_ENEMY_C_ROW              ; Phase 1: bobble up

; --- 16-bit decrement; rearm only on the narrow $0000..$003B band ---
.tick:
        LDA ZP_ENEMY_C_POS
        SEC
        SBC ZP_ADVANCE_RATE
        STA ZP_ENEMY_C_POS
        LDA ZP_ENEMY_C_POS+1
        SBC #$00
        STA ZP_ENEMY_C_POS+1
        BEQ .check_lo                   ; hi == 0: maybe rearm
.exit:
        RTS                             ; hi != 0: still ticking, exit
.check_lo:
        LDA ZP_ENEMY_C_POS
        CMP #$3C
        BCS .exit                       ; lo >= $3C: not yet in window

; --- Rearm: reload counter, pick row anchor, deactivate self ---
.rearm:
        LDA #$52
        STA ZP_ENEMY_C_POS              ; Reload lo to ZP_INPUT_1
        LDA #$03
        STA ZP_ENEMY_C_POS+1            ; Reload hi to ZP_PLAYER_STANCE (counter = $0352)
        LDA ZP_PRNG_A
        AND #$03
        BNE .have_idx                   ; PRNG&3 != 0: X := 1, 2, or 3
        LDA #$01                        ; PRNG&3 == 0: force X := 1
.have_idx:
        TAX                             ; X in {1, 2, 3}
        LDA ENEMY_C_ROW_TBL,X           ; $85, $86, or $87: row anchor
        SEC
        SBC #$0A
        STA ZP_ENEMY_C_ROW              ; Row := anchor - $0A
        LDA #$00
        STA ZP_ENEMY_C_STATE            ; Deactivate self (state := $00)
        RTS

; --- Drift path: counter counts UP; on lo-byte overflow fall to .rearm ---
.drift_tick:
        INC ZP_ENEMY_C_POS
        BNE .exit                       ; No overflow: exit
        JMP .rearm                      ; Lo wrapped: jump to rearm reload
@ %def ENEMY_C_ADVANCE
@ %def ZP_ENEMY_C_SND_CTR ZP_ENEMY_C_POS SND_PITCH_TBL_C ENEMY_C_ROW_TBL

\section{Enemy-C draw and enemy-slot collision}

[[ENEMY_C_DRAW]] is the draw+hit routine for the enemy-C
slot --- the third member of the sprite-draw family alongside
[[ENEMY_A_DRAW]] (enemy-A) and [[ENEMY_B_DRAW]] (enemy-B).
Called from [[MAIN_LOOP]] immediately after [[ENEMY_C_ADVANCE]] has
ticked the slot.  (Previously mislabeled [[PLAYER_RENDER]] in
the stub; that name was a misnomer and is retired here --- this
routine does not draw the player at all.)

\paragraph{Shape.}  Same state-gate / perspective-clip / main-draw /
hit-test / drift-draw-tail shape as [[ENEMY_B_DRAW]], with three
substantive differences:
\begin{enumerate}
\item \textbf{Body sprite is smaller.}  [[ENEMY_B_DRAW]] draws a
  $[[$05]]\times[[$11]]$ body; enemy-C's body is a narrow $[[$02]]\times[[$0B]]$
  sprite read from [[SPRITE_TABLE_C_LO]] / [[SPRITE_TABLE_C_HI]]
  (indexed by [[PROJ_FRAME_IDX]]).  The column bound
  is [[$94]] rather than [[$9C]], so enemy-C clips slightly sooner at the
  right edge.
\item \textbf{Secondary ``tail'' sprite below the body.}  Immediately
  after the main draw, enemy-C issues a \emph{second} [[DRAW_SPRITE]]
  call for a $[[$01]]\times[[$07]]$ sprite at (clip\_X$-$1, row $+$ [[$0B]]),
  reading from the level-specific pointer pair
  [[ENEMY_C_TAIL_LO]]/[[ENEMY_C_TAIL_HI]] (also
  indexed by [[PROJ_FRAME_IDX]]).  The tail lives in the per-level
  swappable region [[$7500]]--[[$7AFF]] so each level contributes its own
  tail art.  A [[BCS]] inside [[ENEMY_C_DRAW]] skips both the second draw and
  the hit test if the shifted X underflowed (i.e.\ clip\_X was [[$00]]).
\item \textbf{Hit target is a 4-slot enemy table, not the player.}
  The hit test inside [[ENEMY_C_DRAW]] walks the four-slot floor-enemy
  table at [[ZP_ENEMY_FLAG]]/[[ZP_ENEMY_COL]]/[[ZP_ENEMY_Y]] (the same slots the beam targets), scanning
  X~=~3..0 for the first active flag.  The test compares enemy-C's
  screen-X ([[ZP_CLIP_X_LO]]) against [[ZP_ENEMY_COL]] and its row
  ([[ZP_ENEMY_C_ROW]]) against [[ZP_ENEMY_Y]].  On a match,
  enemy-C \emph{consumes} the floor-enemy slot.
\end{enumerate}

\paragraph{Hit action: the C$\rightarrow$\{A,C\}
broadcast.}  On a hit:
\begin{enumerate}
\item Write [[$FF]] to [[ZP_ENEMY_C_STATE]] (put self into drift mode,
  triggering the vertical bobble animation in [[ENEMY_C_ADVANCE]]).
\item If [[ZP_ENEMY_A_STATE]] is non-zero, write [[$FF]] to it too ---
  putting enemy-A into PRNG-gated drift mode.  This is the
  \emph{cross-slot broadcast}: C's hit animates both itself and A.
\item Reload [[ZP_ENEMY_C_POS]] to ($\$$AF,$\$$D0) (hi~=~clip\_X,
  lo~=~[[$D0]]) and bump [[ZP_ENEMY_C_ROW]] by 2.
\item Clear the floor-enemy slot: [[STA ZP_ENEMY_FLAG]],X with A~=~[[$00]]
  retires the same slot the beam would retire on a laser kill.
\item Rearm the click counter ([[ZP_ENEMY_C_SND_CTR]]~=~[[$04]]).
\item Award \textbf{100~BCD} points via [[SCORE_ADD]] (addend
  [[$0100]]).  Note: unlike [[ENEMY_B_DRAW]], enemy-C does
  \emph{not} decrement [[ZP_GAME_OVER]] --- this hit path is not a
  player-life event.
\end{enumerate}

\paragraph{Hit-box.}  Screen-X window is (clip\_X$-$[[$08]], clip\_X]
(enemy-C's X $\pm$ 4 pixels of the target's column); Y window is
(row$-$[[$04]], row$+$[[$0A]]) (a 13-row band centred four rows above
enemy-C's top).  Only the \emph{first} active slot (highest X with
the flag set) is tested per frame.

\paragraph{Drift-mode tail.}  Reached when
[[ZP_ENEMY_C_STATE]] is negative (set by the hit path above, or
externally by [[ENEMY_A_ADVANCE]]'s rearm which writes
[[$01]] --- wait, only hits write [[$FF]]; A's rearm writes [[$01]] for
steady mode).  The drift-mode draw emits a single $[[$02]]\times[[$06]]$
``puff'' sprite at [[ZP_ENEMY_C_POS]]$+1$'s column index, reading
from [[ENEMY_C_PUFF_LO]]/[[ENEMY_C_PUFF_HI]] ---
a different level-specific pointer pair from [[ENEMY_B_DRAW]]'s
[[ENEMY_B_PUFF_LO]]/[[ENEMY_B_PUFF_HI]] puff (one byte earlier).

\paragraph{Contrast with [[ENEMY_B_DRAW]]:}

\begin{center}
\begin{tabular}{lll}
                        & Enemy-B                        & Enemy-C               \\ \hline
Slot state              & [[ZP_ENEMY_B_STATE]]                          & [[ZP_ENEMY_C_STATE]]                  \\
16-bit pos              & [[ZP_ENEMY_B_POS]]                     & [[ZP_ENEMY_C_POS]]             \\
Row                     & [[ZP_ENEMY_B_ROW]]                          & [[ZP_ENEMY_C_ROW]]                  \\
Main sprite size        & $[[$05]]\times[[$11]]$              & $[[$02]]\times[[$0B]]$      \\
Main sprite table       & [[SPRITE_TABLE_B_LO]]/[[SPRITE_TABLE_B_HI]]     & [[SPRITE_TABLE_C_LO]]/[[SPRITE_TABLE_C_HI]] \\
Right X clip            & [[$9C]]                          & [[$94]]                  \\
Secondary sprite        & \emph{none}                   & $[[$01]]\times[[$07]]$ tail at [[ENEMY_C_TAIL_LO]]/[[ENEMY_C_TAIL_HI]] \\
Hit target              & player ([[ZP_PLAYER_COL]]/[[ZP_PLAYER_Y]])            & 4-slot enemy ([[ZP_ENEMY_COL]]/[[ZP_ENEMY_Y]]) \\
Hit X window            & [[[$42]], [[$55]])                  & (clip\_X$-$8, clip\_X] \\
Hit Y window            & $[\textrm{player}-[[$0E]], \textrm{player}+[[$0D]]]$ & $[\textrm{row}-[[$03]], \textrm{row}+[[$09]]]$ \\
Score awarded           & +[[$0300]] (300)                 & +[[$0100]] (100)         \\
Game-over decrement     & yes                           & \emph{no}             \\
Post-hit state writes   & [[ZP_ENEMY_B_STATE]]~$\leftarrow$~[[$FF]]        & [[ZP_ENEMY_C_STATE]]~$\leftarrow$~[[$FF]]; [[ZP_ENEMY_A_STATE]]~$\leftarrow$~[[$FF]] (if non-zero); [[ZP_ENEMY_FLAG]],X~$\leftarrow$~[[$00]] \\
Sound counter reload    & [[ZP_ENEMY_B_SND_CTR]]~$\leftarrow$~[[$05]]        & [[ZP_ENEMY_C_SND_CTR]]~$\leftarrow$~[[$04]] \\
Drift-mode puff src     & [[ENEMY_B_PUFF_LO]]/[[ENEMY_B_PUFF_HI]]                 & [[ENEMY_C_PUFF_LO]]/[[ENEMY_C_PUFF_HI]]         \\
\end{tabular}
\end{center}

\paragraph{Topology restated.}  The C$\rightarrow$\{A,C\} broadcast
in this routine is triggered by enemy-C striking a floor-enemy, not
by striking the player.  Combined with enemy-A's rearm writing
[[$01]] to [[ZP_ENEMY_C_STATE]] (A$\rightarrow$C wake), the three-slot handshake graph
is: A wakes C on its own rearm; C arms both itself and A into drift
mode when it kills a floor-enemy; B has no outgoing handshake and
only affects its own state.

