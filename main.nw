<<digit tile data>>=

        ORG $B4B1
DIGIT_TILE_DATA:
        ; 10 digit glyphs (0..9), 2 bytes per row x 6 rows = 12 bytes each.
        ; Pixel format matches DRAW_SPRITE_OPAQUE with ZP_SPRITE_W = 1 and
        ; ZP_SPRITE_H = 6: row-major, rightmost byte first within each row
        ; (DEX loops leftward from ZP_SPRITE_X).  High bit set on most
        ; bytes selects the blue/orange palette so the HUD digits render
        ; in blue on the decorative strip.
        HEX 82 D4 8A C5 8A C5    ; '0' ($B4B1) rows 0-2
