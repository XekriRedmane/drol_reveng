        ORG $1423
ENEMY_A_DRAW:
        SUBROUTINE
        ; Per-frame draw + player-collision for the enemy-A slot.
        ; Completes the entity-draw triplet (with ENEMY_B_DRAW and
        ; ENEMY_C_DRAW).  Unlike B/C, enemy-A is rendered as a
        ; two-sprite composite (body + feet) with a four-frame
        ; walking animation driven by ZP_FRAME_COUNTER bits 1-2;
        ; drift state simply collapses the animation to a fixed
        ; stance (there is no drift puff).  Player-hit awards +$0300
        ; BCD and decrements ZP_GAME_OVER, matching enemy-B.
        ;
        ; Inputs:
        ;   ZP_ENEMY_A_STATE    --- $00 off; +steady (animates); -drift (stance).
        ;   ZP_ENEMY_A_POS      --- 16-bit world X for enemy-A.
        ;   ZP_ENEMY_A_ROW      --- Body-sprite starting screen row.
        ;   ZP_PLAYER_Y   --- Player Y (index into perspective tables).
        ;   ZP_PLAYER_COL --- Player column (collision X reference).
        ;   ZP_SPRITE_XREF --- Level-fixed X reference.
        ;   ZP_FRAME_COUNTER --- Frame-counter source for walk gate.
        ;   PERSPECTIVE_XOFF_LO/HI --- Y-to-X transform tables.
        ;   SPRITE_TABLE_A_BODY_LO/HI   --- Body-sprite pointer table.
        ;   SPRITE_TABLE_A_FEET_LO/HI   --- Stance-feet pointer table.
        ;   SPRITE_TABLE_A_STEP1_LO/HI  --- Walk feet variant 1 (phase $03).
        ;   SPRITE_TABLE_A_STEP2_LO/HI  --- Walk feet variant 2 (phase $01).
        ;
        ; Behavior:
        ;   1. State gate: $00 exits.
        ;   2. Clip: compute screen-relative X into ZP_CLIP_X_LO/HI;
        ;      exit if high byte non-zero or low byte >= $9A.
        ;   3. Set up common sprite params: $5D = screen col,
        ;      $56 = 3, $57 = $13 (body dims).
        ;   4. State-polarity dispatch: positive -> .walk_phase
        ;      (animation scan); negative -> fall through to .stance.
        ;   5. .stance (also reached when walk_phase = 0 or 2):
        ;      draw body at ZP_ENEMY_A_ROW from SPRITE_TABLE_A_BODY;
        ;      draw $03x$03 feet at row+$13 from SPRITE_TABLE_A_FEET;
        ;      JMP to hit test.
        ;   6. .walk_phase: extract ZP_FRAME_COUNTER & $06 >> 1 into A;
        ;      if 0 or 2 jump to .stance; else stash in
        ;      ZP_ENEMY_A_LEG_PHASE and draw body at row-1 from
        ;      SPRITE_TABLE_A_BODY, then a $03x$04 walking-feet
        ;      sprite at row+$12 chosen by the stashed phase
        ;      (phase 3 = STEP1 / $B010; phase 1 = STEP2 / $B01E).
        ;   7. Hit test: ZP_CLIP_X_LO in [$42, $4F) AND
        ;      ZP_ENEMY_A_ROW in [player-$14, player+$10].
        ;   8. On hit (.hit): $00 -> ZP_ENEMY_A_STATE (deactivate
        ;      immediately; no drift), $07 -> ZP_ENEMY_A_SND_CTR
        ;      (one death click), DEC ZP_GAME_OVER, award +$0300
        ;      BCD via SCORE_ADD, RTS.
        ;
        ; Modifies:
        ;   ZP_CLIP_X_LO/HI, ZP_ENEMY_A_LEG_PHASE, ZP_SAVE_X,
        ;   sprite-param ZPs ($56/$57/$5B/$5D), ZP_SCORE_ADD_LO/HI,
        ;   ZP_ENEMY_A_STATE, ZP_ENEMY_A_SND_CTR, ZP_GAME_OVER,
        ;   SMC_DS_SRC_LO/HI.
        ; Clobbers: A, X, Y

; --- State gate: $00 -> exit ---
        LDA ZP_ENEMY_A_STATE
        BNE .active                     ; $00: slot inactive
        RTS

; --- Clip: compute screen-relative X from world X ---
.active:
        LDX ZP_PLAYER_Y
        LDA PERSPECTIVE_XOFF_LO,X       ; Y-indexed X offset (low)
        SEC
        SBC ZP_SPRITE_XREF              ; ... minus fixed X-reference
        STA ZP_CLIP_X_LO
        LDA PERSPECTIVE_XOFF_HI,X       ; (high byte propagation)
        SBC #$00
        STA ZP_CLIP_X_HI
        SEC
        LDA ZP_ENEMY_A_POS              ; Subtract from enemy world X
        SBC ZP_CLIP_X_LO
        STA ZP_CLIP_X_LO                ; ZP_CLIP_X_LO = screen-relative X (lo)
        LDA ZP_ENEMY_A_POS+1
        SBC ZP_CLIP_X_HI
        BEQ .in_bounds                  ; hi diff == 0: on-screen
.exit:
        RTS                             ; hi diff != 0: off-screen, exit
.in_bounds:
        LDA ZP_CLIP_X_LO
        CMP #$9A
        BCS .exit                       ; clipped X >= $9A: off right edge

; --- Common sprite-parameter setup (body dimensions) ---
        TAX                             ; X := clipped screen-X
        LDA PROJ_SCREEN_COL,X           ; -> screen column index
        STA ZP_SPRITE_X
        LDA PROJ_FRAME_IDX,X            ; -> sprite frame index
        TAX                             ; X := frame index
        LDA #$03
        STA ZP_SPRITE_W                 ; Body width = 3 bytes
        LDA #$13
        STA ZP_SPRITE_H                 ; Body height = $13 rows

; --- State-polarity dispatch: +steady animates; -drift = stance ---
        LDA ZP_ENEMY_A_STATE
        BPL .walk_phase                 ; positive: try walking animation
;       fall through to .stance         ; negative: no animation

; --- Stance draw: body at row + 03x03 feet at row+$13 (no animation) ---
.stance:
        LDA ZP_ENEMY_A_ROW
        STA ZP_SPRITE_Y                 ; Body row = enemy row
        LDA SPRITE_TABLE_A_BODY_LO,X    ; Patch DRAW_SPRITE src (body lo)
        STA SMC_DS_SRC_LO
        LDA SPRITE_TABLE_A_BODY_HI,X    ; Patch DRAW_SPRITE src (body hi)
        STA SMC_DS_SRC_HI
        STX ZP_SAVE_X                   ; Preserve frame idx across JSR
        JSR DRAW_SPRITE                 ; Blit body

        LDA #$03
        STA ZP_SPRITE_W                 ; Feet width = 3 bytes
        STA ZP_SPRITE_H                 ; Feet height = 3 rows
        LDX ZP_CLIP_X_LO                ; Re-derive screen column
        LDA PROJ_SCREEN_COL,X
        STA ZP_SPRITE_X
        LDA ZP_ENEMY_A_ROW
        CLC
        ADC #$13
        STA ZP_SPRITE_Y                 ; Feet row = body row + $13
        LDX ZP_SAVE_X                   ; Restore frame idx
        LDA SPRITE_TABLE_A_FEET_LO,X    ; Patch src (stance feet lo)
        STA SMC_DS_SRC_LO
        LDA SPRITE_TABLE_A_FEET_HI,X    ; Patch src (stance feet hi)
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE                 ; Blit stance feet
        JMP .hit_test

; --- Walking animation phase gate: $FD bits 1-2 -> {0,1,2,3} ---
.walk_phase:
        LDA ZP_FRAME_COUNTER
        AND #$06                        ; Keep bits 2,1 -> {0,2,4,6}
        LSR                             ; -> phase in {0,1,2,3}
        BEQ .stance                     ; phase 0: use stance frame
        CMP #$02
        BEQ .stance                     ; phase 2: use stance frame
        STA ZP_ENEMY_A_LEG_PHASE        ; phase 1 or 3: animate

; --- Animated walking: body at row-1 + 03x04 feet at row+$12 ---
        LDA ZP_ENEMY_A_ROW
        SEC
        SBC #$01
        STA ZP_SPRITE_Y                 ; Body row = enemy row - 1
        LDA SPRITE_TABLE_A_BODY_LO,X    ; Same body base as stance
        STA SMC_DS_SRC_LO
        LDA SPRITE_TABLE_A_BODY_HI,X
        STA SMC_DS_SRC_HI
        STX ZP_SAVE_X                   ; Preserve frame idx
        JSR DRAW_SPRITE                 ; Blit body

        LDA #$03
        STA ZP_SPRITE_W                 ; Walking feet width = 3 bytes
        LDA #$04
        STA ZP_SPRITE_H                 ; Walking feet height = 4 rows
        LDX ZP_CLIP_X_LO                ; Re-derive screen column
        LDA PROJ_SCREEN_COL,X
        STA ZP_SPRITE_X
        LDA ZP_ENEMY_A_ROW
        CLC
        ADC #$12
        STA ZP_SPRITE_Y                 ; Feet row = body row + $12
        LDY ZP_ENEMY_A_LEG_PHASE        ; Phase: 1 or 3
        CPY #$01
        BEQ .walk_step2                 ; phase 1 -> STEP2 table
        LDX ZP_SAVE_X                   ; phase 3 -> STEP1 table
        LDA SPRITE_TABLE_A_STEP1_LO,X
        STA SMC_DS_SRC_LO
        LDA SPRITE_TABLE_A_STEP1_HI,X
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE                 ; Blit walk variant 1
        JMP .hit_test
.walk_step2:
        LDX ZP_SAVE_X
        LDA SPRITE_TABLE_A_STEP2_LO,X
        STA SMC_DS_SRC_LO
        LDA SPRITE_TABLE_A_STEP2_HI,X
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE                 ; Blit walk variant 2

; --- Player-hit test: narrow X window + wide Y band ---
.hit_test:
        LDA ZP_CLIP_X_LO
        CMP #$42
        BCC .no_hit                     ; clipped X < $42: no overlap
        CMP #$4F
        BCS .no_hit                     ; clipped X >= $4F: no overlap
        LDA ZP_PLAYER_COL
        SEC
        SBC #$14
        CMP ZP_ENEMY_A_ROW
        BCS .no_hit                     ; enemy-row < player-$14: no overlap
        CLC
        ADC #$24                        ; (player-$14) + $24 = player+$10
        CMP ZP_ENEMY_A_ROW
        BCC .no_hit                     ; enemy-row >= player+$10: no overlap

; --- Hit: deactivate A, rearm death click, DEC $39, +$0300 BCD ---
.hit:
        LDA #$00
        STA ZP_ENEMY_A_STATE            ; Immediate deactivation (not drift)
        LDA #$07
        STA ZP_ENEMY_A_SND_CTR          ; One last death click
        DEC ZP_GAME_OVER                ; Consume a player-hit credit
        LDA #$00
        STA ZP_SCORE_ADD_LO             ; addend lo = $00
        LDA #$03
        STA ZP_SCORE_ADD_HI             ; addend hi = $03 ($0300 BCD = 300)
        JSR SCORE_ADD                   ; ... score += 300
.no_hit:
        RTS
@ %def ENEMY_A_DRAW ZP_ENEMY_A_LEG_PHASE
@ %def SPRITE_TABLE_A_BODY_LO SPRITE_TABLE_A_BODY_HI
@ %def SPRITE_TABLE_A_STEP1_LO SPRITE_TABLE_A_STEP1_HI
@ %def SPRITE_TABLE_A_FEET_LO SPRITE_TABLE_A_FEET_HI
@ %def SPRITE_TABLE_A_STEP2_LO SPRITE_TABLE_A_STEP2_HI

\section{Enemy-B advance timer}

[[ENEMY_B_ADVANCE]] at [[$1536]] is the per-frame tick for the second of
three ``moving hazard'' slots.  It completes the triplet with
[[ENEMY_A_ADVANCE]] and [[ENEMY_C_ADVANCE]], but has
fundamentally different cadence semantics: it is a slow
\emph{up}-counting slot, gated on the player's animation counter
[[ZP_ANIM_COUNTER]], not a downward-counting phase variable.
The slot uses the B-record [[ZP_ENEMY_B_STATE]],
[[ZP_ENEMY_B_POS]], [[ZP_ENEMY_B_ROW]], and the  % TODO-SYM: $E2
independent sound counter [[ZP_ENEMY_B_SND_CTR]].  See \S
Enemy-A advance timer for the shared click+gate+rearm template; this
section documents only the differences.

\paragraph{Sound.}  Same shape as enemy-A's [[SFX_TONE]] click
(duration~[[$0A]]), but reading [[SND_PITCH_TBL_B]] at [[$0231]] and using
the independent [[ZP_ENEMY_B_SND_CTR]] ([[$E4]], not [[$B7]]/[[$B8]] shared with
A/C).

\paragraph{Tick direction is inverted.}  Enemy-A and enemy-C subtract
[[ZP_ADVANCE_RATE]] ([[$40]], set by [[DIFFICULTY_UPDATE]] to 1/2/3) from
the 16-bit counter each frame.  Enemy-B does the opposite: it
\emph{adds} a small value to [[ZP_ENEMY_B_POS]] each frame, counting up
toward a rearm threshold.  The per-frame add value is not
[[ZP_ADVANCE_RATE]] at all but the \emph{player animation counter}
[[ZP_ANIM_COUNTER]] itself, loaded via \emph{self-modifying code} at
[[SMC_ENEMY_B_ADD]] ([[$1551]], the immediate operand byte of the
\texttt{ADC~\#[[$01]]} at [[$1550]]).  The initial on-disk value of the  % TODO-SYM: $1550
operand is [[$01]], and the only values ever written back are [[$01]] or
[[$03]] (see gate below), so B still counts strictly upward by a small
increment each frame.

\paragraph{Animation-counter gate with SMC patch.}  After the 16-bit
add, enemy-B inspects [[ZP_ANIM_COUNTER]]:

\begin{enumerate}
\item If [[$1F]]~$\geq$~[[$04]]: exit without patching --- the counter is out
  of the gated range.
\item If [[$1F]]~=~[[$00]], [[$02]]: exit without patching --- these two values
  are treated as ``pause'' states and do not advance the tick rate.
\item Otherwise ([[$1F]] $\in$ \{[[$01]], [[$03]]\}): write the current value of
  [[$1F]] into [[SMC_ENEMY_B_ADD]], patching the \texttt{ADC} operand so
  the \emph{next} frame adds 1 or 3 instead of the previous amount,
  then exit.
\end{enumerate}

The practical effect is that enemy-B's counter accelerates during
certain player-animation frames ([[$1F]]~=~[[$03]], tripling the per-frame
add) and runs at the baseline ([[$01]]) otherwise.  Since [[ZP_ANIM_COUNTER]]
is also the low byte of the PRNG state (\emph{see} [[PRNG]]) and is
separately used as the player climb/descend pause index (\emph{see}
[[ATTRACT_ANIM_3]] which pauses at [[$1F]]~=~5), the gate has a
pseudorandom flavour but is anchored to actual animation-frame
transitions, not a free-running timer.

The high byte check at [[$155A]] (\texttt{CMP \#[[$03]]; BCS [[$1570]]}) splits  % TODO-SYM: $155A $1570
the routine: until [[ZP_ENEMY_B_POS]]$+1$ reaches [[$03]], each frame only
runs the animation-gated SMC patch.  Once it reaches [[$03]] the routine
instead falls through to the rearm attempt.

\paragraph{Rearm.}  When [[ZP_ENEMY_B_POS]]$+1$~$\geq$~[[$03]], the
routine re-examines the low byte: if [[$E1]]~$<$~[[$5A]] it exits (still
counting up within the window), otherwise the counter is reloaded to
[[$003E]], the row is reseated from the four-entry anchor table at  % TODO-SYM: $003E
[[$84]]--[[$87]] (addressed as [[$84]],X with $X=\text{[[$1F]]}~\&~3$), and the  % TODO-SYM: $87
routine returns with [[ZP_ENEMY_B_STATE]] \emph{unchanged}.  Unlike
enemy-A's rearm, B's rearm does \emph{not} wake another slot; unlike
enemy-C's rearm, it does \emph{not} deactivate itself.  B's slot
self-deactivation (into drift mode, where it then counts out via the
256-frame drift-path wrap) happens inside the \emph{draw} routine
[[ENEMY_B_DRAW]] at [[$15FE]] when B overlaps the player  % TODO-SYM: $15FE
([[$FF]]~$\rightarrow$~[[ZP_ENEMY_B_STATE]]).  This is \emph{not} a  % TODO-SYM: $FF
B$\rightarrow$\{A,C\} handshake: B only writes its own state byte
[[$E0]], not [[$D4]] or [[$DC]].

\paragraph{Drift path: count up to overflow, then deactivate.}  If
[[ZP_ENEMY_B_STATE]] is negative (drift mode), the routine jumps to
[[$1588]]: it \texttt{INC}s [[ZP_ENEMY_B_POS]] (lo only) each frame and  % TODO-SYM: $1588
on lo-byte wrap writes [[$00]] to [[ZP_ENEMY_B_STATE]]
--- deactivating the slot.  So drift-mode B fires 256 frames after
activation (~4.3s at 60Hz).

\paragraph{Row table reuse.}  Enemy-B reads from [[$84]],X with X $\in
\{0,1,2,3\}$, so all four entries of the anchor table at
[[$84]]--[[$87]] can select its row.  Enemy-C uses the same table but only  % TODO-SYM: $87
the three entries at [[$85]]--[[$87]] (X $\in \{1,2,3\}$).  The base [[$84]] is  % TODO-SYM: $85 $87
shared with [[LEVEL_INTRO_TICK]]'s per-level intro Y seed.

\paragraph{Cross-references.}  [[ZP_ADVANCE_RATE]] is \emph{not}
consumed here, so B does not share the difficulty-controlled advance
rate of A and C.  The draw counterpart [[ENEMY_B_DRAW]] at [[$1591]]
reads [[ZP_ENEMY_B_STATE]], [[ZP_ENEMY_B_POS]] and
[[ZP_ENEMY_B_ROW]], and its collision path at [[$15FE]] writes [[$FF]] to  % TODO-SYM: $15FE $FF
[[ZP_ENEMY_B_STATE]] (putting B into drift mode for self-deactivation)
when B's screen sprite overlaps the player hit-box.  The [[$D4]]/[[$DC]]
writes at [[$1757]]-[[$1763]] belong to [[ENEMY_C_DRAW]] (enemy-C draw),  % TODO-SYM: $1757 $1763
not to [[ENEMY_B_DRAW]] --- enemy-C's collision path is what
broadcasts [[$FF]] to both neighbours.  % TODO-SYM: $FF

