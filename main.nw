        ;   $02B5-$02B9 (5 bytes of ZP_SPRITE_BLOCK head) --- emitted
        ;     by the row-copy-data chunk.
        ;   $02BA-$02C5 (12 bytes of $FF, ENTITY_HIT_STATE seed) ---
        ;     emitted by LVL_INIT_ENTITY_HIT_STATE.
        ;   $02C6-$02E1 (28 bytes, this chunk) --- ZP_ENEMY_FLAG tail
