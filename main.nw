<<interlace restore p1>>=

        ORG $09FE
INTERLACE_RESTORE_P1:
        SUBROUTINE
        ; Page-1 text-strip restore: repaint the column range
        ; [[[ZP_SCORE_0] .. [ZP_SCORE_1]+1]] of hi-res page 1 from the
        ; 40-byte [$0300..$0327] buffer, using [[INTERLACE_FILL_P1]]
        ; ([[$0A0F]]) per column to broadcast one source byte across
        ; 105 interlaced rows.
        ;
        ; Inputs:
        ;   ZP_SCORE_0 --- high (starting) column (inclusive).
        ;   ZP_SCORE_1 --- low terminator (the loop stops WHEN
        ;                         X == ZP_SCORE_1; the terminator itself
        ;                         is NOT painted).
        ;   $0300,X  --- 40-byte text-area source buffer
        ;                (same buffer that CLEAR_PAGE1's text_restore
        ;                loop copies into the bottom 12 hi-res rows).
        ;
        ; Behavior:
        ;   X starts at ZP_SCORE_0 and decrements.  For each X, load
        ;   the source byte,X and call INTERLACE_FILL_P1 to
        ;   broadcast it across 105 hi-res rows at column X (rows
        ;   72-106 / 112-146 / 152-186 --- the same 3-band interlace
        ;   pattern as CLEAR_PAGE1).  Exit early when X == ZP_SCORE_1.
        ;
        ; Callers:
        ;   REFRESH_RIGHT_WALL shared tail at $625C (paired with
        ;                      JSR INTERLACE_BLIT_P1 at $625F).
        ;   REFRESH_LEFT_WALL  shared tail at $62BC (paired with
        ;                      JSR INTERLACE_BLIT_P1 at $62BF).
        ;   (REFRESH_PILLARS does NOT call the restore helper --- it
        ;    relies on CLEAR_DRAW_PAGE's earlier pass instead.)
        ;   BIT ZP_PAGE_FLAG gate at each caller selects page 1 (this
        ;   routine) when ZP_PAGE_FLAG is positive; page 2
        ;   (INTERLACE_RESTORE_P2) otherwise.
        ;
        ; Note on ZP aliasing:
        ;   $2B and $2C are aliased as ZP_SCORE_0 / ZP_SCORE_1 (HUD
        ;   digit sprite slots) --- here they're reused as column
        ;   bounds for the text-restore helper.  CLEAR_PAGE1 uses the
        ;   NEXT pair ($2D/$2E = ZP_CLEAR_COL_END / ZP_CLEAR_COL) for
        ;   its own outer-loop bounds.  The four HUD slots SLOT_X16-$2E
        ;   thus double as two (low, high) column-range pairs for the
        ;   two restore helpers.
        ;
        ; Clobbers: A, X
        LDX ZP_SCORE_0                  ; outer-loop column start
.loop:
        CPX ZP_SCORE_1                  ; terminator
        BNE .paint
        RTS
.paint:
        LDA $0300,X                     ; text-buffer byte for column X
        JSR INTERLACE_FILL_P1           ; paint 105 rows
        DEX
        JMP .loop
