ZP_PERSP_OFFSET_HI = $10        ; Pre-computed perspective X offset (high)
                                ; (Set once per call by RESCUE_DRAW_PERSPECTIVE_CACHE
                                ; from PERSPECTIVE_XOFF_LO/HI[ZP_PLAYER_Y]
