<<stage residue dead defines>>=

; --- Disk II data latch + drive-motor soft switches (dead residue) ---
; (Live loader defines these in loader.asm; we redeclare locally for
; the dead-residue routine that lives in drol.bin.)
STAGE_DISK_DATA      = $C08C    ; Read data latch
STAGE_DISK_MOTOR_ON  = $C089    ; Drive motor on

; --- Cross-target bridges (live routines in other .asm files) ---
; RWTS_RELOAD lives in rwts.asm at the same address; we declare it
; locally because drol.asm cannot see the rwts label table.  Ditto
; SCREEN_ROW_COPY at $0100 (installed by FIRST_BOOT from STAGE_STACK
; into the stack page; drol.asm's live copy is at the
; SCREEN_ROW_COPY label, but the dead call above targets the same
; address symbolically).
STAGE_RWTS_RELOAD    = $BE00    ; Entry point in rwts.bin (cross-target)

; --- Dead-residue ZP aliases ---
; The $5E00 dead residue uses $48/$49 as a generic indirect pointer
; (to a 17-byte sector-header record) and $47 as a scratch flags
; byte.  These ZP slots have unrelated live-engine meanings
; (ZP_INPUT_MODE / unused) so we give them dead-code aliases here to
; keep the disassembly readable without perturbing the live aliases.
ZP_DEAD_SECHDR   = $48          ; 16-bit sector-header indirect pointer
ZP_DEAD_FLAGS    = $47          ; cached header flag byte
ZP_DEAD_HDR_AUX  = $3C          ; 16-bit indirect -- secondary header ptr
ZP_DEAD_HDR_DST  = $0036        ; 4-byte scratch destination (ZP $36..$3F)
                                 ; -- absolute addressed so Y=6..9 maps
                                 ; to ZP $3C/$3D/$3E/$3F (overlaps
                                 ; ZP_DEAD_HDR_AUX).

; --- Disk II soft switches read by the dead residue ---
DISK_Q6_OFF      = $C08A        ; Q6L: "sense write protect" / read mode
DISK_Q6_ON       = $C08B        ; Q6H: latch load / write mode
DISK_Q7_OFF      = $C08E        ; Q7L: shift register into read mode

; --- Text-page scratch slots used as retry counters ---
TXT_RETRY_04F8   = $04F8        ; Apple II text-page row 2 col 56
TXT_RETRY_05F8   = $05F8        ; Apple II text-page row 4 col 56
TXT_RETRY_06F8   = $06F8        ; Apple II text-page row 6 col 56

; --- Overlay entry into a live RWTS label (dead-code target) ---
; $BA00 lands inside SPRITE_TABLE_B_DATA at runtime (sprite bytes, not
; code), so the JSR here is a nonsense call preserved only because the
; containing routine is never reached.
DEAD_BA00_OVL    = $BA00        ; dead-code target inside sprite region
NIBBLE_READER_OVL = $BE5A       ; mid-instruction entry into live NIBBLE_READER

<<stage residue dead>>=

        ORG $5E00
STAGE_RESIDUE_DEAD:
        SUBROUTINE
        ; Dead residue ($5E00-$5EC4, 197 bytes): a fragment of a
        ; Disk II nibble-level sector reader followed by a
        ; GAME_START_INIT-style level-restart tail.  No shipped binary
        ; calls any address in this range; the bytes are staged
        ; residue from some pre-release layout, preserved here for
        ; byte-exactness only.  Falls through into RESTART_DISPATCH.
        ;
        ; Reconstructed control flow (all dead):
        ;   .head  $5E00 - save caller's header pointer, seed text-page
        ;                  retry counters, inspect header byte 1.
        ;   .sync_wait $5E19 - header byte 1 != byte $0F: drain the
        ;                  data latch until it settles on header byte
        ;                  $0F, then restore X from the saved copy.
        ;   .spin1 $5E34 - spin on the data latch until two reads
        ;                  agree, saving the drive slot in
        ;                  TXT_RETRY_05F8 mid-spin.
        ;   .read_hdr $5E52 - pull a 4-byte field from header offsets
        ;                  6..9 into ZP_DEAD_HDR_DST+Y and the third
        ;                  byte of the (ZP_DEAD_HDR_AUX) indirect into
        ;                  ZP_DEAD_FLAGS.
        ;   .nib_check $5E64 - optionally cache header byte $02 into
        ;                  byte $10; preserves processor flags across
        ;                  the optional store via PHP/PLP.
        ;   .phase_step $5E74 - ROR A picks phase $C08A vs $C08B per
        ;                  the saved flags; ROR's result is shifted
        ;                  into $35 (the live engine's
        ;                  ZP_DIFF_THRESH_B).
        ;   .retry_loop $5E83 - on sync mismatch, JSR DEAD_BA00_OVL
        ;                  seven times (junk: $BA00 is sprite data at
        ;                  run-time), reload the slot, and re-enter
        ;                  the header read.
        ;   .finalise $5E8D - pull header byte 4, call into NIBBLE_READER
        ;                  ($BE5A entry), then restart the game.
        ;   .restart  $5EAB - tail is a GAME_START_INIT clone (zero
        ;                  ZP_SCORE_0..2, seed HUD_LIVES_COL / HUD_SCORE_COL,
        ;                  ZP_CLEAR_COL, ZP_PLAYER_Y, call INIT_LEVEL_STATE,
        ;                  set ZP_GAME_OVER <- #$01, fall through to
        ;                  RESTART_DISPATCH).

; --- .head: save caller's pointer + reseed text-page retry counters ---
        STY ZP_DEAD_SECHDR       ; ZP_DEAD_SECHDR <- Y (lo byte of hdr ptr)
        STA ZP_DEAD_SECHDR+1     ; ZP_DEAD_SECHDR+1 <- A (hi byte)
        LDY #$02
        STY TXT_RETRY_06F8       ; outer-retry counter <- #$02
        LDY #$04
        STY TXT_RETRY_04F8       ; inner-retry counter <- #$04

; --- .head tail: inspect header byte 1; jump to spin1 if already matches byte $0F ---
        LDY #$01
        LDA (ZP_DEAD_SECHDR),Y   ; hdr[1] -> A
        TAX                      ; stash in X
        LDY #$0F
        CMP (ZP_DEAD_SECHDR),Y   ; compare against hdr[$0F]
        BEQ .spin1

; --- .sync_wait: drain the data latch until hdr[$0F] appears ---
        TXA
        PHA                      ; stash original hdr[1] on stack
        LDA (ZP_DEAD_SECHDR),Y   ; hdr[$0F] -> A, Y=$0F
        TAX
        PLA
        PHA
        STA (ZP_DEAD_SECHDR),Y   ; hdr[$0F] <- original hdr[1]
        LDA DISK_Q7_OFF,X        ; shift register -> read
.drain_reset:
        LDY #$08
        LDA STAGE_DISK_DATA,X
.drain_cmp:
        CMP STAGE_DISK_DATA,X
        BNE .drain_reset         ; two reads disagreed: restart
        DEY
        BNE .drain_cmp           ; 8 iterations
        PLA
        TAX                      ; X <- original hdr[1]

; --- .spin1: spin on data latch until two reads agree ---
.spin1:
        LDA DISK_Q7_OFF,X
        LDA STAGE_DISK_DATA,X          ; prime latch
        LDY #$08
.spin1_cmp:
        LDA STAGE_DISK_DATA,X
        PHA                      ; PHA/PLA pair = timing pad (7 cycles)
        PLA
        PHA
        PLA
        STX TXT_RETRY_05F8       ; cache slot in text-page
        CMP STAGE_DISK_DATA,X
        BNE .retry_check         ; mismatch: check retry budget
        DEY
        BNE .spin1_cmp

; --- .read_hdr: 4-byte header pull into ZP $0036+Y + flag byte via ($3C) ---
.retry_check:
        PHP                      ; stash result flags
        LDA STAGE_DISK_MOTOR_ON,X      ; motor-on kick (drive 1)
        LDY #$06
.hdr_copy:
        LDA (ZP_DEAD_SECHDR),Y   ; hdr[Y]
        STA ZP_DEAD_HDR_DST,Y    ; -> ZP $36+Y (absolute addr; Y=6..9)
        INY
        CPY #$0A                 ; 4 bytes: Y=6..9
        BNE .hdr_copy
        LDY #$03
        LDA (ZP_DEAD_HDR_AUX),Y  ; aux header ptr: byte [3]
        STA ZP_DEAD_FLAGS

; --- .nib_check: optionally mirror hdr[2] into hdr[$10] ---
        LDY #$02
        LDA (ZP_DEAD_SECHDR),Y   ; hdr[2] -> A
        LDY #$10
        CMP (ZP_DEAD_SECHDR),Y   ; compare against hdr[$10]
        BEQ .phase_step          ; match: skip store, fall through to ROR
        STA (ZP_DEAD_SECHDR),Y   ; hdr[$10] <- hdr[2]
        PLP                      ; restore saved flags
        LDY #$00

; --- .phase_step: saved-flag-driven stepper phase read ---
        PHP
.phase_step:
        ROR                      ; carry <- low bit of A
        BCC .phase_low
        LDA DISK_Q6_OFF,X        ; Q6L
        BCS .shift_in            ; always taken
.phase_low:
        LDA DISK_Q6_ON,X         ; Q6H
.shift_in:
        ROR ZP_DIFF_THRESH_B     ; fold carry into ZP $35
        PLP
        PHP
        BNE .finalise            ; Z=0: skip retry-loop

; --- .retry_loop: 7x delay into $BA00, reload X from cache, retry hdr read ---
        LDY #$07
.mon_delay:
        JSR DEAD_BA00_OVL        ; lands inside sprite data -- dead call
        DEY
        BNE .mon_delay
        LDX TXT_RETRY_05F8

; --- .finalise: pull hdr[4], call NIBBLE_READER, branch on flags ---
.finalise:
        LDY #$04
        LDA (ZP_DEAD_SECHDR),Y
        JSR NIBBLE_READER_OVL    ; enters live NIBBLE_READER mid-instruction
        PLP
        BNE .restart_skip        ; Z=0: skip ZP_SCORE zeroing
        LDY ZP_DEAD_FLAGS
        BPL .restart_skip        ; flags positive: same skip

; --- bridge: redirect to SCREEN_ROW_COPY + RWTS_RELOAD before .restart_full ---
        LDY #$12
        JSR SCREEN_ROW_COPY      ; $0100 (resident stage-stack entry)
        JSR STAGE_RWTS_RELOAD    ; cross-target call into rwts.bin

; --- .restart_full: GAME_START_INIT-style level restart (clone of $13A4) ---
; Two entry points: .restart_full zeroes the three BCD-score digits;
; .restart_skip lands on a BIT-abs 3-byte NOP ($2C 8D AB = BIT $AB8D)
; formed by the second byte of STA ZP_SCORE_2 + the first two bytes
; of STA HUD_LIVES_COL.  The BIT reads $AB8D harmlessly (STA HUD_LIVES_COL
; on the next instruction still takes effect).
.restart_full:
        LDA #$00
        STA ZP_SCORE_0
        ; The STA ZP_SCORE_1 below is 85 2C.  When .restart_skip enters
        ; at the $2C operand byte ($5EAB), the $2C $85 $2D decodes as
        ; BIT $2D85 (3-byte NOP) which skips the store of ZP_SCORE_2
        ; and falls through into STA HUD_SCORE_COL.  We emit the STA
        ; as raw bytes so we can place .restart_skip on the operand.
        DC.B $85                 ; STA zp opcode
.restart_skip:
        DC.B <ZP_SCORE_1         ; operand -- also reads as BIT opcode
        STA ZP_SCORE_2
        STA HUD_SCORE_COL
        LDA #$27
        STA ZP_CLEAR_COL
        LDA #$28
        STA HUD_LIVES_COL
        LDA #$6B
        STA ZP_PLAYER_Y
        JSR INIT_LEVEL_STATE
        LDA #$01
        STA ZP_GAME_OVER         ; falls through into RESTART_DISPATCH
@ %def STAGE_RESIDUE_DEAD ZP_DEAD_SECHDR ZP_DEAD_FLAGS ZP_DEAD_HDR_AUX ZP_DEAD_HDR_DST
@ %def DISK_Q6_OFF DISK_Q6_ON DISK_Q7_OFF
@ %def TXT_RETRY_04F8 TXT_RETRY_05F8 TXT_RETRY_06F8
@ %def NIBBLE_READER_OVL DEAD_BA00_OVL
@ %def STAGE_DISK_DATA STAGE_DISK_MOTOR_ON STAGE_RWTS_RELOAD

<<restart dispatch>>=

        ORG $5EC5
RESTART_DISPATCH:
        SUBROUTINE
        ; Restart-flag dispatcher (STATICALLY DEAD CODE).
        ;
        ; No JMP/JSR anywhere in boot1.bin, loader.bin, rwts.bin, or
        ; drol.bin targets $5EC5 (nor any address in the $5E00-$5EFF
        ; block that this routine sits at the end of).  The 15 bytes
        ; here appear to be a leftover from a development restart
        ; flow that was superseded by the live LIFE_LOST_HANDLER /
        ; START_GAME_FROM_ATTRACT / INPUT_PROCESS Ctrl-R paths.
        ; ZP_RESTART_FLAG is written to $FF by GAME_START_INIT
        ; but never read at runtime --- this is the only read in the
        ; whole binary and it never executes.
        ;
        ; Were the routine live, the intent (per the branch layout)
        ; would be a 3-way dispatch on ZP_RESTART_FLAG:
        ;   flag < 0 ($FF cold)    --> JMP MAIN_LOOP  (plain resume)
        ;   flag == 0              --> JMP LIFE_LOST_RESUME ($720E;
        ;                             skip-prologue re-entry into the
        ;                             life-lost animation)
        ;   flag > 0               --> JSR GAME_RESTART (skip player/
        ;                             HUD reseed) then JMP MAIN_LOOP
        ;
        ; The GAME_RESTART sub-entry is tailored for exactly
        ; this caller --- it skips the player-Y and HUD-column reseed
        ; that GAME_START_INIT does from the main entry --- which is
        ; further evidence that this dispatcher was the originally
        ; intended gateway between restart flows before the code was
        ; reorganised around the MAIN_LOOP exit-check style.

        LDA ZP_RESTART_FLAG
        BEQ .flag_zero                  ; == 0 --> life-lost resume
        BMI .flag_negative              ; < 0  --> plain main-loop entry
        JSR GAME_RESTART                ; > 0  --> partial reset then...
.flag_negative:
        JMP MAIN_LOOP                   ;         MAIN_LOOP
.flag_zero:
        JMP LIFE_LOST_RESUME            ; Skip-prologue re-entry into
                                        ;   the life-lost handler.
@ %def RESTART_DISPATCH

<<stage dead reload>>=

        ORG $5ED4
STAGE_DEAD_RELOAD:
        SUBROUTINE
        ; Dead residue ($5ED4-$5EFF, 44 bytes): two small RWTS-retry
        ; helpers unique to the pre-relocation staging area.  No
        ; shipped binary jumps into either entry point; they are kept
        ; for byte-exact matching only.  Both helpers fall through
        ; into STAGE_DEAD_RESET at $5F00 to select one of the four
        ; "error" variants using the same BIT-abs skip pattern as the
        ; live RESET_R/P/L/BANG handlers at $BF00.
        ;
        ; The two entries are:
        ;   $5ED4: calls $BE95 (rwts reload), decrements a retry
        ;          counter at $06F8; on zero branches to $5F04 --- a
        ;          BNE opcode ($D0) that with Z-set always falls
        ;          through to the 'L' error char LDA #$CC at $5F06.
        ;          Otherwise reseeds $04F8 <- #$04, calls $BE5A twice
        ;          (with A=0, then with the stacked byte) and JMPs
        ;          to $BDBC.
        ;   $5EED: reads ZP $2E, compares against $0478; on match
        ;          branches to $5F10 which lands inside the operand
        ;          of the following JSR $FB2F (byte $2F, an illegal
        ;          6502 opcode), so that path would crash.  Otherwise
        ;          saves $0478, calls $BE95, decrements $04F8 and
        ;          falls through into STAGE_DEAD_RESET at $5F00 (the
        ;          'R' error-char path).

; --- $5ED4: retry helper 1 ---
        JSR $BE95                       ; mid-instruction byte (dead code)
        DEC $06F8                       ; text-page scratch as retry counter
        BEQ STAGE_DEAD_RESET_L_ALT      ; counter=0 -> 'L' error path (via Z-set BNE fall-through)
        LDA #$04
        STA $04F8                       ; reseed inner counter <- #$04
        LDA #$00
        JSR $BE5A                       ; mid-instruction byte (dead code)
        PLA
        JSR $BE5A                       ; call again with stacked byte
        JMP $BDBC                       ; mid-instruction byte (dead code)

; --- $5EED: retry helper 2 ---
        LDY $2E                         ; ZP $2E
        CPY $0478                       ; compare against text-page byte
        BEQ STAGE_DEAD_RESET_L_BROKEN   ; match -> $5F10 (mid-operand: would crash)
        LDA $0478
        PHA
        TYA
        JSR $BE95
        PLA
        DEC $04F8
;       fall through into STAGE_DEAD_RESET
@ %def STAGE_DEAD_RELOAD

<<stage dead reset>>=

STAGE_DEAD_RESET:
        SUBROUTINE
        ; Dead residue ($5F00-$5F47, 72 bytes): a near-exact duplicate
        ; of the reset-handler common body at $BF00-$BF47.  The live
        ; handler is RESET_R/P/L/BANG (address $BF00-$BF0A: four BIT
        ; $XXYY skip entries that each LDA #error_char, then fall
        ; through to the common body).  This twin is byte-identical
        ; through $5F47 except for one byte: at $5F21 the clear-memory
        ; self-modifying page is $BE instead of $BD, so this twin
        ; would wipe $BE00 downward while the live handler wipes
        ; $BD00 downward.
        ;
        ; Nothing in any shipped binary jumps here.  STAGE_DEAD_RELOAD
        ; above falls through into this body but STAGE_DEAD_RELOAD
        ; itself has no callers.

; --- Error-char select prefix (BIT-abs skips between LDA #imm slots) ---
; The four entry points here are shifted by one byte relative to the
; live RESET_R/P/L/BANG (at $BF00).  In that layout each entry was
; exactly at $BF00/$BF03/$BF06/$BF09 (LDA #imm directly).  Here the
; twin lays them at $5F00/$5F04/$5F06/... with the second entry
; hidden behind a BNE (opcode $D0) that the only real caller
; (STAGE_DEAD_RELOAD's BEQ) always falls through (because Z is
; guaranteed set when branching here).
        LDA #$D2                        ; 'R' error char
        DC.B $2C                        ; BIT abs (skip 2)
STAGE_DEAD_RESET_L_ALT = *+1
        LDA #$D0                        ; 'P' error char (direct entry not exposed as a label)
        DC.B $2C                        ; BIT abs (skip 2)
STAGE_DEAD_RESET_L = *
        LDA #$CC                        ; 'L' error char
        DC.B $2C                        ; BIT abs (skip 2)
STAGE_DEAD_RESET_BANG = *
        LDA #$A1                        ; '!' error char

; --- Common body (copied from RESET_R tail at $BF0B) ---
        PHA                             ; save error char
        JSR $BEE0                       ; COPY_ROM_TO_LC
        JSR $FB2F                       ; MON_INIT
        JSR $FC58                       ; MON_HOME
        JSR $FE84                       ; MON_NORMAL
        PLA
        STA $0400                       ; write error char to text row 0

; --- Clear memory $BEFF downward with speaker beeps ---
; (In the live RESET_R at $BF1F this STA targets $BD00; here it
; targets $BE00 instead --- the only genuine-code byte of this twin
; that differs from the live handler.  The self-modifying DEC / LDA
; below still reference $BF21 --- the live handler's internal SM
; byte --- because when this twin was cloned from the $BF00 routine
; nobody updated its SM addresses to the new $5F21 location.  So if
; this twin were ever called it would nonsensically mutate the live
; RESET_R's SM byte rather than its own.  Dead regardless.)
STAGE_DEAD_CLEAR_OUTER:
        LDY #$00
        TYA
STAGE_DEAD_CLEAR_INNER:
        STA $BE00,Y                     ; self-modifying page start (baked high byte $BE vs $BD)
        INY
        BNE STAGE_DEAD_CLEAR_INNER
        DEC $BF21                       ; decrements LIVE RESET_R's SM byte, not this twin's!
        BIT SW_SPEAKER                  ; beep
        LDA $BF21                       ; likewise reads the live handler's SM byte
        CMP #$08                        ; stop at page 8
        BCS STAGE_DEAD_CLEAR_OUTER
; --- Reboot via slot ROM (soft-entry invalidate + PHA/PHA/RTS trick) ---
        STA $03F3                       ; invalidate SOFTEV high
        STA $03F4                       ; invalidate SOFTEV checksum
        LDA $BF49                       ; LDR_SLOT (slot*16)
        LSR
        LSR
        LSR
        LSR                             ; A = slot
        ORA #$C0
        SBC #$00                        ; A = $Cn (carry was set)
        PHA
        LDA #$FF
        PHA
        RTS                             ; 'returns' to $CnFF+1 = $Cn00 slot ROM

; STAGE_DEAD_RESET_L_BROKEN is the target of $5EED's BEQ $5F10 ---
; $5F10 lands inside the operand of JSR $FB2F (byte $2F), so on this
; illegal opcode path the machine enters undefined territory.  Since
; STAGE_DEAD_RELOAD has no live callers, this path never runs.
STAGE_DEAD_RESET_L_BROKEN = STAGE_DEAD_RESET + $10
@ %def STAGE_DEAD_RESET STAGE_DEAD_RESET_L_ALT STAGE_DEAD_RESET_L STAGE_DEAD_RESET_BANG STAGE_DEAD_CLEAR_OUTER STAGE_DEAD_CLEAR_INNER STAGE_DEAD_RESET_L_BROKEN

<<stage dead ldr slots>>=

STAGE_DEAD_LDR_TRACK:
        ; Dead twin of $BF48-$BF4A (the trailing PHP/RTS/BRK trio
        ; that serves as the on-disk initial values for LDR_TRACK /
        ; LDR_SLOT / LDR_PHASE in the live RWTS).  Here the bytes
        ; differ from the live slot (drol has $00/$60/$FF, rwts.bin
        ; has $08/$60/$00) because these slot values were re-seeded
        ; at install time for the live region but left at their
        ; pre-release values here.  Not referenced at runtime.
        HEX 00 60 FF
@ %def STAGE_DEAD_LDR_TRACK

<<stage dead scroll defines>>=

; --- Cross-target references: the stage-dead scroll twins mirror the
; live RWTS routines that use ZP_RWTS_PTR / ZP_RWTS_PTR2 (defined in
; rwts.asm) as destination/source pointer pairs, and they read from
; the post-relocation SCREEN_ADDR_TBL (also in rwts.asm) plus the live
; TEXT_STRIP_SRC (defined in drol.asm's clear-page1 defines chunk).
; Introduce local ZP EQUs matching the rwts.asm names for symbolic
; parity; TEXT_STRIP_SRC is visible here via the collection-chunk
; ordering so no redefine is needed.
SCREEN_ADDR_TBL = $BFC0         ; 32 pairs of hi-res page-2 row addresses
ZP_RWTS_PTR     = $A0           ; 16-bit dest pointer (lo/hi at $A0/$A1)
ZP_RWTS_PTR2    = $A2           ; 16-bit source pointer (lo/hi at $A2/$A3)
@

<<stage dead scroll up>>=

STAGE_DEAD_SCROLL_UP_PRE:
        SUBROUTINE
        ; Dead residue ($5F4B-$5F7E, 52 bytes): exact byte-for-byte
        ; duplicate of SCROLL_UP_PRE / SCROLL_UP at $BF4B in the live
        ; RWTS.  Both entry points index SCREEN_ADDR_TBL at the
        ; post-relocation address $BFC0 (not at the $5FC0 twin below),
        ; so even if this dead entry were called it would reach into
        ; the live language-card table.  See SCROLL_UP_PRE ($BF4B) for
        ; the live annotated version.
        TAY
        INY
        BEQ .skip
        HEX 4C A0 28                    ; JMP $28A0 (dead delegation twin;
                                        ;   operand bytes form LDY #$28 at
                                        ;   the SCROLL_UP entry below)
STAGE_DEAD_SCROLL_UP = STAGE_DEAD_SCROLL_UP_PRE + 5
.skip:
        LDA #$40
        STY ZP_RWTS_PTR                 ; lo <- Y (0 via BEQ, $28 via SCROLL_UP)
        STA ZP_RWTS_PTR+1               ; hi <- #$40 (buffer page = $40xx)
        LDX #$00
.copy_line:
        LDA SCREEN_ADDR_TBL,X           ; post-relocation live table (not this chunk's local twin)
        STA ZP_RWTS_PTR2
        LDA SCREEN_ADDR_TBL+1,X
        STA ZP_RWTS_PTR2+1
        LDY #$27
.copy_byte:
        LDA (ZP_RWTS_PTR2),Y            ; read from screen
        STA (ZP_RWTS_PTR),Y              ; write to buffer
        DEY
        BPL .copy_byte
        CLC
        LDA ZP_RWTS_PTR
        ADC #$28
        STA ZP_RWTS_PTR
        BCC .no_carry
        INC ZP_RWTS_PTR+1
.no_carry:
        INX
        INX
        CPX #$40
        BCC .copy_line
        RTS
@ %def STAGE_DEAD_SCROLL_UP_PRE STAGE_DEAD_SCROLL_UP

<<stage dead scroll dn>>=

STAGE_DEAD_SCROLL_DN:
        SUBROUTINE
        ; Dead residue ($5F7F-$5FBF, 65 bytes): exact byte-for-byte
        ; duplicate of SCROLL_DN at $BF7F in the live RWTS.  Also
        ; references SCREEN_ADDR_TBL at $BFC0 rather than at the
        ; local $5FC0 twin.  See SCROLL_DN ($BF7F) for annotation.
        LDY #$00
        LDA #$45
        STY $A0
        STA $A1
        LDX #$3E
.copy_line:
        LDA SCREEN_ADDR_TBL,X           ; post-relocation live table
        STA $A2
        LDA SCREEN_ADDR_TBL+1,X
        STA $A3
        LDY #$27
.copy_byte:
        LDA ($A0),Y
        STA ($A2),Y
        DEY
        BPL .copy_byte
        SEC
        LDA $A0
        SBC #$28
        STA $A0
        BCS .no_borrow
        DEC $A1
.no_borrow:
        DEX
        DEX
        BPL .copy_line
; --- Fill bottom 4 hi-res rows (188-191) from text-strip source ---
        LDX #$27
.fill_bottom:
        LDA $0300,X                     ; TEXT_STRIP_SRC
        STA $53D0,X                     ; hi-res page 2 row 188
        STA $57D0,X                     ; row 189
        STA $5BD0,X                     ; row 190
        STA $5FD0,X                     ; row 191
        DEX
        BPL .fill_bottom
        RTS
@ %def STAGE_DEAD_SCROLL_DN

<<stage dead addr tbl>>=

STAGE_DEAD_ADDR_TBL:
        ; Dead residue ($5FC0-$5FFF, 64 bytes): exact byte-for-byte
        ; duplicate of SCREEN_ADDR_TBL at $BFC0 (32 (lo, hi) pairs
        ; pointing at hi-res page 2 line addresses $4028, $4128,
        ; $4228, ...).  Not read at runtime --- the live SCROLL_UP /
        ; SCROLL_DN routines index $BFC0 directly, and so do the
        ; $5F4B / $5F7F twins above.  Preserved here for byte-exact
        ; matching only.
        HEX 80 40 00 41 80 41 00 42
        HEX 00 44 80 44 00 45 80 45
        HEX 00 48 80 48 00 49 80 49
        HEX 00 4C 80 4C 00 4D 80 4D
