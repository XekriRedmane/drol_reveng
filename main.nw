        HEX 50 26 C8 B1 FE 9D 28 29
        HEX 9D A8 2B 9D 50 2A C8 B1
        HEX FE 9D 28 2D 9D A8 2F 9D
        HEX 50 2E C8 B1 FE 9D 28 31
        HEX 9D A8 33 9D 50 32 C8 B1
        HEX FE 9D 28 35 9D
@ %def GAME_INIT_EXTRA

@ \chapter{Input system}

\section{Input dispatcher}

[[INPUT_DISPATCH]] at \$6000 handles keyboard and joystick input during
gameplay. If the input mode flag (\$48) is negative, it delegates to the
joystick handler at \$012B. Otherwise it reads the keyboard and processes
five keys:

\begin{itemize}
\item Right arrow (\$95): enable [[DO_MOVE_RIGHT]], disable [[DO_MOVE_LEFT]]
\item Left arrow (\$88): enable [[DO_MOVE_LEFT]], disable [[DO_MOVE_RIGHT]]
\item `A' (\$C1): fire/ascend --- enable [[DO_ASCEND]], disable [[DO_DESCEND]],
  search for a rescuable entity within range
\item `Z' (\$DA): descend --- enable [[DO_DESCEND]], disable [[DO_ASCEND]],
  search for a rescuable entity, advance floor counter
\item Space (\$A0): set jump flag (\$05 = \$FF)
\end{itemize}

Direction keys work by patching the opcode byte of the movement slots in
the main loop: \$20 (JSR) to enable, \$2C (BIT) to disable.

<<drol input defines>>=

; --- Input constants ---
KEY_RIGHT       = $95           ; Right arrow key code
KEY_LEFT        = $88           ; Left arrow key code
KEY_ACTION      = $C1           ; 'A' key code (fire/ascend)
KEY_DESCEND     = $DA           ; 'Z' key code (descend)
KEY_JUMP        = $A0           ; Space key code (jump)
OPCODE_JSR      = $20           ; JSR opcode (enable direction)
OPCODE_BIT      = $2C           ; BIT abs opcode (disable direction)

; --- Game code stubs (referenced by input) ---
@

<<input dispatch>>=

        ORG $6000
INPUT_DISPATCH:
        SUBROUTINE
        ; Keyboard/joystick input dispatcher.
        ;
        ; Inputs:
        ;   $48 — input mode (positive = keyboard, negative = joystick)
        ;
        ; Behavior:
        ;   Joystick mode: delegates to JOYSTICK_HANDLER.
        ;   Keyboard mode: reads $C000, dispatches on key code.
        ;   Direction keys patch main loop movement slots (JSR/BIT toggle).
        ;   Action keys search for rescuable entities within range.
        ;
        ; Modifies:
        ;   SMC_ASCEND, SMC_DESCEND, SMC_MOVE_LEFT, SMC_MOVE_RIGHT,
        ;   ZP $02-$07, $0B-$0D, $1D, $8D+X
        ; Clobbers: A, X, Y

        LDA ZP_INPUT_MODE       ; Input mode flag
        BPL .keyboard           ; Positive = keyboard
        JMP JOYSTICK_HANDLER    ; Negative = joystick

; --- Keyboard handler ---
.keyboard:
        LDA KEYBOARD            ; Read keyboard
        BMI .got_key            ; Bit 7 set = key available
        RTS                     ; No key pressed
.got_key:

; --- Right arrow ---
        CMP #KEY_RIGHT
        BNE .check_left
        BIT KBDSTROBE           ; Clear keyboard strobe
INPUT_SET_RIGHT:
        STA ZP_KEY_CODE         ; Store key code
        LDY #OPCODE_JSR
        STY SMC_MOVE_RIGHT      ; Enable move right
        LDY #OPCODE_BIT
        STY SMC_MOVE_LEFT       ; Disable move left
        RTS

; --- Left arrow ---
.check_left:
        CMP #KEY_LEFT
        BNE .check_action
        BIT KBDSTROBE
INPUT_SET_LEFT:
        STA ZP_KEY_CODE
        LDY #OPCODE_JSR
        STY SMC_MOVE_LEFT       ; Enable move left
        LDY #OPCODE_BIT
        STY SMC_MOVE_RIGHT      ; Disable move right
        RTS

; --- 'A' key (fire / ascend) ---
.check_action:
        CMP #KEY_ACTION
        BNE .check_descend
        BIT KBDSTROBE
INPUT_DO_ASCEND:
        LDY #OPCODE_JSR
        STY SMC_ASCEND          ; Enable ascend
        LDY #OPCODE_BIT
        STY SMC_DESCEND         ; Disable descend
        LDA $03                 ; Current floor/level
        BMI .clamp_low
        CMP #$03
        BCC .clamp_low
        CMP #$0A
        BCC .set_action
        LDA #$09                ; Clamp high
        STA $03
        BPL .set_action
.clamp_low:
        LDA #$03                ; Clamp low
        STA $03
.set_action:
        LDY #$01
        STY $02                 ; Set action flag
        DEY
        STY ZP_KEY_CODE         ; Clear key code
        DEY
        STY $0D                 ; Set search direction ($FF)
        LDX $41                 ; Number of entities
.search_entity:
        SEC
        LDA $66,X               ; Entity Y position
        SBC ZP_PLAYER_Y         ; Player Y position
        CMP #$18                ; Distance check
        BCS .next_entity
        CMP #$15
        BCC .next_entity
        LDY $0B                 ; Current rescue index
        DEY
        BEQ .next_entity
        LDA FLOOR_Y_TABLE,Y     ; Floor Y-coordinate
        CMP $72,X               ; Compare with entity attribute
        BEQ .found_entity
.next_entity:
        DEX
        BPL .search_entity
        RTS                     ; No entity found
.found_entity:
        STY $0B                 ; Update rescue index
        LDA #$01
        STA $8D,X               ; Activate entity
        STA $1D                 ; Set entity-found flag
        LDA #$00
        STA $04                 ; Clear state
        RTS

; --- 'Z' key (descend) ---
.check_descend:
        CMP #KEY_DESCEND
        BNE .check_jump
        BIT KBDSTROBE
INPUT_DO_DESCEND:
        LDA $0D                 ; Check current direction
        BMI .check_floor
        LDX $41                 ; Number of entities
.search_descend:
        SEC
        LDA $66,X               ; Entity Y position
        SBC ZP_PLAYER_Y         ; Player Y position
        CMP #$18
        BCS .no_match_d
        CMP #$15
        BCC .no_match_d
        LDY $0C                 ; Descend rescue index
        LDA FLOOR_Y_TABLE,Y     ; Floor Y-coordinate
        CMP $72,X               ; Compare entity attribute
        BEQ .found_descend
.no_match_d:
        DEX
        BPL .search_descend
.check_floor:
        LDA $06                 ; Floor counter
        LDX $0C
        CMP $83,X               ; Compare with limit
        BEQ .done_descend
        BNE .set_descend_dir
.found_descend:
        INY
        STY $0C                 ; Update descend index
        LDY #$00
        STY $04                 ; Clear state
        INY
        STY $8D,X               ; Activate entity
        STY $1D                 ; Set entity-found flag
        CLC
        LDA $06                 ; Advance floor counter
        ADC #$04
        STA $06
.set_descend_dir:
        LDA #OPCODE_JSR
        STA SMC_DESCEND         ; Enable descend
        LDA #OPCODE_BIT
        STA SMC_ASCEND          ; Disable ascend
        LDA $03                 ; Current floor
        BMI .clamp_low_d
        CMP #$03
        BCC .clamp_low_d
        CMP #$0A
        BCC .set_descend
        LDA #$09
        STA $03
        BPL .set_descend
.clamp_low_d:
        LDA #$03
        STA $03
.set_descend:
        LDY #$FF
        STY $02                 ; Set descend direction flag
        INY
        STY ZP_KEY_CODE         ; Clear key code
.done_descend:
        RTS

; --- Space key (jump) ---
.check_jump:
        CMP #KEY_JUMP
        BNE .unknown_key
        LDY #$FF
        STY ZP_JUMP_FLAG        ; Set jump flag
        BIT KBDSTROBE
.unknown_key:
        RTS
@ %def INPUT_DISPATCH INPUT_SET_RIGHT INPUT_SET_LEFT INPUT_DO_ASCEND INPUT_DO_DESCEND

\section{Meta-key handler}

[[INPUT_PROCESS]] at \$6109 handles non-movement keys during gameplay:
ESC pauses, Ctrl-R restarts, Ctrl-S toggles sound. Unrecognized keys
fall through to [[KEY_HANDLER_EXT]] at \$0194, which handles
Ctrl-J (joystick mode), Ctrl-K (keyboard mode), and Ctrl-V (speaker click).

<<input process defines>>=

; --- Meta-key codes ---
KEY_ESC         = $9B           ; ESC key (pause)
KEY_CTRL_R      = $92           ; Ctrl-R (restart game)
KEY_CTRL_S      = $93           ; Ctrl-S (toggle sound)
KEY_CTRL_J      = $8A           ; Ctrl-J (switch to joystick)
KEY_CTRL_K      = $8B           ; Ctrl-K (switch to keyboard)
KEY_CTRL_V      = $96           ; Ctrl-V (speaker click)

; --- Sound ---
; $36/$37 form an indirect pointer used by SFX_TONE ($67C1) as a
; speaker-click address.  $37 = $C0 (set during boot and never changed),
; so the effective target is $C0xx.  Bit 4 of $36 selects between:
;   $36 = $30 → ($36) points at $C030 (SW_SPEAKER) — clicks the speaker
;   $36 = $20 → ($36) points at $C020 (cassette output, unused) — silent
; Ctrl-S flips bit 4 to mute/unmute without touching the rest of the byte.
; $38 is a preserved copy used across game/attract transitions (ATTRACT_LOOP
; saves $36 into $38 on no-more-lives; restores $38 into $36 on game start).
SOUND_FLAG_MASK = $10           ; Bit that flips $C030↔$C020 in ZP_SFX_CLICK
@

<<input process>>=

        ORG $6109
INPUT_PROCESS:
        SUBROUTINE
        ; Meta-key handler — ESC/Ctrl-R/Ctrl-S and extended keys.
        ;
        ; Behavior:
        ;   Checks keyboard for special control keys. ESC pauses
        ;   (waits for next keypress). Ctrl-R restarts the game.
        ;   Ctrl-S toggles the sound flag. Other keys dispatch
        ;   to KEY_HANDLER_EXT.
        ;
        ; Modifies:
        ;   ZP_SFX_CLICK ($36), ZP_SFX_CLICK_SAVED ($38)
        ;   (Ctrl-S flips bit 4 to mute/unmute the SFX_TONE click target).
        ; Clobbers: A

        LDA KEYBOARD            ; Check for key
        BMI .got_key
        RTS                     ; No key
.got_key:
        CMP #KEY_ESC
        BNE .check_restart
        JSR PAUSE_HANDLER       ; Wait for next keypress
        BIT KBDSTROBE
        RTS

.check_restart:
        CMP #KEY_CTRL_R
        BNE .check_sound
        BIT KBDSTROBE
        JSR GAME_START_INIT     ; Restart game
        RTS

.check_sound:
        CMP #KEY_CTRL_S
        BEQ .toggle_sound
        JMP KEY_HANDLER_EXT     ; Try extended key handler

.toggle_sound:
        LDA ZP_SFX_CLICK        ; Flip bit 4 of the speaker-click pointer:
        EOR #SOUND_FLAG_MASK    ;   $30 (click $C030) ↔ $20 (silent $C020)
        STA ZP_SFX_CLICK        ; Update working copy
        STA ZP_SFX_CLICK_SAVED  ; Keep the preserved copy in sync
        BIT KBDSTROBE
        RTS
@ %def INPUT_PROCESS

\section{Pause handler}

[[PAUSE_HANDLER]] at \$0E51 clears the keyboard strobe, then waits in a
tight loop until a new key is pressed. Used by the ESC key to pause the game.

<<pause handler>>=

        ORG $0E51
PAUSE_HANDLER:
        ; Wait for keypress — clear strobe, loop until key available.
        BIT KBDSTROBE           ; Clear keyboard strobe
.wait:
        LDA KEYBOARD            ; Poll keyboard
        BPL .wait               ; Loop until bit 7 set
        RTS
@ %def PAUSE_HANDLER

\section{Screen row copy}

[[SCREEN_ROW_COPY]] at \$0100 copies all 192 rows of hi-res page~1 from
a 40-byte buffer at \$024C. For each screen row~X (0--191), it loads the
row's base address from a pair of tables (\$7380 for the low byte,
\$72C0 for the high byte), stores it in ZP pointer~\$29/\$2A, then copies
40~bytes from the buffer to that address. Between rows it calls the
Monitor [[WAIT]] routine for a brief delay and [[SCREEN_ROW_HELPER]] to
update game state (scrolling effect). The first call to
[[DISPLAY_PAGE_FLIP]] is gated on ZP~\$00 being positive (every other
frame).

<<screen row copy defines>>=

; --- Screen row tables (level data area) ---
SCREEN_ROW_ADDR_LO = $7380      ; Screen row address table, low bytes (192 entries)
SCREEN_ROW_ADDR_HI = $72C0      ; Screen row address table, high bytes (192 entries)

; --- Data buffer ---
ROW_COPY_BUFFER = $024C         ; 40-byte buffer holding row pixel data

; --- Apple II ROM ---
MON_WAIT        = $FCA8         ; Monitor WAIT: delay loop (A = duration)

; (SCREEN_ROW_HELPER has its own ORG chunk)
@

<<screen row copy>>=

        ORG $0100
SCREEN_ROW_COPY:
        SUBROUTINE
        ; Screen row copy — copies buffer to all 192 hi-res rows.
        ;
        ; Behavior:
        ;   Conditionally flips display page (if ZP $00 positive).
        ;   For each row X = 0..191:
        ;     Loads row address from tables, copies 40 bytes from buffer,
        ;     calls WAIT and SCREEN_ROW_HELPER.
        ;
        ; Modifies:
        ;   Hi-res page 1 ($2000-$3FFF), ZP $29/$2A
        ; Clobbers: A, X, Y

; --- Conditional page flip ---
        LDA $00
        BMI .skip_flip
        JSR DISPLAY_PAGE_FLIP    ; Flip page if ZP $00 positive
.skip_flip:

; --- Row loop ---
        LDX #$00
.row_loop:
        LDA SCREEN_ROW_ADDR_LO,X ; Row address low byte
        STA ZP_HGR_SRC           ; Store in pointer low
        LDA SCREEN_ROW_ADDR_HI,X ; Row address high byte
        STA ZP_HGR_SRC+1         ; Store in pointer high
        LDY #$27                  ; 40 bytes per row (0-$27)
.copy_byte:
        LDA ROW_COPY_BUFFER,Y    ; Read from buffer
        STA (ZP_HGR_SRC),Y       ; Write to screen row
        DEY
        BPL .copy_byte            ; Next byte
        LDA #$20
        JSR MON_WAIT              ; Brief delay
        JSR SCREEN_ROW_HELPER     ; Per-row helper
        INX
        CPX #$C0                  ; 192 rows
        BNE .row_loop
        RTS
@ %def SCREEN_ROW_COPY

\section{Projectile update}

[[HAZARD_CHECK]] at \$0E5A processes up to four active projectiles
(indexed by \$31 down to~0). Each projectile has three state bytes:
\begin{itemize}
\item \$C5+X: direction flag (0~=~inactive, negative~=~moving left,
  positive~=~moving right).
\item \$C9+X: horizontal screen position.
\item \$CD+X: vertical (Y) position.
\end{itemize}

Each frame the Y position increments by~2 (projectiles always fall).
If Y reaches a floor boundary (\$6B, \$93, or~\$BB) the projectile
deactivates. The horizontal position moves left or right by 4~pixels
per frame.  An extra 2~pixels are added when the player is moving in
the \emph{opposite} horizontal direction (parallax cue from
[[ZP_MOVE_DIR]] at \$04): left-moving projectiles speed up when
\$04 is positive (player moving right); right-moving projectiles
speed up when \$04 is negative (player moving left). If the
horizontal position exceeds \$91 the projectile is also deactivated.

After drawing, a collision check tests whether the projectile overlaps
the player. The player's horizontal position is taken as column range
\$40--\$47 (from ZP~\$06), and the vertical overlap is checked against
\$CD+X. A hit sets ZP~\$1E to \$FF and deactivates the projectile.

Left-moving projectiles use sprite tables at \$AFD3/\$B053; right-moving
ones use \$75F7/\$76F7. Screen column lookup is via \$1C34 indexed by
\$C9+X, and sprite frame selection via \$1B8F.

<<hazard check defines>>=

; --- Zero-page (projectile) ---
ZP_PROJ_MAX     = $31           ; Max active projectile slot index
ZP_PROJ_DIR     = $C5           ; Projectile direction (4 bytes: $C5-$C8)
ZP_PROJ_X       = $C9           ; Projectile horizontal position (4 bytes: $C9-$CC)
ZP_PROJ_Y       = $CD           ; Projectile vertical position (4 bytes: $CD-$D0)
ZP_MOVE_DIR     = $04           ; Player horizontal motion: $00 idle, $01 right, $FF left
ZP_PLAYER_COL   = $06           ; Player screen column
ZP_HIT_FLAG     = $1E           ; Hit detection flag ($FF = player hit)

; --- Projectile lookup tables ---
PROJ_SCREEN_COL = $1C34         ; Horizontal position → screen column
PROJ_FRAME_IDX  = $1B8F         ; Horizontal position → sprite frame index
PROJ_SPR_L_LO   = $AFD3         ; Left-moving projectile sprite table, low
PROJ_SPR_L_HI   = $B053         ; Left-moving projectile sprite table, high
PROJ_SPR_R_LO   = $75F7         ; Right-moving projectile sprite table, low
PROJ_SPR_R_HI   = $76F7         ; Right-moving projectile sprite table, high

@

<<hazard check>>=

        ORG $0E5A
HAZARD_CHECK:
        SUBROUTINE
        ; Projectile update — moves, draws, and collision-checks projectiles.
        ;
        ; Inputs:
        ;   $31 — max projectile slot index
        ;   $C5-$D0 — projectile state arrays
        ;
        ; Modifies:
        ;   $C5-$D0 (projectile state), sprite params, $1E (hit flag)
        ; Clobbers: A, X, Y

; --- Loop through projectile slots ---
        LDX ZP_PROJ_MAX
        BMI .done                 ; No projectiles if negative
.check_slot:
        LDA ZP_PROJ_DIR,X        ; Projectile direction
        BEQ .next                 ; 0 = inactive
        BMI .move_left            ; Negative = moving left
        JMP .move_right           ; Positive = moving right
.next:
        DEX
        BPL .check_slot
.done:
        RTS

; ========== Moving left ==========
.move_left:
        LDA ZP_PROJ_Y,X          ; Current Y position
        CLC
        ADC #$02                  ; Fall down 2 pixels
        CMP #$6B                  ; Floor 1?
        BEQ .deactivate
        CMP #$93                  ; Floor 2?
        BEQ .deactivate
        CMP #$BB                  ; Floor 3?
        BEQ .deactivate
        STA ZP_PROJ_Y,X          ; Update Y
        STA ZP_SPRITE_Y

        LDA ZP_PROJ_X,X          ; Current X position
        SEC
        SBC #$04                  ; Move left 4 pixels
        BIT ZP_MOVE_DIR           ; Check move direction
        BEQ .store_left_x         ; Zero = normal speed
        BMI .store_left_x         ; Negative = normal speed
        SEC
        SBC #$02                  ; Move left 2 more (total 6)
.store_left_x:
        STA ZP_PROJ_X,X
        CMP #$92                  ; Off screen?
        BCS .deactivate
        TAY
        JMP .draw_left

.deactivate:
        LDA #$00
        STA ZP_PROJ_DIR,X        ; Deactivate projectile
        JMP .next

; --- Draw left-moving projectile ---
.draw_left:
        LDA #$02
        STA ZP_SPRITE_W           ; Width = 2
        LDA #$03
        STA ZP_SPRITE_H           ; Height = 3
        LDA PROJ_SCREEN_COL,Y     ; Screen column from position
        STA ZP_SPRITE_X
        LDA PROJ_FRAME_IDX,Y      ; Sprite frame index
        TAY
        LDA PROJ_SPR_L_LO,Y       ; Left sprite data low
        STA SPRITE_PTR_LO
        LDA PROJ_SPR_L_HI,Y       ; Left sprite data high
        STA SPRITE_PTR_HI
        STX ZP_SAVE_X
        JSR DRAW_SPRITE      ; Draw projectile
        LDX ZP_SAVE_X
        JMP .collision_check

; ========== Moving right ==========
.move_right:
        LDA ZP_PROJ_Y,X          ; Current Y position
        CLC
        ADC #$02                  ; Fall down 2 pixels
        CMP #$6B                  ; Floor 1?
        BEQ .deactivate
        CMP #$93                  ; Floor 2?
        BEQ .deactivate
        CMP #$BB                  ; Floor 3?
        BEQ .deactivate
        STA ZP_PROJ_Y,X
        STA ZP_SPRITE_Y

        LDA ZP_PROJ_X,X          ; Current X position
        CLC
        ADC #$04                  ; Move right 4 pixels
        BIT ZP_MOVE_DIR
        BPL .store_right_x        ; Positive = normal speed
        CLC
        ADC #$02                  ; Move right 2 more (total 6)
.store_right_x:
        STA ZP_PROJ_X,X
        CMP #$92                  ; Off screen?
        BCS .deactivate
        TAY

; --- Draw right-moving projectile ---
        LDA #$02
        STA ZP_SPRITE_W           ; Width = 2
        LDA #$03
        STA ZP_SPRITE_H           ; Height = 3
        LDA PROJ_SCREEN_COL,Y     ; Screen column from position
        STA ZP_SPRITE_X
        LDA PROJ_FRAME_IDX,Y      ; Sprite frame index
        TAY
        LDA PROJ_SPR_R_LO,Y       ; Right sprite data low
        STA SPRITE_PTR_LO
        LDA PROJ_SPR_R_HI,Y       ; Right sprite data high
        STA SPRITE_PTR_HI
        STX ZP_SAVE_X
        JSR DRAW_SPRITE      ; Draw projectile
        LDX ZP_SAVE_X

; --- Player collision check ---
.collision_check:
        LDA ZP_PROJ_X,X          ; Projectile horizontal pos
        CMP #$40                  ; Left edge of player zone
        BCC .no_hit
        CMP #$48                  ; Right edge of player zone
        BCS .no_hit
        LDA ZP_PLAYER_COL         ; Player column
        SEC
        SBC #$03
        CMP ZP_PROJ_Y,X          ; Compare with projectile Y
        BCS .no_hit
        CLC
        ADC #$15                  ; Player height extent
        CMP ZP_PROJ_Y,X
        BCC .no_hit
        LDA #$FF
        STA ZP_HIT_FLAG           ; Signal player hit
        LDA #$00
        STA ZP_PROJ_DIR,X        ; Deactivate projectile
.no_hit:
        JMP .next
@ %def HAZARD_CHECK

\section{Joystick input handler}

[[JOYSTICK_HANDLER]] at \$012B reads the Apple~II game-port buttons and
paddles. The input dispatcher jumps here when joystick mode is active
(\$48 negative).

Buttons~0 and~1 both trigger a jump (\$05~=~\$FF). The zero-page flag
\$49 tracks press state to prevent auto-repeat: the jump flag is only
set on the initial button-down transition.

Paddle reading alternates between axes each frame, gated by the display
page flag in ZP~\$00 (which toggles sign every frame via
[[DISPLAY_PAGE_FLIP]]). On positive frames the vertical axis~(1) is
read; on negative frames the horizontal axis~(0). This spreads the
paddle timing overhead across two frames.

Vertical zones: $<$\$50 = ascend, \$50--\$AE = dead zone, $\ge$\$AF =
descend. Horizontal zones: $<$\$3C = hard left, \$3C--\$63 = soft left
(with hysteresis), \$64--\$9B = dead zone, \$9C--\$C2 = soft right
(with hysteresis), $\ge$\$C3 = hard right. In the soft zones the
joystick won't re-issue a direction command if the player is already
moving that way, preventing jitter at the threshold.

Each direction branch tail-calls into [[INPUT_DISPATCH]] at the
appropriate entry point to share the keyboard handler's direction-setting
logic.

<<joystick handler defines>>=

; --- Apple II ROM ---
PREAD           = $FB1E         ; Read paddle axis X → Y (ROM)

; --- Zero-page (input) ---
ZP_PAGE_FLAG    = $00           ; Display page flag (toggles sign each frame)
ZP_LAST_DIR     = $01           ; Last direction key code
ZP_JUMP_FLAG    = $05           ; Jump flag ($FF = jump requested)
ZP_KEY_CODE     = $07           ; Current key code
ZP_INPUT_MODE   = $48           ; Input mode (positive = keyboard, negative = joystick)
ZP_BTN_STATE    = $49           ; Button state ($FF = pressed, $01 = released)

; --- Joystick thresholds ---
JOY_V_UP        = $50           ; Vertical: below = ascend
JOY_V_DOWN      = $AF           ; Vertical: above = descend
JOY_H_LEFT_HARD = $3C           ; Horizontal: below = hard left
JOY_H_LEFT_SOFT = $64           ; Horizontal: below = soft left
JOY_H_RIGHT_SOFT = $9C          ; Horizontal: above = soft right
JOY_H_RIGHT_HARD = $C3          ; Horizontal: above = hard right
@

<<joystick handler>>=

        ORG $012B
JOYSTICK_HANDLER:
        SUBROUTINE
        ; Joystick input handler — reads buttons and paddles.
        ;
        ; Inputs:
        ;   SW_PUSH_BTN0/1 — button state (bit 7 = pressed)
        ;   ZP_PAGE_FLAG — selects vertical or horizontal axis
        ;
        ; Behavior:
        ;   Buttons: set jump flag on initial press.
        ;   Vertical axis (even frames): ascend or descend.
        ;   Horizontal axis (odd frames): move left or right.
        ;   Tail-calls into INPUT_DISPATCH entry points.
        ;
        ; Modifies:
        ;   ZP_BTN_STATE, ZP_JUMP_FLAG, direction slots via INPUT_DISPATCH
        ; Clobbers: A, X, Y

; --- Button handling ---
        LDA SW_PUSH_BTN0        ; Check button 0
        BPL .check_btn1         ; Not pressed → check button 1
.btn_pressed:
        LDA ZP_BTN_STATE        ; Already in pressed state?
        BMI .read_paddle        ; Yes → skip (no auto-repeat)
        LDA #$FF
        STA ZP_BTN_STATE        ; Mark as pressed
        STA ZP_JUMP_FLAG        ; Set jump flag
        BMI .read_paddle        ; Always taken

.check_btn1:
        LDA SW_PUSH_BTN1        ; Check button 1
        BMI .btn_pressed        ; Pressed → same as button 0
        LDA #$01
        STA ZP_BTN_STATE        ; Mark as released

; --- Paddle axis selection ---
.read_paddle:
        LDA ZP_PAGE_FLAG        ; Display page flag
        BMI .read_horizontal    ; Negative → horizontal axis

; --- Vertical axis (paddle 1) ---
        LDX #$01                ; Axis 1 = vertical
        JSR PREAD               ; Read paddle → Y
        CPY #JOY_V_UP           ; Above ascend threshold?
        BCS .check_descend_v    ; Yes → check descend zone
        JMP INPUT_DO_ASCEND     ; Ascend

.check_descend_v:
        CPY #JOY_V_DOWN         ; Above descend threshold?
        BCS .do_descend_v       ; Yes → descend
        RTS                     ; Dead zone — no action

.do_descend_v:
        JMP INPUT_DO_DESCEND    ; Descend

; --- Horizontal axis (paddle 0) ---
.read_horizontal:
        LDX #$00                ; Axis 0 = horizontal
        JSR PREAD               ; Read paddle → Y
        CPY #JOY_H_LEFT_HARD   ; Hard left zone?
        BCS .check_soft_left    ; No → check soft left
        LDA #KEY_LEFT           ; Left arrow key code
        JMP INPUT_SET_LEFT      ; Set left direction

.check_soft_left:
        CPY #JOY_H_LEFT_SOFT   ; Soft left zone?
        BCS .check_dead_zone    ; No → check dead zone
        LDA ZP_LAST_DIR         ; Already moving left?
        CMP #KEY_LEFT
        BEQ .no_change          ; Yes → no action (hysteresis)
        LDA #KEY_LEFT
        JMP INPUT_SET_LEFT      ; Set left direction

.no_change:
        RTS

.check_dead_zone:
        CPY #JOY_H_RIGHT_SOFT  ; In dead zone?
        BCS .check_soft_right   ; No → check right zones
        RTS                     ; Dead zone — no action

.check_soft_right:
        CPY #JOY_H_RIGHT_HARD  ; Hard right zone?
        BCS .hard_right         ; Yes → set right
        LDA ZP_LAST_DIR         ; Already moving right?
        CMP #KEY_RIGHT
        BEQ .no_change          ; Yes → no action (hysteresis)
        LDA #KEY_RIGHT
        JMP INPUT_SET_RIGHT     ; Set right direction

.hard_right:
        LDA #KEY_RIGHT
        JMP INPUT_SET_RIGHT     ; Set right direction
@ %def JOYSTICK_HANDLER

\section{Extended key handler}

[[KEY_HANDLER_EXT]] at \$0194 handles Ctrl-J (switch to joystick mode),
Ctrl-K (switch to keyboard mode), and Ctrl-V (click the speaker). Any
other key just clears the strobe and returns.

<<key handler ext>>=

        ORG $0194
KEY_HANDLER_EXT:
        SUBROUTINE
        ; Extended key handler — input mode switching and speaker.
        ;
        ; Inputs:
        ;   A — key code from keyboard
        ;
        ; Behavior:
        ;   Ctrl-J: set $48=$FF (joystick mode).
        ;   Ctrl-K: set $48=$01 (keyboard mode).
        ;   Ctrl-V: toggle speaker.
        ;   Other: clear strobe and return.
        ;
        ; Modifies:
        ;   ZP $48 (input mode flag)
        ; Clobbers: A

        CMP #KEY_CTRL_J
        BNE .check_kbd
        LDA #$FF
        STA ZP_INPUT_MODE       ; Joystick mode
        BIT KBDSTROBE
        RTS

.check_kbd:
        CMP #KEY_CTRL_K
        BNE .check_speaker
        LDA #$01
        STA ZP_INPUT_MODE       ; Keyboard mode
        BIT KBDSTROBE
        RTS

.check_speaker:
        CMP #KEY_CTRL_V
        BNE .unknown
        BIT SW_SPEAKER          ; Click speaker
.unknown:
        BIT KBDSTROBE           ; Clear strobe
        RTS
@ %def KEY_HANDLER_EXT

@ \chapter{Game loop}

The main game loop lives at \$67CB in the persistent game code area
(\$6000--\$66FF). Each frame calls approximately 25~subroutines that handle
rendering, input, physics, collision detection, and AI.

\section{Main loop dispatcher}

[[MAIN_LOOP]] at \$67CB calls subroutines in a fixed order each frame.
After all per-frame work, it increments the frame counter at \$FD, checks
two game-state flags (\$5E and \$39), and either loops back to \$67CB or
branches to level-complete (\$7208) or game-over (\$BDA0) handlers.

\paragraph{Attract mode.}
During the attract/title screen, the loop is entered via [[JSR $67D7]],
which skips the first three calls (rendering setup, scroll, and input).
Four [[BIT abs]] instructions at \$67D7--\$67E0 serve as 3-byte NOPs
during normal play; during attract mode they are the entry point that
harmlessly reads memory before falling through to the active subroutines.

\paragraph{Self-modifying patches.}
Three bytes are patched when transitioning from attract to game mode:
\begin{itemize}
\item \$67D1: changed from [[BIT]] (\$2C) to [[JSR]] (\$20) --- enables input handling
\item \$67EF: changed from [[BIT]] (\$2C) to [[JSR]] (\$20) --- enables another subsystem
\item \$6827: changed from [[JSR]] (\$20) to [[NOP]] (\$EA) --- disables attract-mode behavior
\end{itemize}

<<main loop>>=

        ORG $67CB
MAIN_LOOP:
        SUBROUTINE
        ; Main game loop — executes one frame of game logic.
        ;
        ; Behavior:
        ;   Calls ~25 subroutines for rendering, input, physics, AI.
        ;   Increments frame counter. Checks $5E (level complete) and
        ;   $39 (game over) flags to exit the loop.
        ;
        ; Modifies:
        ;   All game state via subroutine calls, ZP $FD (frame counter)
        ; Clobbers: A, X, Y

; --- Per-frame subroutine calls ---
        JSR LEVEL_INTRO_TICK    ; Level intro / countdown state tick
        JSR DIFFICULTY_UPDATE   ; Ramp difficulty tier from score
SMC_INPUT = *
        JSR INPUT_DISPATCH      ; Input handler (BIT during attract)
        JSR INPUT_PROCESS       ; Input processing

; --- Movement direction slots ($67D7) ---
; Each slot is either JSR (active direction) or BIT (inactive / attract).
; The input handler patches the opcode byte to toggle directions.
; During attract mode, all four are BIT (harmless reads).
ATTRACT_ENTRY:
SMC_ASCEND = *
        BIT DO_ASCEND           ; Ascend (JSR when active)
SMC_DESCEND = *
        BIT DO_DESCEND          ; Descend (JSR when active)
SMC_MOVE_LEFT = *
        BIT DO_MOVE_LEFT        ; Move left (JSR when active)
SMC_MOVE_RIGHT = *
        BIT DO_MOVE_RIGHT       ; Move right (JSR when active)

        JSR DISPLAY_PAGE_FLIP   ; Toggle hi-res display page
        JSR PLAYER_MOVE_TICK    ; Player movement tick dispatcher
        JSR ENEMY_AI_1          ; Enemy AI (part 1)
        JSR ENEMY_AI_2          ; Enemy AI (part 2)
SMC_RENDER = *
        JSR DRAW_PLAYER         ; Draw player sprite (BIT during attract)
        JSR SCREEN_EFFECTS      ; Screen effects
        JSR SCORE_DISPLAY       ; Score / status display
        JSR SOUND_UPDATE        ; Sound effects
        JSR ANIM_UPDATE         ; Animation update
        JSR ENTITY_PROCESS      ; Entity processing
        JSR LEVEL_LOGIC         ; Level logic
        JSR PROJECTILE_HANDLER  ; Projectile handling
        JSR HAZARD_CHECK        ; Hazard checking
        JSR ENEMY_C_ADVANCE     ; Enemy-C advance timer + respawn
        JSR ENEMY_C_DRAW        ; Enemy-C draw + enemy-slot collision
        JSR ENEMY_A_ADVANCE     ; Enemy-A advance timer + respawn
        JSR ENEMY_A_DRAW        ; Enemy-A draw + player-hit detection
        JSR ENEMY_B_ADVANCE     ; Enemy-B advance timer + respawn
        JSR ENEMY_B_DRAW        ; Enemy-B draw + player-hit detection
        JSR BEAM_UPDATE         ; Player laser-beam subsystem
        JSR DISPLAY_UPDATE      ; Display update
        JSR DRAW_ENTITIES       ; Entity draw dispatcher

; --- Frame end ---
        INC $FD                 ; Increment frame counter
SMC_ATTRACT = *
        NOP                     ; (JSR during attract mode)
        JSR POST_FRAME          ; Post-frame cleanup

; --- Exit checks ---
        LDA $5E                 ; Level-complete flag
        BPL .check_game_over
        JMP LEVEL_COMPLETE      ; Level complete handler
.check_game_over:
        LDA $39                 ; Game-over flag
        BPL .next_frame
        JMP GAME_OVER           ; Game over handler
.next_frame:
        JMP MAIN_LOOP           ; Next frame
@ %def MAIN_LOOP SMC_INPUT ATTRACT_ENTRY SMC_ASCEND SMC_DESCEND SMC_MOVE_LEFT SMC_MOVE_RIGHT SMC_RENDER SMC_ATTRACT

\section{Display page flip}

[[DISPLAY_PAGE_FLIP]] at \$6138 toggles the active hi-res display page
using self-modifying code. The instruction at \$6138 alternates between
[[LDA $C054]] (page~1) and [[LDA $C055]] (page~2) by XOR-patching its
own operand byte at \$6139. It also adjusts ZP \$00 by adding \$80 each
frame (a half-page scroll offset counter).

<<display page flip>>=

        ORG $6138
DISPLAY_PAGE_FLIP:
        ; Toggle hi-res display page via self-modifying LDA $C054/$C055.
        ;
        ; Behavior:
        ;   XOR-patches its own operand byte to alternate between
        ;   $C054 (page 1) and $C055 (page 2) each frame. Also
        ;   advances ZP $00 by $80.
        ;
        ; Modifies:
        ;   Display page soft switch, ZP $00, self ($6139)
        ; Clobbers: A
SMC_PAGE_SWITCH = *+1
        LDA $C055               ; Toggle display page (operand patched)
        LDA SMC_PAGE_SWITCH     ; Read current page switch low byte
        EOR #$01                ; Toggle $54 ↔ $55
        STA SMC_PAGE_SWITCH     ; Patch for next frame
        LDA ZP_PAGE_FLAG
        CLC
        ADC #$80                ; Advance scroll offset
        STA ZP_PAGE_FLAG
        RTS
@ %def DISPLAY_PAGE_FLIP SMC_PAGE_SWITCH

\section{Pseudo-random number generator}

[[PRNG]] at \$6674 generates an 8-bit pseudo-random value using a
two-byte state in ZP~\$1F and~\$5F. The algorithm shifts \$1F right one
bit, rotates the result into \$5F, XORs with the old \$1F, then swaps
the two state bytes. The result is returned in~A.

<<prng defines>>=

; --- Zero-page (PRNG state) ---
ZP_PRNG_A       = $5F           ; PRNG state byte A
@

<<prng>>=

        ORG $6674
PRNG:
        SUBROUTINE
        ; Pseudo-random number generator — 8-bit LFSR-style.
        ;
        ; Inputs:
        ;   ZP $1F, $5F — PRNG state
        ;
        ; Outputs:
        ;   A — pseudo-random value
        ;
        ; Modifies:
        ;   ZP $1F, $5F
        ; Clobbers: A, Y

        LDA ZP_ANIM_COUNTER       ; State byte 1
        LSR                       ; Shift right, bit 0 → carry
        LDA ZP_PRNG_A             ; State byte 2
        ROR                       ; Rotate carry in from left
        EOR ZP_ANIM_COUNTER       ; XOR with original state 1
        LDY ZP_PRNG_A             ; Save old state 2
        STA ZP_PRNG_A             ; Store new state 2
        STY ZP_ANIM_COUNTER       ; Swap: old state 2 → state 1
        RTS
@ %def PRNG

\section{Timer display update}

[[DISPLAY_UPDATE]] at \$10AB draws an animated timer element on the status
bar. It sets up a 1$\times$6 sprite at column~9, row~\$16, then indexes
the animation counter (ZP~\$1F) into frame tables at \$6800 and \$6900 to
select the current frame's tile data. The selected pair is stored at
\$6662/\$6663 and drawn via [[DRAW_SPRITE_OPAQUE]] at \$662C.

<<display update defines>>=

; --- Timer display tables ---
TIMER_FRAME_LO  = $6800         ; Timer animation frame table, low bytes
TIMER_FRAME_HI  = $6900         ; Timer animation frame table, high bytes

; --- Digit tile tables ---
DIGIT_TILE_LO   = $AFF6         ; Digit tile data table, low bytes (0-9)
DIGIT_TILE_HI   = $B076         ; Digit tile data table, high bytes (0-9)
@

<<display update>>=

        ORG $10AB
DISPLAY_UPDATE:
        SUBROUTINE
        ; Timer display update — draws animated timer element.
        ;
        ; Inputs:
        ;   ZP_ANIM_COUNTER ($1F) — animation frame index
        ;
        ; Modifies:
        ;   SMC_TILE_SRC_LO/HI (tile data pointer), sprite params
        ; Clobbers: A, X

; --- Set up sprite parameters ---
        LDA #$09
        STA ZP_SPRITE_X          ; Column = 9
        LDA #$01
        STA ZP_SPRITE_W          ; Width = 1
        LDA #$06
        STA ZP_SPRITE_H          ; Height = 6
        LDA #$16
        STA ZP_SPRITE_Y          ; Row = $16

; --- Select animation frame ---
        LDX ZP_ANIM_COUNTER      ; Current frame index
        LDA TIMER_FRAME_HI,X     ; Frame data high byte
        AND #$7F                  ; Strip high bit
        STA SMC_TILE_SRC_HI
        LDA TIMER_FRAME_LO,X     ; Frame data low byte
        STA SMC_TILE_SRC_LO
        JSR DRAW_SPRITE_OPAQUE    ; Draw the tile
        RTS
@ %def DISPLAY_UPDATE

\section{Score and status display}

[[POST_FRAME]] at \$10CF runs after each game frame to draw the score and
status digits on the screen. It extracts BCD nibbles from ZP~\$D1,
\$D2, and~\$D3, and draws each digit at a specific column position. The
level-state flag (\$5E) is also drawn as two digits.

Two helper sub-entries exist:
\begin{itemize}
\item \$1150 ([[DRAW_DIGIT_SHORT]]) sets width/height/row to 1/6/\$0C
  before falling through.
\item \$115C ([[DRAW_DIGIT]]) looks up digit tile data from tables at
  \$AFF6 (low) and \$B076 (high), stores it at [[SMC_TILE_SRC_LO]]/[[HI]]
  (\$6662/\$6663), and calls [[DRAW_SPRITE_OPAQUE]].
\end{itemize}

The digit positions (column values stored in~\$5D) are:
2, 4, 6, 8, and~10 for the five nibbles of D1--D3; columns~6 and~4
for the level-state digits.

<<post frame>>=

        ORG $10CF
POST_FRAME:
        SUBROUTINE
        ; Score and status display — draws BCD digits each frame.
        ;
        ; Inputs:
        ;   ZP_SCORE_HI/MID/LO ($D1/$D2/$D3) — BCD score
        ;   ZP_LEVEL_STATE ($5E) — level state flag
        ;
        ; Modifies:
        ;   Sprite parameters, SMC_TILE_SRC_LO/HI
        ; Clobbers: A, X

; --- Digit 1: low nibble of $D1, column 2 ---
        LDA ZP_SCORE_HI
        AND #$0F
        TAX
        LDA #$02
        STA ZP_SPRITE_X
        JSR DRAW_DIGIT_SHORT

; --- Digit 2: low nibble of $D2, column 6 ---
        LDA ZP_SCORE_MID
        AND #$0F
        TAX
        LDA #$06
        STA ZP_SPRITE_X
        JSR DRAW_DIGIT_SHORT

; --- Digit 3: high nibble of $D2, column 4 ---
        LDA ZP_SCORE_MID
        AND #$F0
        LSR
        LSR
        LSR
        LSR
        TAX
        LDA #$04
        STA ZP_SPRITE_X
        JSR DRAW_DIGIT_SHORT

; --- Digit 4: low nibble of $D3, column $0A ---
        LDA ZP_SCORE_LO
        AND #$0F
        TAX
        LDA #$0A
        STA ZP_SPRITE_X
        JSR DRAW_DIGIT_SHORT

; --- Digit 5: high nibble of $D3, column 8 ---
        LDA ZP_SCORE_LO
        AND #$F0
        LSR
        LSR
        LSR
        LSR
        TAX
        LDA #$08
        STA ZP_SPRITE_X
        JSR DRAW_DIGIT_SHORT

; --- Level state digit 1: low nibble of $5E, column 6 ---
        LDA ZP_LEVEL_STATE
        BPL .level_ok1
        LDA #$00                  ; Clamp negative to 0
.level_ok1:
        AND #$0F
        TAX
        LDA #$01
        STA ZP_SPRITE_W
        LDA #$06
        STA ZP_SPRITE_H
        LDA #$16
        STA ZP_SPRITE_Y
        LDA #$06
        STA ZP_SPRITE_X
        JSR DRAW_DIGIT

; --- Level state digit 2: high nibble of $5E, column 4 ---
        LDA ZP_LEVEL_STATE
        BPL .level_ok2
        LDA #$00                  ; Clamp negative to 0
.level_ok2:
        AND #$F0
        LSR
        LSR
        LSR
        LSR
        TAX
        LDA #$01
        STA ZP_SPRITE_W
        LDA #$06
        STA ZP_SPRITE_H
        LDA #$16
        STA ZP_SPRITE_Y
        LDA #$04
        STA ZP_SPRITE_X
        JSR DRAW_DIGIT
        RTS

; --- Helper: draw digit with default sprite params ---
DRAW_DIGIT_SHORT:
        LDA #$01
        STA ZP_SPRITE_W          ; Width = 1
        LDA #$06
        STA ZP_SPRITE_H          ; Height = 6
        LDA #$0C
        STA ZP_SPRITE_Y          ; Row = $0C
; --- Draw digit from lookup table ---
DRAW_DIGIT:
        LDA DIGIT_TILE_LO,X      ; Digit tile data low
        STA SMC_TILE_SRC_LO
        LDA DIGIT_TILE_HI,X      ; Digit tile data high
        STA SMC_TILE_SRC_HI
        JSR DRAW_SPRITE_OPAQUE    ; Draw the digit tile
        RTS
@ %def POST_FRAME DRAW_DIGIT_SHORT DRAW_DIGIT

\section{High score check}

[[LEVEL_TRANSITION]] at \$116C is called during the level-complete
sequence. It performs a 3-byte BCD comparison of the current score
(\$D1/\$D2/\$D3) against the stored high score (\$20/\$21/\$22). If the
current score does not exceed the high score, it returns immediately.

When a new high score is detected, it copies the current score into the
high-score slots, then copies six rows of the score display area from
hi-res page~1 to page~2 (rows~\$0C--\$11). The source address comes from
[[SCREEN_ROW_ADDR_LO]]/[[SCREEN_ROW_ADDR_HI]] offset by~1 (skipping
the first byte of each row), and the destination uses a second high-byte
table at \$7440 (page~2 addresses). This makes the high-score area
visible on both display pages.

<<level transition defines>>=

; --- Zero-page (high score) ---
ZP_HIGH_SCORE_0 = $20           ; High score byte 0 (highest BCD digits)
ZP_HIGH_SCORE_1 = $21           ; High score byte 1
ZP_HIGH_SCORE_2 = $22           ; High score byte 2

; --- Screen row address table (page 2) ---
SCREEN_ROW_ADDR_HI2 = $7440    ; Hi-res page 2 row address high bytes
@

<<level transition>>=

        ORG $116C
LEVEL_TRANSITION:
        SUBROUTINE
        ; High score check — updates high score and copies display rows.
        ;
        ; Inputs:
        ;   ZP_SCORE_HI/MID/LO ($D1/$D2/$D3) — current score (BCD)
        ;   ZP_HIGH_SCORE_0/1/2 ($20/$21/$22) — stored high score (BCD)
        ;
        ; Modifies:
        ;   $20-$22 (if new high score), hi-res page 2 rows
        ; Clobbers: A, X, Y

; --- BCD comparison: high score >= current score? ---
        SED
        SEC
        LDA ZP_HIGH_SCORE_2      ; Compare byte 2 (low digits)
        SBC ZP_SCORE_LO
        LDA ZP_HIGH_SCORE_1      ; Compare byte 1
        SBC ZP_SCORE_MID
        LDA ZP_HIGH_SCORE_0      ; Compare byte 0 (high digits)
        SBC ZP_SCORE_HI
        CLD
        BCC .new_high_score       ; Carry clear = current > high
        RTS                       ; No new high score

; --- Update high score ---
.new_high_score:
        LDA ZP_SCORE_HI
        STA ZP_HIGH_SCORE_0
        LDA ZP_SCORE_MID
        STA ZP_HIGH_SCORE_1
        LDA ZP_SCORE_LO
        STA ZP_HIGH_SCORE_2

; --- Copy score display rows from page 1 to page 2 ---
        LDX #$0C                  ; Start at row $0C
.copy_row:
        LDA SCREEN_ROW_ADDR_HI,X ; Page 1 row address high
        STA $24                   ; Dest pointer A high
        STA $26                   ; Dest pointer B high
        LDA SCREEN_ROW_ADDR_HI2,X ; Page 2 row address high
        STA $28                   ; Source pointer high
        LDA SCREEN_ROW_ADDR_LO,X ; Row address low
        CLC
        ADC #$01                  ; Skip first byte of row
        STA $23                   ; Dest pointer A low
        CLC
        ADC #$1D                  ; Offset to second half
        STA $25                   ; Dest pointer B low
        STA $27                   ; Source pointer low
        LDY #$09                  ; Copy 10 bytes per row
.copy_byte:
        LDA ($23),Y               ; Read from page 1
        STA ($25),Y               ; Write to page 2 (half A)
        STA ($27),Y               ; Write to page 2 (half B)
        DEY
        BPL .copy_byte
        INX
        CPX #$12                  ; Rows $0C through $11
        BNE .copy_row
        RTS
@ %def LEVEL_TRANSITION

\section{Level state initialization}

[[INIT_LEVEL_STATE]] at \$11B8 restores game state from three buffer
areas in page~2 memory, then zeros out entity slots and direction
patches.

Three block copies restore ZP regions from saved buffers:
\begin{itemize}
\item \$029C--\$02B4 $\to$ \$D4--\$EC (25~bytes, entity parameters)
\item \$02E2--\$02FF $\to$ \$01--\$1E (30~bytes, input/direction state)
\item \$02B5--\$02E1 $\to$ \$88--\$B4 (45~bytes, sprite/collision state)
\end{itemize}

After restoring state, it zeroes the entity activity table at
\$03A8--\$03BB, the movement slots at \$C5--\$C8,
[[ZP_MOVE_DIR]] (\$04, player horizontal move direction), and the
frame counter~\$FD. It also zeroes \$03FF, sets
\$4B/\$4C~=~2, \$39~=~1, fills \$0237--\$023B with \$FF, and patches
the four direction slots in the main loop to [[BIT]] (\$2C, inactive).
Finally it loads two bytes from \$029A/\$029B into \$42/\$43.

<<init level state>>=

        ORG $11B8
INIT_LEVEL_STATE:
        SUBROUTINE
        ; Level state initialization — restores game state from buffers.
        ;
        ; Modifies:
        ;   ZP $01-$1E, $39, $42-$43, $4B-$4C, $88-$B4, $C5-$C8,
        ;   $D4-$EC, $FD, $03A8-$03BB, $03FF, $0237-$023B,
        ;   Main loop direction patches ($67D7-$67E0)
        ; Clobbers: A, X

; --- Restore entity parameters ($029C → $D4, 25 bytes) ---
        LDX #$18
.copy_entities:
        LDA $029C,X
        STA $D4,X
        DEX
        BPL .copy_entities

; --- Restore input/direction state ($02E2 → $01, 30 bytes) ---
        LDX #$1D
.copy_input:
        LDA $02E2,X
        STA $01,X
        DEX
        BPL .copy_input

; --- Restore sprite/collision state ($02B5 → $88, 45 bytes) ---
        LDX #$2C
.copy_sprites:
        LDA $02B5,X
        STA $88,X
        DEX
        BPL .copy_sprites

; --- Zero entity activity table ($03A8-$03BB) ---
        LDA #$00
        LDX #$13
.zero_entities:
        STA ENTITY_ACTIVE,X
        DEX
        BPL .zero_entities

; --- Zero movement slots ($C5-$C8) ---
        LDX #$03
.zero_movement:
        STA $C5,X
        DEX
        BPL .zero_movement

        STA ZP_MOVE_DIR           ; Clear player horizontal move direction
        STA $FD                   ; Clear frame counter
        STA $03FF                 ; Clear floor flag

; --- Initialize game-state variables ---
        LDX #$02
        STX $4B                   ; Unknown state A
        STX $4C                   ; Unknown state B
        DEX
        STX $39                   ; Set game-over flag to 1

; --- Fill $0237-$023B with $FF ---
        LDA #$FF
        LDX #$04
.fill_ff:
        STA $0237,X
        DEX
        BPL .fill_ff

; --- Disable all direction slots (BIT = inactive) ---
        LDA #$2C                  ; BIT abs opcode
        STA SMC_ASCEND            ; Disable ascend
        STA SMC_DESCEND           ; Disable descend
        STA SMC_MOVE_LEFT         ; Disable move left
        STA SMC_MOVE_RIGHT        ; Disable move right

; --- Load game parameters ---
        LDA $029A
        STA $42                   ; Unknown param A
        LDA $029B
        STA $43                   ; Unknown param B
        RTS
@ %def INIT_LEVEL_STATE

\section{Score add}

[[SCORE_ADD]] at \$121A adds a BCD value to the 3-byte score. The
addend's low byte is in ZP~\$1A and high byte in ZP~\$1B; these are added
to \$D3 and \$D2 respectively, with carry propagating into \$D1. All
arithmetic is performed in BCD mode.

<<score add defines>>=

; --- Zero-page (score add) ---
ZP_SCORE_ADD_LO = $1A           ; Score addend low byte (BCD)
ZP_SCORE_ADD_HI = $1B           ; Score addend high byte (BCD)
@

<<score add>>=

        ORG $121A
SCORE_ADD:
        SUBROUTINE
        ; Score add — adds BCD value to 3-byte score.
        ;
        ; Inputs:
        ;   ZP_SCORE_ADD_LO/HI ($1A/$1B) — BCD addend
        ;
        ; Modifies:
        ;   ZP_SCORE_HI/MID/LO ($D1/$D2/$D3)
        ; Clobbers: A

        SED                       ; BCD mode
        CLC
        LDA ZP_SCORE_LO          ; Score low byte
        ADC ZP_SCORE_ADD_LO       ; Add low addend
        STA ZP_SCORE_LO
        LDA ZP_SCORE_MID          ; Score mid byte
        ADC ZP_SCORE_ADD_HI       ; Add high addend + carry
        STA ZP_SCORE_MID
        LDA ZP_SCORE_HI          ; Score high byte
        ADC #$00                  ; Propagate carry only
        STA ZP_SCORE_HI
        CLD                       ; Exit BCD mode
        RTS
@ %def SCORE_ADD

\section{Game start initialization}

[[GAME_START_INIT]] at \$13A4 is called from the attract loop when the
player presses a key or button. It resets the player position to the
starting Y-coordinate (\$6B), zeros the three score digits (\$2B--\$2D),
sets the initial lives count, calls two initialization subroutines
([[DIFFICULTY_RESET]] and [[INIT_LEVEL_STATE]]), and then tail-calls
[[LOAD_LEVEL]] to load the first level.

<<game start init defines>>=

; --- Zero-page (game start) ---
ZP_PLAYER_Y     = $4A           ; Player Y position
ZP_SCORE_0      = $2B           ; Score digit 0 (ones)
ZP_SCORE_1      = $2C           ; Score digit 1 (tens)
ZP_SCORE_2      = $2D           ; Score digit 2 (hundreds)
ZP_LIVES        = $2E           ; Lives remaining
ZP_LEVEL_STATE  = $5E           ; Level state flag
ZP_LEVEL_NUM    = $46           ; Current level number
ZP_HIGH_SCORE_FLAG = $44        ; High score flag ($FF = no high score)

; --- Game state ---
SCORE_DISPLAY_VAL = $65AB       ; Score display value
LIVES_DISPLAY_VAL = $65A7       ; Lives display value
ZP_SCORE_HI     = $D1           ; BCD score, high byte (ten-thousands / hundred-thousands)
ZP_SCORE_MID    = $D2           ; BCD score, middle byte (thousands / hundreds)
ZP_SCORE_LO     = $D3           ; BCD score, low byte (tens / ones)

; --- Subroutine stubs (game start) ---
; (INIT_LEVEL_STATE has its own ORG chunk)
LOAD_LEVEL      = $6AA7         ; Load level data (in game engine hex data)
@

<<game start init>>=

        ORG $13A4
GAME_START_INIT:
        SUBROUTINE
        ; Game start initialization — reset player and game state.
        ;
        ; Behavior:
        ;   Sets player Y to starting position ($6B).
        ;   Zeros score digits. Sets initial lives ($27).
        ;   Calls entity and level initialization.
        ;   Tail-calls LOAD_LEVEL to begin first level.
        ;
        ; Modifies:
        ;   ZP_SCORE_0..2, ZP_LIVES, ZP_HIGH_SCORE_FLAG, ZP_LEVEL_NUM,
        ;   ZP_PLAYER_Y, ZP_LEVEL_STATE, ZP_SCORE_HI/MID/LO,
        ;   SCORE_DISPLAY_VAL, LIVES_DISPLAY_VAL
        ; Clobbers: A, X

; --- Player start position ---
        LDA #$6B
        STA ZP_PLAYER_Y         ; Starting Y position

; --- Clear score ---
        LDA #$00
        STA ZP_SCORE_0           ; Score digit 0
        STA ZP_SCORE_1           ; Score digit 1
        STA ZP_SCORE_2           ; Score digit 2
        STA SCORE_DISPLAY_VAL    ; Clear score display

; --- Set initial lives ---
        LDA #$27
        STA ZP_LIVES             ; Initial lives count
        LDA #$28
        STA LIVES_DISPLAY_VAL    ; Initial lives display value

; --- Initialize subsystems ---
        JSR DIFFICULTY_RESET     ; Set minimum difficulty preset
        JSR INIT_LEVEL_STATE     ; Reset level state tables

; --- Set level state ---
        LDA #$04
        STA ZP_LEVEL_STATE       ; Initial level state
        LDX #$00
        STX ZP_SCORE_HI          ; Clear score high byte
        STX ZP_SCORE_MID         ; Clear score mid byte
        STX ZP_SCORE_LO          ; Clear score low byte
        STX ZP_LEVEL_NUM         ; Start at level 0
        DEX
        STX ZP_HIGH_SCORE_FLAG   ; No high score yet ($FF)

; --- Load first level ---
        JMP LOAD_LEVEL           ; Tail-call: load level data
@ %def GAME_START_INIT

\section{Difficulty update}

[[DIFFICULTY_UPDATE]] at \$719D is called once per frame from
[[MAIN_LOOP]], but only does work on the frame where the free-running
counter [[ZP_FRAME_COUNTER]] wraps to zero --- i.e.\ about every
256~frames ($\sim$4~seconds at 60~Hz).  On that frame it promotes the
game to a harder difficulty tier whenever the player's score has
climbed into a new bracket.

The tier index is built by combining two BCD digits of
[[ZP_SCORE_HI]]/[[ZP_SCORE_MID]]: the ten-thousands digit goes in the
high nibble and the thousands digit in the low nibble.  (These are the
two leftmost digits of the on-screen 5-digit score; see [[POST_FRAME]]
for how they are drawn.)  The resulting byte is compared against three
thresholds that pick one of four presets.  Each preset writes into six
shared ZP variables that other per-frame routines consult:

\begin{center}
\begin{tabular}{l|l|l|l|l|l|l|l}
Tier (score)       & Index & \$31 & \$32 & \$33 & \$34 & \$35 & \$40 \\
\hline
Minimum (<4000)    & <\$04   & \$FF & \$FF & \$FF & \$00 & \$50 & \$01 \\
Moderate (4000--9999) & \$04--\$0F & \$00 & \$FF & \$01 & \$40 & ---  & ---  \\
Standard (10000--17999) & \$10--\$17 & \$01 & \$01 & \$01 & \$80 & ---  & \$02 \\
Maximum (18000+)   & \$18+  & \$03 & \$01 & \$01 & \$F0 & \$30 & \$03 \\
\end{tabular}
\end{center}

A cell of~--- means that preset does not touch that variable, so it
retains the value left by the previous tier or by [[DIFFICULTY_RESET]].
The three ``slot count'' variables ($31, $32, $33) are gates for
indexed loops elsewhere in the engine: \$FF flags the BMI-guarded
loops as empty.  [[HAZARD_CHECK]] at \$0E5A reads [[ZP_PROJ_MAX]]
($31); [[BEAM_UPDATE]] at \$130A checks [[ZP_PROJ_GATE]] ($32) as a
single-bit enable (\$FF~=~subsystem off, otherwise on); and the
[[DRAW_ENTITIES]] phase-4 companion draw gates on
[[ZP_COMPANION_GATE]] ($33).  Thus the beam is disabled at the
minimum and moderate tiers and enabled from ``standard'' onward
($\geq$~10000 points).  \$40 ([[ZP_ADVANCE_RATE]]) is the per-tick
decrement applied to the 16-bit counters at \$DD/\$DE and
\$D5/\$D6 by the as-yet-unlabelled routines at \$13F4 and \$1670 ---
a larger rate means those events fire more often.

The sub-entry at [[DIFFICULTY_RESET]] (\$71D6) also serves as the
minimum-tier preset and is called directly by [[GAME_START_INIT]] when
a new game begins.  Note that nothing in this routine scrolls or
touches the camera: the previous label [[SCROLL_CAMERA]] was a
placeholder guess and has been retired.

<<difficulty update defines>>=

; --- Zero-page (difficulty tiers) ---
ZP_DIFF_TMP     = $5C           ; Scratch: holds D2 high nibble shifted right
ZP_PROJ_GATE    = $32           ; Beam-subsystem gate (BPL=active; $FF=suppress)
                                ; Read at entry of BEAM_UPDATE ($130A).
ZP_DIFF_THRESH_A = $34          ; Primary tier threshold (varies: $00/$40/$80/$F0)
ZP_DIFF_THRESH_B = $35          ; Secondary tier threshold ($50 min, $30 max)
ZP_ADVANCE_RATE = $40           ; Per-tick decrement for 16-bit event timers
                                ; Read by $13F7 SBC $40 and $1675 SBC $40.
ZP_FRAME_COUNTER = $FD          ; Free-running frame counter (incremented in MAIN_LOOP)

@

<<difficulty update>>=

        ORG $719D
DIFFICULTY_UPDATE:
        SUBROUTINE
        ; Per-frame difficulty ramp.  When the free-running frame
        ; counter wraps to zero, promotes game parameters to the tier
        ; dictated by the current score.
        ;
        ; Inputs:
        ;   ZP_FRAME_COUNTER ($FD)          --- run only when zero.
        ;   ZP_SCORE_HI ($D1) low nibble    --- ten-thousands digit.
        ;   ZP_SCORE_MID ($D2) high nibble  --- thousands digit.
        ;
        ; Behavior:
        ;   Builds tier index = (D1_lo << 4) | (D2_hi >> 4), dispatches
        ;   to one of four presets by comparing against $04/$10/$18.
        ;   Each preset writes slot-count maxima ($31, $32, $33), tier
        ;   thresholds ($34, $35), and timer-advance rate ($40).
        ;
        ; Modifies:
        ;   ZP_PROJ_MAX ($31), ZP_PROJ_GATE ($32), ZP_COMPANION_GATE ($33),
        ;   ZP_DIFF_THRESH_A ($34), ZP_DIFF_THRESH_B ($35),
        ;   ZP_ADVANCE_RATE ($40), ZP_DIFF_TMP ($5C).
        ; Clobbers: A, X

; --- Guard: only run on frame-counter wrap ---
        LDA ZP_FRAME_COUNTER
        BNE .done

; --- Build tier index from BCD score ---
        LDA ZP_SCORE_MID                ; Thousands digit in high nibble
        AND #$F0
        LSR
        LSR
        LSR
        LSR
        STA ZP_DIFF_TMP                 ; ...shifted to low nibble
        LDA ZP_SCORE_HI                 ; Ten-thousands digit in low nibble
        AND #$0F
        ASL
        ASL
        ASL
        ASL                             ; ...shifted to high nibble
        ORA ZP_DIFF_TMP                 ; Index = (D1_lo << 4) | (D2_hi >> 4)

; --- Dispatch by tier threshold ---
        CMP #$04
        BCC DIFFICULTY_RESET            ; <$04: minimum tier (tail-call)
        CMP #$10
        BCC .tier_moderate              ; $04..$0F: moderate tier
        CMP #$18
        BCC .tier_standard              ; $10..$17: standard tier

; --- Tier: maximum (index >= $18, score >= 18000) ---
        LDA #$03
        STA ZP_ADVANCE_RATE             ; Fast 16-bit timer advance
        STA ZP_PROJ_MAX                 ; 4 projectile slots (index 0..3)
        LDA #$01
        STA ZP_PROJ_GATE                ; Enemy slot active
        STA ZP_COMPANION_GATE           ; Companion slot active
        LDA #$F0
        STA ZP_DIFF_THRESH_A            ; Max primary threshold
        LDA #$30
        STA ZP_DIFF_THRESH_B            ; Max secondary threshold
.done:
        RTS

; --- Tier: minimum (index < $04, score < 4000) ---
; Also entered directly by GAME_START_INIT to reset difficulty.
DIFFICULTY_RESET:
        LDX #$FF
        STX ZP_PROJ_MAX                 ; No projectiles
        STX ZP_PROJ_GATE                ; Enemy slot suppressed
        STX ZP_COMPANION_GATE           ; Companion slot suppressed
        INX                             ; X=$00
        STX ZP_DIFF_THRESH_A            ; Zero primary threshold
        INX                             ; X=$01
        STX ZP_ADVANCE_RATE             ; Slow 16-bit timer advance
        LDA #$50
        STA ZP_DIFF_THRESH_B            ; Min secondary threshold
        RTS

; --- Tier: moderate (index $04..$0F, score 4000-9999) ---
.tier_moderate:
        LDX #$FF
        STX ZP_PROJ_GATE                ; Enemy slot suppressed
        INX                             ; X=$00
        STX ZP_PROJ_MAX                 ; 1 projectile slot
        INX                             ; X=$01
        STX ZP_COMPANION_GATE           ; Companion slot active
        LDA #$40
        STA ZP_DIFF_THRESH_A            ; Moderate primary threshold
        RTS

; --- Tier: standard (index $10..$17, score 10000-17999) ---
.tier_standard:
        LDX #$01
        STX ZP_PROJ_MAX                 ; 2 projectile slots
        STX ZP_PROJ_GATE                ; Enemy slot active
        STX ZP_COMPANION_GATE           ; Companion slot active
        INX                             ; X=$02
        STX ZP_ADVANCE_RATE             ; Medium 16-bit timer advance
        LDA #$80
        STA ZP_DIFF_THRESH_A            ; Standard primary threshold
        RTS
@ %def DIFFICULTY_UPDATE DIFFICULTY_RESET

\section{Level complete handler}

[[LEVEL_COMPLETE]] at \$7208 runs when the level-complete flag (\$5E)
goes negative. It first clears the keyboard strobe, calls a transition
routine, then patches the main loop to disable attract behavior.

If extra lives remain (\$8C $>$ 0), the handler loops showing an
extra-life animation. Each iteration decrements the extra-life counter,
sets up sprite parameters, draws a sprite, and runs one frame of the
main loop. During this animation, keyboard or joystick input is polled;
if detected, control transfers to the attract loop's input-detection
code.

When the extra-life count reaches zero, [[GAME_START_INIT]] is called
to reset game state, the sound flag is refreshed, sprite rendering is
re-enabled, and execution falls through into [[ATTRACT_LOOP]].

<<level complete defines>>=

; --- Subroutine stubs (level complete) ---
; (LEVEL_TRANSITION has its own ORG chunk)
; (DRAW_SPRITE / SPRITE_PTR_LO / SPRITE_PTR_HI have their own ORG chunk)
; (ZP_SPRITE_W / _H / _Y / _X live in draw sprite defines)
SMC_ATTRACT_RTS = $6827         ; Self-mod: attract loop control
; SMC_SR_YSRC ($64FA) / SMC_SR_HEIGHT ($64F6) are the operand bytes of
; DRAW_PLAYER's idle-path "LDA $06" and "LDA #$13" (sprite Y source and
; height).  Declared in the draw-player defines chunk.  LEVEL_COMPLETE
; reasserts their default values ($06 / $13) on entry because
; LEVEL_INTRO_TICK may have patched them for the countdown animation.

; --- Zero-page (level complete) ---
ZP_EXTRA_LIVES  = $8C           ; Extra lives counter for animation
; ZP_SFX_CLICK / ZP_SFX_CLICK_SAVED are the low bytes of the speaker-click
; pointer used by SFX_TONE ($67C1).  See the sound section of the input
; processor for how $36/$38 encode sound on/off via bit 4.
ZP_SFX_CLICK       = $36        ; Current SFX click pointer low ($20 silent, $30 speaker)
ZP_SFX_CLICK_SAVED = $38        ; Preserved copy across attract/game transitions
@

<<level complete>>=

        ORG $7208
LEVEL_COMPLETE:
        SUBROUTINE
        ; Level complete handler — shows extra-life animation, restarts.
        ;
        ; Inputs:
        ;   ZP_EXTRA_LIVES ($8C) — extra lives to animate
        ;
        ; Behavior:
        ;   Animates each extra life with a sprite loop.
        ;   Polls input during animation.
        ;   When done, calls GAME_START_INIT and falls into ATTRACT_LOOP.
        ;
        ; Modifies:
        ;   $8C, sprite parameters, main loop patches
        ; Clobbers: A, X, Y

; --- Initialization ---
        LDA KBDSTROBE            ; Clear keyboard strobe
        JSR LEVEL_TRANSITION     ; Transition effects
        LDA #$60                 ; RTS opcode
        STA SMC_ATTRACT_RTS      ; Patch: disable attract subroutine
        LDA #$06
        STA SMC_SR_YSRC          ; Reset DRAW_PLAYER Y source to ZP_PLAYER_COL
        LDA #$13
        STA SMC_SR_HEIGHT        ; Reset DRAW_PLAYER sprite height to default

; --- Extra-life animation loop ---
.check_extra:
        LDA ZP_EXTRA_LIVES       ; Extra lives remaining?
        BEQ .no_more_lives       ; None left → start new game
        DEC ZP_EXTRA_LIVES       ; Consume one extra life

; --- Draw extra-life sprite ---
        LDA #$06
        STA ZP_SPRITE_W          ; Sprite width = 6
        LDA #$0E
        STA ZP_SPRITE_H          ; Sprite height = 14
        LDA #$2E
        STA ZP_SPRITE_Y          ; Y position = $2E
        LDA #$17
        STA ZP_SPRITE_X          ; X column = $17
        LDA #$7D
        STA SPRITE_PTR_LO        ; Sprite data pointer low
        LDA #$B6
        STA SPRITE_PTR_HI        ; Sprite data pointer high
        JSR DRAW_SPRITE     ; Draw extra-life sprite

; --- Poll input during animation ---
        LDA KEYBOARD             ; Check keyboard
        BMI ATTRACT_KEY_DETECT   ; Key pressed → handle input
        LDY #$00
        LDA (ZP_INPUT_1),Y       ; Check joystick button 1
        BMI ATTRACT_JOY_DETECT   ; Pressed → handle input
        LDA (ZP_INPUT_2),Y       ; Check joystick button 2
        BMI ATTRACT_JOY_DETECT   ; Pressed → handle input

; --- Run one frame and continue loop ---
        JSR MAIN_LOOP            ; Run one game frame
        JMP .check_extra         ; Check for more extra lives

; --- No more extra lives: reset and restart ---
.no_more_lives:
        JSR GAME_START_INIT      ; Reset game state
        LDA ZP_SFX_CLICK         ; Save current sound-on/off state
        STA ZP_SFX_CLICK_SAVED   ;   into the preserved slot
        LDA #OPCODE_JSR          ; $20 — JSR opcode AND "silent" pointer low
        STA ZP_SFX_CLICK         ; Force attract mode to silent
        STA SMC_RENDER           ; Re-enable sprite rendering (same $20 byte)
                                 ; Fall through to ATTRACT_LOOP
@ %def LEVEL_COMPLETE

\section{Attract entity movement}

[[ATTRACT_ANIM_1]] at \$17A6 updates the vertical positions of up to four
attract-mode entities (X~=~3 down to~0). Each entity has a direction flag
in \$88+X: negative means moving down, positive means moving up, zero
means inactive.

When moving down, the Y position (\$E9+X) increments by~2 each frame
until it reaches \$6A, at which point the direction reverses to~up.
When moving up, the Y position decrements by~2 until it reaches \$52.
At the top, a pseudo-random check (via [[PRNG]] at \$6674) determines
whether to reverse; if the random value is less than~5 the entity keeps
pausing, otherwise it reverses to move down again.

<<attract anim 1 defines>>=

; --- Zero-page (attract entity movement) ---
ZP_ATTRACT_ENT_DIR = $88        ; Entity direction flags (4 bytes: $88-$8B)
ZP_ATTRACT_ENT_Y   = $E9       ; Entity Y positions (4 bytes: $E9-$EC)
ZP_ATTRACT_ENT_X   = $E5       ; Entity X columns (4 bytes: $E5-$E8)
ZP_ATTRACT_ENT_W   = $ED       ; Entity widths (4 bytes: $ED-$F0)

; (PRNG has its own ORG chunk)
@

<<attract anim 1>>=

        ORG $17A6
ATTRACT_ANIM_1:
        SUBROUTINE
        ; Attract entity movement — updates Y positions of 4 entities.
        ;
        ; Inputs:
        ;   $88+X — direction (negative=down, positive=up, zero=skip)
        ;   $E9+X — Y position
        ;
        ; Modifies:
        ;   $88+X (direction), $E9+X (Y position)
        ; Clobbers: A, X

        LDX #$03
.check_entity:
        LDA ZP_ATTRACT_ENT_DIR,X ; Direction flag
        BMI .moving_down          ; Negative → moving down
        BNE .moving_up            ; Positive → moving up
.next_entity:
        DEX
        BPL .check_entity
        RTS

; --- Moving down: increment Y toward $6A ---
.moving_down:
        LDA ZP_ATTRACT_ENT_Y,X
        CMP #$6A                  ; Reached bottom?
        BNE .step_down
        LDA #$01                  ; Reverse: now moving up
        STA ZP_ATTRACT_ENT_DIR,X
        BPL .next_entity          ; Always taken
.step_down:
        CLC
        ADC #$02                  ; Move down 2 pixels
        STA ZP_ATTRACT_ENT_Y,X
        JMP .next_entity

; --- Moving up: decrement Y toward $52 ---
.moving_up:
        LDA ZP_ATTRACT_ENT_Y,X
        CMP #$52                  ; Reached top?
        BNE .step_up
        JSR PRNG                  ; Random check at top
        CMP #$05                  ; Random < 5?
        BCS .next_entity          ; Yes → keep pausing
        LDA #$FF                  ; Reverse: now moving down
        STA ZP_ATTRACT_ENT_DIR,X
        BMI .next_entity          ; Always taken
.step_up:
        SEC
        SBC #$02                  ; Move up 2 pixels
        STA ZP_ATTRACT_ENT_Y,X
        JMP .next_entity
@ %def ATTRACT_ANIM_1

\section{Attract entity draw}

[[ATTRACT_ANIM_2]] at \$17E1 draws the four attract-mode entities. For
each entity (X~=~3 down to~0), it loads the X column from \$E5+X, width
from \$ED+X, and Y position from \$E9+X. The sprite height is computed as
\$6B minus the Y position, clamped to a maximum of~\$0E (14~pixels).
Sprite data pointers come from tables at \$B002 and \$B082.

<<attract anim 2 defines>>=

; --- Attract sprite tables (secondary) ---
ATTRACT_SPR2_LO = $B002         ; Attract sprite pointer table 2, low bytes
ATTRACT_SPR2_HI = $B082         ; Attract sprite pointer table 2, high bytes
@

<<attract anim 2>>=

        ORG $17E1
ATTRACT_ANIM_2:
        SUBROUTINE
        ; Attract entity draw — renders 4 attract-mode entities.
        ;
        ; Inputs:
        ;   $E5+X — X column, $ED+X — width, $E9+X — Y position
        ;
        ; Modifies:
        ;   Sprite parameters ($56, $57, $5B, $5D, $65B3, $65B4)
        ; Clobbers: A, X

        LDX #$03
.draw_entity:
        LDA ZP_ATTRACT_ENT_X,X   ; Entity X column
        STA ZP_SPRITE_X
        LDA ZP_ATTRACT_ENT_W,X   ; Entity width
        STA ZP_SPRITE_W
        LDA ZP_ATTRACT_ENT_Y,X   ; Entity Y position
        STA ZP_SPRITE_Y
        LDA #$6B                  ; Bottom boundary
        SEC
        SBC ZP_ATTRACT_ENT_Y,X   ; Distance from Y to bottom
        CMP #$0F                  ; > 14?
        BCC .height_ok
        LDA #$0E                  ; Clamp to 14
.height_ok:
        STA ZP_SPRITE_H
        LDA ATTRACT_SPR2_LO,X    ; Sprite data pointer low
        STA SPRITE_PTR_LO
        LDA ATTRACT_SPR2_HI,X    ; Sprite data pointer high
        STA SPRITE_PTR_HI
        STX ZP_SAVE_X             ; Save loop index
        JSR DRAW_SPRITE      ; Draw entity
        LDX ZP_SAVE_X             ; Restore loop index
        DEX
        BPL .draw_entity
        RTS
@ %def ATTRACT_ANIM_2

\section{Attract elevator animation}

[[ATTRACT_ANIM_3]] at \$1813 controls the vertical oscillation of an
attract-mode element (likely an elevator or platform). ZP \$F3 holds the
current Y position and \$F7 the direction flag: negative means moving
down (incrementing Y), positive means moving up (decrementing Y).

The element bounces between Y~=~\$81 (top) and Y~=~\$86 (bottom). At
Y~=~\$84 while moving up, the animation pauses until ZP~\$1F reaches~5,
creating a brief hesitation in the middle of the travel.

<<attract anim 3 defines>>=

; --- Zero-page (attract elevator) ---
ZP_ELEV_Y       = $F3           ; Elevator Y position (attract)
ZP_ELEV_DIR     = $F7           ; Elevator direction (negative=down, positive=up)
ZP_ANIM_COUNTER = $1F           ; Animation frame counter
@

<<attract anim 3>>=

        ORG $1813
ATTRACT_ANIM_3:
        SUBROUTINE
        ; Attract elevator animation — oscillate Y position.
        ;
        ; Inputs:
        ;   ZP_ELEV_DIR ($F7) — direction flag
        ;   ZP_ELEV_Y ($F3) — current Y position
        ;
        ; Modifies:
        ;   ZP_ELEV_Y, ZP_ELEV_DIR
        ; Clobbers: A, Y

; --- Check direction ---
        LDA ZP_ELEV_DIR          ; Direction flag
        BPL .moving_up           ; Positive → moving up

; --- Moving down: increment Y toward $86 ---
        LDA ZP_ELEV_Y
        CMP #$86                 ; Reached bottom?
        BNE .step_down
        LDA #$01                 ; Reverse: start moving up
        STA ZP_ELEV_DIR
        RTS

.step_down:
        CLC
        ADC #$01                 ; Move down one step
        STA ZP_ELEV_Y
        RTS

; --- Moving up: decrement Y toward $81 ---
.moving_up:
        LDA ZP_ELEV_Y
        CMP #$81                 ; Reached top?
        BEQ .reverse_down        ; Yes → reverse direction

        CMP #$84                 ; At pause point?
        BNE .step_up             ; No → continue
        LDY ZP_ANIM_COUNTER      ; Check animation counter
        CPY #$05                 ; Counter >= 5?
        BCC .step_up             ; No → keep moving
        RTS                      ; Yes → pause (wait for counter)

.step_up:
        SEC
        SBC #$01                 ; Move up one step
        STA ZP_ELEV_Y
        RTS

.reverse_down:
        LDA #$FF                 ; Reverse: start moving down
        STA ZP_ELEV_DIR
        RTS
@ %def ATTRACT_ANIM_3

\section{Attract sprite draw}

[[ATTRACT_ANIM_4]] at \$1844 draws the attract-mode sprites each frame.
It loops over two entity slots (X~=~1 down to X~=~0), reading each
entity's X column from ZP~\$F2/\$F1, Y position from ZP~\$F4/\$F3,
and width from ZP~\$F6/\$F5. Sprite data pointers are fetched from
tables at \$B006 and \$B086. Each entity is drawn with height~8 via
[[SPRITE_DRAW_CALL]].

After the entity loop, it draws a fixed ``logo'' sprite at column~\$1D,
row~\$A5, dimensions \$12$\times$\$08, with sprite data at \$BCF1.

<<attract anim 4 defines>>=

; --- Zero-page (attract sprites) ---
ZP_ATTRACT_X    = $F1           ; Attract entity X columns (2 bytes: F1, F2)
ZP_ATTRACT_Y    = $F3           ; Attract entity Y positions (2 bytes: F3, F4)
ZP_ATTRACT_W    = $F5           ; Attract entity widths (2 bytes: F5, F6)
ZP_SAVE_X       = $5C           ; Saved X index during draw

; --- Attract sprite tables ---
ATTRACT_SPR_LO  = $B006         ; Attract sprite pointer table, low bytes
ATTRACT_SPR_HI  = $B086         ; Attract sprite pointer table, high bytes
@

<<attract anim 4>>=

        ORG $1844
ATTRACT_ANIM_4:
        SUBROUTINE
        ; Attract sprite draw — renders attract-mode entities and logo.
        ;
        ; Behavior:
        ;   Loops X = 1..0, drawing each entity from ZP arrays.
        ;   Then draws a fixed logo sprite.
        ;
        ; Modifies:
        ;   Sprite parameters ($56, $57, $5B, $5D, $65B3, $65B4)
        ; Clobbers: A, X

; --- Entity draw loop (X = 1 down to 0) ---
        LDX #$01
.draw_entity:
        LDA ZP_ATTRACT_X,X      ; Entity X column
        STA ZP_SPRITE_X
        LDA ZP_ATTRACT_Y,X      ; Entity Y position
        STA ZP_SPRITE_Y
        LDA ZP_ATTRACT_W,X      ; Entity width
        STA ZP_SPRITE_W
        LDA #$08
        STA ZP_SPRITE_H          ; Height = 8 for all entities
        STX ZP_SAVE_X            ; Save loop index
        LDA ATTRACT_SPR_LO,X    ; Sprite data pointer low
        STA SPRITE_PTR_LO
        LDA ATTRACT_SPR_HI,X    ; Sprite data pointer high
        STA SPRITE_PTR_HI
        JSR DRAW_SPRITE     ; Draw this entity
        LDX ZP_SAVE_X            ; Restore loop index
        DEX
        BPL .draw_entity         ; Next entity (1 → 0)

; --- Draw fixed logo sprite ---
        LDA #$12
        STA ZP_SPRITE_W          ; Width = $12
        LDA #$08
        STA ZP_SPRITE_H          ; Height = $08
        LDA #$A5
        STA ZP_SPRITE_Y          ; Y = $A5
        LDA #$1D
        STA ZP_SPRITE_X          ; X column = $1D
        LDA #$BC
        STA SPRITE_PTR_HI        ; Sprite data high = $BC
        LDA #$F1
        STA SPRITE_PTR_LO        ; Sprite data low = $F1
        JSR DRAW_SPRITE     ; Draw logo sprite
        RTS
@ %def ATTRACT_ANIM_4

\section{Title screen and attract}

At startup, [[JMP (ZP_GAME_ENTRY)]] enters [[START_ATTRACT]]
in the level data area. This copies the title screen from hi-res page~1
to page~2, clears the keyboard strobe, and enters the attract loop.

The attract loop at [[ATTRACT_LOOP]] (\$7263) calls the main game loop's
attract entry point ([[JSR $67D7]]), which runs the game's rendering and
animation subsystems without input handling. After each frame, it polls
the joystick buttons and keyboard. When input is detected, it patches
the main loop for game mode and jumps to [[MAIN_LOOP]].

<<attract loop>>=

        ORG $7263
ATTRACT_LOOP:
        SUBROUTINE
        ; Title screen attract loop — animates until input detected.
        ;
        ; Behavior:
        ;   Calls main loop from attract entry (skipping input).
        ;   Polls joystick buttons ($52/$54) and keyboard ($C000).
        ;   On input: sets input mode flag ($48), patches main loop
        ;   for game mode, calls $13A4 (game start init), enters
        ;   MAIN_LOOP.
        ;
        ; Modifies:
        ;   $48, $67D1, $67EF, $6827 (self-modifying patches)
        ; Clobbers: A, X, Y

; --- Attract frame ---
        JSR ATTRACT_ENTRY       ; Run one frame (rendering/animation only)
        JSR ATTRACT_ANIM_1      ; Attract-mode animation 1
        JSR ATTRACT_ANIM_2      ; Attract-mode animation 2
        JSR ATTRACT_ANIM_3      ; Attract-mode animation 3
        JSR ATTRACT_ANIM_4      ; Attract-mode animation 4

; --- Poll input ---
        LDY #$00
        LDA ($52),Y             ; Read joystick button 1
        BMI ATTRACT_JOY_DETECT  ; Bit 7 set = button pressed
        LDA ($54),Y             ; Read joystick button 2
        BMI ATTRACT_JOY_DETECT
        LDA KEYBOARD            ; Read keyboard
        BPL ATTRACT_LOOP        ; No key = continue attract
ATTRACT_KEY_DETECT:
        LDA #$01                ; Keyboard input mode
        BPL ATTRACT_SET_MODE    ; Always taken
ATTRACT_JOY_DETECT:
        LDA #$FF                ; Joystick input mode
ATTRACT_SET_MODE:
        STA ZP_INPUT_MODE       ; Store input mode flag
        LDA KBDSTROBE           ; Clear keyboard strobe

; --- Patch main loop for game mode ---
        LDA #$EA                ; NOP opcode
        STA SMC_ATTRACT         ; $6827: disable attract JSR → NOP
        LDA #$20                ; JSR opcode
        STA SMC_INPUT           ; $67D1: enable input handler
        STA SMC_RENDER          ; $67EF: enable sprite rendering

; --- Start game ---
        JSR GAME_START_INIT     ; Game start initialization
        LDA ZP_SFX_CLICK_SAVED  ; Restore saved sound-on/off state
        STA ZP_SFX_CLICK        ;   into the working SFX click pointer
        JMP MAIN_LOOP           ; Enter main game loop
@ %def ATTRACT_LOOP ATTRACT_KEY_DETECT ATTRACT_JOY_DETECT ATTRACT_SET_MODE

<<start attract>>=

        ORG $72A3
START_ATTRACT:
        SUBROUTINE
        ; Copy hi-res page 1 to page 2, then enter attract loop.
        ;
        ; Inputs:
        ;   ZP_HGR_SRC ($29/$2A) = $2000 (hi-res page 1)
        ;   ZP_HGR_DST ($2F/$30) = $4000 (hi-res page 2)
        ;
        ; Behavior:
        ;   Page-by-page copy from $2000-$3FFF to $4000-$5FFF,
        ;   then clears keyboard strobe and enters ATTRACT_LOOP.
        ;
        ; Modifies:
        ;   Hi-res page 2 ($4000-$5FFF), ZP_HGR_SRC+1, ZP_HGR_DST+1
        ; Clobbers: A, Y

        LDY #$00
.copy:
        LDA (ZP_HGR_SRC),Y     ; Read from hi-res page 1
        STA (ZP_HGR_DST),Y     ; Write to hi-res page 2
        INY
        BNE .copy
        INC ZP_HGR_SRC+1       ; Next source page
        INC ZP_HGR_DST+1       ; Next dest page
        LDA ZP_HGR_SRC+1
        CMP #$40                ; Done when source reaches $4000
        BNE .copy
        LDA KBDSTROBE           ; Clear keyboard strobe
        JMP ATTRACT_LOOP        ; Enter attract loop
@ %def START_ATTRACT
