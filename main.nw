        ORG $16AC
ENEMY_C_DRAW:
        SUBROUTINE
        ; Per-frame draw + enemy-slot collision for the enemy-C slot.
        ; Previously mislabeled PLAYER_RENDER --- this routine does
        ; not render the player.  Dispatches on ZP_ENEMY_C_STATE:
        ; $00 exits; positive does the full steady-mode draw (main
        ; body + tail sprite) and 4-slot enemy hit-test; negative
        ; takes the drift-mode tail that draws a smaller puff sprite
        ; using a level-specific pointer pair.
        ;
        ; Inputs:
        ;   ZP_ENEMY_C_STATE    --- $00 off; +steady; -drift.
        ;   ZP_ENEMY_C_POS      --- 16-bit world X for enemy-C.
        ;   ZP_ENEMY_C_ROW      --- Sprite starting screen row.
        ;   ZP_PLAYER_Y   --- Player Y (index into perspective tables).
        ;   ZP_SPRITE_XREF --- Level-fixed X reference.
        ;   ZP_ENEMY_A_STATE    --- Inspected by cross-slot broadcast.
        ;   ZP_ENEMY_FLAG/COL/Y --- 4-slot floor-enemy tables ($9B/$9F/$A3).
        ;   PERSPECTIVE_XOFF_LO/HI --- Y-to-X transform tables.
        ;   SPRITE_TABLE_C_LO/HI   --- Body-sprite pointer table base.
        ;   ENEMY_C_TAIL_LO/HI     --- Per-level tail-sprite pointers (indexed).
        ;   ENEMY_C_PUFF_LO/HI     --- Per-level drift-puff pointer (un-indexed).
        ;
        ; Behavior:
        ;   1. State gate: $00 exits; negative jumps to .drift_draw.
        ;   2. Clip: compute screen-relative X into ZP_CLIP_X_LO/HI;
        ;      exit if high byte non-zero or low byte >= $94.
        ;   3. Main draw: set sprite params ($5D = col, $56 = 2,
        ;      ZP_SPRITE_H <- #$0B, $5B = ZP_ENEMY_C_ROW), patch DRAW_SPRITE
        ;      src to SPRITE_TABLE_C_{LO,HI}[PROJ_FRAME_IDX],
        ;      JSR DRAW_SPRITE.
        ;   4. Tail draw: decrement clip_X by 1 (exit if it underflows);
        ;      set sprite params ($56 = 1, $57 = 7, $5B = row + $0B),
        ;      patch src to ENEMY_C_TAIL_{LO,HI}[PROJ_FRAME_IDX],
        ;      JSR DRAW_SPRITE.
        ;   5. Hit test: walk X = 3..0 searching for an active slot
        ;      (ZP_ENEMY_FLAG,X != 0); on the first active slot,
        ;      test ZP_CLIP_X_LO in (ZP_ENEMY_COL,X, ZP_ENEMY_COL,X + $08]
        ;      AND ZP_ENEMY_C_ROW in (ZP_ENEMY_Y,X - $0A, ZP_ENEMY_Y,X + $04].
        ;   6. On hit (.hit): write $FF to ZP_ENEMY_C_STATE; if
        ;      ZP_ENEMY_A_STATE non-zero, write $FF to it too; reload
        ;      ZP_ENEMY_C_POS to (hi = clip_X, lo = $D0); retire the
        ;      floor-enemy slot (STA $00 -> ZP_ENEMY_FLAG,X); bump
        ;      ZP_ENEMY_C_ROW by 2; reset ZP_ENEMY_C_SND_CTR to ZP_MOVE_DIR;
        ;      award +$0100 BCD via SCORE_ADD; RTS.  Does NOT
        ;      decrement ZP_GAME_OVER.
        ;   7. Drift-mode draw tail (.drift_draw at $1783): draw a
        ;      $02x$06 puff at (ZP_ENEMY_C_POS+1, ZP_ENEMY_C_ROW)
        ;      using the un-indexed pointer pair ENEMY_C_PUFF_LO/ENEMY_C_PUFF_HI.
        ;
        ; Modifies:
        ;   ZP_CLIP_X_LO/HI, sprite-param ZPs ($56/$57/$5B/$5D),
        ;   ZP_SCORE_ADD_LO/HI, ZP_ENEMY_C_STATE, ZP_ENEMY_A_STATE,
        ;   ZP_ENEMY_C_POS, ZP_ENEMY_C_ROW, ZP_ENEMY_C_SND_CTR,
        ;   ZP_ENEMY_FLAG (one slot), SMC_DS_SRC_LO/HI.
        ; Clobbers: A, X

; --- State dispatch: $00 exit, +steady, -drift ---
        LDA ZP_ENEMY_C_STATE
        BEQ .exit                       ; $00: slot inactive
        BPL .steady                     ; positive: steady-mode draw
        JMP .drift_draw                 ; negative: drift-mode draw tail

; --- Clip: compute screen-relative X from world X ---
.steady:
        LDX ZP_PLAYER_Y
        LDA PERSPECTIVE_XOFF_LO,X       ; Y-indexed X offset (low)
        SEC
        SBC ZP_SPRITE_XREF              ; ... minus fixed X-reference
        STA ZP_CLIP_X_LO
        LDA PERSPECTIVE_XOFF_HI,X       ; (high byte propagation)
        SBC #$00
        STA ZP_CLIP_X_HI
        SEC
        LDA ZP_ENEMY_C_POS              ; Subtract from enemy world X
        SBC ZP_CLIP_X_LO
        STA ZP_CLIP_X_LO                ; ZP_CLIP_X_LO = screen-relative X (lo)
        LDA ZP_ENEMY_C_POS+1
        SBC ZP_CLIP_X_HI
        BEQ .in_bounds                  ; hi diff == 0: on-screen
.exit:
        RTS                             ; hi diff != 0: off-screen, exit
.in_bounds:
        LDA ZP_CLIP_X_LO
        CMP #$94
        BCS .exit                       ; clipped X >= $94: off right edge

; --- Main body draw (narrow 2x$0B sprite) ---
        TAX                             ; X := clipped screen-X
        LDA PROJ_SCREEN_COL,X           ; -> screen column index
        STA ZP_SPRITE_X
        LDA PROJ_FRAME_IDX,X            ; -> sprite frame index
        TAX                             ; X := frame index
        LDA #$02
        STA ZP_SPRITE_W                 ; Body width = 2 bytes
        LDA #$0B
        STA ZP_SPRITE_H                 ; Body height = 11 rows
        LDA ZP_ENEMY_C_ROW
        STA ZP_SPRITE_Y                 ; Row = enemy-C row
        LDA SPRITE_TABLE_C_LO,X         ; Patch DRAW_SPRITE src (lo)
        STA SMC_DS_SRC_LO
        LDA SPRITE_TABLE_C_HI,X         ; Patch DRAW_SPRITE src (hi)
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE                 ; Blit enemy-C body

; --- Tail draw: $01x$07 sprite one column left, $0B rows below ---
        LDA ZP_CLIP_X_LO
        SEC
        SBC #$01                        ; shift left one column
        CMP #$94
        BCS .done                       ; underflow: skip tail and hit test
        TAX                             ; X := shifted screen-X
        LDA PROJ_SCREEN_COL,X           ; -> screen column index
        STA ZP_SPRITE_X
        LDA PROJ_FRAME_IDX,X            ; -> sprite frame index
        TAX                             ; X := frame index
        LDA #$01
        STA ZP_SPRITE_W                 ; Tail width = 1 byte
        LDA #$07
        STA ZP_SPRITE_H                 ; Tail height = 7 rows
        LDA ZP_ENEMY_C_ROW
        CLC
        ADC #$0B
        STA ZP_SPRITE_Y                 ; Row = enemy-C row + $0B
        LDA ENEMY_C_TAIL_LO,X           ; Patch DRAW_SPRITE src (lo, per-level)
        STA SMC_DS_SRC_LO
        LDA ENEMY_C_TAIL_HI,X           ; Patch DRAW_SPRITE src (hi, per-level)
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE                 ; Blit enemy-C tail

; --- Hit test: walk 4-slot floor-enemy table for first active slot ---
        LDX #$03
.scan:
        LDA ZP_ENEMY_FLAG,X             ; 4-slot active flag (ZP_ENEMY_FLAG[X])
        BNE .test_slot                  ; non-zero: test this slot
.next:
        DEX
        BPL .scan                       ; loop X = 3..0
.done:
        RTS                             ; no active slot (or tail underflow)

.test_slot:
        LDA ZP_CLIP_X_LO
        CMP ZP_ENEMY_COL,X              ; enemy_col > clip_X? skip
        BCC .next
        SEC
        SBC #$08
        CMP ZP_ENEMY_COL,X              ; enemy_col <= clip_X - 8? skip
        BCS .next
        LDA ZP_ENEMY_C_ROW
        SEC
        SBC #$04
        CMP ZP_ENEMY_Y,X                ; enemy_Y <= row - 4? skip
        BCS .next
        CLC
        ADC #$0E
        CMP ZP_ENEMY_Y,X                ; enemy_Y > row + $0A? skip
        BCC .next

; --- Hit: C -> drift; A -> drift (if active); retire floor-enemy; +100 BCD ---
.hit:
        LDA #$FF
        STA ZP_ENEMY_C_STATE            ; Self -> drift mode (bobble)
        LDA ZP_ENEMY_A_STATE
        BEQ .skip_a                     ; A inactive: leave it alone
        LDA #$FF
        STA ZP_ENEMY_A_STATE            ; A -> drift mode too
.skip_a:
        LDA #$D0
        STA ZP_ENEMY_C_POS              ; counter lo := $D0
        LDA #$00
        STA ZP_ENEMY_FLAG,X             ; retire the floor-enemy slot
        LDA ZP_CLIP_X_LO
        STA ZP_ENEMY_C_POS+1            ; counter hi := clip_X
        INC ZP_ENEMY_C_ROW              ; row += 2 (shift bobble down)
        INC ZP_ENEMY_C_ROW
        LDA #$04
        STA ZP_ENEMY_C_SND_CTR          ; rearm click counter
        LDA #$00
        STA ZP_SCORE_ADD_LO             ; addend lo = $00
        LDA #$01
        STA ZP_SCORE_ADD_HI             ; addend hi = $01 ($0100 BCD = 100)
        JSR SCORE_ADD                   ; ... so score += 100
        RTS                             ; Note: no DEC ZP_GAME_OVER

; --- Drift-mode draw tail: $02x$06 puff from level-data pointer pair ---
.drift_draw:
        LDA #$02
        STA ZP_SPRITE_W                 ; Puff width = 2 bytes
        LDA #$06
        STA ZP_SPRITE_H                 ; Puff height = 6 rows
        LDX ZP_ENEMY_C_POS+1            ; Use counter hi as X-col index
        LDA PROJ_SCREEN_COL,X
        STA ZP_SPRITE_X
        LDA ZP_ENEMY_C_ROW
        STA ZP_SPRITE_Y                 ; Row = enemy-C row
        LDA ENEMY_C_PUFF_LO             ; Patch DRAW_SPRITE src with the
        STA SMC_DS_SRC_LO               ; level-specific puff pointer
        LDA ENEMY_C_PUFF_HI             ; (un-indexed)
        STA SMC_DS_SRC_HI
        JSR DRAW_SPRITE
        RTS
@ %def ENEMY_C_DRAW
@ %def SPRITE_TABLE_C_LO SPRITE_TABLE_C_HI

\section{Perspective-grid lookup tables ([[$188A]]--[[$1CED]])}

The [[$188A]]--[[$1CED]] region holds six data tables that drive the
perspective-grid sprite placement used by [[DRAW_ENTITIES]] phases
3--5, the projectile hazard, the [[RESCUE_DRAW]] meet-player logic,
the drift-mode draw tails of [[ENEMY_B_DRAW]]/[[ENEMY_C_DRAW]], and
the floor-enemy spawn gate inside [[FLOOR_ENEMY_ADVANCE]].  All six
live back-to-back in the [[drol.bin]] persistent region (loaded
from tracks 1--2 alongside [[ENEMY_A_ADVANCE]] etc.) and are
\emph{not} swapped between levels.

\begin{center}
\begin{tabular}{l|l|l|l}
Address         & Label                        & Size & Role \\
\hline
[[$188A]]       & [[FLOOR_BASE_ROW_PAD]]       & 5    & Pad --- indices 0..4 never read \\
[[$188F]]       & [[FLOOR_BASE_ROW]]           & 256  & Floor-column $\to$ base row (plateaus of 7) \\
[[$198F]]       & [[PERSPECTIVE_XOFF_HI]]      & 256  & Y-to-X transform, high byte ($\lceil \text{idx}/72 \rceil$) \\
[[$1A8F]]       & [[PERSPECTIVE_XOFF_LO]]      & 256  & Y-to-X transform, low byte ($3.5 \cdot \text{idx} + 6$) \\
[[$1B8F]]       & [[PROJ_FRAME_IDX]]           & 165  & $\text{idx} \bmod 7$ (horizontal-sprite frame pick) \\
[[$1C34]]       & [[PROJ_SCREEN_COL]]          & 132  & $\lfloor (7 \cdot \text{idx} + 3) / 25 \rfloor$ (screen-col from hi-res residue) \\
[[$1CB8]]       & [[FLOOR_ENEMY_SPAWN_SCHED]]  & 54   & [[ZP_PLAYER_COL]] $\to$ spawn-row seed (35 live + pad) \\
\end{tabular}
\end{center}

\paragraph{[[FLOOR_BASE_ROW]].}
A 256-entry [[ZP_PLAYER_COL]]-style floor-column to screen-row map.
Each plateau is seven indices wide and the value increments by [[$02]]
every plateau: indices [[$05]]--[[$0B]] map to row [[$00]], [[$0C]]--[[$12]]
to [[$02]], ..., indices [[$F0]]--[[$F6]] to [[$46]], and the trailing
four indices [[$FC]]--[[$FF]] to [[$48]] (the bottom-most reachable
floor).  The first 12 indices ([[$00]]--[[$0B]]) are all [[$00]];
the five bytes before the table ([[FLOOR_BASE_ROW_PAD]])
are unreferenced pre-pad --- [[FLOOR_BASE_ROW]] is exported
starting from the pad's first in-table offset because every caller
reads indices $\ge$~[[$05]], not the pad.

Consumed by:
\begin{itemize}
\item [[DRAW_ENTITIES]] phase~3/4/5 base-row computation
  ([[FLOOR_BASE_ROW]],X $+$ [[PERSPECTIVE_XOFF_BYTE]],X).
\item [[RESCUE_UPDATE]]'s ``meet-player'' compute ([[$6FED]]) to
  decide whether the rescue is to the left or right of the player.
\end{itemize}

\paragraph{[[PERSPECTIVE_XOFF_HI]]/[[PERSPECTIVE_XOFF_LO]].}
A paired 16-bit table, indexed by [[ZP_PLAYER_Y]] (0..255) and
consumed by the three enemy clip-computations ([[ENEMY_A_DRAW]],
[[ENEMY_B_DRAW]], [[ENEMY_C_DRAW]]).  The combined value is
$(\text{HI} \cdot 256) + \text{LO}$: for index [[$00]] the value is
[[$0006]]; every second index it grows by [[$07]]
($(\text{LO}+7) \bmod 256$ with the carry lifted into HI), so the
combined value at index [[$FE]] is [[$037F]] = 895.  The
[[PERSPECTIVE_XOFF_BYTE]] zero-page mirror at [[$B9]] is the byte-domain
summary of the same transform (used where only the low-domain 7-bit
contribution is relevant).

\paragraph{[[PROJ_FRAME_IDX]].}
165-byte $X \bmod 7$ table: cycles [[$00]]..[[$06]] then repeats, for
[[$17]] full cycles plus an extra four entries [[$00]]--[[$03]].
Selects the frame within a 7-frame walking-sprite cycle given a
horizontal position index.  Used by [[ENEMY_C_DRAW]]'s body draw
(sprite pointer tables [[SPRITE_TABLE_C_LO]] / [[SPRITE_TABLE_C_HI]]
are indexed by this) and by the drift-mode draw tails in
[[ENEMY_B_DRAW]] and [[ENEMY_C_DRAW]].

\paragraph{[[PROJ_SCREEN_COL]].}
132-byte ``unpack horizontal-residue to screen column'' table.
Indexed by the same horizontal position index as [[PROJ_FRAME_IDX]];
the return value grows from [[$00]] to [[$25]] across the 132 entries
with the step pattern [[$04]],[[$03]],[[$04]],[[$03]],\ldots\ (twice per
column boundary).  Used by the projectile hazard check and by
[[ENEMY_C_DRAW]]'s drift-mode draw to map an 8-bit horizontal counter
onto a [[$00]]..[[$27]] screen column.

\paragraph{[[FLOOR_ENEMY_SPAWN_SCHED]].}
A [[ZP_PLAYER_COL]]-indexed table queried by [[FLOOR_ENEMY_ADVANCE]]
on every floor-enemy spawn attempt.  If the player's floor column has
a non-negative entry, [[FLOOR_ENEMY_ADVANCE]] uses $\text{entry} + [[$09]]$
as the starting sprite row for the new enemy (otherwise the spawn is
suppressed).  Only indices [[$00]]--[[$22]] carry nonzero seeds
([[$25]]..[[$2E]] in near-monotonic plateaus of 3--4); the remaining
[[$13]] bytes up to the chunk end at [[$1CEC]] are [[$00]] (still
non-negative, so a spawn would be allowed at floor row [[$09]] --- but
normal gameplay keeps [[ZP_PLAYER_COL]] inside the active range).
The [[$1CED]] byte is a final pad [[$00]] before the unallocated
gap [[$1CEE]]--[[$1CF6]] (written as [[$FF]] by dasm's inter-chunk
filler, and identical to the bytes present in [[drol.bin]]).

\paragraph{Naming.}  The chunk was previously a single 1124-byte
[[HEX]] blob labelled ``Game logic [[$188A]]'' with a placeholder
comment about level layout / doors / entity spawning --- none of which
describes what the bytes actually do.  All six sub-tables are simple
lookup arrays; there is no code in this region.

