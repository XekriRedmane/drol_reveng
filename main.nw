SPRITE_TABLE_A_STEP1_HI = $B090 ; Walking feet variant 1, high
SPRITE_TABLE_A_FEET_LO  = $B017 ; Stance feet pointers, low (drift / phase $00/$02)
SPRITE_TABLE_A_FEET_HI  = $B097 ; Stance feet, high
SPRITE_TABLE_A_STEP2_LO = $B01E ; Walking feet variant 2 (phase $01), low
SPRITE_TABLE_A_STEP2_HI = $B09E ; Walking feet variant 2, high

