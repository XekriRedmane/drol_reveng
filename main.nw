        HEX DA 4A B8 26 94 02 6E DA
        HEX 4A B8 26 94

; --- $5D6C-$5D7F -> $036C-$037F: ENTITY_XOFF_IDX (20 bytes) ---
STAGE_ENTITY_XOFF_IDX:
        HEX 00 00 01 01 02 02 03 00
        HEX 00 01 01 02 02 03 00 00
        HEX 01 01 02 02

; --- $5D80-$5D93 -> $0380-$0393: ENTITY_FLOOR_POS (20 bytes) ---
STAGE_ENTITY_FLOOR_POS:
        HEX 51 51 51 51 51 51 51 79
        HEX 79 79 79 79 79 79 A1 A1
        HEX A1 A1 A1 A1

; --- $5D94-$5DA7 -> $0394-$03A7: RESCUE_DIR (20 bytes) ---
STAGE_RESCUE_DIR:
        HEX 01 01 FF FF 01 01 FF 01
        HEX 01 FF FF 01 01 FF 01 FF
        HEX 01 FF 01 FF

; --- $5DA8-$5DBB -> $03A8-$03BB: ENTITY_ACTIVE (20 bytes, all zero) ---
STAGE_ENTITY_ACTIVE:
        HEX 00 00 00 00 00 00 00 00
        HEX 00 00 00 00 00 00 00 00
        HEX 00 00 00 00

; --- $5DBC-$5DCF -> $03BC-$03CF: RESCUE_ANIM (20 bytes) ---
STAGE_RESCUE_ANIM:
        HEX 07 07 00 00 07 07 00 07
        HEX 07 00 00 07 07 00 07 00
        HEX 07 00 07 00

; --- $5DD0-$5DE3 -> $03D0-$03E3: RESCUE_FLOOR (20 bytes) ---
STAGE_RESCUE_FLOOR:
