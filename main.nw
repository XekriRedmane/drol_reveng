        ; Behavior:
        ;   Joystick mode: delegates to JOYSTICK_HANDLER.
        ;   Keyboard mode: reads KEYBOARD, dispatches on key code.
        ;   Direction keys patch main loop movement slots (JSR/BIT toggle).
        ;   Action keys search for rescuable entities within range.
        ;
        ; Modifies:
        ;   SMC_ASCEND, SMC_DESCEND, SMC_MOVE_LEFT, SMC_MOVE_RIGHT,
        ;   ZP_ACTION_DIR, ZP_PLAYER_STANCE, ZP_MOVE_DIR, ZP_JUMP_FLAG,
        ;   ZP_PLAYER_COL, ZP_ASC_FLOOR, ZP_DSC_FLOOR, ZP_DSC_DIR,
        ;   ZP_ENT_RESCUED, ENTITY_HIT_STATE,X
        ; Clobbers: A, X, Y

        LDA ZP_INPUT_MODE       ; Input mode flag
        BPL .keyboard           ; Positive = keyboard
        JMP JOYSTICK_HANDLER    ; Negative = joystick

; --- Keyboard handler ---
.keyboard:
        LDA KEYBOARD            ; Read keyboard
        BMI .got_key            ; Bit 7 set = key available
        RTS                     ; No key pressed
.got_key:

; --- Right arrow ---
SMC_KEY_RIGHT = *+1             ; Immediate operand of CMP; patched to #$CC on IIc
        CMP #KEY_RIGHT
        BNE .check_left
        BIT KBDSTROBE           ; Clear keyboard strobe
INPUT_SET_RIGHT:
        STA ZP_KEY_CODE         ; Store key code
        LDY #OPCODE_JSR
        STY SMC_MOVE_RIGHT      ; Enable move right
        LDY #OPCODE_BIT
        STY SMC_MOVE_LEFT       ; Disable move left
        RTS

; --- Left arrow ---
.check_left:
SMC_KEY_LEFT = *+1              ; Immediate operand of CMP; patched to #$CB on IIc
        CMP #KEY_LEFT
        BNE .check_action
        BIT KBDSTROBE
INPUT_SET_LEFT:
        STA ZP_KEY_CODE
        LDY #OPCODE_JSR
        STY SMC_MOVE_LEFT       ; Enable move left
        LDY #OPCODE_BIT
        STY SMC_MOVE_RIGHT      ; Disable move right
        RTS

; --- 'A' key (fire / ascend) ---
.check_action:
        CMP #KEY_ACTION
        BNE .check_descend
        BIT KBDSTROBE
INPUT_DO_ASCEND:
        LDY #OPCODE_JSR
        STY SMC_ASCEND          ; Enable ascend
        LDY #OPCODE_BIT
        STY SMC_DESCEND         ; Disable descend
        LDA ZP_PLAYER_STANCE    ; Clamp stance into [$03..$09]
        BMI .clamp_low
        CMP #$03
        BCC .clamp_low
        CMP #$0A
        BCC .set_action
        LDA #$09
        STA ZP_PLAYER_STANCE    ; ZP_PLAYER_STANCE <- #$09 (clamp high)
        BPL .set_action
.clamp_low:
        LDA #$03
        STA ZP_PLAYER_STANCE    ; ZP_PLAYER_STANCE <- #$03 (clamp low)
.set_action:
        LDY #$01
        STY ZP_ACTION_DIR       ; ZP_ACTION_DIR <- #$01 (ascend)
        DEY
        STY ZP_KEY_CODE         ; ZP_KEY_CODE <- 0
        DEY
        STY ZP_DSC_DIR          ; ZP_DSC_DIR <- #$FF (searching)
        LDX ZP_HIT_MAX          ; Iterate hit-entity slots
.search_entity:
        SEC
        LDA ENTITY_HIT_Y,X      ; ENTITY_HIT_Y[X] - ZP_PLAYER_Y
        SBC ZP_PLAYER_Y
        CMP #$18                ; Distance window: [$15, $18)
        BCS .next_entity
        CMP #$15
        BCC .next_entity
        LDY ZP_ASC_FLOOR        ; Current ascent-target floor index
        DEY
        BEQ .next_entity        ; Floor 0 (top): nothing to ascend to
        LDA FLOOR_Y_TABLE,Y     ; Y row of the next floor up
        CMP ENTITY_HIT_ROW,X    ; Match entity's anchor row?
        BEQ .found_entity
.next_entity:
        DEX
        BPL .search_entity
        RTS                     ; No entity found
.found_entity:
        STY ZP_ASC_FLOOR        ; Commit new ascent-target floor
        LDA #$01
        STA ENTITY_HIT_STATE,X  ; ENTITY_HIT_STATE[X] <- #$01 (activate)
        STA ZP_ENT_RESCUED      ; ZP_ENT_RESCUED <- #$01 (rescue succeeded)
        LDA #$00
        STA ZP_MOVE_DIR         ; ZP_MOVE_DIR <- #$00 (halt horizontal)
        RTS

; --- 'Z' key (descend) ---
.check_descend:
        CMP #KEY_DESCEND
        BNE .check_jump
        BIT KBDSTROBE
INPUT_DO_DESCEND:
        LDA ZP_DSC_DIR          ; Check current direction
        BMI .check_floor        ;   $FF = still searching
        LDX ZP_HIT_MAX          ; Iterate hit-entity slots
.search_descend:
        SEC
        LDA ENTITY_HIT_Y,X
        SBC ZP_PLAYER_Y
        CMP #$18
        BCS .no_match_d
        CMP #$15
        BCC .no_match_d
        LDY ZP_DSC_FLOOR        ; Descend-target floor index
        LDA FLOOR_Y_TABLE,Y
        CMP ENTITY_HIT_ROW,X
        BEQ .found_descend
.no_match_d:
        DEX
        BPL .search_descend
.check_floor:
        LDA ZP_PLAYER_COL       ; Player screen column
        LDX ZP_DSC_FLOOR
        CMP FLOOR_THRESH,X      ; FLOOR_THRESH[X]
        BEQ .done_descend
        BNE .set_descend_dir
.found_descend:
        INY
        STY ZP_DSC_FLOOR        ; Commit new descent-target floor
        LDY #$00
        STY ZP_MOVE_DIR         ; ZP_MOVE_DIR <- #$00 (halt horizontal)
        INY
        STY ENTITY_HIT_STATE,X  ; ENTITY_HIT_STATE[X] <- #$01 (activate)
        STY ZP_ENT_RESCUED      ; ZP_ENT_RESCUED <- #$01
        CLC
        LDA ZP_PLAYER_COL
        ADC #$04
        STA ZP_PLAYER_COL       ; ZP_PLAYER_COL += 4
.set_descend_dir:
        LDA #OPCODE_JSR
        STA SMC_DESCEND         ; Enable descend
        LDA #OPCODE_BIT
        STA SMC_ASCEND          ; Disable ascend
        LDA ZP_PLAYER_STANCE    ; Clamp stance into [$03..$09]
        BMI .clamp_low_d
        CMP #$03
        BCC .clamp_low_d
        CMP #$0A
        BCC .set_descend
        LDA #$09
        STA ZP_PLAYER_STANCE    ; ZP_PLAYER_STANCE <- #$09
        BPL .set_descend
.clamp_low_d:
        LDA #$03
        STA ZP_PLAYER_STANCE    ; ZP_PLAYER_STANCE <- #$03
.set_descend:
        LDY #$FF
        STY ZP_ACTION_DIR       ; ZP_ACTION_DIR <- #$FF (descend)
        INY
        STY ZP_KEY_CODE         ; ZP_KEY_CODE <- 0
.done_descend:
        RTS

; --- Space key (jump) ---
.check_jump:
        CMP #KEY_JUMP
        BNE .unknown_key
        LDY #$FF
        STY ZP_JUMP_FLAG        ; Set jump flag
        BIT KBDSTROBE
.unknown_key:
        RTS
@ %def INPUT_DISPATCH INPUT_SET_RIGHT INPUT_SET_LEFT INPUT_DO_ASCEND INPUT_DO_DESCEND SMC_KEY_LEFT SMC_KEY_RIGHT

\section{Meta-key handler}

[[INPUT_PROCESS]] handles non-movement keys during gameplay:
ESC pauses, Ctrl-R restarts, Ctrl-S toggles sound. Unrecognized keys
fall through to [[KEY_HANDLER_EXT]], which handles
Ctrl-J (joystick mode), Ctrl-K (keyboard mode), and Ctrl-V (speaker click).

<<input process defines>>=

; --- Meta-key codes ---
KEY_ESC         = $9B           ; ESC key (pause)
KEY_CTRL_R      = $92           ; Ctrl-R (restart game)
KEY_CTRL_S      = $93           ; Ctrl-S (toggle sound)
KEY_CTRL_J      = $8A           ; Ctrl-J (switch to joystick)
KEY_CTRL_K      = $8B           ; Ctrl-K (switch to keyboard)
KEY_CTRL_V      = $96           ; Ctrl-V (speaker click)

; --- Sound ---
; ZP_SFX_CLICK (2 bytes) forms an indirect pointer used by SFX_TONE as a
; speaker-click address.  ZP_SFX_CLICK+1 = $C0 (set during boot and never
; changed), so the effective target is $C0xx.  Bit 4 of ZP_SFX_CLICK
; selects between:
;   ZP_SFX_CLICK <- #<SW_SPEAKER  ($30) -> clicks the speaker
;   ZP_SFX_CLICK <- #<SW_CASSOUT  ($20) -> silent (cassette output, unused)
; Ctrl-S flips bit 4 to mute/unmute without touching the rest of the byte.
; ZP_SFX_CLICK_SAVED is a preserved copy used across game/attract transitions
; (ATTRACT_LOOP saves ZP_SFX_CLICK on no-more-lives; restores ZP_SFX_CLICK_SAVED
; on game start).
SOUND_FLAG_MASK = $10           ; Bit that flips SW_SPEAKER <-> SW_CASSOUT
                                ;   in ZP_SFX_CLICK
@

<<input process>>=

        ORG $6109
INPUT_PROCESS:
        SUBROUTINE
        ; Meta-key handler -- ESC/Ctrl-R/Ctrl-S and extended keys.
        ;
        ; Behavior:
        ;   Checks keyboard for special control keys. ESC pauses
        ;   (waits for next keypress). Ctrl-R restarts the game.
        ;   Ctrl-S toggles the sound flag. Other keys dispatch
        ;   to KEY_HANDLER_EXT.
        ;
        ; Modifies:
        ;   ZP_SFX_CLICK, ZP_SFX_CLICK_SAVED
        ;   (Ctrl-S flips bit 4 to mute/unmute the SFX_TONE click target).
        ; Clobbers: A

        LDA KEYBOARD            ; Check for key
        BMI .got_key
        RTS                     ; No key
.got_key:
        CMP #KEY_ESC
        BNE .check_restart
        JSR PAUSE_HANDLER       ; Wait for next keypress
        BIT KBDSTROBE
        RTS

.check_restart:
        CMP #KEY_CTRL_R
        BNE .check_sound
        BIT KBDSTROBE
        JSR GAME_START_INIT     ; Restart game
        RTS

.check_sound:
        CMP #KEY_CTRL_S
        BEQ .toggle_sound
        JMP KEY_HANDLER_EXT     ; Try extended key handler

.toggle_sound:
        LDA ZP_SFX_CLICK        ; Flip bit 4 of the speaker-click pointer:
        EOR #SOUND_FLAG_MASK    ;   SW_SPEAKER (click) <-> SW_CASSOUT (silent)
        STA ZP_SFX_CLICK        ; Update working copy
        STA ZP_SFX_CLICK_SAVED  ; Keep the preserved copy in sync
        BIT KBDSTROBE
        RTS
@ %def INPUT_PROCESS

\section{Pause handler}

[[PAUSE_HANDLER]] clears the keyboard strobe, then waits in a
tight loop until a new key is pressed. Used by the ESC key to pause the game.

<<pause handler>>=

        ORG $0E51
PAUSE_HANDLER:
        ; Wait for keypress -- clear strobe, loop until key available.
        BIT KBDSTROBE           ; Clear keyboard strobe
.wait:
        LDA KEYBOARD            ; Poll keyboard
        BPL .wait               ; Loop until bit 7 set
        RTS
@ %def PAUSE_HANDLER

\section{Screen row copy}

[[SCREEN_ROW_COPY]] copies all 192 rows of hi-res page~1 from
a 40-byte buffer at [[ROW_COPY_BUFFER]]. For each screen row~X (0--191), it loads the
row's base address from a pair of tables ([[SCREEN_ROW_ADDR_LO]] for the low byte,
[[SCREEN_ROW_ADDR_HI]] for the high byte), stores it in ZP pointer~[[ZP_HGR_SRC]], then copies
40~bytes from the buffer to that address. Between rows it calls the
Monitor [[WAIT]] routine for a brief delay and [[ROW_COPY_CLICK]] to
emit an ascending speaker click (pitch proportional to the row index),
which gives the wipe its characteristic whistle. The first call to
[[DISPLAY_PAGE_FLIP]] is gated on [[ZP_PAGE_FLAG]] being positive (every other
frame).

<<screen row copy defines>>=

; --- Data buffer ---
ROW_COPY_BUFFER = $024C         ; 40-byte buffer holding row pixel data

; --- Apple II ROM ---
MON_WAIT        = $FCA8         ; Monitor WAIT: delay loop (A = duration)

; (ROW_COPY_CLICK has its own ORG chunk at $01B7.)
@

<<screen row copy>>=

        ORG $0100
SCREEN_ROW_COPY:
        SUBROUTINE
        ; Screen row copy -- copies buffer to all 192 hi-res rows.
        ;
        ; Behavior:
        ;   Conditionally flips display page (if ZP $00 positive).
        ;   For each row X = 0..191:
        ;     Loads row address from tables, copies 40 bytes from buffer,
        ;     calls WAIT and ROW_COPY_CLICK.
        ;
        ; Modifies:
        ;   Hi-res page 1 ($2000-$3FFF), ZP $29/$2A
        ; Clobbers: A, X, Y

; --- Conditional page flip ---
        LDA ZP_PAGE_FLAG
        BMI .skip_flip
        JSR DISPLAY_PAGE_FLIP    ; Flip page if ZP_PAGE_FLAG is positive
.skip_flip:

; --- Row loop ---
        LDX #$00
.row_loop:
        LDA SCREEN_ROW_ADDR_LO,X ; Row address low byte
        STA ZP_HGR_SRC           ; Store in pointer low
        LDA SCREEN_ROW_ADDR_HI,X ; Row address high byte
        STA ZP_HGR_SRC+1         ; Store in pointer high
        LDY #$27                  ; 40 bytes per row (0-$27)
.copy_byte:
        LDA ROW_COPY_BUFFER,Y    ; Read from buffer
        STA (ZP_HGR_SRC),Y       ; Write to screen row
        DEY
        BPL .copy_byte            ; Next byte
        LDA #$20
        JSR MON_WAIT              ; Brief delay
        JSR ROW_COPY_CLICK        ; speaker click, pitch = X/4
        INX
        CPX #$C0                  ; 192 rows
        BNE .row_loop
        RTS
@ %def SCREEN_ROW_COPY

\section{Projectile update}

[[HAZARD_CHECK]] processes up to four active projectiles
(indexed by [[ZP_PROJ_MAX]] down to~0). Each projectile has three state bytes:
\begin{itemize}
\item [[ZP_PROJ_DIR]]+X: direction flag (0~=~inactive, negative~=~moving left,
  positive~=~moving right).
\item [[ZP_PROJ_X]]+X: horizontal screen position.
\item [[ZP_PROJ_Y]]+X: vertical (Y) position.
\end{itemize}

Each frame the Y position increments by~2 (projectiles always fall).
If Y reaches a floor boundary ([[$6B]], [[$93]], or~[[$BB]]) the projectile
deactivates. The horizontal position moves left or right by 4~pixels
per frame.  An extra 2~pixels are added when the player is moving in
the \emph{opposite} horizontal direction (parallax cue from
[[ZP_MOVE_DIR]]): left-moving projectiles speed up when
[[ZP_MOVE_DIR]] is positive (player moving right); right-moving projectiles
speed up when [[ZP_MOVE_DIR]] is negative (player moving left). If the
horizontal position exceeds [[$91]] the projectile is also deactivated.

After drawing, a collision check tests whether the projectile overlaps
the player. The player's horizontal position is taken as column range
[[$40]]--[[$47]] (from [[ZP_PLAYER_COL]]), and the vertical overlap is checked against
[[ZP_PROJ_Y]]+X. A hit sets [[ZP_HIT_FLAG]] to [[$FF]] and deactivates the projectile.

Left-moving projectiles use sprite tables at [[PROJ_SPR_L_LO]]/[[PROJ_SPR_L_HI]]; right-moving
ones use [[PROJ_SPR_R_LO]]/[[PROJ_SPR_R_HI]]. Screen column lookup is via [[PROJ_SCREEN_COL]]
indexed by [[ZP_PROJ_X]]+X, and sprite frame selection via [[PROJ_FRAME_IDX]].

<<hazard check defines>>=

; --- Zero-page (projectile) ---
ZP_PROJ_MAX     = $31           ; Max active projectile slot index
ZP_PROJ_DIR     = $C5           ; Projectile direction (4 bytes: $C5-$C8)
ZP_PROJ_X       = $C9           ; Projectile horizontal position (4 bytes: $C9-$CC)
ZP_PROJ_Y       = $CD           ; Projectile vertical position (4 bytes: $CD-$D0)
ZP_MOVE_DIR     = $04           ; Player horizontal motion: $00 idle, $01 right, $FF left
ZP_PLAYER_COL   = $06           ; Player screen column
ZP_HIT_FLAG     = $1E           ; Hit detection flag ($FF = player hit)

; --- Projectile lookup tables ---
; PROJ_SCREEN_COL at $1C34 and PROJ_FRAME_IDX at $1B8F are defined as
; labels in their ORG chunks inside the perspective-grid data region.
PROJ_SPR_L_LO   = $AFD3         ; Left-moving projectile sprite table, low
PROJ_SPR_L_HI   = $B053         ; Left-moving projectile sprite table, high

@

\paragraph{Projectile sprite art.}  Each projectile slot is rendered
as a $3\times 3$-byte sprite (that is, [[ZP_SPRITE_W]]~=~2 and
[[ZP_SPRITE_H]]~=~3), indexed by the perspective-frame index
[[PROJ_FRAME_IDX]].  Figure~\ref{fig:projectile_sprites} shows the 8
right-moving frames (top row, pointers fetched from [[PROJ_SPR_R_LO]]/[[PROJ_SPR_R_HI]])
and the 8 left-moving frames (bottom row, from [[PROJ_SPR_L_LO]]/[[PROJ_SPR_L_HI]] in the
level-swappable region).  The right-moving pointer table is in
[[drol.bin]] but the sprite bytes themselves live beyond it, so
rendering requires replaying the loader's phase-0 track read; the
left-moving table is entirely inside the swappable region.

\begin{figure}[H]
\centering
\includegraphics[width=0.98\textwidth]{images/projectile_sprites.png}
\caption{Projectile sprite frames.  Top row: right-moving
([[PROJ_SPR_R]]).  Bottom row: left-moving ([[PROJ_SPR_L]]).  Eight
frames per direction, chosen by the projectile's perspective row via
[[PROJ_FRAME_IDX]].}
\label{fig:projectile_sprites}
\end{figure}

<<hazard check>>=

        ORG $0E5A
HAZARD_CHECK:
        SUBROUTINE
        ; Projectile update -- moves, draws, and collision-checks projectiles.
        ;
        ; Inputs:
        ;   ZP_PROJ_MAX          --- max active projectile slot index.
        ;   ZP_PROJ_DIR[0..3]    --- direction (0=inactive, neg=left, pos=right).
        ;   ZP_PROJ_X[0..3]      --- horizontal world position.
        ;   ZP_PROJ_Y[0..3]      --- vertical world position.
        ;   ZP_MOVE_DIR          --- player motion (parallax speed-up cue).
        ;
        ; Modifies:
        ;   ZP_PROJ_DIR/X/Y, sprite params, ZP_HIT_FLAG
        ; Clobbers: A, X, Y

; --- Loop through projectile slots ---
        LDX ZP_PROJ_MAX
        BMI .done                 ; No projectiles if negative
.check_slot:
        LDA ZP_PROJ_DIR,X        ; Projectile direction
        BEQ .next                 ; 0 = inactive
        BMI .move_left            ; Negative = moving left
        JMP .move_right           ; Positive = moving right
.next:
        DEX
        BPL .check_slot
.done:
        RTS

; ========== Moving left ==========
.move_left:
        LDA ZP_PROJ_Y,X          ; Current Y position
        CLC
        ADC #$02                  ; Fall down 2 pixels
        CMP #$6B                  ; Floor 1?
        BEQ .deactivate
        CMP #$93                  ; Floor 2?
        BEQ .deactivate
        CMP #$BB                  ; Floor 3?
        BEQ .deactivate
        STA ZP_PROJ_Y,X          ; Update Y
        STA ZP_SPRITE_Y

        LDA ZP_PROJ_X,X          ; Current X position
        SEC
        SBC #$04                  ; Move left 4 pixels
        BIT ZP_MOVE_DIR           ; Check move direction
        BEQ .store_left_x         ; Zero = normal speed
        BMI .store_left_x         ; Negative = normal speed
        SEC
        SBC #$02                  ; Move left 2 more (total 6)
.store_left_x:
        STA ZP_PROJ_X,X
        CMP #$92                  ; Off screen?
        BCS .deactivate
        TAY
        JMP .draw_left

.deactivate:
        LDA #$00
        STA ZP_PROJ_DIR,X        ; Deactivate projectile
        JMP .next

; --- Draw left-moving projectile ---
.draw_left:
        LDA #$02
        STA ZP_SPRITE_W           ; Width = 2
        LDA #$03
        STA ZP_SPRITE_H           ; Height = 3
        LDA PROJ_SCREEN_COL,Y     ; Screen column from position
        STA ZP_SPRITE_X
        LDA PROJ_FRAME_IDX,Y      ; Sprite frame index
        TAY
        LDA PROJ_SPR_L_LO,Y       ; Left sprite data low
        STA SPRITE_PTR_LO
        LDA PROJ_SPR_L_HI,Y       ; Left sprite data high
        STA SPRITE_PTR_HI
        STX ZP_SAVE_X
        JSR DRAW_SPRITE      ; Draw projectile
        LDX ZP_SAVE_X
        JMP .collision_check

; ========== Moving right ==========
.move_right:
        LDA ZP_PROJ_Y,X          ; Current Y position
        CLC
        ADC #$02                  ; Fall down 2 pixels
        CMP #$6B                  ; Floor 1?
        BEQ .deactivate
        CMP #$93                  ; Floor 2?
        BEQ .deactivate
        CMP #$BB                  ; Floor 3?
        BEQ .deactivate
        STA ZP_PROJ_Y,X
        STA ZP_SPRITE_Y

        LDA ZP_PROJ_X,X          ; Current X position
        CLC
        ADC #$04                  ; Move right 4 pixels
        BIT ZP_MOVE_DIR
        BPL .store_right_x        ; Positive = normal speed
        CLC
        ADC #$02                  ; Move right 2 more (total 6)
.store_right_x:
        STA ZP_PROJ_X,X
        CMP #$92                  ; Off screen?
        BCS .deactivate
        TAY

; --- Draw right-moving projectile ---
        LDA #$02
        STA ZP_SPRITE_W           ; Width = 2
        LDA #$03
        STA ZP_SPRITE_H           ; Height = 3
        LDA PROJ_SCREEN_COL,Y     ; Screen column from position
        STA ZP_SPRITE_X
        LDA PROJ_FRAME_IDX,Y      ; Sprite frame index
        TAY
        LDA PROJ_SPR_R_LO,Y       ; Right sprite data low
        STA SPRITE_PTR_LO
        LDA PROJ_SPR_R_HI,Y       ; Right sprite data high
        STA SPRITE_PTR_HI
        STX ZP_SAVE_X
        JSR DRAW_SPRITE      ; Draw projectile
        LDX ZP_SAVE_X

; --- Player collision check ---
.collision_check:
        LDA ZP_PROJ_X,X          ; Projectile horizontal pos
        CMP #$40                  ; Left edge of player zone
        BCC .no_hit
        CMP #$48                  ; Right edge of player zone
        BCS .no_hit
        LDA ZP_PLAYER_COL         ; Player column
        SEC
        SBC #$03
        CMP ZP_PROJ_Y,X          ; Compare with projectile Y
        BCS .no_hit
        CLC
        ADC #$15                  ; Player height extent
        CMP ZP_PROJ_Y,X
        BCC .no_hit
        LDA #$FF
        STA ZP_HIT_FLAG           ; Signal player hit
        LDA #$00
        STA ZP_PROJ_DIR,X        ; Deactivate projectile
.no_hit:
        JMP .next
@ %def HAZARD_CHECK

\section{Joystick input handler}

[[JOYSTICK_HANDLER]] reads the Apple~II game-port buttons and
paddles. The input dispatcher jumps here when joystick mode is active
([[$48]] negative).

Buttons~0 and~1 both trigger a jump ([[ZP_JUMP_FLAG]]~$\leftarrow$~[[$FF]]). The zero-page flag
[[$49]] tracks press state to prevent auto-repeat: the jump flag is only
set on the initial button-down transition.

Paddle reading alternates between axes each frame, gated by the display
page flag in ZP~[[$00]] (which toggles sign every frame via
[[DISPLAY_PAGE_FLIP]]). On positive frames the vertical axis~(1) is
read; on negative frames the horizontal axis~(0). This spreads the
paddle timing overhead across two frames.

Vertical zones: $<$[[$50]] = ascend, [[$50]]--[[$AE]] = dead zone, $\ge$[[$AF]] =
descend. Horizontal zones: $<$[[$3C]] = hard left, [[$3C]]--[[$63]] = soft left
(with hysteresis), [[$64]]--[[$9B]] = dead zone, [[$9C]]--[[$C2]] = soft right
(with hysteresis), $\ge$[[$C3]] = hard right. In the soft zones the
joystick won't re-issue a direction command if the player is already
moving that way, preventing jitter at the threshold.

Each direction branch tail-calls into [[INPUT_DISPATCH]] at the
appropriate entry point to share the keyboard handler's direction-setting
logic.

<<joystick handler defines>>=

; --- Apple II ROM ---
PREAD           = $FB1E         ; Read paddle axis X -> Y (ROM)

; --- Zero-page (input) ---
ZP_PAGE_FLAG    = $00           ; Display page flag (toggles sign each frame)
ZP_LAST_DIR     = $01           ; Last direction key code
ZP_JUMP_FLAG    = $05           ; Jump flag ($FF = jump requested)
ZP_KEY_CODE     = $07           ; Current key code
ZP_INPUT_MODE   = $48           ; Input mode (positive = keyboard, negative = joystick)
ZP_BTN_STATE    = $49           ; Button state ($FF = pressed, $01 = released)

; --- Joystick thresholds ---
JOY_V_UP        = $50           ; Vertical: below = ascend
JOY_V_DOWN      = $AF           ; Vertical: above = descend
JOY_H_LEFT_HARD = $3C           ; Horizontal: below = hard left
JOY_H_LEFT_SOFT = $64           ; Horizontal: below = soft left
JOY_H_RIGHT_SOFT = $9C          ; Horizontal: above = soft right
JOY_H_RIGHT_HARD = $C3          ; Horizontal: above = hard right
@

<<joystick handler>>=

        ORG $012B
JOYSTICK_HANDLER:
        SUBROUTINE
        ; Joystick input handler -- reads buttons and paddles.
        ;
        ; Inputs:
        ;   SW_PUSH_BTN0/1 -- button state (bit 7 = pressed)
        ;   ZP_PAGE_FLAG -- selects vertical or horizontal axis
        ;
        ; Behavior:
        ;   Buttons: set jump flag on initial press.
        ;   Vertical axis (even frames): ascend or descend.
        ;   Horizontal axis (odd frames): move left or right.
        ;   Tail-calls into INPUT_DISPATCH entry points.
        ;
        ; Modifies:
        ;   ZP_BTN_STATE, ZP_JUMP_FLAG, direction slots via INPUT_DISPATCH
        ; Clobbers: A, X, Y

; --- Button handling ---
        LDA SW_PUSH_BTN0        ; Check button 0
        BPL .check_btn1         ; Not pressed -> check button 1
.btn_pressed:
        LDA ZP_BTN_STATE        ; Already in pressed state?
        BMI .read_paddle        ; Yes -> skip (no auto-repeat)
        LDA #$FF
        STA ZP_BTN_STATE        ; Mark as pressed
        STA ZP_JUMP_FLAG        ; Set jump flag
        BMI .read_paddle        ; Always taken

.check_btn1:
        LDA SW_PUSH_BTN1        ; Check button 1
        BMI .btn_pressed        ; Pressed -> same as button 0
        LDA #$01
        STA ZP_BTN_STATE        ; Mark as released

; --- Paddle axis selection ---
.read_paddle:
        LDA ZP_PAGE_FLAG        ; Display page flag
        BMI .read_horizontal    ; Negative -> horizontal axis

; --- Vertical axis (paddle 1) ---
        LDX #$01                ; Axis 1 = vertical
        JSR PREAD               ; Read paddle -> Y
        CPY #JOY_V_UP           ; Above ascend threshold?
        BCS .check_descend_v    ; Yes -> check descend zone
        JMP INPUT_DO_ASCEND     ; Ascend

.check_descend_v:
        CPY #JOY_V_DOWN         ; Above descend threshold?
        BCS .do_descend_v       ; Yes -> descend
        RTS                     ; Dead zone -- no action

.do_descend_v:
        JMP INPUT_DO_DESCEND    ; Descend

; --- Horizontal axis (paddle 0) ---
.read_horizontal:
        LDX #$00                ; Axis 0 = horizontal
        JSR PREAD               ; Read paddle -> Y
        CPY #JOY_H_LEFT_HARD   ; Hard left zone?
        BCS .check_soft_left    ; No -> check soft left
        LDA #KEY_LEFT           ; Left arrow key code
        JMP INPUT_SET_LEFT      ; Set left direction

.check_soft_left:
        CPY #JOY_H_LEFT_SOFT   ; Soft left zone?
        BCS .check_dead_zone    ; No -> check dead zone
        LDA ZP_LAST_DIR         ; Already moving left?
        CMP #KEY_LEFT
        BEQ .no_change          ; Yes -> no action (hysteresis)
        LDA #KEY_LEFT
        JMP INPUT_SET_LEFT      ; Set left direction

.no_change:
        RTS

.check_dead_zone:
        CPY #JOY_H_RIGHT_SOFT  ; In dead zone?
        BCS .check_soft_right   ; No -> check right zones
        RTS                     ; Dead zone -- no action

.check_soft_right:
        CPY #JOY_H_RIGHT_HARD  ; Hard right zone?
        BCS .hard_right         ; Yes -> set right
        LDA ZP_LAST_DIR         ; Already moving right?
        CMP #KEY_RIGHT
        BEQ .no_change          ; Yes -> no action (hysteresis)
        LDA #KEY_RIGHT
        JMP INPUT_SET_RIGHT     ; Set right direction

.hard_right:
        LDA #KEY_RIGHT
        JMP INPUT_SET_RIGHT     ; Set right direction
@ %def JOYSTICK_HANDLER

\section{Extended key handler}

[[KEY_HANDLER_EXT]] handles Ctrl-J (switch to joystick mode),
Ctrl-K (switch to keyboard mode), and Ctrl-V (click the speaker). Any
other key just clears the strobe and returns.

<<key handler ext>>=

        ORG $0194
KEY_HANDLER_EXT:
        SUBROUTINE
        ; Extended key handler -- input mode switching and speaker.
        ;
        ; Inputs:
        ;   A -- key code from keyboard
        ;
        ; Behavior:
        ;   Ctrl-J: set ZP_INPUT_MODE <- #$FF (joystick mode).
        ;   Ctrl-K: set ZP_INPUT_MODE <- #$01 (keyboard mode).
        ;   Ctrl-V: toggle speaker.
        ;   Other: clear strobe and return.
        ;
        ; Modifies:
        ;   ZP $48 (input mode flag)
        ; Clobbers: A

        CMP #KEY_CTRL_J
        BNE .check_kbd
        LDA #$FF
        STA ZP_INPUT_MODE       ; Joystick mode
        BIT KBDSTROBE
        RTS

.check_kbd:
        CMP #KEY_CTRL_K
        BNE .check_speaker
        LDA #$01
        STA ZP_INPUT_MODE       ; Keyboard mode
        BIT KBDSTROBE
        RTS

.check_speaker:
        CMP #KEY_CTRL_V
        BNE .unknown
        BIT SW_SPEAKER          ; Click speaker
.unknown:
        BIT KBDSTROBE           ; Clear strobe
        RTS
@ %def KEY_HANDLER_EXT

@ \chapter{Game loop}

The main game loop lives at [[MAIN_LOOP]] in the persistent game code area
([[$6000]]--[[$66FF]]). Each frame calls approximately 25~subroutines that handle
rendering, input, physics, collision detection, and AI.

\section{Main loop dispatcher}

[[MAIN_LOOP]] calls subroutines in a fixed order each frame.
After all per-frame work, it increments the frame counter at
[[ZP_FRAME_COUNTER]], checks two game-state flags ([[ZP_LIVES_BCD]] and
[[ZP_GAME_OVER]]), and either loops back to [[MAIN_LOOP]] or branches to
level-complete ([[LIFE_LOST_HANDLER]]) or game-over ([[GAME_OVER]])
handlers.

\paragraph{Attract mode.}
During the attract/title screen, the loop is entered via
[[JSR ATTRACT_ENTRY]], which skips the first three calls (rendering
setup, scroll, and input).  Four [[BIT abs]] instructions at
[[ATTRACT_ENTRY]] serve as 3-byte NOPs during normal play; during
attract mode they are the entry point that harmlessly reads memory
before falling through to the active subroutines.

\paragraph{Self-modifying patches.}
Three bytes are patched when transitioning from attract to game mode:
\begin{itemize}
\item [[SMC_INPUT]]: changed from [[BIT]] ([[$2C]]) to [[JSR]]
  ([[OPCODE_JSR]]) --- enables input dispatch.
\item [[SMC_RENDER]]: changed from [[BIT]] ([[$2C]]) to [[JSR]]
  ([[OPCODE_JSR]]) --- enables sprite rendering.
\item [[SMC_ATTRACT]]: changed from [[JSR]] ([[OPCODE_JSR]]) to
  [[NOP]] ([[$EA]]) --- disables the attract post-frame callback.
\end{itemize}

<<main loop>>=

        ORG $67CB
MAIN_LOOP:
        SUBROUTINE
        ; Main game loop -- executes one frame of game logic.
        ;
        ; Behavior:
        ;   Calls ~25 subroutines for rendering, input, physics, AI.
        ;   Increments frame counter. Checks $5E (lives exhausted ->
        ;   LIFE_LOST_HANDLER) and $39 (hit credits exhausted ->
        ;   GAME_OVER) to exit the loop.
        ;
        ; Modifies:
        ;   All game state via subroutine calls, ZP $FD (frame counter)
        ; Clobbers: A, X, Y

; --- Per-frame subroutine calls ---
        JSR LEVEL_INTRO_TICK    ; Level intro / countdown state tick
        JSR DIFFICULTY_UPDATE   ; Ramp difficulty tier from score
SMC_INPUT = *
        JSR INPUT_DISPATCH      ; Input handler (BIT during attract)
        JSR INPUT_PROCESS       ; Input processing

; --- Movement direction slots ---
; Each slot is either JSR (active direction) or BIT (inactive / attract).
; The input handler patches the opcode byte to toggle directions.
; During attract mode, all four are BIT (harmless reads).
ATTRACT_ENTRY:
SMC_ASCEND = *
        BIT DO_ASCEND           ; Ascend (JSR when active)
SMC_DESCEND = *
        BIT DO_DESCEND          ; Descend (JSR when active)
SMC_MOVE_LEFT = *
        BIT DO_MOVE_LEFT        ; Move left (JSR when active)
SMC_MOVE_RIGHT = *
        BIT DO_MOVE_RIGHT       ; Move right (JSR when active)

        JSR DISPLAY_PAGE_FLIP   ; Toggle hi-res display page
        JSR PLAYER_MOVE_TICK    ; Player movement tick dispatcher
        JSR SCROLL_EDGE_R       ; Right-edge top-band pillar painter
        JSR SCROLL_EDGE_L       ; Left-edge top-band pillar painter
SMC_RENDER = *
        JSR DRAW_PLAYER         ; Draw player sprite (BIT during attract)
        JSR FLOOR_ENEMY_ADVANCE ; 4-slot floor-enemy AI advance + spawn
        JSR FLOOR_ENEMY_DRAW    ; 4-slot floor-enemy perspective-grid draw
        JSR SPECIAL_TICK        ; Special sprite slot: sound + position + rearm
        JSR SPECIAL_DRAW        ; Special sprite draw + hit/catch logic
        JSR COMPANION_UPDATE    ; Companion slot tick+draw
        JSR RESCUE_UPDATE       ; Rescue-child entity 20-slot tick
        JSR RESCUE_DRAW         ; Rescue-child draw + collision + projectile-spawn
        JSR HAZARD_CHECK        ; Hazard checking
        JSR ENEMY_C_ADVANCE     ; Enemy-C advance timer + respawn
        JSR ENEMY_C_DRAW        ; Enemy-C draw + enemy-slot collision
        JSR ENEMY_A_ADVANCE     ; Enemy-A advance timer + respawn
        JSR ENEMY_A_DRAW        ; Enemy-A draw + player-hit detection
        JSR ENEMY_B_ADVANCE     ; Enemy-B advance timer + respawn
        JSR ENEMY_B_DRAW        ; Enemy-B draw + player-hit detection
        JSR BEAM_UPDATE         ; Player laser-beam subsystem
        JSR DISPLAY_UPDATE      ; Display update
        JSR DRAW_ENTITIES       ; Entity draw dispatcher

; --- Frame end ---
        INC ZP_FRAME_COUNTER    ; Increment frame counter
SMC_ATTRACT = *
        NOP                     ; (JSR during attract mode)
        JSR POST_FRAME          ; Post-frame cleanup

; --- Exit checks ---
        LDA ZP_LIVES_BCD        ; HUD lives counter (BCD)
        BPL .check_game_over
        JMP LIFE_LOST_HANDLER   ; Lives exhausted (BCD underflow -> $99)
.check_game_over:
        LDA ZP_GAME_OVER        ; Per-hit credit counter
        BPL .next_frame
        JMP GAME_OVER           ; Hit credits exhausted
.next_frame:
        JMP MAIN_LOOP           ; Next frame
@ %def MAIN_LOOP SMC_INPUT ATTRACT_ENTRY SMC_ASCEND SMC_DESCEND SMC_MOVE_LEFT SMC_MOVE_RIGHT SMC_RENDER SMC_ATTRACT

\section{Display page flip}

[[DISPLAY_PAGE_FLIP]] toggles the active hi-res display page
using self-modifying code. The instruction at [[DISPLAY_PAGE_FLIP]] alternates between
[[SW_PAGE1]] and [[SW_PAGE2]] by XOR-patching its own operand byte at
[[SMC_PAGE_SWITCH]]. It also adjusts [[ZP_PAGE_FLAG]] by adding [[$80]] each
frame (a half-page scroll offset counter).

<<display page flip>>=

        ORG $6138
DISPLAY_PAGE_FLIP:
        ; Toggle hi-res display page via self-modifying LDA SW_PAGE1/SW_PAGE2.
        ;
        ; Behavior:
        ;   XOR-patches its own operand byte to alternate between
        ;   SW_PAGE1 (page 1) and SW_PAGE2 (page 2) each frame.  Also
        ;   advances ZP_PAGE_FLAG by $80.
        ;
        ; Modifies:
        ;   Display page soft switch, ZP_PAGE_FLAG, self
        ; Clobbers: A
SMC_PAGE_SWITCH = *+1
        LDA SW_PAGE2            ; Toggle display page (operand patched)
        LDA SMC_PAGE_SWITCH     ; Read current page switch low byte
        EOR #$01                ; Toggle SW_PAGE1 <-> SW_PAGE2
        STA SMC_PAGE_SWITCH     ; Patch for next frame
        LDA ZP_PAGE_FLAG
        CLC
        ADC #$80                ; Advance scroll offset
        STA ZP_PAGE_FLAG
        RTS
@ %def DISPLAY_PAGE_FLIP SMC_PAGE_SWITCH

\section{Pseudo-random number generator}

[[PRNG]] generates an 8-bit pseudo-random value using a
two-byte state in [[ZP_ANIM_COUNTER]] and [[ZP_PRNG_A]]. The
algorithm shifts [[ZP_ANIM_COUNTER]] right one bit, rotates the
result into [[ZP_PRNG_A]], XORs with the old [[ZP_ANIM_COUNTER]],
then swaps the two state bytes. The result is returned in~A.

<<prng defines>>=

; --- Zero-page (PRNG state) ---
ZP_PRNG_A       = $5F           ; PRNG state byte A
@

<<prng>>=

        ORG $6674
PRNG:
        SUBROUTINE
        ; Pseudo-random number generator -- 8-bit LFSR-style.
        ;
        ; Inputs:
        ;   ZP $1F, $5F -- PRNG state
        ;
        ; Outputs:
        ;   A -- pseudo-random value
        ;
        ; Modifies:
        ;   ZP $1F, $5F
        ; Clobbers: A, Y

        LDA ZP_ANIM_COUNTER       ; State byte 1
        LSR                       ; Shift right, bit 0 -> carry
        LDA ZP_PRNG_A             ; State byte 2
        ROR                       ; Rotate carry in from left
        EOR ZP_ANIM_COUNTER       ; XOR with original state 1
        LDY ZP_PRNG_A             ; Save old state 2
        STA ZP_PRNG_A             ; Store new state 2
        STY ZP_ANIM_COUNTER       ; Swap: old state 2 -> state 1
        RTS
@ %def PRNG

\section{Timer display update}

[[DISPLAY_UPDATE]] draws an animated timer element on the status
bar. It sets up a 1$\times$6 sprite at column~9, row~[[$16]], then indexes
the animation counter ([[ZP_ANIM_COUNTER]]) into frame tables at [[TIMER_FRAME_LO]] and [[TIMER_FRAME_HI]] to
select the current frame's tile data. The selected pair is stored at
[[SMC_TILE_SRC_LO]]/[[SMC_TILE_SRC_HI]] and drawn via [[DRAW_SPRITE_OPAQUE]].

<<display update defines>>=

; --- Timer display tables ---
TIMER_FRAME_LO  = $6800         ; Timer animation frame table, low bytes
TIMER_FRAME_HI  = $6900         ; Timer animation frame table, high bytes

; --- Digit tile tables ---
DIGIT_TILE_LO   = $AFF6         ; Digit tile data table, low bytes (0-9)
DIGIT_TILE_HI   = $B076         ; Digit tile data table, high bytes (0-9)
@

<<display update>>=

        ORG $10AB
DISPLAY_UPDATE:
        SUBROUTINE
        ; Timer display update -- draws animated timer element.
        ;
        ; Inputs:
        ;   ZP_ANIM_COUNTER -- animation frame index
        ;
        ; Modifies:
        ;   SMC_TILE_SRC_LO/HI (tile data pointer), sprite params
        ; Clobbers: A, X

; --- Set up sprite parameters ---
        LDA #$09
        STA ZP_SPRITE_X          ; Column = 9
        LDA #$01
        STA ZP_SPRITE_W          ; Width = 1
        LDA #$06
        STA ZP_SPRITE_H          ; Height = 6
        LDA #$16
        STA ZP_SPRITE_Y          ; Row = $16

; --- Select animation frame ---
        LDX ZP_ANIM_COUNTER      ; Current frame index
        LDA TIMER_FRAME_HI,X     ; Frame data high byte
        AND #$7F                  ; Strip high bit
        STA SMC_TILE_SRC_HI
        LDA TIMER_FRAME_LO,X     ; Frame data low byte
        STA SMC_TILE_SRC_LO
        JSR DRAW_SPRITE_OPAQUE    ; Draw the tile
        RTS
@ %def DISPLAY_UPDATE

\section{Score and status display}

[[POST_FRAME]] runs after each game frame to draw the score and
status digits on the screen. It extracts BCD nibbles from
[[ZP_SCORE_HI]], [[ZP_SCORE_MID]], and~[[ZP_SCORE_LO]], and draws each
digit at a specific column position.  The BCD lives counter
([[ZP_LIVES_BCD]]) is also drawn as two digits.

Two helper sub-entries exist:
\begin{itemize}
\item [[DRAW_DIGIT_SHORT]] sets width/height/row to 1/6/[[$0C]]
  before falling through.
\item [[DRAW_DIGIT]] looks up a pointer from the 10-entry tables
  [[DIGIT_TILE_LO]] / [[DIGIT_TILE_HI]] (indexed by the BCD nibble
  0--9), patches [[SMC_TILE_SRC_LO]] / [[SMC_TILE_SRC_HI]] inside
  [[DRAW_SPRITE_OPAQUE]], and calls the opaque blitter to
  overwrite the HUD-strip dither pattern with the digit glyph.
\end{itemize}

The digit positions (column values stored in~[[ZP_SPRITE_X]]) are:
2, 4, 6, 8, and~10 for the five nibbles of D1--D3; columns~6 and~4
for the level-state digits.

\paragraph{Digit tile data.}  All ten HUD digit glyphs live
contiguously in the level-1 swappable bank at [[DIGIT_TILE_DATA]]
([[$B4B1]]--[[$B528]], 120 bytes: ten 12-byte glyphs, each
$2\times 6$ bytes matching [[ZP_SPRITE_W]]~=~[[$01]] /
[[ZP_SPRITE_H]]~=~[[$06]]).  The pointer tables
[[DIGIT_TILE_LO]] / [[DIGIT_TILE_HI]] sit one page below the main
[[SPRITE_TABLE_LO]] / [[SPRITE_TABLE_HI]] pointer bank and
coincidentally resolve to the same ten glyph addresses.  Each byte
has its high bit set to select the blue/orange palette so the
digits render in blue on the HUD strip's violet-and-white dither.
Figure~\ref{fig:digit_tiles} shows the decoded glyph forms.

\begin{figure}[H]
\centering
\includegraphics[width=0.98\textwidth]{images/digit_tiles.png}
\caption{[[DIGIT_TILE_DATA]] ([[$B4B1]]--[[$B528]]), ten
[[$02]]$\times$[[$06]] HUD digit glyphs blitted by
[[POST_FRAME]] and [[DISPLAY_UPDATE]] via [[DRAW_SPRITE_OPAQUE]].
On-pixels are rendered here in blue; the surrounding black is
``transparent'' for the purposes of the figure but in the game it
overwrites whatever dither was beneath (opaque blit).}
\label{fig:digit_tiles}
\end{figure}

<<post frame>>=

        ORG $10CF
POST_FRAME:
        SUBROUTINE
        ; Score and status display -- draws BCD digits each frame.
        ;
        ; Inputs:
        ;   ZP_SCORE_HI/MID/LO -- 3-byte BCD score (packed nibbles)
        ;   ZP_LIVES_BCD       -- BCD lives counter drawn as two HUD digits
        ;
        ; Modifies:
        ;   Sprite parameters, SMC_TILE_SRC_LO/HI
        ; Clobbers: A, X

; --- Digit 1: low nibble of ZP_SCORE_HI, column 2 ---
        LDA ZP_SCORE_HI
        AND #$0F
        TAX
        LDA #$02
        STA ZP_SPRITE_X
        JSR DRAW_DIGIT_SHORT

; --- Digit 2: low nibble of ZP_SCORE_MID, column 6 ---
        LDA ZP_SCORE_MID
        AND #$0F
        TAX
        LDA #$06
        STA ZP_SPRITE_X
        JSR DRAW_DIGIT_SHORT

; --- Digit 3: high nibble of ZP_SCORE_MID, column 4 ---
        LDA ZP_SCORE_MID
        AND #$F0
        LSR
        LSR
        LSR
        LSR
        TAX
        LDA #$04
        STA ZP_SPRITE_X
        JSR DRAW_DIGIT_SHORT

; --- Digit 4: low nibble of ZP_SCORE_LO, column $0A ---
        LDA ZP_SCORE_LO
        AND #$0F
        TAX
        LDA #$0A
        STA ZP_SPRITE_X
        JSR DRAW_DIGIT_SHORT

; --- Digit 5: high nibble of ZP_SCORE_LO, column 8 ---
        LDA ZP_SCORE_LO
        AND #$F0
        LSR
        LSR
        LSR
        LSR
        TAX
        LDA #$08
        STA ZP_SPRITE_X
        JSR DRAW_DIGIT_SHORT

; --- Lives digit 1: low nibble of ZP_LIVES_BCD, column 6 ---
        LDA ZP_LIVES_BCD
        BPL .lives_ok1
        LDA #$00                  ; Clamp negative to 0 (post-game-over frames)
.lives_ok1:
        AND #$0F
        TAX
        LDA #$01
        STA ZP_SPRITE_W
        LDA #$06
        STA ZP_SPRITE_H
        LDA #$16
        STA ZP_SPRITE_Y
        LDA #$06
        STA ZP_SPRITE_X
        JSR DRAW_DIGIT

; --- Lives digit 2: high nibble of ZP_LIVES_BCD, column 4 ---
        LDA ZP_LIVES_BCD
        BPL .lives_ok2
        LDA #$00                  ; Clamp negative to 0
.lives_ok2:
        AND #$F0
        LSR
        LSR
        LSR
        LSR
        TAX
        LDA #$01
        STA ZP_SPRITE_W
        LDA #$06
        STA ZP_SPRITE_H
        LDA #$16
        STA ZP_SPRITE_Y
        LDA #$04
        STA ZP_SPRITE_X
        JSR DRAW_DIGIT
        RTS

; --- Helper: draw digit with default sprite params ---
DRAW_DIGIT_SHORT:
        LDA #$01
        STA ZP_SPRITE_W          ; Width = 1
        LDA #$06
        STA ZP_SPRITE_H          ; Height = 6
        LDA #$0C
        STA ZP_SPRITE_Y          ; Row = $0C
; --- Draw digit from lookup table ---
DRAW_DIGIT:
        LDA DIGIT_TILE_LO,X      ; Digit tile data low
        STA SMC_TILE_SRC_LO
        LDA DIGIT_TILE_HI,X      ; Digit tile data high
        STA SMC_TILE_SRC_HI
        JSR DRAW_SPRITE_OPAQUE    ; Draw the digit tile
        RTS
@ %def POST_FRAME DRAW_DIGIT_SHORT DRAW_DIGIT

\section{High score check}

[[LEVEL_TRANSITION]] is called during the level-complete
sequence. It performs a 3-byte BCD comparison of the current score
([[ZP_SCORE_HI]]/[[ZP_SCORE_MID]]/[[ZP_SCORE_LO]]) against the stored
high score ([[ZP_HIGH_SCORE_0]]/[[ZP_HIGH_SCORE_1]]/[[ZP_HIGH_SCORE_2]]).
If the current score does not exceed the high score, it returns
immediately.

When a new high score is detected, it copies the current score into the
high-score slots, then mirrors the six-row score-digit strip across the
HUD on both hi-res pages (rows~[[$0C]]--[[$11]]).  For each row [[X]]
in that range the routine stages three 16-bit scratch pointers in
zero~page: [[ZP_HISCORE_SRC]] (read pointer, page~1 row+[[$01]]; the
left HUD digit strip at columns~1--10), [[ZP_HISCORE_DST1]] (write
pointer, page~1 row+[[$1E]]; the right HUD strip at columns~30--39 on
page~1) and [[ZP_HISCORE_DST2]] (write pointer, page~2 row+[[$1E]];
the right HUD strip on page~2).  The inner loop reads ten bytes from
[[ZP_HISCORE_SRC]] and stores them to both destinations, so the new
high score is visible in the right HUD strip regardless of which
display page the attract/game loop is showing.  The row-low byte comes
from [[SCREEN_ROW_ADDR_LO]] (shared between pages~1 and~2); the row-hi
bytes come from [[SCREEN_ROW_ADDR_HI]] (page~1) and
[[SCREEN_ROW_ADDR_HI2]] (page~2).

<<level transition defines>>=

; --- Zero-page (high score) ---
ZP_HIGH_SCORE_0 = $20           ; High score byte 0 (highest BCD digits)
ZP_HIGH_SCORE_1 = $21           ; High score byte 1
ZP_HIGH_SCORE_2 = $22           ; High score byte 2

; --- Zero-page (high-score mirror pointers) ---
; Three 16-bit scratch pointer pairs used only by LEVEL_TRANSITION's
; hi-res row-copy inner loop.  SRC reads from the left HUD digit strip
; on page 1 (col $01-$0A); DST1 / DST2 write to the right HUD strip
; (col $1E-$27) on page 1 and page 2 respectively.  No other routine
; touches $23-$28.
ZP_HISCORE_SRC  = $23           ; SRC  pointer lo/hi: page 1 row + $01
ZP_HISCORE_DST1 = $25           ; DST1 pointer lo/hi: page 1 row + $1E
ZP_HISCORE_DST2 = $27           ; DST2 pointer lo/hi: page 2 row + $1E
@

<<level transition>>=

        ORG $116C
LEVEL_TRANSITION:
        SUBROUTINE
        ; High score check -- if current > stored high, update the
        ; stored high score and mirror six rows of the score-digit strip
        ; into both pages' right HUD areas.
        ;
        ; Inputs:
        ;   ZP_SCORE_HI/MID/LO        -- current score (BCD).
        ;   ZP_HIGH_SCORE_0/1/2       -- stored high score (BCD).
        ;   SCREEN_ROW_ADDR_LO/HI/HI2 -- row-base tables (pages 1/2).
        ;
        ; Modifies:
        ;   ZP_HIGH_SCORE_0/1/2 (on new high),
        ;   ZP_HISCORE_SRC/DST1/DST2 (scratch pointer pairs),
        ;   hi-res page-1 and page-2 right HUD strip (rows $0C..$11,
        ;   cols $1E..$27).
        ; Clobbers: A, X, Y

; --- BCD comparison: high score >= current score? ---
        SED
        SEC
        LDA ZP_HIGH_SCORE_2      ; Compare byte 2 (low digits)
        SBC ZP_SCORE_LO
        LDA ZP_HIGH_SCORE_1      ; Compare byte 1
        SBC ZP_SCORE_MID
        LDA ZP_HIGH_SCORE_0      ; Compare byte 0 (high digits)
        SBC ZP_SCORE_HI
        CLD
        BCC .new_high_score       ; Carry clear = current > high
        RTS                       ; No new high score

; --- Update high score ---
.new_high_score:
        LDA ZP_SCORE_HI
        STA ZP_HIGH_SCORE_0
        LDA ZP_SCORE_MID
        STA ZP_HIGH_SCORE_1
        LDA ZP_SCORE_LO
        STA ZP_HIGH_SCORE_2

; --- Mirror the score-digit strip into the HUD, rows $0C..$11 ---
; Reads page 1 row+$01..+$0A (the left HUD digit strip) and writes it
; to row+$1E..+$27 on BOTH page 1 (DST1) and page 2 (DST2).  The page-1
; and page-2 DSTs share a common row-low byte via SCREEN_ROW_ADDR_LO;
; only the high byte differs.
        LDX #$0C                        ; top HUD row (first of six)
.copy_row:
        LDA SCREEN_ROW_ADDR_HI,X        ; page-1 row hi
        STA ZP_HISCORE_SRC+1            ; SRC  page-1 hi
        STA ZP_HISCORE_DST1+1           ; DST1 page-1 hi
        LDA SCREEN_ROW_ADDR_HI2,X       ; page-2 row hi
        STA ZP_HISCORE_DST2+1           ; DST2 page-2 hi
        LDA SCREEN_ROW_ADDR_LO,X        ; row lo (shared by pages 1/2)
        CLC
        ADC #$01                        ; +$01 = left-strip column 1
        STA ZP_HISCORE_SRC              ; SRC  lo = row + $01
        CLC
        ADC #$1D                        ; +$1E = right-strip column $1E
        STA ZP_HISCORE_DST1             ; DST1 lo = row + $1E (page 1)
        STA ZP_HISCORE_DST2             ; DST2 lo = row + $1E (page 2)
        LDY #$09                        ; 10 bytes per row (Y = 9..0)
.copy_byte:
        LDA (ZP_HISCORE_SRC),Y          ; read page-1 digit byte
        STA (ZP_HISCORE_DST1),Y         ; mirror into page-1 HUD
        STA (ZP_HISCORE_DST2),Y         ; mirror into page-2 HUD
        DEY
        BPL .copy_byte
        INX
        CPX #$12                        ; rows $0C..$11 inclusive
        BNE .copy_row
        RTS
@ %def LEVEL_TRANSITION

\section{Level state initialization}

[[INIT_LEVEL_STATE]] restores game state from three buffer
areas in page~2 memory, then zeros out entity slots and direction
patches.

Three block copies restore ZP regions from saved buffers:
\begin{itemize}
\item [[LVL_INIT_ENTITY]] (25~bytes) $\to$ [[ZP_ENTITY_BLOCK]] (entity parameters)
\item [[LVL_INIT_INPUT]] (30~bytes) $\to$ [[ZP_INPUT_BLOCK]] (input/direction state)
\item [[LVL_INIT_SPRITE]] (45~bytes) $\to$ [[ZP_SPRITE_BLOCK]] (sprite/collision state)
\end{itemize}

After restoring state, it zeroes the entity activity table at
[[ENTITY_ACTIVE]] (20 slots), the [[ZP_PROJ_DIR]] 4-slot projectile
direction array, [[ZP_MOVE_DIR]] (player horizontal move direction),
the [[ZP_FRAME_COUNTER]], and [[BEAM_STATE]]. It sets
[[ZP_WALK_FRAME]] and [[ZP_SPRITE_XREF]]~=~[[$02]],
[[ZP_GAME_OVER]]~=~[[$01]], fills [[TRACER_STATE]] (5~slots) with
[[$FF]], and patches the four direction slots in the main loop to
[[BIT]] ([[$2C]], inactive).  Finally it loads the 2-byte
[[LVL_INIT_HIT_Y]] pair into [[ZP_HIT_Y_OFFSET]]/[[ZP_HIT_Y_SPAN]],
the level-tuned floor-enemy collision Y-window (see
[[RESCUE_UPDATE]]).

<<init level state defines>>=

; --- Zero-page (level-state restore targets) ---
ZP_HIT_Y_OFFSET = $42           ; Rescue-vs-floor-enemy Y-window near edge
                                ; (loaded from LVL_INIT_HIT_Y low byte)
ZP_HIT_Y_SPAN   = $43           ; Rescue-vs-floor-enemy Y-window span
                                ; (loaded from LVL_INIT_HIT_Y high byte)
ZP_ENTITY_BLOCK = $D4           ; Entity parameter block ($D4-$EC, 25 bytes)
ZP_SPRITE_BLOCK = $88           ; Sprite/collision state block ($88-$B4, 45 bytes)
ZP_INPUT_BLOCK  = $01           ; Input/direction state block ($01-$1E, 30 bytes)

; --- Level-state initialization source buffers ---
; These four blocks live at $029A-$02FF inside the per-level swappable
; region (loaded from track-5+ sector 0 by the level loader).  Their
; contents are specific to each level; level 1's block-02 payload is the
; reference.  INIT_LEVEL_STATE copies them into their ZP destinations
; every time a level is entered or a life is lost.
LVL_INIT_HIT_Y  = $029A         ; 2-byte Y-window pair -> ZP_HIT_Y_OFFSET/SPAN
LVL_INIT_ENTITY = $029C         ; 25-byte entity block -> ZP_ENTITY_BLOCK
LVL_INIT_SPRITE = $02B5         ; 45-byte sprite block -> ZP_SPRITE_BLOCK
LVL_INIT_INPUT  = $02E2         ; 30-byte input block -> ZP_INPUT_BLOCK
@ %def ZP_HIT_Y_OFFSET ZP_HIT_Y_SPAN ZP_ENTITY_BLOCK ZP_SPRITE_BLOCK ZP_INPUT_BLOCK
@ %def LVL_INIT_HIT_Y LVL_INIT_ENTITY LVL_INIT_SPRITE LVL_INIT_INPUT

<<init level state>>=

        ORG $11B8
INIT_LEVEL_STATE:
        SUBROUTINE
        ; Level state initialization -- restores game state from buffers.
        ;
        ; Behavior:
        ;   Copies three contiguous source blocks from the per-level
        ;   swappable region ($029A-$02FF) into their ZP destinations,
        ;   then zeros a handful of per-life state slots and disables
        ;   the four main-loop direction-dispatch JSRs by rewriting
        ;   their opcode bytes to BIT ($2C).  Finally, seeds the
        ;   floor-enemy Y-window from the 2-byte LVL_INIT_HIT_Y pair.
        ;
        ; Modifies:
        ;   ZP_INPUT_BLOCK ($01-$1E), ZP_GAME_OVER, ZP_HIT_Y_OFFSET,
        ;   ZP_HIT_Y_SPAN, ZP_WALK_FRAME, ZP_SPRITE_XREF,
        ;   ZP_SPRITE_BLOCK ($88-$B4), ZP_PROJ_DIR ($C5-$C8),
        ;   ZP_ENTITY_BLOCK ($D4-$EC), ZP_FRAME_COUNTER, ENTITY_ACTIVE,
        ;   BEAM_STATE, TRACER_STATE,
        ;   Main loop direction patches (SMC_ASCEND/DESCEND/MOVE_LEFT/RIGHT)
        ; Clobbers: A, X

; --- Restore entity parameter block (LVL_INIT_ENTITY -> ZP_ENTITY_BLOCK, 25 bytes) ---
        LDX #$18
.copy_entities:
        LDA LVL_INIT_ENTITY,X
        STA ZP_ENTITY_BLOCK,X
        DEX
        BPL .copy_entities

; --- Restore input/direction block (LVL_INIT_INPUT -> ZP_INPUT_BLOCK, 30 bytes) ---
        LDX #$1D
.copy_input:
        LDA LVL_INIT_INPUT,X
        STA ZP_INPUT_BLOCK,X
        DEX
        BPL .copy_input

; --- Restore sprite/collision block (LVL_INIT_SPRITE -> ZP_SPRITE_BLOCK, 45 bytes) ---
        LDX #$2C
.copy_sprites:
        LDA LVL_INIT_SPRITE,X
        STA ZP_SPRITE_BLOCK,X
        DEX
        BPL .copy_sprites

; --- Zero entity activity table ($03A8-$03BB) ---
        LDA #$00
        LDX #$13
.zero_entities:
        STA ENTITY_ACTIVE,X
        DEX
        BPL .zero_entities

; --- Zero 4-slot projectile direction array ---
        LDX #$03
.zero_movement:
        STA ZP_PROJ_DIR,X
        DEX
        BPL .zero_movement

        STA ZP_MOVE_DIR                 ; no horizontal player motion
        STA ZP_FRAME_COUNTER            ; reset free-running frame counter
        STA BEAM_STATE                  ; beam idle

; --- Initialize per-life scalar state ---
        LDX #$02
        STX ZP_WALK_FRAME               ; ZP_WALK_FRAME <- #$02
        STX ZP_SPRITE_XREF              ; ZP_SPRITE_XREF <- #$02
        DEX
        STX ZP_GAME_OVER                ; ZP_GAME_OVER <- #$01 (hits-remaining seed)

; --- Fill TRACER_STATE (5 slots) with $FF = inactive ---
        LDA #$FF
        LDX #$04
.fill_ff:
        STA TRACER_STATE,X
        DEX
        BPL .fill_ff

; --- Disable the four main-loop direction-dispatch JSRs (rewrite opcode to BIT) ---
        LDA #$2C                        ; BIT abs opcode
        STA SMC_ASCEND                  ; ascend slot -> BIT (no-op)
        STA SMC_DESCEND                 ; descend slot -> BIT
        STA SMC_MOVE_LEFT               ; left slot -> BIT
        STA SMC_MOVE_RIGHT              ; right slot -> BIT

; --- Seed floor-enemy collision Y-window ---
        LDA LVL_INIT_HIT_Y
        STA ZP_HIT_Y_OFFSET             ; near edge of Y window
        LDA LVL_INIT_HIT_Y+1
        STA ZP_HIT_Y_SPAN               ; far-edge delta
        RTS
@ %def INIT_LEVEL_STATE

\section{Score add}

[[SCORE_ADD]] adds a BCD value to the 3-byte score. The
addend's low byte is in [[ZP_SCORE_ADD_LO]] and high byte in
[[ZP_SCORE_ADD_HI]]; these are added to [[ZP_SCORE_LO]] and
[[ZP_SCORE_MID]] respectively, with carry propagating into
[[ZP_SCORE_HI]]. All arithmetic is performed in BCD mode.

<<score add defines>>=

; --- Zero-page (score add) ---
ZP_SCORE_ADD_LO = $1A           ; Score addend low byte (BCD)
ZP_SCORE_ADD_HI = $1B           ; Score addend high byte (BCD)
@

<<score add>>=

        ORG $121A
SCORE_ADD:
        SUBROUTINE
        ; Score add -- adds BCD value to 3-byte score.
        ;
        ; Inputs:
        ;   ZP_SCORE_ADD_LO/HI -- BCD addend
        ;
        ; Modifies:
        ;   ZP_SCORE_HI/MID/LO ($D1/$D2/$D3)
        ; Clobbers: A

        SED                       ; BCD mode
        CLC
        LDA ZP_SCORE_LO          ; Score low byte
        ADC ZP_SCORE_ADD_LO       ; Add low addend
        STA ZP_SCORE_LO
        LDA ZP_SCORE_MID          ; Score mid byte
        ADC ZP_SCORE_ADD_HI       ; Add high addend + carry
        STA ZP_SCORE_MID
        LDA ZP_SCORE_HI          ; Score high byte
        ADC #$00                  ; Propagate carry only
        STA ZP_SCORE_HI
        CLD                       ; Exit BCD mode
        RTS
@ %def SCORE_ADD

\section{Game start initialization}

[[GAME_START_INIT]] is called on the attract-to-game
transition and on in-game restart paths.  It resets the BCD-score
triple, BCD lives counter, HUD column bounds, and other top-of-game
state, then tail-calls [[RESUME_GAMEPLAY_SMC]] to re-arm the
three main-loop SMC slots ([[SMC_SR_YSRC]], [[SMC_INPUT]],
[[SMC_RENDER]], [[SMC_SR_HEIGHT]]) so the engine starts running the
input and draw subsystems.

\paragraph{Callers.}  Three direct [[JSR]] sites exist:
\begin{itemize}
\item Ctrl-R restart path inside [[INPUT_PROCESS]] --- fires when the
  start key is pressed in attract mode.
\item [[RESTART_NEW_GAME]] and [[START_GAME_FROM_ATTRACT]] --- restart paths
  inside the game-over / high-score code region at
  [[LIFE_LOST_HANDLER]]--[[START_ATTRACT]].
\end{itemize}

\paragraph{Second entry point.}  [[GAME_RESTART]] is the
skip-past-init sub-entry invoked from [[RESTART_DISPATCH]] (another restart path)
via [[JSR GAME_RESTART]].  It only resets the BCD lives counter, the
score triple, [[ZP_DEAD_SLOT_46]], and the restart flag [[ZP_RESTART_FLAG]]
before jumping into [[RESUME_GAMEPLAY_SMC]].

\paragraph{What [[RESUME_GAMEPLAY_SMC]] actually does.}  Despite its address landing
inside the [[SPECIAL_TICK]]--[[DIFFICULTY_UPDATE]] game-engine region, [[RESUME_GAMEPLAY_SMC]]
is a short 13-byte routine that re-patches main-loop self-modifying
bytes: [[SMC_SR_YSRC]] $\gets$ [[$06]] (i.e.\ the operand of
[[LDA ZP_PLAYER_COL]]), [[SMC_INPUT]] $\gets$ [[$20]] (JSR opcode),
[[SMC_RENDER]] $\gets$ [[$20]], and [[SMC_SR_HEIGHT]]
$\gets$ [[$13]] (default sprite height).  These are the exact three/four
SMC slots [[LEVEL_INTRO_TICK]] inlines the stores to when it flips
from intro to gameplay; the only difference is that
[[RESUME_GAMEPLAY_SMC]] is a callable entry used by cold-start and
restart paths instead of being inlined.

\paragraph{Initial values written (in order).}

\begin{center}
\begin{tabular}{l|l|l}
Addr & Name & Initial value \\
\hline
[[ZP_PLAYER_Y]]       & Player world-Y index & [[$6B]] (starting perspective-table Y) \\
[[ZP_SCORE_0]]        & BCD score byte 0 & [[$00]] \\
[[ZP_SCORE_1]]        & BCD score byte 1 & [[$00]] \\
[[ZP_SCORE_2]]        & BCD score byte 2 & [[$00]] \\
[[HUD_SCORE_COL]]     & Score-HUD right edge & [[$00]] (= left edge of playfield) \\
[[ZP_CLEAR_COL]]      & Playfield-clear col & [[$27]] (column 39) \\
[[HUD_LIVES_COL]]     & Lives-HUD left edge & [[$28]] (= right edge of playfield) \\
[[ZP_SCORE_HI]]       & BCD score hi & [[$00]] \\
[[ZP_SCORE_MID]]      & BCD score mid & [[$00]] \\
[[ZP_SCORE_LO]]       & BCD score lo & [[$00]] \\
[[ZP_LIVES_BCD]]      & On-screen lives & [[$04]] (four lives, BCD-decremented on death) \\
[[ZP_DEAD_SLOT_46]]   & (write-only) & [[$00]] (never read --- dead store) \\
[[ZP_RESTART_FLAG]]   & Restart flag & [[$FF]] (write-only in practice; the
only read is at [[RESTART_DISPATCH]] which is dead code) \\
\end{tabular}
\end{center}

In addition two subsystem resets are called: [[DIFFICULTY_RESET]]
installs the minimum-tier preset, and [[INIT_LEVEL_STATE]] restores
the 100-byte ZP bank from the page-2 master buffers and clears the
entity-active table.

\paragraph{HUD column bounds.}  The pair [[HUD_SCORE_COL]] / [[HUD_LIVES_COL]] are not HUD
``values'' but the left / right column bounds of the playable strip:
[[BEAM_UPDATE]] gates its tracer pixel-draw on
[[HUD_SCORE_COL]]~$\le$~col~$<$~[[HUD_LIVES_COL]] (see the
``skip-draw'' pair inside [[BEAM_UPDATE]]).  Initializing them to 0 and [[$28]]
opens the full 40-column strip; [[REFRESH_RIGHT_WALL]]/[[REFRESH_LEFT_WALL]] later adjust
them (together with [[ZP_CLEAR_COL]]) as the lives count changes so
the HUD numerals paint to the right of the playfield.

\paragraph{[[ZP_LIVES_BCD]] is the on-screen lives counter.}
[[POST_FRAME]] draws the two BCD nibbles of [[ZP_LIVES_BCD]] as sprite digits at
HUD columns 4 and 6 every frame.  [[ZP_LIVES_BCD]] is BCD-decremented inside [[SPECIAL_TICK]]
(under [[SED]]) when the player dies, and by
[[LEVEL_INTRO_TICK]]'s wait-phase tick.  When it goes negative the
game-over path at [[LIFE_LOST_HANDLER]] takes over from [[MAIN_LOOP]] --- this is the "lose"
exit, not a level-timer.  The previous naming [[ZP_LEVEL_STATE]] was a
guess that pre-dated understanding [[POST_FRAME]] / [[SPECIAL_TICK]];
[[ZP_LIVES_BCD]] is the correct label.

<<game start init defines>>=

; --- Zero-page (game start) ---
ZP_PLAYER_Y     = $4A           ; Player Y (perspective-table index)
ZP_WALK_FRAME   = $4B           ; Walking-animation frame (floor-stripe index)
ZP_SCORE_0      = $2B           ; Score HUD digit 0 (runtime sprite slot)
ZP_SCORE_1      = $2C           ; Score HUD digit 1
ZP_SCORE_2      = $2D           ; Score HUD digit 2
ZP_CLEAR_COL    = $2E           ; Playfield-clear column counter / right edge
ZP_LIVES_BCD    = $5E           ; BCD lives counter (shown in HUD; <0 = game over)
ZP_RESTART_FLAG = $44           ; Dispatch flag written to $FF on cold start;
                                ; only read (dead code)
ZP_DEAD_SLOT_46 = $46           ; Write-only ZP slot in GAME_RESTART (dead
                                ; store: the only access is the STX at
                                ; GAME_RESTART; no LDA/CMP/BIT reads exist)

; --- Playfield-column HUD bounds (read by BEAM_UPDATE, written here) ---
HUD_SCORE_COL   = $65AB         ; Score-HUD right edge / playfield left bound
HUD_LIVES_COL   = $65A7         ; Lives-HUD left edge / playfield right bound

; --- Score (declared here; $D1/$D2/$D3 are the BCD score triple) ---
ZP_SCORE_HI     = $D1           ; BCD score, high byte (ten-thousands / hundred-thousands)
ZP_SCORE_MID    = $D2           ; BCD score, middle byte (thousands / hundreds)
ZP_SCORE_LO     = $D3           ; BCD score, low byte (tens / ones)

; --- Tail-call target (sub-entry inside LEVEL_INTRO_TICK's .activate) ---
; RESUME_GAMEPLAY_SMC is a module-level label, inside the
; LEVEL_INTRO_TICK chunk; it's the 13-byte SMC-patch tail of the
; .activate block, also reached directly by GAME_START_INIT's JMP.
@

<<game start init>>=

        ORG $13A4
GAME_START_INIT:
        SUBROUTINE
        ; Game start initialization -- reset BCD score, lives, HUD
        ; column bounds, then resume main-loop subsystems.
        ;
        ; Behavior:
        ;   Seeds ZP_PLAYER_Y to starting position ($6B).
        ;   Zeros the three on-screen score digits and the score BCD
        ;     triple.  Sets the two HUD column bounds that clip the
        ;     beam-tracer draw to the playfield.
        ;   Sets lives counter to #$04 (BCD).  Sets restart flag to #$FF.
        ;   Calls DIFFICULTY_RESET (minimum tier preset) and
        ;     INIT_LEVEL_STATE (restore ZP from master buffers).
        ;   Tail-calls RESUME_GAMEPLAY_SMC to re-enable input
        ;     and sprite-render main-loop slots.
        ;
        ; Modifies:
        ;   ZP_PLAYER_Y, ZP_SCORE_0..2, ZP_CLEAR_COL, ZP_LIVES_BCD,
        ;   ZP_SCORE_HI/MID/LO, ZP_RESTART_FLAG, ZP_DEAD_SLOT_46,
        ;   HUD_SCORE_COL, HUD_LIVES_COL
        ; Clobbers: A, X

; --- Player start position ---
        LDA #$6B
        STA ZP_PLAYER_Y          ; Starting Y (perspective-table index)

; --- Clear on-screen score digits + score-HUD left column ---
        LDA #$00
        STA ZP_SCORE_0           ; HUD score sprite slot 0
        STA ZP_SCORE_1           ; HUD score sprite slot 1
        STA ZP_SCORE_2           ; HUD score sprite slot 2
        STA HUD_SCORE_COL        ; Playfield left bound = col 0

; --- Set playfield column bounds (full 40-column strip) ---
        LDA #$27
        STA ZP_CLEAR_COL         ; Clear-loop max column = 39
        LDA #$28
        STA HUD_LIVES_COL        ; Playfield right bound = col 40

; --- Subsystem resets ---
        JSR DIFFICULTY_RESET     ; Minimum-tier preset
        JSR INIT_LEVEL_STATE     ; Restore ZP from master buffers

GAME_RESTART:
        ; Sub-entry: skips player-Y and HUD-column reseed.  The only
        ; textual caller is the [[JSR GAME_RESTART]] at $5ECB inside
        ; [[RESTART_DISPATCH]], which is statically dead code --- so
        ; this entry is also unreached in practice.  Kept as a
        ; documented sub-entry so the GAME_RESTART semantics (the
        ; lives/score/flag subset of GAME_START_INIT) remain explicit.

; --- Reset lives / score / flags ---
        LDA #$04
        STA ZP_LIVES_BCD         ; Four lives (BCD)
        LDX #$00
        STX ZP_SCORE_HI          ; Clear BCD score triple
        STX ZP_SCORE_MID
        STX ZP_SCORE_LO
        STX ZP_DEAD_SLOT_46      ; Write-only ZP slot; no reader exists
        DEX
        STX ZP_RESTART_FLAG      ; $FF cold-start marker; only read at
                                 ;   RESTART_DISPATCH(dead code) --- effectively
                                 ;   a dead store in the live engine

; --- Tail-call: resume main-loop input/render ---
        JMP RESUME_GAMEPLAY_SMC  ; Re-patches SMC slots in MAIN_LOOP
@ %def GAME_START_INIT GAME_RESTART

\section{Difficulty update}

[[DIFFICULTY_UPDATE]] is called once per frame from
[[MAIN_LOOP]], but only does work on the frame where the free-running
counter [[ZP_FRAME_COUNTER]] wraps to zero --- i.e.\ about every
256~frames ($\sim$4~seconds at 60~Hz).  On that frame it promotes the
game to a harder difficulty tier whenever the player's score has
climbed into a new bracket.

The tier index is built by combining two BCD digits of
[[ZP_SCORE_HI]]/[[ZP_SCORE_MID]]: the ten-thousands digit goes in the
high nibble and the thousands digit in the low nibble.  (These are the
two leftmost digits of the on-screen 5-digit score; see [[POST_FRAME]]
for how they are drawn.)  The resulting byte is compared against three
thresholds that pick one of four presets.  Each preset writes into six
shared ZP variables that other per-frame routines consult:

\begin{center}
\begin{tabular}{l|l|l|l|l|l|l|l}
Tier (score)       & Index & [[ZP_PROJ_MAX]] & [[ZP_PROJ_GATE]] & [[ZP_COMPANION_GATE]] & [[ZP_DIFF_THRESH_A]] & [[$35]] & [[ZP_ADVANCE_RATE]] \\
\hline
Minimum (<4000)    & <[[$04]]   & [[$FF]] & [[$FF]] & [[$FF]] & [[$00]] & [[$50]] & [[$01]] \\
Moderate (4000--9999) & [[$04]]--[[$0F]] & [[$00]] & [[$FF]] & [[$01]] & [[$40]] & ---  & ---  \\
Standard (10000--17999) & [[$10]]--[[$17]] & [[$01]] & [[$01]] & [[$01]] & [[$80]] & ---  & [[$02]] \\
Maximum (18000+)   & [[$18]]+  & [[$03]] & [[$01]] & [[$01]] & [[$F0]] & [[$30]] & [[$03]] \\
\end{tabular}
\end{center}

A cell of~--- means that preset does not touch that variable, so it
retains the value left by the previous tier or by [[DIFFICULTY_RESET]].
The three ``slot count'' variables ([[ZP_PROJ_MAX]], [[ZP_PROJ_GATE]], [[ZP_COMPANION_GATE]]) are gates for
indexed loops elsewhere in the engine: [[$FF]] flags the BMI-guarded
loops as empty.  [[HAZARD_CHECK]] reads [[ZP_PROJ_MAX]];
[[BEAM_UPDATE]] checks [[ZP_PROJ_GATE]] as a
single-bit enable ([[$FF]]~=~subsystem off, otherwise on); and the
[[DRAW_ENTITIES]] phase-4 companion draw gates on
[[ZP_COMPANION_GATE]].  Thus the beam is disabled at the
minimum and moderate tiers and enabled from ``standard'' onward
($\geq$~10000 points).  [[ZP_ADVANCE_RATE]] is the per-tick
decrement applied to the 16-bit counters at [[ZP_ENEMY_A_POS]] and
[[ZP_ENEMY_C_STATE]]+1 by [[ENEMY_A_ADVANCE]]'s tick path and
[[ENEMY_C_ADVANCE]]'s equivalent --- a larger rate means those events fire more often.

The sub-entry at [[DIFFICULTY_RESET]] also serves as the
minimum-tier preset and is called directly by [[GAME_START_INIT]] when
a new game begins.  Note that nothing in this routine scrolls or
touches the camera: the previous label [[SCROLL_CAMERA]] was a
placeholder guess and has been retired.

<<difficulty update defines>>=

; --- Zero-page (difficulty tiers) ---
ZP_DIFF_TMP     = $5C           ; Scratch: holds D2 high nibble shifted right
ZP_PROJ_GATE    = $32           ; Beam-subsystem gate (BPL=active; $FF=suppress)
                                ; Read at entry of BEAM_UPDATE.
ZP_DIFF_THRESH_A = $34          ; Primary tier threshold (varies: $00/$40/$80/$F0)
ZP_DIFF_THRESH_B = $35          ; Secondary tier threshold ($50 min, $30 max)
ZP_ADVANCE_RATE = $40           ; Per-tick decrement for 16-bit event timers
                                ; Read by $13F7 SBC $40 and $1675 SBC $40.
ZP_FRAME_COUNTER = $FD          ; Free-running frame counter (incremented in MAIN_LOOP)

@

<<difficulty update>>=

        ORG $719D
DIFFICULTY_UPDATE:
        SUBROUTINE
        ; Per-frame difficulty ramp.  When the free-running frame
        ; counter wraps to zero, promotes game parameters to the tier
        ; dictated by the current score.
        ;
        ; Inputs:
        ;   ZP_FRAME_COUNTER          --- run only when zero.
        ;   ZP_SCORE_HI low nibble    --- ten-thousands digit.
        ;   ZP_SCORE_MID high nibble  --- thousands digit.
        ;
        ; Behavior:
        ;   Builds tier index = (D1_lo << 4) | (D2_hi >> 4), dispatches
        ;   to one of four presets by comparing against ZP_MOVE_DIR/SOUND_FLAG_MASK/$18.
        ;   Each preset writes slot-count maxima ($31, $32, $33), tier
        ;   thresholds ($34, $35), and timer-advance rate.
        ;
        ; Modifies:
        ;   ZP_PROJ_MAX, ZP_PROJ_GATE, ZP_COMPANION_GATE,
        ;   ZP_DIFF_THRESH_A, ZP_DIFF_THRESH_B,
        ;   ZP_ADVANCE_RATE, ZP_DIFF_TMP.
        ; Clobbers: A, X

; --- Guard: only run on frame-counter wrap ---
        LDA ZP_FRAME_COUNTER
        BNE .done

; --- Build tier index from BCD score ---
        LDA ZP_SCORE_MID                ; Thousands digit in high nibble
        AND #$F0
        LSR
        LSR
        LSR
        LSR
        STA ZP_DIFF_TMP                 ; ...shifted to low nibble
        LDA ZP_SCORE_HI                 ; Ten-thousands digit in low nibble
        AND #$0F
        ASL
        ASL
        ASL
        ASL                             ; ...shifted to high nibble
        ORA ZP_DIFF_TMP                 ; Index = (D1_lo << 4) | (D2_hi >> 4)

; --- Dispatch by tier threshold ---
        CMP #$04
        BCC DIFFICULTY_RESET            ; <$04: minimum tier (tail-call)
        CMP #$10
        BCC .tier_moderate              ; $04..$0F: moderate tier
        CMP #$18
        BCC .tier_standard              ; $10..$17: standard tier

; --- Tier: maximum (index >= $18, score >= 18000) ---
        LDA #$03
        STA ZP_ADVANCE_RATE             ; Fast 16-bit timer advance
        STA ZP_PROJ_MAX                 ; 4 projectile slots (index 0..3)
        LDA #$01
        STA ZP_PROJ_GATE                ; Enemy slot active
        STA ZP_COMPANION_GATE           ; Companion slot active
        LDA #$F0
        STA ZP_DIFF_THRESH_A            ; Max primary threshold
        LDA #$30
        STA ZP_DIFF_THRESH_B            ; Max secondary threshold
.done:
        RTS

; --- Tier: minimum (index < $04, score < 4000) ---
; Also entered directly by GAME_START_INIT to reset difficulty.
DIFFICULTY_RESET:
        LDX #$FF
        STX ZP_PROJ_MAX                 ; No projectiles
        STX ZP_PROJ_GATE                ; Enemy slot suppressed
        STX ZP_COMPANION_GATE           ; Companion slot suppressed
        INX                             ; X=$00
        STX ZP_DIFF_THRESH_A            ; Zero primary threshold
        INX                             ; X=$01
        STX ZP_ADVANCE_RATE             ; Slow 16-bit timer advance
        LDA #$50
        STA ZP_DIFF_THRESH_B            ; Min secondary threshold
        RTS

; --- Tier: moderate (index $04..$0F, score 4000-9999) ---
.tier_moderate:
        LDX #$FF
        STX ZP_PROJ_GATE                ; Enemy slot suppressed
        INX                             ; X=$00
        STX ZP_PROJ_MAX                 ; 1 projectile slot
        INX                             ; X=$01
        STX ZP_COMPANION_GATE           ; Companion slot active
        LDA #$40
        STA ZP_DIFF_THRESH_A            ; Moderate primary threshold
        RTS

; --- Tier: standard (index $10..$17, score 10000-17999) ---
.tier_standard:
        LDX #$01
        STX ZP_PROJ_MAX                 ; 2 projectile slots
        STX ZP_PROJ_GATE                ; Enemy slot active
        STX ZP_COMPANION_GATE           ; Companion slot active
        INX                             ; X=$02
        STX ZP_ADVANCE_RATE             ; Medium 16-bit timer advance
        LDA #$80
        STA ZP_DIFF_THRESH_A            ; Standard primary threshold
        RTS
@ %def DIFFICULTY_UPDATE DIFFICULTY_RESET

\section{Life-lost handler (``game over'')}

[[LIFE_LOST_HANDLER]] is the end-of-life handler reached
from [[MAIN_LOOP]] when the on-screen lives counter [[ZP_LIVES_BCD]] goes negative.  Earlier prose called this
[[LEVEL_COMPLETE]], but [[ZP_LIVES_BCD]] is the BCD lives counter, not a
level-state flag --- this routine runs after the last on-screen life
has been consumed.  It is one of two end-game paths; the other is
[[GAME_OVER]] (reached when [[ZP_GAME_OVER]] goes
negative, per-hit credit exhausted).

On entry, the handler clears the keyboard strobe, runs the level
transition effect, and patches the main loop's attract-control slot
to an [[RTS]] so that inner frames of the extra-life animation do
not re-enter attract animation callbacks.

If the ``extras'' stash [[ZP_EXTRA_LIVES]] is positive, the
handler draws one extra-life sprite, polls for input, and calls
[[MAIN_LOOP]] once.  [[MAIN_LOOP]] itself terminates via
[[JMP LIFE_LOST_HANDLER]] (not RTS), so each ``iteration'' of the extras
animation is a fresh entry from [[MAIN_LOOP]]'s BCD-underflow branch with a slowly-growing stack;
the JSR/JMP loop structure here is only a local fallback in case
[[MAIN_LOOP]] ever did return normally.

When the extras stash reaches zero, control enters
[[RESTART_NEW_GAME]] which calls [[GAME_START_INIT]] to reset
score/lives/flags, rearms the silent SFX pointer, re-enables the
sprite-render main-loop slot, and falls through into [[ATTRACT_LOOP]]
to display the title screen.

During the animation, any detected key or joystick press diverts to
[[ATTRACT_KEY_DETECT]]/[[ATTRACT_JOY_DETECT]] at the end of
[[ATTRACT_LOOP]], which starts the next game immediately.

<<life lost handler defines>>=

; --- Subroutine stubs (life-lost handler) ---
; (LEVEL_TRANSITION has its own ORG chunk)
; (DRAW_SPRITE / SPRITE_PTR_LO / SPRITE_PTR_HI have their own ORG chunk)
; (ZP_SPRITE_W / _H / _Y / _X live in draw sprite defines)
SMC_ATTRACT_RTS = $6827         ; Self-mod: attract-loop control slot

; --- Extra-life glyph sprite (level-1 swappable) ---
; 98-byte sprite (W=6 -> 7 bytes/row, H=14 rows) in the level-1
; swappable region.  LIFE_LOST_HANDLER draws one instance per
; remaining extra life while ticking ZP_EXTRA_LIVES down.  Defined
; as a label in the level1 target as EXTRA_LIFE_SPR_DATA at the
; same address.
EXTRA_LIFE_SPR  = $B67D         ; Extra-life glyph (W=6, H=14)

; SMC_SR_YSRC / SMC_SR_HEIGHT are the operand bytes of
; DRAW_PLAYER's idle-path "LDA $06" and "LDA #$13" (sprite Y source and
; height).  Declared in the draw-player defines chunk.
; LIFE_LOST_HANDLER reasserts their default values ($06 / $13) on
; entry because LEVEL_INTRO_TICK may have patched them for the
; countdown animation.

; --- Zero-page (life-lost handler) ---
ZP_EXTRA_LIVES  = $8C           ; Stash of extra lives (separate from
                                ;   HUD counter ZP_LIVES_BCD); animated
                                ;   down when the HUD counter bottoms out.
; ZP_SFX_CLICK / ZP_SFX_CLICK_SAVED are the low bytes of the speaker-click
; pointer used by SFX_TONE.  See the sound section of the input
; processor for how ZP_SFX_CLICK/ZP_SFX_CLICK_SAVED encode sound on/off via bit 4.
ZP_SFX_CLICK       = $36        ; Current SFX click pointer low ($20 silent, $30 speaker)
ZP_SFX_CLICK_SAVED = $38        ; Preserved copy across attract/game transitions
@ %def EXTRA_LIFE_SPR

<<life lost handler>>=

        ORG $7208
LIFE_LOST_HANDLER:
        SUBROUTINE
        ; End-of-life handler --- fires when ZP_LIVES_BCD goes
        ; negative (BCD underflow below ZP_PAGE_FLAG yields $99, bit~7 set).
        ; MAIN_LOOP reaches this via [[JMP LIFE_LOST_HANDLER]] at $682F.
        ;
        ; Inputs:
        ;   ZP_EXTRA_LIVES  --- stash of extra lives to animate
        ;
        ; Behavior:
        ;   Clears keyboard strobe, runs level-transition effect, pins
        ;   the attract-control main-loop slot to RTS.  Then draws one
        ;   extra-life sprite per iteration, polls for input (diverts
        ;   to ATTRACT_KEY_DETECT / ATTRACT_JOY_DETECT if found), and
        ;   runs one frame of MAIN_LOOP between draws.  When the
        ;   extras stash is empty, enters the RESTART_NEW_GAME tail
        ; which resets game state and falls through to
        ;   ATTRACT_LOOP.
        ;
        ; Modifies:
        ;   ZP_EXTRA_LIVES, sprite-draw params, ZP_SFX_CLICK,
        ;   ZP_SFX_CLICK_SAVED, SMC_ATTRACT_RTS, SMC_SR_YSRC,
        ;   SMC_SR_HEIGHT, SMC_RENDER.
        ; Clobbers: A, X, Y

; --- Initialization ---
        LDA KBDSTROBE            ; Clear keyboard strobe
        JSR LEVEL_TRANSITION     ; Transition effects
LIFE_LOST_RESUME:
        ; Sub-entry: RESTART_DISPATCH's flag=0 path JMPs here, skipping
        ; the strobe clear + transition effect above.
        LDA #$60                 ; RTS opcode
        STA SMC_ATTRACT_RTS      ; Patch: disable attract subroutine
        LDA #$06
        STA SMC_SR_YSRC          ; Reset DRAW_PLAYER Y source to ZP_PLAYER_COL
        LDA #$13
        STA SMC_SR_HEIGHT        ; Reset DRAW_PLAYER sprite height to default

; --- Extra-life animation loop ---
.check_extra:
        LDA ZP_EXTRA_LIVES       ; Extras stash > 0?
        BEQ RESTART_NEW_GAME     ; Empty --- reset game and fall to attract
        DEC ZP_EXTRA_LIVES       ; Consume one extra

; --- Draw extra-life sprite ---
        LDA #$06
        STA ZP_SPRITE_W          ; Sprite width = 6
        LDA #$0E
        STA ZP_SPRITE_H          ; Sprite height = 14
        LDA #$2E
        STA ZP_SPRITE_Y          ; Y position = $2E
        LDA #$17
        STA ZP_SPRITE_X          ; X column = $17
        LDA #<EXTRA_LIFE_SPR
        STA SPRITE_PTR_LO        ; SPRITE_PTR_LO <- #<EXTRA_LIFE_SPR
        LDA #>EXTRA_LIFE_SPR
        STA SPRITE_PTR_HI        ; SPRITE_PTR_HI <- #>EXTRA_LIFE_SPR
        JSR DRAW_SPRITE          ; Draw extra-life sprite

; --- Poll input during animation ---
        LDA KEYBOARD             ; Check keyboard
        BMI ATTRACT_KEY_DETECT   ; Key pressed --- start next game
        LDY #$00
        LDA (ZP_INPUT_1),Y       ; Check joystick button 1
        BMI ATTRACT_JOY_DETECT   ; Pressed --- start next game
        LDA (ZP_INPUT_2),Y       ; Check joystick button 2
        BMI ATTRACT_JOY_DETECT   ; Pressed --- start next game

; --- Run one frame and continue loop ---
        JSR MAIN_LOOP            ; Run one game frame
        JMP .check_extra         ; (MAIN_LOOP normally re-enters
                                 ;  via JMP, so this JMP is fallback only)

; --- No more extras: reset game and fall through to attract ---
RESTART_NEW_GAME:
        ; First of three GAME_START_INIT callers (the others are
        ; INPUT_PROCESS's Ctrl-R path and START_GAME_FROM_ATTRACT).
        ; Reached when LIFE_LOST_HANDLER's extras stash is empty;
        ; performs a full game reset and falls through into ATTRACT_LOOP.
        JSR GAME_START_INIT      ; Reset score/lives/flags
        LDA ZP_SFX_CLICK         ; Save current sound-on/off state
        STA ZP_SFX_CLICK_SAVED   ;   into the preserved slot
        LDA #OPCODE_JSR          ; $20 --- JSR opcode AND "silent" pointer low
        STA ZP_SFX_CLICK         ; Force attract mode to silent
        STA SMC_RENDER           ; Re-enable sprite rendering (same $20 byte)
                                 ; Fall through to ATTRACT_LOOP
@ %def LIFE_LOST_HANDLER LIFE_LOST_RESUME RESTART_NEW_GAME

\section{Attract entity movement}

[[ATTRACT_ANIM_1]] updates the vertical positions of up to four
attract-mode entities (X~=~3 down to~0). Each entity has a direction flag
in [[ZP_ATTRACT_ENT_DIR]]+X: negative means moving down, positive means moving up, zero
means inactive.

When moving down, the Y position ([[ZP_ATTRACT_ENT_Y]]+X) increments by~2 each frame
until it reaches [[$6A]], at which point the direction reverses to~up.
When moving up, the Y position decrements by~2 until it reaches [[$52]].
At the top, a pseudo-random check (via [[PRNG]]) determines
whether to reverse; if the random value is less than~5 the entity keeps
pausing, otherwise it reverses to move down again.

<<attract anim 1 defines>>=

; --- Zero-page (attract entity movement) ---
ZP_ATTRACT_ENT_DIR = $88        ; Entity direction flags (4 bytes: $88-$8B)
ZP_ATTRACT_ENT_Y   = $E9       ; Entity Y positions (4 bytes: $E9-$EC)
ZP_ATTRACT_ENT_X   = $E5       ; Entity X columns (4 bytes: $E5-$E8)
ZP_ATTRACT_ENT_W   = $ED       ; Entity widths (4 bytes: $ED-$F0)

; (PRNG has its own ORG chunk)
@

<<attract anim 1>>=

        ORG $17A6
ATTRACT_ANIM_1:
        SUBROUTINE
        ; Attract entity movement -- updates Y positions of 4 entities.
        ;
        ; Inputs:
        ;   $88+X -- direction (negative=down, positive=up, zero=skip)
        ;   $E9+X -- Y position
        ;
        ; Modifies:
        ;   $88+X (direction), $E9+X (Y position)
        ; Clobbers: A, X

        LDX #$03
.check_entity:
        LDA ZP_ATTRACT_ENT_DIR,X ; Direction flag
        BMI .moving_down          ; Negative -> moving down
        BNE .moving_up            ; Positive -> moving up
.next_entity:
        DEX
        BPL .check_entity
        RTS

; --- Moving down: increment Y toward $6A ---
.moving_down:
        LDA ZP_ATTRACT_ENT_Y,X
        CMP #$6A                  ; Reached bottom?
        BNE .step_down
        LDA #$01                  ; Reverse: now moving up
        STA ZP_ATTRACT_ENT_DIR,X
        BPL .next_entity          ; Always taken
.step_down:
        CLC
        ADC #$02                  ; Move down 2 pixels
        STA ZP_ATTRACT_ENT_Y,X
        JMP .next_entity

; --- Moving up: decrement Y toward ZP_INPUT_1 ---
.moving_up:
        LDA ZP_ATTRACT_ENT_Y,X
        CMP #$52                  ; Reached top?
        BNE .step_up
        JSR PRNG                  ; Random check at top
        CMP #$05                  ; Random < 5?
        BCS .next_entity          ; Yes -> keep pausing
        LDA #$FF                  ; Reverse: now moving down
        STA ZP_ATTRACT_ENT_DIR,X
        BMI .next_entity          ; Always taken
.step_up:
        SEC
        SBC #$02                  ; Move up 2 pixels
        STA ZP_ATTRACT_ENT_Y,X
        JMP .next_entity
@ %def ATTRACT_ANIM_1

\section{Attract entity draw}

[[ATTRACT_ANIM_2]] draws the four attract-mode entities. For
each entity (X~=~3 down to~0), it loads the X column from [[ZP_ATTRACT_ENT_X]]+X, width
from [[ZP_ATTRACT_ENT_W]]+X, and Y position from [[ZP_ATTRACT_ENT_Y]]+X. The sprite height is computed as
[[$6B]] minus the Y position, clamped to a maximum of~[[$0E]] (14~pixels).
Sprite data pointers come from tables at [[ATTRACT_SPR2_LO]] and [[ATTRACT_SPR2_HI]].

<<attract anim 2 defines>>=

; --- Attract sprite tables (secondary) ---
ATTRACT_SPR2_LO = $B002         ; Attract sprite pointer table 2, low bytes
ATTRACT_SPR2_HI = $B082         ; Attract sprite pointer table 2, high bytes
@

<<attract anim 2>>=

        ORG $17E1
ATTRACT_ANIM_2:
        SUBROUTINE
        ; Attract entity draw -- renders 4 attract-mode entities.
        ;
        ; Inputs:
        ;   $E5+X -- X column, $ED+X -- width, $E9+X -- Y position
        ;
        ; Modifies:
        ;   Sprite parameters ($56, $57, $5B, $5D, $65B3, $65B4)
        ; Clobbers: A, X

        LDX #$03
.draw_entity:
        LDA ZP_ATTRACT_ENT_X,X   ; Entity X column
        STA ZP_SPRITE_X
        LDA ZP_ATTRACT_ENT_W,X   ; Entity width
        STA ZP_SPRITE_W
        LDA ZP_ATTRACT_ENT_Y,X   ; Entity Y position
        STA ZP_SPRITE_Y
        LDA #$6B                  ; Bottom boundary
        SEC
        SBC ZP_ATTRACT_ENT_Y,X   ; Distance from Y to bottom
        CMP #$0F                  ; > 14?
        BCC .height_ok
        LDA #$0E                  ; Clamp to 14
.height_ok:
        STA ZP_SPRITE_H
        LDA ATTRACT_SPR2_LO,X    ; Sprite data pointer low
        STA SPRITE_PTR_LO
        LDA ATTRACT_SPR2_HI,X    ; Sprite data pointer high
        STA SPRITE_PTR_HI
        STX ZP_SAVE_X             ; Save loop index
        JSR DRAW_SPRITE      ; Draw entity
        LDX ZP_SAVE_X             ; Restore loop index
        DEX
        BPL .draw_entity
        RTS
@ %def ATTRACT_ANIM_2

\section{Attract elevator animation}

[[ATTRACT_ANIM_3]] controls the vertical oscillation of an
attract-mode element (likely an elevator or platform). [[ZP_ELEV_Y]] holds the
current Y position and [[ZP_ELEV_DIR]] the direction flag: negative means moving
down (incrementing Y), positive means moving up (decrementing Y).

The element bounces between Y~=~[[$81]] (top) and Y~=~[[$86]] (bottom). At
Y~=~[[$84]] while moving up, the animation pauses until [[ZP_ANIM_COUNTER]] reaches~5,
creating a brief hesitation in the middle of the travel.

<<attract anim 3 defines>>=

; --- Zero-page (attract elevator) ---
ZP_ELEV_Y       = $F3           ; Elevator Y position (attract)
ZP_ELEV_DIR     = $F7           ; Elevator direction (negative=down, positive=up)
ZP_ANIM_COUNTER = $1F           ; Animation frame counter
@

<<attract anim 3>>=

        ORG $1813
ATTRACT_ANIM_3:
        SUBROUTINE
        ; Attract elevator animation -- oscillate Y position.
        ;
        ; Inputs:
        ;   ZP_ELEV_DIR -- direction flag
        ;   ZP_ELEV_Y -- current Y position
        ;
        ; Modifies:
        ;   ZP_ELEV_Y, ZP_ELEV_DIR
        ; Clobbers: A, Y

; --- Check direction ---
        LDA ZP_ELEV_DIR          ; Direction flag
        BPL .moving_up           ; Positive -> moving up

; --- Moving down: increment Y toward $86 ---
        LDA ZP_ELEV_Y
        CMP #$86                 ; Reached bottom?
        BNE .step_down
        LDA #$01                 ; Reverse: start moving up
        STA ZP_ELEV_DIR
        RTS

.step_down:
        CLC
        ADC #$01                 ; Move down one step
        STA ZP_ELEV_Y
        RTS

; --- Moving up: decrement Y toward $81 ---
.moving_up:
        LDA ZP_ELEV_Y
        CMP #$81                 ; Reached top?
        BEQ .reverse_down        ; Yes -> reverse direction

        CMP #$84                 ; At pause point?
        BNE .step_up             ; No -> continue
        LDY ZP_ANIM_COUNTER      ; Check animation counter
        CPY #$05                 ; Counter >= 5?
        BCC .step_up             ; No -> keep moving
        RTS                      ; Yes -> pause (wait for counter)

.step_up:
        SEC
        SBC #$01                 ; Move up one step
        STA ZP_ELEV_Y
        RTS

.reverse_down:
        LDA #$FF                 ; Reverse: start moving down
        STA ZP_ELEV_DIR
        RTS
@ %def ATTRACT_ANIM_3

\section{Attract sprite draw}

[[ATTRACT_ANIM_4]] draws the attract-mode sprites each frame.
It loops over two entity slots (X~=~1 down to X~=~0), reading each
entity's X column from [[$F1]],X, Y position from [[$F3]],X,
and width from [[$F5]],X. Sprite data pointers are fetched from
tables at [[ATTRACT_SPR_LO]] and [[ATTRACT_SPR_HI]]. Each entity is drawn with height~8 via
[[SPRITE_DRAW_CALL]].

After the entity loop, it draws a fixed ``logo'' sprite at column~[[$1D]],
row~[[$A5]], dimensions [[$12]]$\times$[[$08]], with sprite data at
[[BRODERBUND_LOGO_SPR]].

\paragraph{The ``logo'' sprite at [[BRODERBUND_LOGO_SPR]].}  Despite the
code comment, rendering the [[$13]]$\times$[[$08]] byte region at
[[BRODERBUND_LOGO_SPR]] (Figure~\ref{fig:drol_logo}) reveals that this
fixed sprite is not the game title at all --- it is the
\textbf{\textcopyright 1983 Broderbund} attribution strip shown during
the attract sequence.
The title-screen ``DROL'' logo is drawn by a different routine via
the [[ATTRACT_SPR2_LO]] / [[ATTRACT_SPR_LO]] pointer tables whose
sprite widths and heights come from the runtime ZP slots
[[$E5]]..[[$ED]] and [[$F1]]..[[$F6]], so those cannot be rendered without
simulating the attract-mode animation state.

\begin{figure}[H]
\centering
\includegraphics[width=0.60\textwidth]{images/drol_logo.png}
\caption{The fixed sprite at [[BRODERBUND_LOGO_SPR]], dimensions
$[[$13]]\times[[$08]]$ bytes (W=[[$12]], H=[[$08]]).  Drawn by
[[ATTRACT_ANIM_4]] after the variable-entity loop.  The sprite renders
the ``(c) 1983 Broderbund'' attribution.}
\label{fig:drol_logo}
\end{figure}

<<attract anim 4 defines>>=

; --- Zero-page (attract sprites) ---
ZP_ATTRACT_X    = $F1           ; Attract entity X columns (2 bytes: F1, F2)
ZP_ATTRACT_Y    = $F3           ; Attract entity Y positions (2 bytes: F3, F4)
ZP_ATTRACT_W    = $F5           ; Attract entity widths (2 bytes: F5, F6)
ZP_SAVE_X       = $5C           ; Saved X index during draw

; --- Attract sprite tables ---
ATTRACT_SPR_LO  = $B006         ; Attract sprite pointer table, low bytes
ATTRACT_SPR_HI  = $B086         ; Attract sprite pointer table, high bytes

; --- Broderbund attribution logo sprite (attract mode) ---
; $13 x $08-byte fixed sprite drawn by ATTRACT_ANIM_4 after the
; 2-entity draw loop.  Lives in level-1 swappable data ($8C00-$BDFF)
; and is rendered at column $1D, row $A5.  See figure drol_logo.
BRODERBUND_LOGO_SPR = $BCF1     ; Level-1 "(c) 1983 Broderbund" strip
@ %def BRODERBUND_LOGO_SPR

<<attract anim 4>>=

        ORG $1844
ATTRACT_ANIM_4:
        SUBROUTINE
        ; Attract sprite draw: renders attract-mode entities then the
        ; fixed "(c) 1983 Broderbund" attribution strip.
        ;
        ; Behavior:
        ;   1. Loop X = 1 down to 0, drawing entity X from the
        ;      ZP_ATTRACT_X/Y/W arrays with sprite data pointed at
        ;      by ATTRACT_SPR_LO/HI[X].
        ;   2. Draw BRODERBUND_LOGO_SPR (fixed $13x$08 sprite at
        ;      column $1D, row $A5) via DRAW_SPRITE.
        ;
        ; Modifies:
        ;   ZP_SPRITE_W, ZP_SPRITE_H, ZP_SPRITE_X, ZP_SPRITE_Y,
        ;   SPRITE_PTR_LO, SPRITE_PTR_HI, ZP_SAVE_X
        ; Clobbers: A, X

; --- Entity draw loop (X = 1 down to 0) ---
        LDX #$01
.draw_entity:
        LDA ZP_ATTRACT_X,X      ; Entity X column
        STA ZP_SPRITE_X
        LDA ZP_ATTRACT_Y,X      ; Entity Y position
        STA ZP_SPRITE_Y
        LDA ZP_ATTRACT_W,X      ; Entity width
        STA ZP_SPRITE_W
        LDA #$08
        STA ZP_SPRITE_H          ; Height = 8 for all entities
        STX ZP_SAVE_X            ; Save loop index
        LDA ATTRACT_SPR_LO,X    ; Sprite data pointer low
        STA SPRITE_PTR_LO
        LDA ATTRACT_SPR_HI,X    ; Sprite data pointer high
        STA SPRITE_PTR_HI
        JSR DRAW_SPRITE     ; Draw this entity
        LDX ZP_SAVE_X            ; Restore loop index
        DEX
        BPL .draw_entity         ; Next entity (1 -> 0)

; --- Draw fixed Broderbund-attribution sprite at col $1D, row $A5 ---
        LDA #$12
        STA ZP_SPRITE_W                 ; ZP_SPRITE_W <- #$12 ($13 cols-1)
        LDA #$08
        STA ZP_SPRITE_H                 ; ZP_SPRITE_H <- #$08 (8 rows)
        LDA #$A5
        STA ZP_SPRITE_Y                 ; ZP_SPRITE_Y <- #$A5
        LDA #$1D
        STA ZP_SPRITE_X                 ; ZP_SPRITE_X <- #$1D (left edge)
        LDA #>BRODERBUND_LOGO_SPR
        STA SPRITE_PTR_HI               ; SPRITE_PTR_HI <- #>BRODERBUND_LOGO_SPR
        LDA #<BRODERBUND_LOGO_SPR
        STA SPRITE_PTR_LO               ; SPRITE_PTR_LO <- #<BRODERBUND_LOGO_SPR
        JSR DRAW_SPRITE                 ; Draw attribution strip
        RTS
@ %def ATTRACT_ANIM_4

\section{Title screen and attract}

At startup, [[JMP (ZP_GAME_ENTRY)]] enters [[START_ATTRACT]]
in the level data area. This copies the title screen from hi-res page~1
to page~2, clears the keyboard strobe, and enters the attract loop.

The attract loop at [[ATTRACT_LOOP]] calls the main game loop's
attract entry point ([[JSR ATTRACT_ENTRY]]), which runs the game's rendering and
animation subsystems without input handling. After each frame, it polls
the joystick buttons and keyboard. When input is detected, it patches
the main loop for game mode, enters the
[[START_GAME_FROM_ATTRACT]] sub-entry, calls [[GAME_START_INIT]]
and jumps to [[MAIN_LOOP]].

<<attract loop>>=

        ORG $7263
ATTRACT_LOOP:
        SUBROUTINE
        ; Title screen attract loop -- animates until input detected.
        ;
        ; Behavior:
        ;   Calls main loop from attract entry (skipping input).
        ;   Polls joystick buttons and keyboard.
        ;   On input: sets input mode flag, patches main loop
        ;   for game mode, calls GAME_START_INIT (game start init), enters
        ;   MAIN_LOOP.
        ;
        ; Modifies:
        ;   ZP_INPUT_MODE, SMC_INPUT, SMC_RENDER, SMC_ATTRACT
        ;   (self-modifying patches toggle attract -> game mode)
        ; Clobbers: A, X, Y

; --- Attract frame ---
        JSR ATTRACT_ENTRY       ; Run one frame (rendering/animation only)
        JSR ATTRACT_ANIM_1      ; Attract-mode animation 1
        JSR ATTRACT_ANIM_2      ; Attract-mode animation 2
        JSR ATTRACT_ANIM_3      ; Attract-mode animation 3
        JSR ATTRACT_ANIM_4      ; Attract-mode animation 4

; --- Poll input ---
        LDY #$00
        LDA (ZP_INPUT_1),Y      ; Read joystick button 1
        BMI ATTRACT_JOY_DETECT  ; Bit 7 set = button pressed
        LDA (ZP_INPUT_2),Y      ; Read joystick button 2
        BMI ATTRACT_JOY_DETECT
        LDA KEYBOARD            ; Read keyboard
        BPL ATTRACT_LOOP        ; No key = continue attract
ATTRACT_KEY_DETECT:
        LDA #$01                ; Keyboard input mode
        BPL ATTRACT_SET_MODE    ; Always taken
ATTRACT_JOY_DETECT:
        LDA #$FF                ; Joystick input mode
ATTRACT_SET_MODE:
        STA ZP_INPUT_MODE       ; Store input mode flag
        LDA KBDSTROBE           ; Clear keyboard strobe

; --- Patch main loop for game mode ---
        LDA #$EA                ; NOP opcode
        STA SMC_ATTRACT         ; disable attract JSR -> NOP
        LDA #$20                ; JSR opcode
        STA SMC_INPUT           ; enable input handler
        STA SMC_RENDER          ; enable sprite rendering

; --- Start game ---
START_GAME_FROM_ATTRACT:
        ; Third of three GAME_START_INIT callers (the others are
        ; INPUT_PROCESS's Ctrl-R path and RESTART_NEW_GAME inside
        ; LIFE_LOST_HANDLER when the extras stash runs out).  Reached
        ; after input has been detected at the attract screen;
        ; performs a full game reset then enters MAIN_LOOP.
        JSR GAME_START_INIT     ; Game start initialization
        LDA ZP_SFX_CLICK_SAVED  ; Restore saved sound-on/off state
        STA ZP_SFX_CLICK        ;   into the working SFX click pointer
        JMP MAIN_LOOP           ; Enter main game loop
@ %def ATTRACT_LOOP ATTRACT_KEY_DETECT ATTRACT_JOY_DETECT ATTRACT_SET_MODE START_GAME_FROM_ATTRACT

<<start attract>>=

        ORG $72A3
START_ATTRACT:
        SUBROUTINE
        ; Copy hi-res page 1 to page 2, then enter attract loop.
        ;
        ; Inputs:
        ;   ZP_HGR_SRC ($29/$2A) = $2000 (hi-res page 1)
        ;   ZP_HGR_DST ($2F/$30) = $4000 (hi-res page 2)
        ;
        ; Behavior:
        ;   Page-by-page copy from HGR1_BASE-$3FFF to GAME_INIT_NOP-$5FFF,
        ;   then clears keyboard strobe and enters ATTRACT_LOOP.
        ;
        ; Modifies:
        ;   Hi-res page 2 ($4000-$5FFF), ZP_HGR_SRC+1, ZP_HGR_DST+1
        ; Clobbers: A, Y

        LDY #$00
.copy:
        LDA (ZP_HGR_SRC),Y     ; Read from hi-res page 1
        STA (ZP_HGR_DST),Y     ; Write to hi-res page 2
        INY
        BNE .copy
        INC ZP_HGR_SRC+1       ; Next source page
        INC ZP_HGR_DST+1       ; Next dest page
        LDA ZP_HGR_SRC+1
        CMP #$40                ; Done when source reaches $4000
        BNE .copy
        LDA KBDSTROBE           ; Clear keyboard strobe
SMC_ATTRACT_EXIT_JMP = *+1       ; JMP operand low-byte; loader patches
                                 ; to #<LIFE_LOST_HANDLER so first-boot
                                 ; exit lands on the shared extras-animation
                                 ; path instead of looping attract directly.
        JMP ATTRACT_LOOP        ; Enter attract loop (patched on boot)
@ %def START_ATTRACT SMC_ATTRACT_EXIT_JMP
@ \chapter{Undocumented regions}

The following sections contain raw hex data for regions not yet fully
reverse engineered. They are included to achieve a byte-perfect binary
match against the reference image. Each section will be replaced with
properly annotated assembly as analysis progresses.

\section{Title-wipe per-row speaker click}

[[ROW_COPY_CLICK]] is the per-row audio hook for the
title-wipe effect ([[SCREEN_ROW_COPY]]). The parent routine sweeps
X over all 192 hi-res rows; for each row it calls [[ROW_COPY_CLICK]]
after writing the 40-byte pattern, which emits a single speaker click
via [[SND_DELAY_UP]] with pitch proportional to the current row index
(A = X/4, duration = 4). The result is the familiar ascending
``zipper'' whistle that accompanies Drol's screen-fill transitions.

The 13-byte routine occupies [[$01B7]]--[[$01C3]]. The next 41 bytes
([[$01C4]]--[[$01EE]]) are \emph{dead code}: a standalone [[RTS]] followed by two orphan routines ([[ROW_COPY_CLICK_RANDOM]] and [[ROW_COPY_CLICK_GATE]]) that nothing in
[[boot1.bin]], [[loader.bin]], [[rwts.bin]], or [[drol.bin]] ever
branches or jumps to. They appear to be an earlier, richer version of
the wipe-click hook that also used PRNG-driven extra SFX; the final
game ships only the plain ascending click but leaves the old code in
place. The [[$01EF]]--[[$01FF]] bytes are the unused tail of the stack
page.

After the code, [[$0200]]--[[$02B6]] holds a collection of initial data
tables (music sequences, the [[ROW_COPY_BUFFER]] wipe pattern, and
several small arrays that other subsystems read from). Those sub-regions
are not fully dissected here --- the main artefact of interest is the
40-byte [[ROW_COPY_BUFFER]].

<<row copy click>>=

        ORG $01B7
ROW_COPY_CLICK:
        SUBROUTINE
        ; Per-row speaker click for the title-wipe effect.
        ;
        ; Inputs:
        ;   X  -- current row index (0..$BF), set by SCREEN_ROW_COPY.
        ;
        ; Behavior:
        ;   Saves X to ZP $5C, computes pitch = X/4, calls SND_DELAY_UP
        ;   with pitch in A and duration=4 in X, then restores X.  The
        ;   pitch rises linearly with the row, producing an ascending
        ;   whistle over the 192-row sweep.
        ;
        ; Modifies:
        ;   ZP_SAVE_X (scratch)
        ; Clobbers: A

        STX ZP_SAVE_X           ; ZP_SAVE_X <- X (preserve row index)
        TXA
        LSR
        LSR                     ; A = X / 4  (pitch 0..$2F)
        LDX #$04                ; duration
        JSR SND_DELAY_UP
        LDX ZP_SAVE_X           ; restore row index
        RTS
@ %def ROW_COPY_CLICK

\section{Dead wipe-click variants}

The bytes at [[$01C4]]--[[$01EE]] form a set of orphan routines --- no
JSR or JMP anywhere in any shipped binary reaches them.  The structure
suggests a pre-release wipe-click that used the PRNG to randomly splice
in a longer tone.  For byte-exactness we emit them as labelled dead
code rather than raw hex.

The layout is:
\begin{itemize}
\item [[$01C4]]: a bare [[RTS]] (no caller).
\item [[$01C5]]--[[$01E8]]: [[ROW_COPY_CLICK_RANDOM]] --- rolls the
  [[PRNG]], branches on the result to either a long delay or an
  8-click tone loop through [[SFX_TONE]].
\item [[$01E9]]--[[$01EE]]: [[ROW_COPY_CLICK_GATE]] --- a pre-gate
  that only enters the random branch when [[ZP_ANIM_COUNTER]] is
  [[#$09]] or greater.
\end{itemize}

The [[A9 00]] ([[LDA #$00]]) at [[$01EF]] is a two-byte dangling
prologue to a routine whose body ([[$01F1]]--[[$01FF]]) has been
overwritten by zeros --- the stack page overlay means this region is
trashed after the first push regardless. Nothing reads it.

<<row copy click dead>>=

        ORG $01C4
ROW_COPY_CLICK_DEAD_RTS:
        ; Orphan RTS --- no caller. Possibly a placeholder ``no-op hook''
        ; slot for an alternate wipe-click variant that was never wired.
        RTS

ROW_COPY_CLICK_RANDOM:
        SUBROUTINE
        ; Dead code ($01C5-$01E8).  Original intent:
        ;   rolls PRNG; if result >= $20, short delay of $80 and
        ;   return.  If $10 <= result < $20, run an 8-iteration click
        ;   loop through SFX_TONE with decreasing pitch, then short
        ;   delay $20.  Otherwise (result < $10) short delay $80.
        ; Never reached in the shipped binary.

        JSR PRNG                ; A <- PRNG roll
        CMP #$20
        BCS .short_delay        ; A >= $20: skip the tone loop
        CMP #$10
        BCS .tone_loop          ; $10 <= A < $20: run tone loop
.short_delay:
        LDA #$80                ; else: long delay and return
        JSR MON_WAIT
        RTS
.tone_loop:
        STA $56                 ; seed pitch counter
.next_click:
        LDX #$08                ; duration per click (reset each iteration,
                                ;   SFX_TONE clobbers X)
        LDA $56
        JSR SFX_TONE            ; emit one click at current pitch
        DEC $56
        BNE .next_click
        LDA #$20
        JSR MON_WAIT
        RTS

ROW_COPY_CLICK_GATE:
        ; Dead code ($01E9-$01EE).  Gates entry into the random branch
        ; on ZP_ANIM_COUNTER being at least $09; otherwise falls
        ; through into the zero-padded stack-page tail at $01EF.
        LDA ZP_ANIM_COUNTER
        CMP #$09
        BCS ROW_COPY_CLICK_RANDOM

        ; Fall-through: LDA #$00 at $01EF then stack-page zero padding.
        HEX A9 00 00 00 00 00 00 00
        HEX 00 00 00 00 00 00 00 00
        HEX 00
@ %def ROW_COPY_CLICK_DEAD_RTS ROW_COPY_CLICK_RANDOM ROW_COPY_CLICK_GATE

\section{Initial data tables on page 2}

The bytes at [[$0200]]--[[$02B6]] hold a mixed bag of small data
tables consumed by distinct subsystems: level tones, pitch sequences
for each sound-emitting subsystem, the beam tracer's runtime state,
the post-hit beam jingle, and the [[ROW_COPY_BUFFER]] wipe pattern.
Sub-table layout (running concatenated so adjacent tables share a
boundary byte; see the EQU declarations elsewhere in the document for
each table's semantic role):

\begin{itemize}
\item [[LEVEL_DATA_BASE]] ([[$0200]]) --- 19 bytes, level-intro tone
  amplitude/pitch table indexed $0..\$12$ by [[ZP_INTRO_COUNTDOWN]].
\item [[RESCUE_DRIFT_PITCH]] ([[$0213]]) --- 5 bytes, rescue-child
  drift-mode pitch indexed by [[RESCUE_COUNTDOWN]].
\item [[SND_PITCH_TBL_SPECIAL]] ([[$0218]]) --- 12 bytes, ascending
  pitch table for the special-sprite sound channel.
\item [[SND_PITCH_TBL_SPECIAL_B]] ([[$021F]]) --- tail 5 bytes
  (overlaps [[SND_PITCH_TBL_SPECIAL]]); descending-tone variant.
\item [[SND_PITCH_TBL_C]] ([[$0224]]) --- 8 bytes, enemy-C click pitches.
\item [[SND_PITCH_TBL_A]] ([[$0229]]) --- 8 bytes (overlaps C tail);
  enemy-A click pitches.
\item [[SND_PITCH_TBL_B]] ([[$0231]]) --- 6 bytes, enemy-B click
  pitches.  Followed by five sentinel [[$FF]] bytes.
\item [[TRACER_STATE]] ([[$0237]]) / [[TRACER_ROW]] ([[$023C]]) ---
  two 5-slot parallel arrays for the beam tracer subsystem.  Initial
  state is [[$FF]] / [[$00]] (inactive slot).
\item [[BEAM_JINGLE]] ([[$0241]]) --- 11 bytes, post-hit jingle
  pitch table.
\item [[ROW_COPY_BUFFER]] ([[$024C]]) --- 40 bytes, title/restore
  wipe pattern consumed by [[SCREEN_ROW_COPY]].
\item [[PAGE2_DEAD_ZEROS]] ([[$0274]]) --- 13 bytes of [[$00]]; tail
  of the [[ROW_COPY_BUFFER]] sector.
\item [[PAGE2_DEAD_DITHER]] ([[$0281]]) --- 10 bytes of the
  [[$D4]]/[[$82]] hi-res stripe pattern repeated five times;
  an alternate-look wipe/dither sample that the shipped game never
  reads.
\item [[PAGE2_DEAD_SEP]] ([[$028B]]) --- one [[$2A]] byte; looks like
  a record-terminator between [[PAGE2_DEAD_DITHER]] and the 14-byte
  record pair that follows.
\item [[PAGE2_DEAD_RECORDS]] ([[$028C]]) --- 14 bytes arranged as two
  7-byte records
  ([[$00]]\,[[$07]]\,[[$00]]\,[[$40]]\,[[$03]]\,[[$00]]\,[[$60]]
  then [[$41]]\,[[$02]]\,[[$07]]\,[[$00]]\,[[$40]]\,[[$03]]\,[[$00]]).
  Shape matches a pre-release entity-init record
  (state / col-lo / col-hi / row-hi / row-lo / ? / ?) but nothing
  in any shipped binary consumes them.
\item [[LVL_INIT_HIT_Y]] ([[$029A]]) --- 2-byte Y-window pair copied
  into [[ZP_HIT_Y_OFFSET]] / [[ZP_HIT_Y_SPAN]] by [[INIT_LEVEL_STATE]].
\item [[LVL_INIT_ENTITY]] ([[$029C]]) --- 25-byte entity block copied
  into [[ZP_ENTITY_BLOCK]] ([[$D4]]--[[$EC]]) by [[INIT_LEVEL_STATE]].
  Seeds the three enemy slots and attract-mode entity Y positions.
\item [[LVL_INIT_SPRITE_HEAD]] ([[$02B5]]) --- 5 bytes, the head of
  the 45-byte [[LVL_INIT_SPRITE]] block copied into
  [[ZP_SPRITE_BLOCK]] by [[INIT_LEVEL_STATE]].
\item [[LVL_INIT_ENTITY_HIT_STATE]] ([[$02BA]]) --- 12 bytes of [[$FF]]
  forming the [[LVL_INIT_SPRITE]]\([[$05]]..[[$10]]\) seed for the
  12-slot [[ENTITY_HIT_STATE]] array at ZP [[$8D]]--[[$98]].
  Seeds every hit-entity slot to [[$FF]] (``inactive'') on every level
  restart.
\end{itemize}

\paragraph{Dead-residue span [[$0274]]--[[$0299]].}  The 38~bytes
between [[ROW_COPY_BUFFER]] and [[LVL_INIT_HIT_Y]] split into four
labeled sub-blocks: [[PAGE2_DEAD_ZEROS]] / [[PAGE2_DEAD_DITHER]] /
[[PAGE2_DEAD_SEP]] / [[PAGE2_DEAD_RECORDS]].  An exhaustive scan of
[[boot1.bin]], [[loader.bin]], [[rwts.bin]], [[drol.bin]] and
[[level1.bin]] finds no absolute opcode (LDA/STA/CMP/BIT/... in any
addressing mode) targeting any byte in this span; [[INIT_LEVEL_STATE]]
starts reading at [[$029A]] (just past the span).  The same 38 bytes
in [[reference/level1.bin]] (built by replaying the loader's phase-0
track-5 read) are all [[$00]], whereas in [[reference/drol.bin]] (the
cold-start image) they carry the non-zero pattern shown in the
sub-chunks.  Two readings are consistent with both observations: the
bytes are (i)~stale source-file residue from the sector image that
ships on track~1 but never gets re-loaded, and (ii)~zeroed on the
first per-level swap.  Either way the bytes are dead as shipped ---
the non-zero pattern only exists at cold boot and vanishes after the
first level transition.

