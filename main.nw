\section{Top-center HUD strip painter}

[[PAINT_HUD_STRIP_P1]] and its page-2 twin
[[PAINT_HUD_STRIP_P2]] paint the 16-column wide, 31-row
tall ``HUD-strip'' decoration centered above the playfield, at hi-res
columns [[$0C]]..[[$1B]] (columns~12--27, the middle 16 of 40) and rows
1--31.  Each routine reads 112 source bytes from [[HUD_STRIP_SRC]]
([[$A30D]]--[[$A37C]], 16 columns~$\times$~7 bytes each) in the
swappable level-data region and expands each column's 7-byte strip into
a 31-row vertical pattern by repeating bytes as follows:

\begin{itemize}
\item bytes 0 $\to$ rows 1--7 (7 identical rows)
\item byte 1 $\to$ row 8
\item byte 2 $\to$ rows 9--15
\item byte 3 $\to$ row 16
\item byte 4 $\to$ rows 17--23
\item byte 5 $\to$ row 24
\item byte 6 $\to$ rows 25--31
\end{itemize}

Row 0 is deliberately skipped (left untouched by this painter).  The X
register runs from [[$0F]] down to [[$00]], so columns are painted
right-to-left; Y runs monotonically from [[$00]] to [[$6F]] across the
outer loop and is \emph{not} reset per column.  The two routines are a
strict twin pair: byte-for-byte identical except that the page-2 variant
rebases every [[STA]] destination from [[$2xxx]] to [[$4xxx]]
(high byte $+$[[$20]]).

The pair is dispatched from [[TEXT_ROW_DISPATCH]]: every
per-frame tick selects page~1 or page~2 based on [[ZP_PAGE_FLAG]].  The
source at [[HUD_STRIP_SRC]] is per-level (loaded from the swappable
track-5+ data set), so the top HUD decoration changes when the level
does.

\begin{figure}[H]
\centering
\includegraphics[width=0.6\textwidth]{images/hud_icon_a30d.png}
\caption{The level-1 top-center HUD strip: 16 columns~$\times$~31 rows
(columns 12--27, rows 1--31) rendered from the 112-byte
[[HUD_STRIP_SRC]] buffer.  Rendered at 6$\times$ scale from
[[reference/level1.bin]].}
\label{fig:hud_strip}
\end{figure}

<<paint hud strip defines>>=

; --- Level-data source for the top-center HUD strip ---
; 112 bytes, 16 columns x 7 bytes/column (see PAINT_HUD_STRIP_P1 prose).
HUD_STRIP_SRC   = $A30D         ; Top-center HUD strip source (level data)
@

<<paint hud strip p1>>=

        ORG $08F6
PAINT_HUD_STRIP_P1:
        SUBROUTINE
        ; Page-1 HUD-strip painter: read 112 bytes from HUD_STRIP_SRC,Y
        ; and paint a 16-column x 31-row decoration at hi-res columns
        ; $0C..$1B, rows 1..31.  Row 0 is left blank.
        ;
        ; Inputs:
        ;   HUD_STRIP_SRC ($A30D)  --- 112-byte source buffer (level data).
        ;
        ; Behavior:
        ;   X counts $0F down to $00 (one iteration per column, painting
        ;   right-to-left at screen column $0C+X).  Y counts monotonically
        ;   $00..$6F across the entire outer loop (NOT reset per column).
        ;   Per column: fetch b0..b6 from HUD_STRIP_SRC and store each
        ;   into row-group targets on hi-res page 1.
        ;
        ; Callers:
        ;   TEXT_ROW_DISPATCH ($636C), via JSR when ZP_PAGE_FLAG is
        ;                               positive (page 1 selected).
        ;
        ; Clobbers: A, X, Y
        LDX #$0F                        ; 16 columns, right-to-left
        LDY #$00                        ; source-byte index (monotonic)
.column:
        LDA HUD_STRIP_SRC,Y             ; b0 -> rows 1..7
        STA $240C,X                     ; row 1
        STA $280C,X                     ; row 2
        STA $2C0C,X                     ; row 3
        STA $300C,X                     ; row 4
        STA $340C,X                     ; row 5
        STA $380C,X                     ; row 6
        STA $3C0C,X                     ; row 7
        INY
        LDA HUD_STRIP_SRC,Y             ; b1 -> row 8
        STA $208C,X                     ; row 8
        INY
        LDA HUD_STRIP_SRC,Y             ; b2 -> rows 9..15
        STA $248C,X                     ; row 9
        STA $288C,X                     ; row 10
        STA $2C8C,X                     ; row 11
        STA $308C,X                     ; row 12
        STA $348C,X                     ; row 13
        STA $388C,X                     ; row 14
        STA $3C8C,X                     ; row 15
        INY
        LDA HUD_STRIP_SRC,Y             ; b3 -> row 16
        STA $210C,X                     ; row 16
        INY
        LDA HUD_STRIP_SRC,Y             ; b4 -> rows 17..23
        STA $250C,X                     ; row 17
        STA $290C,X                     ; row 18
        STA $2D0C,X                     ; row 19
        STA $310C,X                     ; row 20
        STA $350C,X                     ; row 21
        STA $390C,X                     ; row 22
        STA $3D0C,X                     ; row 23
        INY
        LDA HUD_STRIP_SRC,Y             ; b5 -> row 24
        STA $218C,X                     ; row 24
        INY
        LDA HUD_STRIP_SRC,Y             ; b6 -> rows 25..31
        STA $258C,X                     ; row 25
        STA $298C,X                     ; row 26
        STA $2D8C,X                     ; row 27
        STA $318C,X                     ; row 28
        STA $358C,X                     ; row 29
        STA $398C,X                     ; row 30
        STA $3D8C,X                     ; row 31
        INY
        DEX
        BMI .done
        JMP .column
.done:
        RTS
