<<game init>>=

        ORG $4000
GAME_INIT_NOP:
        SUBROUTINE
        ; HUD/frame unpacker -- draws the static playfield chrome.
        ;
        ; Inputs:
        ;   Data stream: [dest_lo, dest_hi, 40 bytes]... $FF
        ;
        ; Behavior:
        ;   Reads records from HUD_FRAME_DATA. Each record has a 2-byte destination
        ;   address followed by 40 bytes of screen data, written via
        ;   indirect indexed store. $FF terminates the stream.
        ;   Fills 37 rows of hi-res page 1 ($2000-$3FFF).
        ;
        ; Modifies:
        ;   Hi-res page 1 ($2000-$3FFF)
        ; Clobbers: A, Y

; GAME_INIT_NOP-$4012: NOPs (copy protection removed).
        DS 19,$EA

GAME_INIT:
        LDY #<HUD_FRAME_DATA ; Stream pointer low
        LDA #>HUD_FRAME_DATA ; Stream pointer high
        STY ZP_STREAM
        STA ZP_STREAM+1
.next_record:
        JSR READ_BYTE          ; Read destination low
        CMP #$FF                ; Terminator?
        BNE .store_lo
        RTS                     ; Done
.store_lo:
        STA ZP_UNPACK_DEST      ; Destination low byte
        JSR READ_BYTE
        STA ZP_UNPACK_DEST+1   ; Destination high byte
        LDY #$27                ; 40 bytes per record
.copy_byte:
        JSR READ_BYTE
        STA (ZP_UNPACK_DEST),Y  ; Store to destination
        DEY
        BPL .copy_byte
        BMI .next_record        ; Always taken -- next record

; Read next byte from the data stream at (ZP_STREAM).
READ_BYTE:
        SUBROUTINE

        STY ZP_SAVED_Y
        LDY #$00
        LDA (ZP_STREAM),Y      ; Read byte
        LDY ZP_SAVED_Y         ; Restore Y
        INC ZP_STREAM           ; Advance pointer
        BNE .read_done
        INC ZP_STREAM+1
.read_done:
        RTS
@ %def GAME_INIT_NOP GAME_INIT READ_BYTE

