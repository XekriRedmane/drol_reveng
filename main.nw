@ \chapter{RWTS relocated code}

This code lives at [[RWTS_HIGH]]--[[$59FF]] on disk (loaded by boot1 as part of the
loader) and is relocated to [[RWTS_RELOAD]]--[[$BFFF]] by boot1. It is never called by
the loader itself; the game calls into it directly.

<<rwts defines>>=

; --- Zero-page scratch pointers ---
; $A0/$A1 and $A2/$A3 serve as the two generic 16-bit scratch
; pointer pairs used across the RWTS block.  Each routine reuses
; them for its own purpose:
;   RWTS_RELOAD:    INC $A0/$A1 bumps the SCROLL_UP buffer pointer.
;   NIBBLE_READER:  $A0 is the nibble-combine scratch byte (NOT a
;                   pointer); $A1 is the destination-page counter;
;                   $A2/$A3 is the nibble-decode destination pointer.
;   SCREEN_RESTORE: $A0/$A1 is the hi-res-line or screen-hole
;                   destination pointer.
;   COPY_ROM_TO_LC: $A0/$A1 is simultaneously ROM source and LC
;                   destination (same address, different bank).
;   SCROLL_UP/DN:   $A0/$A1 is the buffer pointer, $A2/$A3 is the
;                   hi-res screen-row pointer.
; Named generically so all the above contexts share the same symbol.
; The $A0 byte is ALSO used as a non-pointer scratch in NIBBLE_READER
; (nibble combiner), where the low-byte alias ZP_RWTS_SCRATCH is
; preferred for clarity.
ZP_RWTS_PTR     = $A0           ; 16-bit scratch pointer (lo/hi at $A0/$A1)
ZP_RWTS_SCRATCH = $A0           ; Low-byte alias (nibble combine temp)
ZP_RWTS_PAGECNT = $A1           ; High-byte alias (nibble page counter)
ZP_RWTS_PTR2    = $A2           ; 16-bit scratch pointer #2 ($A2/$A3)

; $CE/$CF, $DA/$DB, $E6/$E7 are the DIVIDE routine's operand words.
; The dividend is shifted out as the quotient after 16 iterations,
; and the remainder accumulates in $E6/$E7.
ZP_DIV_DIVIDEND = $CE           ; 16-bit dividend (shifted -> quotient)
ZP_DIV_DIVISOR  = $DA           ; 16-bit divisor
ZP_DIV_REMAINDER = $E6          ; 16-bit remainder

; --- Loader addresses ---
LOADER_ENTRY    = $5000
; STAGE_STACK lives at $5C00 in the game binary (real label).  The RWTS
; callback into it uses this EQU because rwts.asm is assembled
; independently of drol.asm.
STAGE_STACK     = $5C00

; --- Soft switches ---
DISK_MOTOR_ON   = $C089
DISK_DATA       = $C08C
LC_BANK1_RWROM  = $C081
LC_BANK1_ROROM  = $C080
SW_SPEAKER      = $C030

; --- Monitor ROM ---
MON_INIT        = $FB2F
MON_HOME        = $FC58
MON_BELL2       = $FC22
MON_NORMAL      = $FE84

; --- Hi-res page 2 row addresses (bottom 4 rows) ---
HIRES2_ROW188   = $53D0         ; Hi-res page 2, row 188
HIRES2_ROW189   = $57D0         ; Hi-res page 2, row 189
HIRES2_ROW190   = $5BD0         ; Hi-res page 2, row 190
HIRES2_ROW191   = $5FD0         ; Hi-res page 2, row 191

; --- Text screen and display data ---
TEXT_SCREEN     = $0400          ; First line of text screen
BOTTOM_ROW_DATA = $0300          ; Screen row data for bottom fill

; --- Reset vector (Apple II soft-entry) ---
SOFTEV          = $03F2          ; Soft-entry reset vector (low/high bytes)
SOFTEV_CHK      = $03F4          ; SOFTEV checksum (SOFTEV+1 EOR #$A5)

; --- Applesoft ROM ---
AS_HPLOT_ENTRY  = $E3E0         ; Applesoft HPLOT entry point
AS_GETNUM       = $E254         ; Applesoft GETNUM (parse numeric parameter)
AS_DIV_ZERO_ERR = $E77E         ; Applesoft division by zero error

; --- Game code stubs (not yet reverse-engineered) ---
GAME_LINE_TBL_LO = $7380        ; Hi-res line address table (low bytes)
GAME_LINE_TBL_HI = $7440        ; Hi-res line address table (high bytes)
