\section{RWTS reload}

When the game needs to load new level data, it calls the RWTS reload entry
at [[RWTS_RELOAD]]. This routine turns the drive motor on, saves the screen,
copies the loader code from the language card backup ([[$D000]]--[[$D7FF]])
back to [[RWTS_ENTRY]]--[[$57FF]], calls the loader entry at [[RWTS_ENTRY]] to load the
next level data set, then restores the screen and returns.

<<rwts reload>>=

        ORG $BE00
RWTS_RELOAD:
        SUBROUTINE
        ; Reload the loader from language card and call it to load level data.
        ;
        ; Inputs:
        ;   LDR_SLOT -- disk slot * 16
        ;
        ; Behavior:
        ;   Turns on drive motor, scrolls screen up to save it,
        ;   copies $D000-$D7FF back to RWTS_ENTRY-$57FF (restoring the loader),
        ;   calls LOADER_ENTRY, then jumps to SCREEN_RESTORE.
        ;
        ; Modifies:
        ;   RWTS_ENTRY-$57FF (loader restored), ZP_RWTS_PTR, screen buffer
        ; Clobbers: A, X
        LDX LDR_SLOT
        LDA DISK_MOTOR_ON,X    ; Turn motor on
        JSR SCROLL_UP          ; Save screen content
        INC ZP_RWTS_PTR        ; Bump pointer lo past buffer header
        INC ZP_RWTS_PTR+1      ; Bump pointer hi
        LDX LDR_SLOT

; Self-modifying loop: copy $D000-$D7FF to RWTS_ENTRY-$57FF (restore loader).
        LDA #$D0
        STA .src+2             ; Patch source page
        LDA #$50
        STA .dst+2             ; Patch dest page
        LDX #$00
.src:   LDA $D000,X
.dst:   STA $5000,X
        INX
        BNE .src
        INC .src+2
        INC .dst+2
        LDA .dst+2
        CMP #$58               ; Done when dest reaches $5800
        BNE .src

; Call loader (saves ZP, loads level data, restores ZP, returns).
        JSR LOADER_ENTRY
JMP_TO_RESTORE:
        JMP SCREEN_RESTORE     ; Restore screen and return
@ %def RWTS_RELOAD JMP_TO_RESTORE

\section{Sector data reader}

An alternate sector data reader at [[NIBBLE_READER]] reads odd/even nibble-encoded
data directly into memory via the [[ZP_RWTS_PTR2]] pointer. It reads
256-byte blocks in a loop, checking for a [[$D4]] marker between blocks,
and repeats until a page counter at [[ZP_RWTS_PAGECNT]] reaches zero.

Note: the entry at [[NIBBLE_READER]] overlaps with the last byte of the [[JMP]]
instruction at [[$BE35]]. The byte [[$BE]] at that position serves double duty
as both the high byte of the JMP target and the [[LDX]] abs,Y opcode.

<<nibble reader>>=

        ORG $BE38
; Read odd/even nibble-encoded sector data into memory via ZP_RWTS_PTR2,
; ZP_RWTS_PAGECNT pages.
; $BE37 is the 3rd byte of the JMP above. When branched to, $BE serves
; as the LDX abs,Y opcode: LDX $C08C,Y.
NIBBLE_READER = $BE37               ; Overlaps with 3rd byte of JMP above

; Bytes $BE38-$BE3B are part of the LDX DISK_DATA,Y instruction
; (overlap with JMP high byte) plus its BPL loop. We emit them as raw
; bytes since they're not independent instructions.
        DC.B $8C,$C0           ; ...continuation of LDX DISK_DATA,Y
        DC.B $10,$FB           ; BPL NIBBLE_READER
        ROL                    ; Shift odd nibble into position
        STA ZP_RWTS_SCRATCH    ; Save partial (low byte of ZP_RWTS_PTR, reused)
.wait_even:
        LDA DISK_DATA,X        ; Wait for even nibble
        BPL .wait_even
        AND ZP_RWTS_SCRATCH    ; Combine odd+even
        STA (ZP_RWTS_PTR2),Y   ; Store decoded byte
        INY
        BNE NIBBLE_READER      ; Loop 256 times (branches to NIBBLE_READER)

; Between blocks: check for ZP_ENEMY_C_STATE sync marker.
        ASL $FFFF              ; Timing pad (6 cycles)
.wait_sync:
        LDA DISK_DATA,X
        BPL .wait_sync
        CMP #$D4               ; Sync byte between sectors
        BNE RWTS_RELOAD+$10    ; Mismatch: retry from page setup ($BE10)
        INC ZP_RWTS_PTR2+1     ; Next destination page
        DEC ZP_RWTS_PAGECNT    ; Decrement block count
        BNE NIBBLE_READER      ; More blocks: continue reading
        JMP SCREEN_PRE_RESTORE ; Done: restore screen
@ %def NIBBLE_READER

\section{Applesoft and Monitor patches}

Several jump vectors patch into Applesoft BASIC and Monitor ROM routines.
These include a 16-bit division routine using [[ZP_DIV_DIVISOR]] (two bytes)
as divisor and [[ZP_DIV_DIVIDEND]]/[[ZP_DIV_REMAINDER]] as
dividend/result (each a 16-bit pair).

<<applesoft patches>>=

        ORG $BE60
; Trampoline: redirect BELL to Monitor BELL2.
PATCH_BELL:
        JMP MON_BELL2           ; Redirect to Monitor bell

; Trampoline: HPLOT with Y=$77 (hi-res page 2 base).
PATCH_HPLOT:
        LDY #$77
        JMP AS_HPLOT_ENTRY      ; Applesoft HPLOT entry

; Trampoline: HPLOT with Y=$7B (alternate base), shares JMP with PATCH_HPLOT.
PATCH_HPLOT2:
        LDY #$7B
        BNE PATCH_HPLOT+2       ; Share JMP $E3E0

DIVIDE:
        SUBROUTINE
        ; 16-bit unsigned division via repeated subtraction.
        ;
        ; Inputs:
        ;   ZP_DIV_DIVISOR   -- 16-bit divisor (lo/hi at $DA/$DB)
        ;   ZP_DIV_DIVIDEND  -- 16-bit dividend (lo/hi at $CE/$CF);
        ;                       shifted out and replaced with the quotient.
        ;
        ; Behavior:
        ;   Calls Applesoft GETNUM to parse parameters. If divisor is
        ;   zero, jumps to Applesoft division-by-zero error. Otherwise
        ;   performs 16 iterations of shift-and-subtract division,
        ;   accumulating the remainder in ZP_DIV_REMAINDER.
        ;
        ; Outputs:
        ;   ZP_DIV_DIVIDEND  -- quotient (16-bit)
        ;   ZP_DIV_REMAINDER -- remainder (16-bit, lo/hi at $E6/$E7)
        ;
        ; Modifies:
        ;   ZP_DIV_DIVIDEND, ZP_DIV_REMAINDER
        ; Clobbers: A, Y
        JSR AS_GETNUM           ; Applesoft GETNUM
        LDA ZP_DIV_DIVISOR      ; Divisor low
        BNE .do_div
        LDA ZP_DIV_DIVISOR+1    ; Divisor high
        BNE .do_div
        JMP AS_DIV_ZERO_ERR     ; Division by zero error
.do_div:
        ASL ZP_DIV_DIVIDEND     ; Shift dividend left; MSB -> remainder via ROLs
        ROL ZP_DIV_DIVIDEND+1
        ROL ZP_DIV_REMAINDER
        ROL ZP_DIV_REMAINDER+1
        LDA ZP_DIV_REMAINDER
        CMP ZP_DIV_DIVISOR      ; Trial subtract: remainder - divisor
        LDA ZP_DIV_REMAINDER+1
        SBC ZP_DIV_DIVISOR+1
        BCC .no_sub             ; remainder < divisor -> skip subtract
        STA ZP_DIV_REMAINDER+1  ; Commit subtract: remainder -= divisor
        LDA ZP_DIV_REMAINDER
        SBC ZP_DIV_DIVISOR
        STA ZP_DIV_REMAINDER
        INC ZP_DIV_DIVIDEND     ; Quotient bit into vacated dividend LSB
.no_sub:
        DEY
        BNE .do_div
        RTS

; Padding
        HEX FF FF FF FF FF FF
@ %def PATCH_BELL PATCH_HPLOT PATCH_HPLOT2 DIVIDE

\section{Screen management}

The screen management routines handle saving and restoring the hi-res
display during disk loads. SCREEN\_PRE\_RESTORE calls the game callback
[[STAGE_STACK]] before restoring --- [[STAGE_STACK]] is a stable
duplicate of [[SCREEN_ROW_COPY]] parked in the staging-buffers region
so it survives stack use.  SCREEN\_RESTORE scrolls the screen back
down, clears hi-res lines using [[SCREEN_ROW_ADDR_LO]]/[[SCREEN_ROW_ADDR_HI2]],
and clears the hi-res screen holes.

<<screen restore>>=

        ORG $BEA0
; Call game screen callback, then fall through to SCREEN_RESTORE.
SCREEN_PRE_RESTORE:
        JSR STAGE_STACK         ; Game callback: repaint screen via
                                ;   the duplicate SCREEN_ROW_COPY body
                                ;   staged in the $5C00 stack-page image

SCREEN_RESTORE:
        SUBROUTINE
        ; Restore hi-res screen after a disk load.
        ;
        ; Inputs:
        ;   Buffer -- saved screen lines from SCROLL_UP
        ;
        ; Behavior:
        ;   Scrolls saved lines back to screen via SCROLL_DN, clears
        ;   hi-res lines $21-$BB using address tables,
        ;   then zeroes screen hole bytes ($x78-$x7F, $xF8-$xFF)
        ;   across hi-res page 2 ($4000-$5FFF).
        ;
        ; Modifies:
        ;   Hi-res page 2, ZP_RWTS_PTR
        ; Clobbers: A, X, Y
; Scroll screen back down, then clear hi-res lines.
        JSR SCROLL_DN
        LDX #$21                ; Start at line ZP_HIGH_SCORE_1
.clear_lines:
        LDA GAME_LINE_TBL_LO,X  ; Line address table low
        STA ZP_RWTS_PTR         ; ZP_RWTS_PTR <- line address
        LDA GAME_LINE_TBL_HI,X  ; Line address table high
        STA ZP_RWTS_PTR+1
        LDY #$27                ; 40 bytes per line
        LDA #$00
.clear_byte:
        STA (ZP_RWTS_PTR),Y
        DEY
        BPL .clear_byte
        INX
        CPX #$BC                ; End at line $BC
        BCC .clear_lines

; Clear hi-res screen "holes" (the unused bytes at the end of each line
; group in hi-res memory: bytes $78-$7F and $F8-$FF of each page).
        LDA #$00
        LDY #$40
        STA ZP_RWTS_PTR         ; ZP_RWTS_PTR <- $4000 (page-aligned)
        STY ZP_RWTS_PTR+1
        LDX #$20                ; 32 pages ($4000-$5FFF)
.clear_page:
        LDY #$78               ; Clear $78-$7F
.clear_hole1:
        STA (ZP_RWTS_PTR),Y
        INY
        BPL .clear_hole1
        LDY #$F8               ; Clear $F8-$FF
.clear_hole2:
        STA (ZP_RWTS_PTR),Y
        INY
        BMI .clear_hole2
        INC ZP_RWTS_PTR+1       ; Next page
        DEX
        BNE .clear_page
        RTS

; RWTS_DEAD_PAD ($BEDE-$BEDF, 2 bytes): dead residue between
; SCREEN_RESTORE's closing RTS and COPY_ROM_TO_LC's opening LDA.
; Not read or executed in any shipped binary --- an earlier prose
; comment speculated "sprite data or flags" but a byte-level search
; of every shipped binary (boot1/loader/rwts/drol/level1) finds no
; 3-byte opcode whose operand is $BEDE.  The bytes are preserved for
; byte-exact matching against rwts.bin and have no runtime role.
RWTS_DEAD_PAD:
        HEX 80 83
@ %def SCREEN_PRE_RESTORE SCREEN_RESTORE RWTS_DEAD_PAD

\section{Copy ROM to language card}

Copies the Apple II ROM ([[$D000]]--[[$FFFF]]) into language card RAM. This is
the same operation performed by boot1's phase 3. Used by the reset handler
to restore the language card state.

<<copy rom to lc>>=

        ORG $BEE0
COPY_ROM_TO_LC:
        SUBROUTINE
        ; Copy Apple II ROM ($D000-$FFFF) into language card RAM.
        ;
        ; Behavior:
        ;   Enables LC bank 1 write mode with ROM readable, then
        ;   copies each byte from ROM into LC RAM via indirect
        ;   addressing. Loops from $D000 until high byte wraps to ZP_PAGE_FLAG.
        ;   Write-protects LC on exit.
        ;
        ; Modifies:
        ;   Language card RAM ($D000-$FFFF), ZP_RWTS_PTR
        ; Clobbers: A, Y
        LDA LC_BANK1_RWROM      ; Enable LC writes, read ROM
        LDA LC_BANK1_RWROM      ; (must read twice)
        LDY #$00
        LDA #$D0
        STY ZP_RWTS_PTR         ; ZP_RWTS_PTR <- #$D000
        STA ZP_RWTS_PTR+1       ; (pointer serves as both source and dest)
.copy:
        LDA (ZP_RWTS_PTR),Y     ; Read from ROM
        STA (ZP_RWTS_PTR),Y     ; Write to LC RAM (same address, different bank)
        INY
        BNE .copy
        INC ZP_RWTS_PTR+1
        BNE .copy               ; Loop until pointer hi wraps ($FF+1=$00)
        BIT LC_BANK1_ROROM      ; Write-protect LC
        RTS

; Three-byte padding to align RESET_R at $BF00. The bytes $4C $55 $12
; decode as JMP $1255 but are never executed --- the RTS above ends the
; routine. The target $1255 lands inside BEAM_TARGET_TICK's .seed body
; (bytes $03 $60, an illegal opcode + RTS) and is not a real entry point.
        HEX 4C 55 12
@ %def COPY_ROM_TO_LC

\section{Reset handlers}

Four entry points display different error characters on reset, using the
BIT abs trick to skip [[LDA #imm]] instructions:
`R' ([[$D2]]), `P' ([[$D0]]), `L' ([[$CC]]), or `!' ([[$A1]]).

The common handler copies ROM to language card, reinitializes the Monitor,
clears the screen, clears memory from [[$BD00]] downward (with beeps via the
speaker toggle), then reboots into the slot's ROM using a PHA/PHA/RTS trick.

<<reset handlers>>=

        ORG $BF00

RESET_R:
        LDA #$D2
        DC.B $2C                ; BIT abs (skip next 2 bytes)
RESET_P:
        LDA #$D0
        DC.B $2C                ; BIT abs (skip next 2 bytes)
RESET_L:
        LDA #$CC
        DC.B $2C                ; BIT abs (skip next 2 bytes)
RESET_BANG:
        LDA #$A1

; Common reset handler.
        ; Restore language card, clear screen, wipe memory $0800-$BDFF
        ; with speaker beeps, then reboot via slot ROM.
        ;
        ; Inputs:
        ;   A -- error character to display (from RESET_R/P/L/BANG)
        ;   LDR_SLOT -- boot slot * 16
        ;
        ; Modifies:
        ;   BOOT1_SECTORS-$BDFF (zeroed), language card RAM, screen
        ; Clobbers: A, X, Y
        PHA                     ; Save error character
        JSR COPY_ROM_TO_LC      ; Restore language card
        JSR MON_INIT            ; Initialize monitor
        JSR MON_HOME            ; Clear screen
        JSR MON_NORMAL          ; Normal text mode
        PLA
        STA TEXT_SCREEN          ; Display error char at top-left

; Clear memory from $BDFF downward to BOOT1_SECTORS, with beeps.
.clear_outer:
        LDY #$00
        TYA
.clear:
.clear_page = *+2
        STA $BD00,Y             ; Self-modifying: page decremented
        INY
        BNE .clear              ; Inner loop: fill one page
        DEC .clear_page         ; Next page down
        BIT SW_SPEAKER          ; Beep
        LDA .clear_page
        CMP #$08                ; Stop
        BCS .clear_outer        ; Outer loop: next page

; Invalidate the soft-entry reset vector (A = $07 from the clear-page
; loop's final page index), then reboot via slot ROM. Writing garbage to
; SOFTEV+1 (high byte) and SOFTEV_CHK (checksum) makes the Monitor
; reset path force a cold boot rather than a warm restart.
        STA SOFTEV+1            ; SOFTEV+1 <- #$07 (reset vector high byte, invalid)
        STA SOFTEV_CHK          ; SOFTEV_CHK <- #$07 (invalid checksum -> cold start)
        LDA LDR_SLOT            ; Get slot * 16
        LSR                     ; Derive slot ROM page $Cn
        LSR
        LSR
        LSR
        ORA #$C0
        SBC #$00                ; A = $Cn (carry was set from LSR)
        PHA                     ; Push high byte
        LDA #$FF
        PHA                     ; Push low byte ($FF)
        RTS                     ; "Return" to $CnFF+1 = $Cn00 (slot ROM)

; Loader persistent state (used as variables, not code).
LDR_TRACK       = $BF48         ; Current track
LDR_SLOT        = $BF49         ; Slot * 16
LDR_PHASE       = $BF4A         ; Boot phase counter

; Emit the initial values at these locations.
        PHP                     ; initial value $08
        RTS                     ; initial value $60 (slot 6 * 16)
        BRK                     ; initial value $00
@ %def RESET_R RESET_P RESET_L RESET_BANG LDR_TRACK LDR_SLOT LDR_PHASE

\section{Screen scroll routines}

Two screen scroll routines save and restore hi-res screen content during
disk loads. SCROLL\_UP copies 32 hi-res lines to a buffer starting at
[[$4028]] (hi-res page~2, skipping the leftmost 40 bytes). SCROLL\_DN
copies from the buffer back to the screen, then fills the bottom 4 text
lines from [[BOTTOM_ROW_DATA]].

SCROLL\_UP has two entry points: a preamble at [[SCROLL_UP_PRE]] that would
delegate to a game scroll handler if A != [[#$FF]] on entry, and the main
entry at [[SCROLL_UP]] which overlaps with the operand bytes of the
delegation [[JMP]] (the byte sequence [[$A0]] [[$28]] reads as [[LDY #$28]]
when entered at [[SCROLL_UP]]).  The delegation path is effectively dead
code --- [[SCROLL_UP_PRE]] has no callers in the shipped game --- but the
[[JMP]] is retained because its operand bytes form the [[LDY #$28]]
initializer at [[SCROLL_UP]].

<<scroll up>>=

        ORG $BF4B
SCROLL_UP_PRE:
        SUBROUTINE
        ; Save 32 hi-res screen lines to a buffer at $4028.
        ;
        ; Inputs:
        ;   A   -- (SCROLL_UP_PRE entry) gate byte: $FF skips to scroll;
        ;          other values would delegate to a game scroll handler.
        ;          SCROLL_UP_PRE is never called in the shipped game;
        ;          SCROLL_UP (+5) is the only live entry point.
        ;
        ; Behavior:
        ;   At SCROLL_UP_PRE: TAY / INY / BEQ .skip. A == $FF yields Y=0
        ;   and takes the branch; any other A falls through to the
        ;   delegation JMP. The JMP's operand bytes ($A0 $28) are reused
        ;   as an LDY #$28 initializer at SCROLL_UP.
        ;
        ;   At SCROLL_UP: LDY #$28 / LDA #$40 / STY ZP_RWTS_PTR /
        ;   STA ZP_RWTS_PTR+1 sets the destination pointer to #$4028,
        ;   then copies 32 lines of 40 bytes each from hi-res page 2
        ;   (via SCREEN_ADDR_TBL) into the buffer.
        ;
        ; Modifies:
        ;   $4028-$44FF, ZP_RWTS_PTR, ZP_RWTS_PTR2
        ; Clobbers: A, X, Y
        TAY                     ; A -> Y so INY sets Z iff A was $FF
        INY
        BEQ .skip               ; A was $FF: fall through to scroll
        HEX 4C A0 28            ; "JMP $28A0" (dead delegation); the $A0
                                ;   $28 operand bytes serve as LDY #$28
                                ;   when entered at SCROLL_UP below.
SCROLL_UP = SCROLL_UP_PRE + 5   ; Live entry: LDY #$28 / LDA #$40 / ...

.skip:
        LDA #$40
        STY ZP_RWTS_PTR         ; lo <- Y (0 via BEQ, $28 via SCROLL_UP)
        STA ZP_RWTS_PTR+1       ; hi <- #$40 (buffer page = $40xx)
        LDX #$00
.copy_line:
        LDA SCREEN_ADDR_TBL,X  ; Line address low
        STA ZP_RWTS_PTR2
        LDA SCREEN_ADDR_TBL+1,X ; Line address high
        STA ZP_RWTS_PTR2+1
        LDY #$27                ; 40 bytes per line
.copy_byte:
        LDA (ZP_RWTS_PTR2),Y    ; Read from screen
        STA (ZP_RWTS_PTR),Y     ; Write to buffer
        DEY
        BPL .copy_byte
        CLC
        LDA ZP_RWTS_PTR
        ADC #$28                ; Advance buffer by 40 bytes
        STA ZP_RWTS_PTR
        BCC .no_carry
        INC ZP_RWTS_PTR+1
.no_carry:
        INX                     ; Next address pair
        INX
        CPX #$40                ; 32 lines (64 bytes in table)
        BCC .copy_line
        RTS
@ %def SCROLL_UP_PRE SCROLL_UP

<<scroll dn>>=

        ORG $BF7F
SCROLL_DN:
        SUBROUTINE
        ; Restore 32 hi-res screen lines from the buffer and fill bottom rows.
        ;
        ; Inputs:
        ;   Buffer-$44FF -- saved screen data from SCROLL_UP
        ;
        ; Behavior:
        ;   Copies 32 lines (40 bytes each) from the buffer back to
        ;   hi-res page 2 in reverse order using SCREEN_ADDR_TBL,
        ;   then fills the bottom 4 screen rows (188-191) from VECTOR_PAGE data.
        ;
        ; Modifies:
        ;   Hi-res page 2, ZP_RWTS_PTR, ZP_RWTS_PTR2
        ; Clobbers: A, X, Y
        LDY #$00
        LDA #$45
        STY ZP_RWTS_PTR         ; Source = $4500 (buffer after scroll data)
        STA ZP_RWTS_PTR+1
        LDX #$3E                ; Start from last line pair
.copy_line:
        LDA SCREEN_ADDR_TBL,X
        STA ZP_RWTS_PTR2
        LDA SCREEN_ADDR_TBL+1,X
        STA ZP_RWTS_PTR2+1
        LDY #$27
.copy_byte:
        LDA (ZP_RWTS_PTR),Y     ; Read from buffer
        STA (ZP_RWTS_PTR2),Y    ; Write to screen
        DEY
        BPL .copy_byte
        SEC
        LDA ZP_RWTS_PTR
        SBC #$28                ; Move buffer pointer back
        STA ZP_RWTS_PTR
        BCS .no_borrow
        DEC ZP_RWTS_PTR+1
.no_borrow:
        DEX
        DEX
        BPL .copy_line

; Fill bottom 4 hi-res rows (188-191) from VECTOR_PAGE data.
        LDX #$27                ; 40 bytes
.fill_bottom:
        LDA BOTTOM_ROW_DATA,X
        STA HIRES2_ROW188,X     ; Row 188
        STA HIRES2_ROW189,X     ; Row 189
        STA HIRES2_ROW190,X     ; Row 190
        STA HIRES2_ROW191,X     ; Row 191
        DEX
        BPL .fill_bottom
        RTS
@ %def SCROLL_DN

