; --- Hi-res screen-clear column bounds (used by CLEAR_PAGE1/CLEAR_PAGE2) ---
; The screen-clear routines loop X from ZP_CLEAR_COL down to
; ZP_CLEAR_COL_END+1 (inclusive), painting $00 across 35 interlaced
; hi-res row-base addresses per iteration.  The column terminators
; are repurposed as score-HUD digit slots ($2B/$2C/$2D) during
; gameplay; only the screen-clear prologue uses them as col bounds.
ZP_CLEAR_COL_END = $2D          ; Low-column terminator (inclusive)
                                ; (game-time alias: ZP_SCORE_2)

; --- Playfield text-strip dither source (40 bytes at $0300-$0327) ---
; TEXT_STRIP_SRC is a column-indexed (X=$00..$27) 40-byte source buffer
; holding the alternating bit-pattern ``55 2A'' used to repaint the
; 3-band playfield text-strip background after sprite draws and
; during CLEAR_PAGE1/CLEAR_PAGE2 wipes.  On the Apple II hi-res
; display, the even/odd pair ($55 = %01010101, $2A = %00101010) paints
; a one-pixel-on / one-pixel-off checker in the native 7-dot cell,
; which reads as a uniform gray dither.  The same byte position is
; reused across every interlaced row the CLEAR/RESTORE helpers touch,
; so the buffer stores one byte per hi-res column.
;
; The buffer is loaded from disk at boot time (the last 40 bytes of
; STAGE_VECTORS copied to VECTOR_PAGE by FIRST_BOOT) and is treated
; as read-only data by the game --- no STA in any shipped routine
; targets it.  See also the prose section "Playfield dither source"
; in the framebuffer-library chapter for the per-caller usage.
TEXT_STRIP_SRC  = $0300         ; Column-indexed dither source (40 bytes)

; Note: the helpers called by CLEAR_PAGE1/CLEAR_PAGE2 ---
; INTERLACE_FILL_P1 and INTERLACE_FILL_P2 --- are
; full ORG chunks later in the framebuffer library (their labels
; become visible through dasm's global symbol resolution, no EQU
; forward-declaration is needed here).
@ %def ZP_CLEAR_COL_END TEXT_STRIP_SRC

