                                ;  screen-X residue in JOY_V_DOWN.)

; --- Rescue-child sprite tables (per step phase x direction) ---
; Width = $03, height = $1A or $1C; indexed by PROJ_FRAME_IDX[$0358,Y].
; The four pairs are RESCUE_SPR_NEG_END / RESCUE_SPR_NEG_MID /
; RESCUE_SPR_POS_END / RESCUE_SPR_POS_MID, each with LO/HI halves.

; --- Drift-state pitch table (4 entries, indexed 1..4 by RESCUE_COUNTDOWN) ---
; The 4 descending pitches that play across the 4 drift-mode frames after
; a hit/pickup.  Disk-image bytes: $07 $0C $10 $13 $15 ... (used 1..4 = $0C $10 $13 $15).
RESCUE_DRIFT_PITCH = $0213
@

<<rescue draw>>=

        ORG $0C98
RESCUE_DRAW:
        SUBROUTINE
        ; Per-frame draw + collision sibling of RESCUE_UPDATE
        ; for the 20-slot rescue-child entity subsystem.  Iterates Y
        ; from ZP_COMPANION_OFF down through the slots, draws each active body
        ; sprite, and runs three collision/spawn checks: floor-enemy
        ; overlap (kill both, +35 BCD), player pickup (centre-band
        ; X + Y window, +35 BCD, ZP_HIT_FLAG <- #$FF, no life-loss), and
        ; hostile projectile-spawn (entity on player floor + odd row
        ; + free $C5/ZP_PROJ_X/ZP_PROJ_Y slot; throw a projectile in walking
        ; direction).  See section Rescue-child draw, collision, and
        ; projectile-spawn for the full description.
        ;
        ; Inputs:
        ;   ENTITY_ACTIVE,Y      --- per-slot state byte.
        ;   ENTITY_FLOOR_COL,Y   --- per-slot world-X low.
        ;   ENTITY_XOFF_IDX,Y    --- per-slot world-X high.
        ;   ENTITY_FLOOR_POS,Y   --- per-slot row Y.
        ;   RESCUE_DIR,Y         --- walk direction.
        ;   RESCUE_ANIM,Y        --- step anim counter.
        ;   RESCUE_FLOOR,Y       --- assigned floor index.
        ;   RESCUE_COUNTDOWN,Y   --- drift-mode countdown.
        ;   ZP_PLAYER_Y            --- player perspective Y.
        ;   ZP_SPRITE_XREF         --- level-fixed X reference.
        ;   ZP_PLAYER_COL          --- player col (pickup band).
        ;   ZP_PLAYER_FLOOR_CUR    --- player floor (proj-spawn gate).
        ;   ZP_PROJ_MAX            --- max projectile slot index.
        ;   ZP_ENEMY_FLAG          --- 4-slot floor-enemy active flag.
        ;   ZP_ENEMY_COL           --- 4-slot enemy column.
        ;   ZP_ENEMY_Y             --- 4-slot enemy Y coordinate.
        ;   ZP_PROJ_DIR            --- 4-slot projectile direction.
        ;   ZP_PROJ_X              --- 4-slot projectile column.
        ;   ZP_PROJ_Y              --- 4-slot projectile row.
        ;   ZP_HIT_Y_OFFSET, ZP_HIT_Y_SPAN --- floor-enemy hit-box Y extents
        ;                                    (level-fixed; loaded by
        ;                                    INIT_LEVEL_STATE from LVL_INIT_HIT_Y).
        ;   PERSPECTIVE_XOFF_LO/HI --- perspective tables.
        ;   PROJ_SCREEN_COL      --- screen-col lookup.
        ;   PROJ_FRAME_IDX      --- frame-index lookup.
        ;
        ; Modifies:
        ;   ZP_PERSP_OFFSET_LO/HI --- pre-compute scratch.
        ;   ZP_HIT_FLAG on player pickup.
        ;   ZP_SPRITE_W/H/X/Y, SMC_DS_SRC_LO/HI, SMC_SPRITE_MASK_OP/ARG.
        ;   ZP_DRAW_LOOP_IDX, ZP_SCORE_ADD_LO/HI.
        ;   ENTITY_ACTIVE,Y (drift transition); RESCUE_COUNTDOWN,Y on hit.
        ;   ZP_ENEMY_FLAG,X (cleared on rescue/enemy mutual-kill).
        ;   ZP_PROJ_DIR/X/Y,X (projectile slot seeded on hostile-spawn).
        ;   ZP_CLIP_X_LO (per-slot screen-X residue scratch).
        ; Clobbers: A, X, Y

        JSR RESCUE_DRAW_PERSPECTIVE_CACHE  ; precompute $0F/$10 once
        LDY #$13                           ; 20 slots
.slot_loop:
        LDA ENTITY_ACTIVE,Y
        BEQ .slot_next                     ; $00 inactive
        BPL .compute_screen_x              ; +ve active walking
        BMI .neg_state                     ; -ve drift or exit-anim
.slot_next:
        DEY
        BPL .slot_loop
        RTS

; --- Skip-this-slot exit (also restores BIT opcode at $65B7) ---
.skip_off_screen:
        LDA #$24                           ; BIT opcode (disable flicker)
        STA SMC_SPRITE_MASK_OP
        JMP .slot_next

; --- Negative state: $FE -> skip; else drift sound + flicker setup ---
.neg_state:
        CMP #$FE
        BEQ .slot_next                     ; $FE exit-anim: invisible
; Drift-mode (any other -ve): play descending click + enable flicker patch.
        LDA #$29                           ; AND #imm opcode
        STA SMC_SPRITE_MASK_OP             ; SMC_SPRITE_MASK_OP(flicker the next draw)
        LDX RESCUE_COUNTDOWN,Y             ; RESCUE_COUNTDOWN[Y] in 1..4
        LDA $D7,X                          ; quasi-random AND-mask byte
        STA SMC_SPRITE_MASK_ARG
        STY ZP_DRAW_LOOP_IDX
        LDA RESCUE_DRIFT_PITCH,X           ; RESCUE_DRIFT_PITCH[X] = pitch for this frame
        LDX #$12                           ; X = duration
        JSR SND_DELAY_DOWN                 ; descending click
        LDY ZP_DRAW_LOOP_IDX

; --- Common: compute screen-X residue and stage sprite XYHW ---
.compute_screen_x:
        SEC
        LDA ENTITY_FLOOR_COL,Y
        SBC ZP_PERSP_OFFSET_LO
        STA ZP_CLIP_X_LO                   ; screen-X residue
        LDA ENTITY_XOFF_IDX,Y
        SBC ZP_PERSP_OFFSET_HI
        BNE .skip_off_screen               ; high-byte != 0: off camera
        LDA ZP_CLIP_X_LO
        CMP #$9A                           ; clip right edge
        BCS .skip_off_screen
        TAX                                ; X = screen-X residue
        LDA ENTITY_FLOOR_POS,Y             ; row
        STA ZP_SPRITE_Y
        LDA PROJ_SCREEN_COL,X              ; PROJ_SCREEN_COL[X] = column
        STA ZP_SPRITE_X
        LDA PROJ_FRAME_IDX,X               ; PROJ_FRAME_IDX[X] = frame index
        TAX                                ; X = sprite frame index
        LDA #$03
        STA ZP_SPRITE_W                    ; $56 = 3 (width)
; --- Direction split: -ve dir (left), +ve dir (right) ---
        LDA RESCUE_DIR,Y
        BMI .draw_neg_dir
; +dir branch.
        LDA RESCUE_ANIM,Y
        BEQ .draw_pos_end                  ; anim 0 -> end-step
        CMP #$07
        BEQ .draw_pos_end                  ; anim 7 -> end-step
        CMP #$08
        BEQ .draw_pos_end                  ; anim 8 -> end-step
; +dir mid-step (anim 1..6, not 7).
.draw_pos_mid:
        LDA #$1C
        STA ZP_SPRITE_H                    ; ZP_SPRITE_H <- #$1C
        LDA RESCUE_SPR_POS_MID_LO,X
        STA SMC_DS_SRC_LO
        LDA RESCUE_SPR_POS_MID_HI,X
        STA SMC_DS_SRC_HI
        STY ZP_DRAW_LOOP_IDX
        JSR DRAW_SPRITE
        LDY ZP_DRAW_LOOP_IDX
        JMP .post_draw

.draw_pos_end:
        LDA #$1A
        STA ZP_SPRITE_H                    ; ZP_SPRITE_H <- #$1A
        LDA RESCUE_SPR_POS_END_LO,X
        STA SMC_DS_SRC_LO
        LDA RESCUE_SPR_POS_END_HI,X
        STA SMC_DS_SRC_HI
        STY ZP_DRAW_LOOP_IDX
        JSR DRAW_SPRITE
        LDX #$0A                           ; ascending-click args
        LDA #$0C
        JSR SND_DELAY_UP                   ; footstep sound
        LDY ZP_DRAW_LOOP_IDX
        JMP .post_draw

; -dir branch.
.draw_neg_dir:
        LDA RESCUE_ANIM,Y
        BEQ .draw_neg_end
        CMP #$07
        BEQ .draw_neg_end
        CMP #$08
        BEQ .draw_neg_end
.draw_neg_mid:
        LDA #$1C
        STA ZP_SPRITE_H
        LDA RESCUE_SPR_NEG_MID_LO,X
        STA SMC_DS_SRC_LO
        LDA RESCUE_SPR_NEG_MID_HI,X
        STA SMC_DS_SRC_HI
        STY ZP_DRAW_LOOP_IDX
        JSR DRAW_SPRITE
        LDY ZP_DRAW_LOOP_IDX
        JMP .post_draw

.draw_neg_end:
        LDA #$1A
        STA ZP_SPRITE_H
        LDA RESCUE_SPR_NEG_END_LO,X
        STA SMC_DS_SRC_LO
        LDA RESCUE_SPR_NEG_END_HI,X
        STA SMC_DS_SRC_HI
        STY ZP_DRAW_LOOP_IDX
        JSR DRAW_SPRITE
        LDX #$0A
        LDA #$0C
        JSR SND_DELAY_UP
        LDY ZP_DRAW_LOOP_IDX
        JMP .post_draw

; --- Pre-compute helper: cache PERSPECTIVE_XOFF[player_Y] - $4C in ZP_ENEMY_A_LEG_PHASE/SOUND_FLAG_MASK ---
RESCUE_DRAW_PERSPECTIVE_CACHE:
        LDX ZP_PLAYER_Y
        LDA PERSPECTIVE_XOFF_LO,X
        SEC
        SBC ZP_SPRITE_XREF
        STA ZP_PERSP_OFFSET_LO
        LDA PERSPECTIVE_XOFF_HI,X
        SBC #$00
        STA ZP_PERSP_OFFSET_HI
        RTS

; --- Post-draw: drift-mode skips collision; active runs all 3 checks ---
.post_draw:
        LDA ENTITY_ACTIVE,Y
        BPL .collide_floor_enemy           ; +ve: run collision
; Drift mode: restore BIT opcode and exit.
        LDA #$24
        STA SMC_SPRITE_MASK_OP
        JMP .slot_next

; --- Floor-enemy collision: walk 4 enemy slots looking for overlap ---
.collide_floor_enemy:
        LDX #$03
.find_enemy:
        LDA ZP_ENEMY_FLAG,X
        BNE .test_enemy_overlap
.next_enemy:
        DEX
        BPL .find_enemy
        BMI .test_player_pickup            ; ran out of slots: try player

.test_enemy_overlap:
        LDA ZP_CLIP_X_LO                   ; entity screen-X
        CMP ZP_ENEMY_COL,X
        BCC .next_enemy                    ; entity left of enemy: skip
        SEC
        SBC #$0A
        CMP ZP_ENEMY_COL,X
        BCS .next_enemy                    ; entity > enemy + 10: skip
        LDA ENTITY_FLOOR_POS,Y             ; entity row
        CLC
        ADC ZP_HIT_Y_OFFSET                ; + level Y-extent low
        CMP ZP_ENEMY_Y,X
        BCS .next_enemy
        CLC
        ADC ZP_HIT_Y_SPAN                  ; + level Y-extent high
        CMP ZP_ENEMY_Y,X
        BCC .next_enemy

; --- Mutual-kill reward path (also entered from player-pickup) ---
.kill_enemy_and_award:
        LDA #$00
        STA ZP_ENEMY_FLAG,X                ; clear floor-enemy slot
.award_reward:
        LDA #$FF
        STA ENTITY_ACTIVE,Y                ; rescue -> drift state
        LDA #$04
        STA RESCUE_COUNTDOWN,Y             ; arm 4-frame drift countdown
        LDA #$35
        STA ZP_SCORE_ADD_LO                ; +$0035 BCD
        LDA #$00
        STA ZP_SCORE_ADD_HI
        JSR SCORE_ADD
        JMP .slot_next

; --- Player pickup: centre-band X + row band ---
.test_player_pickup:
        LDA ZP_CLIP_X_LO                   ; entity screen-X
        CMP #$40
        BCC .test_proj_spawn               ; X < $40: outside band
        CMP #$50
        BCS .test_proj_spawn               ; X >= $50: outside band
        LDA ZP_PLAYER_COL
        SEC
        SBC #$19
        CMP ENTITY_FLOOR_POS,Y
        BCS .test_proj_spawn               ; player_col-$19 > entity_row
        CLC
        ADC #$2B
        CMP ENTITY_FLOOR_POS,Y
        BCC .test_proj_spawn               ; player_col+$12 < entity_row
; Player pickup: signal hit, then merge into reward path (no enemy clear).
        LDA #$FF
        STA ZP_HIT_FLAG
        JMP .award_reward                  ; rescue=drift, +$0035

; --- Hostile projectile spawn (no collision occurred) ---
; Gate 1: entity row must be odd (1-in-2 rate-limit by row parity).
; Gate 2: rescue assigned floor must equal player floor (same-floor only).
; Gate 3: at least one ZP_PROJ_DIR,X projectile slot must be empty.
.test_proj_spawn:
        LDA ENTITY_FLOOR_POS,Y
        AND #$01
        BNE .check_floor_match
        JMP .slot_next
.check_floor_match:
        LDA RESCUE_FLOOR,Y
        CMP ZP_PLAYER_FLOOR_CUR
        BEQ .find_empty_proj
        JMP .slot_next
.find_empty_proj:
        LDX ZP_PROJ_MAX                    ; $31 = max projectile slot
        BMI .proj_skip                     ; $31 < 0: subsystem off
.proj_loop:
        LDA ZP_PROJ_DIR,X
        BNE .proj_advance                  ; slot busy: try next
; Empty slot found: seed it.
        LDA RESCUE_DIR,Y                   ; RESCUE_DIR[Y] = direction
        STA ZP_PROJ_DIR,X
        LDA ENTITY_FLOOR_POS,Y
        STA ZP_PROJ_Y,X                    ; ZP_PROJ_Y[X] = row
        LDA ZP_CLIP_X_LO
        STA ZP_PROJ_X,X                    ; ZP_PROJ_X[X] = screen-X
        LDX #$0A                           ; descending-click args
        LDA #$0D
        STY ZP_DRAW_LOOP_IDX
        JSR SND_DELAY_DOWN                 ; emit-sound
        LDY ZP_DRAW_LOOP_IDX
.proj_skip:
        JMP .slot_next
.proj_advance:
        DEX
        BPL .proj_loop
        JMP .slot_next

@ %def RESCUE_DRAW RESCUE_DRAW_PERSPECTIVE_CACHE RESCUE_DRIFT_PITCH ZP_PERSP_OFFSET_LO ZP_PERSP_OFFSET_HI

\section{Top-band scrolling-edge pillar painters}

\label{sec:scroll_edge}

The two routines [[SCROLL_EDGE_L]] and [[SCROLL_EDGE_R]] paint a decorative
3-column-wide vertical stripe into the topmost perspective band of the
playfield (hi-res rows 35--66, the region above the first floor line at
row~67).  They are called in sequence from [[MAIN_LOOP]] immediately
after [[PLAYER_MOVE_TICK]] and before [[DRAW_PLAYER]].  Each paints the
stripe only when the player's world-Y coordinate [[ZP_PLAYER_Y]] is
within a narrow range that places the pillar on-screen; otherwise the
routine exits immediately without touching the framebuffer.

\paragraph{Two mirrored instances.}  [[SCROLL_EDGE_L]]
paints when [[ZP_PLAYER_Y]] $\le$ [[$10]] (player has walked toward the
left-edge of the world), placing the stripe at column [[$10]] $-$ [[ZP_PLAYER_Y]]
(0..[[$10]]).  [[SCROLL_EDGE_R]] paints when
[[ZP_PLAYER_Y]] $\in$ [[$C4]]..[[$EE]] (player has walked toward the
right edge), placing the stripe at column [[$EE]] $-$ [[ZP_PLAYER_Y]]
(0..[[$2A]]).  The [[CMP #$2B]] / [[BCS]] guard in [[SCROLL_EDGE_R]]
keeps the stripe within the 40-column visible window.

\paragraph{3-byte-per-column source, 7-frame animation.}  Each routine
loads a 16-bit pointer from a 7-entry (Y~=~0..6) table indexed by
[[ZP_SPRITE_XREF]], the sub-frame pacing counter advanced by
[[PLAYER_TICK_MOVE_LEFT/RIGHT]].  The resulting pointer addresses a
9-byte sprite frame laid out as 3~consecutive bytes per column for 3
columns, giving 7~distinct sub-pixel-shifted frames of a 3-column
vertical stripe.  Pointer tables (in level-1 swappable data):

\begin{center}
\begin{tabular}{l|l|l}
Table (level-1) & Address & Consumer \\
\hline
[[SCROLL_EDGE_L_SPR_LO]]  & [[$AFE8]],Y & [[SCROLL_EDGE_L]] \\
[[SCROLL_EDGE_L_SPR_HI]]  & [[$B068]],Y & [[SCROLL_EDGE_L]] \\
[[SCROLL_EDGE_R_SPR_LO]]  & [[$AFEF]],Y & [[SCROLL_EDGE_R]] \\
[[SCROLL_EDGE_R_SPR_HI]]  & [[$B06F]],Y & [[SCROLL_EDGE_R]] \\
\end{tabular}
\end{center}

The two tables overlap by one entry: [[$AFEF]]~=~[[$AFE8]]$+7$ and
[[$B06F]]~=~[[$B068]]$+7$, so [[SCROLL_EDGE_L_SPR_LO]]+7 is
[[SCROLL_EDGE_R_SPR_LO]]+0 (both [[$B472]]).  The shared boundary entry
is the level-1 pointer [[$B472]], which both routines reach at
[[ZP_SPRITE_XREF]]~=~[[$07]] (unused by the normal 7-step cycle
\{[[$00]], [[$01]], [[$02]], [[$03]], [[$04]], [[$05]], [[$06]]\}).

\paragraph{Page-gated blit.}  After the source pointer is staged into
[[ZP_BLIT_SRC]] ([[$FE]]/[[$FF]]), the routine dispatches on
[[ZP_PAGE_FLAG]] bit~7 to call either [[SCROLL_EDGE_BLIT_P1]] (page~1
back-buffer, [[$0F87]]) or [[SCROLL_EDGE_BLIT_P2]] (page~2 back-buffer,
[[$100C]]).  Both blitters share the same algorithm --- only the
destination row-bases differ by [[$2000]].

\paragraph{Blit structure.}  Each blitter sweeps columns [[X]]~=~[[$59]]
down to [[X]]~=~[[$58]]$+1$ (the three column positions
[[$58]]$+1$..[[$59]]).  At each column, three source bytes (advanced
one-by-one via [[INY]]) are fanned across 32 distinct hi-res rows in
the top band:

\begin{itemize}
\item \textbf{Byte 0} ([[Y]]~=~$3k$) writes to rows \{35, 55..65\}
  (12 rows, top cap + lower fill).
\item \textbf{Byte 1} ([[Y]]~=~$3k+1$) writes to rows \{36, 37, 52,
  53, 54, 66\} (6 seam rows).
\item \textbf{Byte 2} ([[Y]]~=~$3k+2$) writes to rows \{38..51, 52\}
  (15 stores, but row~52 is then re-written by the byte-1 store to
  [[$3300]] inside the same column; effective coverage is 38..51 =
  14 middle rows).
\end{itemize}

So each column writes 33 [[STA]]s to cover 32 unique rows (row~52
written twice, byte~1 wins).  Across 3~columns the pointer advances
through all 9~source bytes of the current frame.  Columns X $\ge$ [[$28]]
short-circuit painting (the off-screen guard at the column-loop head)
but still advance [[Y]] by 3 so subsequent columns read the correct
byte triple.

\paragraph{Shared blitter tail quirk.}  The blitter's column guard at
[[$0F8B]]/[[$1010]] uses [[CPX #$28]] / [[BCC]] to skip painting for
[[X]]~$\ge$~[[$28]] and instead adds [[$03]] to [[Y]] via the
[[TYA]]/[[CLC]]/[[ADC #$03]]/[[TAY]] path.  This allows partially
off-screen pillars (the right-edge case when [[X]]~=~[[$58]]+2 lands in
columns 38..40) to correctly skip past the invisible column without
desynchronising the Y pointer.  The guard is fixed at [[$28]] (40
hi-res bytes per row) regardless of the pillar's target column range.

<<scroll edge defines>>=

; --- Pointer tables (level-1 swappable data) ---
; 7 frames x 9 bytes = 63 bytes per sprite block; L-block starts at
; $B433 and R-block at $B472.  $B472 is both the 8th entry of the L
; table (unused) and the 1st entry of the R table.
SCROLL_EDGE_L_SPR_LO = $AFE8    ; lo bytes, Y in 0..6
SCROLL_EDGE_L_SPR_HI = $B068    ; hi bytes, Y in 0..6
SCROLL_EDGE_R_SPR_LO = $AFEF    ; lo bytes, Y in 0..6
SCROLL_EDGE_R_SPR_HI = $B06F    ; hi bytes, Y in 0..6

; --- Scratch for the shared blitter ---
ZP_SCROLL_COL_HI = $59          ; right edge column (inclusive)
ZP_SCROLL_COL_LO = $58          ; left edge column - 1 (sentinel)
ZP_BLIT_SRC_SE   = $FE          ; source pointer (16-bit, alias of ZP_BLIT_SRC)

@

<<scroll edge left>>=

        ORG $0F37
SCROLL_EDGE_L:
        SUBROUTINE
        ; Paint the left-edge 3-column pillar into the top playfield
        ; band (rows 35-66) when the player's world-Y is near the
        ; left-edge world position.  Called from MAIN_LOOP.
        ;
        ; Inputs:
        ;   ZP_PLAYER_Y ($4A)     --- world-Y; pillar shows when Y <= $10.
        ;   ZP_SPRITE_XREF ($4C)  --- sub-frame pacing counter (0..6).
        ;   ZP_PAGE_FLAG ($00)    --- hi-res back-buffer select.
        ;   SCROLL_EDGE_L_SPR_LO/HI[ZP_SPRITE_XREF] --- sprite pointer.
        ;
        ; Behavior:
        ;   Compute right-edge column = #$10 - ZP_PLAYER_Y.  If negative
        ;   (player too far right), return.  Stage column bounds
        ;   ($58/$59 = col-3..col).  Load sprite pointer into
        ;   ZP_BLIT_SRC.  Dispatch to SCROLL_EDGE_BLIT_P1 or _P2 by
        ;   ZP_PAGE_FLAG bit-7.
        ;
        ; Modifies:
        ;   ZP_SCROLL_COL_HI/LO, ZP_BLIT_SRC,
        ;   hi-res page 1 or page 2 rows 35..66 (via the blitter).
        ; Clobbers: A, Y

        LDA #$10                        ; left-edge world-Y reference
        SEC
        SBC ZP_PLAYER_Y
        BCC .off_right                  ; ZP_PLAYER_Y > $10: off-screen right
        STA ZP_SCROLL_COL_HI            ; right edge col = #$10 - ZP_PLAYER_Y
        SEC
        SBC #$03
        STA ZP_SCROLL_COL_LO            ; left edge col - 1
        LDY ZP_SPRITE_XREF              ; sub-frame index
        LDA SCROLL_EDGE_L_SPR_LO,Y
        STA ZP_BLIT_SRC_SE              ; pointer lo
        LDA SCROLL_EDGE_L_SPR_HI,Y
        STA ZP_BLIT_SRC_SE+1            ; pointer hi
        BIT ZP_PAGE_FLAG
        BMI .paint_p2                   ; back-buffer is page 2
        JSR SCROLL_EDGE_BLIT_P1
.off_right:
        RTS
.paint_p2:
        JSR SCROLL_EDGE_BLIT_P2
        RTS
@ %def SCROLL_EDGE_L

<<scroll edge right>>=

        ORG $0F5D
SCROLL_EDGE_R:
        SUBROUTINE
        ; Paint the right-edge 3-column pillar into the top playfield
        ; band (rows 35-66) when the player's world-Y is near the
        ; right-edge world position.  Called from MAIN_LOOP.
        ;
        ; Inputs:
        ;   ZP_PLAYER_Y ($4A)     --- world-Y; pillar shows when
        ;                             #$EE - ZP_PLAYER_Y is in 0..$2A
        ;                             (i.e., ZP_PLAYER_Y in $C4..$EE).
        ;   ZP_SPRITE_XREF ($4C)  --- sub-frame pacing counter (0..6).
        ;   ZP_PAGE_FLAG ($00)    --- hi-res back-buffer select.
        ;   SCROLL_EDGE_R_SPR_LO/HI[ZP_SPRITE_XREF] --- sprite pointer.
        ;
        ; Behavior:
        ;   Compute right-edge column = #$EE - ZP_PLAYER_Y.  Require
        ;   result in 0..$2A (else off-screen, return).  Stage column
        ;   bounds ($58/$59 = col-3..col).  Load sprite pointer.
        ;   Dispatch to SCROLL_EDGE_BLIT_P1 or _P2 by ZP_PAGE_FLAG
        ;   bit-7.
        ;
        ; Modifies:
        ;   ZP_SCROLL_COL_HI/LO, ZP_BLIT_SRC,
        ;   hi-res page 1 or page 2 rows 35..66 (via the blitter).
        ; Clobbers: A, Y

        LDA #$EE                        ; right-edge world-Y reference
        SEC
        SBC ZP_PLAYER_Y
        BCC .off_screen                 ; ZP_PLAYER_Y > $EE: off-screen
        CMP #$2B
        BCS .off_screen                 ; col >= $2B: off-screen right
        STA ZP_SCROLL_COL_HI            ; right edge col = #$EE - ZP_PLAYER_Y
        SEC
        SBC #$03
        STA ZP_SCROLL_COL_LO            ; left edge col - 1
        LDY ZP_SPRITE_XREF              ; sub-frame index
        LDA SCROLL_EDGE_R_SPR_LO,Y
        STA ZP_BLIT_SRC_SE              ; pointer lo
        LDA SCROLL_EDGE_R_SPR_HI,Y
        STA ZP_BLIT_SRC_SE+1            ; pointer hi
        BIT ZP_PAGE_FLAG
        BMI .paint_p2                   ; back-buffer is page 2
        JSR SCROLL_EDGE_BLIT_P1
.off_screen:
        RTS
.paint_p2:
        JSR SCROLL_EDGE_BLIT_P2
        RTS

; --- Shared page-1 blitter ---
SCROLL_EDGE_BLIT_P1:
        SUBROUTINE
        ; Paint 3 columns of a 3-byte-per-column vertical stripe into
        ; hi-res page 1 top band (rows 35-66).  Columns iterate from
        ; ZP_SCROLL_COL_HI down to ZP_SCROLL_COL_LO+1 (3 columns).  For
        ; each column, three source bytes fan out to 32 rows per the
        ; row distribution described in Top-band scrolling-edge pillar
        ; painters.
        ;
        ; Inputs:
        ;   ZP_BLIT_SRC           --- 16-bit source pointer, 9 bytes.
        ;   ZP_SCROLL_COL_HI/LO   --- column bounds.
        ;
        ; Behavior:
        ;   X counts columns (DEX); Y advances through source bytes
        ;   (INY after each byte-group).  If X >= $28 (off-screen),
        ;   skip painting but advance Y by 3 to keep the source pointer
        ;   aligned.  Each active column writes 33 STAs across 32 rows
        ;   (row 52 is overwritten inside the column, byte-1 wins).
        ;
        ; Modifies:
        ;   Hi-res page 1 at rows 35..66, columns
        ;   ZP_SCROLL_COL_LO+1..ZP_SCROLL_COL_HI.
        ; Clobbers: A, X, Y

        LDY #$00
        LDX ZP_SCROLL_COL_HI            ; X = rightmost column
.col:
        CPX #$28
        BCC .do_col                     ; X < $28 (40): paint
        TYA                             ; X >= $28: skip paint, advance Y by 3
        CLC
        ADC #$03
        TAY
        JMP .col_tail
.do_col:
; Byte 0: top cap (row 35) + lower-fill rows (55..65) -- 12 stores
        LDA (ZP_BLIT_SRC_SE),Y
        STA $2E00,X                     ; row 35
        STA $3F00,X                     ; row 55
        STA $2380,X                     ; row 56
        STA $2780,X                     ; row 57
        STA $2B80,X                     ; row 58
        STA $2F80,X                     ; row 59
        STA $3380,X                     ; row 60
        STA $3780,X                     ; row 61
        STA $3B80,X                     ; row 62
        STA $3F80,X                     ; row 63
        STA $2028,X                     ; row 64
        STA $2428,X                     ; row 65
        INY
; Byte 1: seam rows (36, 37, 52, 53, 54, 66) -- 6 stores; row 52 write
;         overwrites the earlier byte-2 write at $3300,X below.
        LDA (ZP_BLIT_SRC_SE),Y
        STA $3200,X                     ; row 36
        STA $3600,X                     ; row 37
        STA $3300,X                     ; row 52 (overwrites byte-2 store)
        STA $3700,X                     ; row 53
        STA $3B00,X                     ; row 54
        STA $2828,X                     ; row 66
        INY
; Byte 2: middle-fill rows (38..51) -- 15 stores; last store to $3300
;         (row 52) is immediately overwritten by the byte-1 store above
;         within the same column iteration.
        LDA (ZP_BLIT_SRC_SE),Y
        STA $3A00,X                     ; row 38
        STA $3E00,X                     ; row 39
        STA $2280,X                     ; row 40
        STA $2680,X                     ; row 41
        STA $2A80,X                     ; row 42
        STA $2E80,X                     ; row 43
        STA $3300,X                     ; row 52 (clobbered by byte-1 store)
        STA $3280,X                     ; row 44
        STA $3680,X                     ; row 45
        STA $3A80,X                     ; row 46
        STA $3E80,X                     ; row 47
        STA $2300,X                     ; row 48
        STA $2700,X                     ; row 49
        STA $2B00,X                     ; row 50
        STA $2F00,X                     ; row 51
        INY
.col_tail:
        DEX
        CPX ZP_SCROLL_COL_LO
        BEQ .done                       ; reached left edge
        JMP .col
.done:
        RTS
@ %def SCROLL_EDGE_R SCROLL_EDGE_BLIT_P1

<<scroll edge blit p2>>=

        ORG $100C
SCROLL_EDGE_BLIT_P2:
        SUBROUTINE
        ; Page-2 twin of SCROLL_EDGE_BLIT_P1.  Byte-for-byte identical
        ; to the page-1 blitter with destination bases rebased from
        ; $2xxx to $4xxx (i.e. +$2000 on each STA address).
        ;
        ; Inputs / Behavior: see SCROLL_EDGE_BLIT_P1.
        ;
        ; Modifies:
        ;   Hi-res page 2 at rows 35..66, columns
        ;   ZP_SCROLL_COL_LO+1..ZP_SCROLL_COL_HI.
        ; Clobbers: A, X, Y

        LDY #$00
        LDX ZP_SCROLL_COL_HI
.col:
        CPX #$28
        BCC .do_col
        TYA
        CLC
        ADC #$03
        TAY
        JMP .col_tail
.do_col:
        LDA (ZP_BLIT_SRC_SE),Y
        STA $4E00,X                     ; row 35
        STA $5F00,X                     ; row 55
        STA $4380,X                     ; row 56
        STA $4780,X                     ; row 57
        STA $4B80,X                     ; row 58
        STA $4F80,X                     ; row 59
        STA $5380,X                     ; row 60
        STA $5780,X                     ; row 61
        STA $5B80,X                     ; row 62
        STA $5F80,X                     ; row 63
        STA $4028,X                     ; row 64
        STA $4428,X                     ; row 65
        INY
        LDA (ZP_BLIT_SRC_SE),Y
        STA $5200,X                     ; row 36
        STA $5600,X                     ; row 37
        STA $5300,X                     ; row 52 (overwrites byte-2 store)
        STA $5700,X                     ; row 53
        STA $5B00,X                     ; row 54
        STA $4828,X                     ; row 66
        INY
        LDA (ZP_BLIT_SRC_SE),Y
        STA $5A00,X                     ; row 38
        STA $5E00,X                     ; row 39
        STA $4280,X                     ; row 40
        STA $4680,X                     ; row 41
        STA $4A80,X                     ; row 42
        STA $4E80,X                     ; row 43
        STA $5300,X                     ; row 52 (clobbered by byte-1 store)
        STA $5280,X                     ; row 44
        STA $5680,X                     ; row 45
        STA $5A80,X                     ; row 46
        STA $5E80,X                     ; row 47
        STA $4300,X                     ; row 48
        STA $4700,X                     ; row 49
        STA $4B00,X                     ; row 50
        STA $4F00,X                     ; row 51
        INY
.col_tail:
